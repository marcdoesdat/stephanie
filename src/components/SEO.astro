---
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();

interface Props {
  title?: string;
  fullTitle?: string;
  description?: string;
  canonicalURL?: string | URL;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  fullTitle,
  description = config.meta_description,
  canonicalURL = new URL(Astro.url.pathname, config.site_url),
  ogImage = "/images/og-image.jpg",
  noindex = false,
} = Astro.props;

const formattedTitle = fullTitle ?? (title ? `${title} | ${config.nom}` : config.meta_title);
const resolvedOgImage = new URL(ogImage, config.site_url);

// Format E.164 pour JSON-LD (Canada : +1 + 10 chiffres)
const digitsOnly = config.telephone.replace(/\D/g, '');
const telephoneE164 = digitsOnly.startsWith('1') ? `+${digitsOnly}` : `+1${digitsOnly}`;

// JSON-LD : FinancialService + LocalBusiness (courtière hypothécaire)
const schema = {
  "@context": "https://schema.org",
  "@type": ["FinancialService", "LocalBusiness"],
  "@id": `${config.site_url}#business`,
  "name": `${config.nom} — ${config.titre}`,
  "alternateName": config.nom,
  "image": resolvedOgImage.toString(),
  "url": config.site_url,
  "telephone": telephoneE164,
  "email": config.courriel,
  "areaServed": [
    { "@type": "City", "name": "Repentigny" },
    { "@type": "City", "name": "Mascouche" },
    { "@type": "City", "name": "Terrebonne" },
    { "@type": "City", "name": "L'Assomption" },
    { "@type": "AdministrativeArea", "name": "Lanaudière" }
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "3344 Fleury Est",
    "addressLocality": "Montréal",
    "addressRegion": "QC",
    "postalCode": "H1H 2R5",
    "addressCountry": "CA"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 45.5794,
    "longitude": -73.6492
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "18:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "10:00",
      "closes": "16:00"
    }
  ],
  "sameAs": [
    config.messenger_url
  ].filter(Boolean),
  "description": description,
  "priceRange": "Free",
  "serviceType": ["Courtage hypothécaire", "Prêt hypothécaire", "Refinancement", "Renouvellement hypothécaire"],
  "hasCredential": {
    "@type": "EducationalOccupationalCredential",
    "credentialCategory": "Permis AMF",
    "recognizedBy": {
      "@type": "Organization",
      "name": "Autorité des marchés financiers"
    },
    "identifier": config.amf
  },
  "parentOrganization": {
    "@type": "Organization",
    "name": config.organisation,
    "url": "https://hypotheca.ca"
  }
};
---

<title>{formattedTitle}</title>
<meta name="description" content={description} />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content={noindex ? "noindex, nofollow, noarchive" : "index, follow"} />
<meta name="theme-color" content="#2D5A3D" />
<link rel="canonical" href={canonicalURL} />

<meta property="og:type" content="website" />
<meta property="og:locale" content="fr_CA" />
<meta property="og:site_name" content={config.nom} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />

{!noindex && <script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />}