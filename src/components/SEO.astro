---
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string | URL;
  ogImage?: string;
}

// On utilise ta configuration JSON pour les valeurs par défaut
const {
  title,
  description = config.meta_description,
  // On utilise le site_url de ta config pour éviter les crashs de build si Astro.site n'est pas défini
  canonicalURL = new URL(Astro.url.pathname, config.site_url),
  ogImage = "/images/og-image.jpg", 
} = Astro.props;

// Construction intelligente du titre
const formattedTitle = title ? `${title} | ${config.nom}` : config.meta_title;

// L'URL de l'image de partage (Facebook/LinkedIn) sécurisée
const resolvedOgImage = new URL(ogImage, config.site_url);

// Données structurées JSON-LD optimisées pour le SEO Local (Courtière)
const schema = {
  "@context": "https://schema.org",
  "@type": "FinancialService", // Plus spécifique et meilleur pour Google que "Person"
  "name": config.nom,
  "image": resolvedOgImage.toString(),
  "url": config.site_url,
  "telephone": config.telephone,
  "email": config.courriel,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "54 rue Bourbon",
    "addressLocality": "Repentigny",
    "addressRegion": "QC",
    "addressCountry": "CA"
  },
  "sameAs": [
    config.messenger_url
  ],
  "description": description
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />

<title>{formattedTitle}</title>
<meta name="description" content={description} />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content="index, follow" />
<link rel="canonical" href={canonicalURL} />

<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={resolvedOgImage} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={formattedTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={resolvedOgImage} />

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="alternate icon" type="image/png" href="/favicon.png" />

<script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />