---
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();

interface Props {
  defaultRate?: number;
}
const { defaultRate = 4.99 } = Astro.props;
---

<section id="calculateur">
  <div class="section-inner">
    <div class="fade-up">
      <h2 class="section-title">Calculez vos <em>versements hypothécaires</em></h2>
      <p class="section-sub">
        Estimez vos versements hypothécaires en quelques secondes. Pour un calcul précis adapté à votre dossier, contactez {config.nom.split(' ')[0]}.
      </p>
    </div>

    <div class="calc-wrapper">
      <form class="calc-form fade-up" id="calc-form" novalidate>

        <div class="form-group">
          <label for="prix">Prix de la propriété ($)</label>
          <input type="text" id="prix" placeholder="450 000" value="450 000" inputmode="numeric" autocomplete="off" />
        </div>

        <div class="form-group">
          <label for="mise">Mise de fonds</label>
          <div class="mise-input-row">
            <input type="text" id="mise" placeholder="45 000" value="45 000" inputmode="numeric" autocomplete="off" />
            <div class="mise-toggle-group" role="group" aria-label="Unité de la mise de fonds">
              <button type="button" id="mise-btn-dollar" class="mise-toggle-btn active" aria-pressed="true" title="Montant en dollars">$</button>
              <button type="button" id="mise-btn-pct" class="mise-toggle-btn" aria-pressed="false" title="Pourcentage du prix">%</button>
            </div>
          </div>
          <small id="mise-pct" style="color:var(--muted);font-size:.75rem;margin-top:.3rem;display:block;"></small>
        </div>

        <!-- Paramètres du prêt -->
        <div class="adv-options">
          <div class="adv-section-label">Paramètres du prêt</div>
          <div class="adv-panel" id="adv-panel">
            <div class="form-group">
              <label for="taux">Taux d'intérêt (%)</label>
              <input type="number" id="taux" placeholder="4.99" value={defaultRate.toFixed(2)} step="0.01" inputmode="decimal" min="0" max="25" />
              <small style="color:var(--muted);font-size:.72rem;margin-top:.3rem;display:block;">Modifiable — taux moyen actuel pré-rempli</small>
              <div class="taux-easter-note" id="calc-taux-note" style="display:none;"></div>
            </div>
            <div class="form-row">
              <div class="form-group" style="width: 100%;">
                <label for="amort">Amortissement</label>
                <select id="amort">
                  <option value="25">25 ans</option>
                  <option value="30">30 ans (mise ≥ 20 %)</option>
                  <option value="20">20 ans</option>
                  <option value="15">15 ans</option>
                </select>
              </div>
              <div class="form-group" style="width: 100%;">
                <label for="freq">Fréquence</label>
                <select id="freq">
                  <option value="12">Mensuel</option>
                  <option value="26">Aux deux semaines</option>
                  <option value="52">Hebdomadaire</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label for="calc-taxes">Taxes municipales et scolaires ($/mois)</label>
              <input type="number" id="calc-taxes" value="250" inputmode="decimal" min="0" />
            </div>
            <div class="form-group">
              <label for="calc-chauffage">Frais de chauffage ($/mois)</label>
              <input type="number" id="calc-chauffage" value="100" inputmode="decimal" min="0" />
            </div>
            <div class="form-group">
              <label for="calc-condo">Frais de copropriété / condo ($/mois)</label>
              <input type="number" id="calc-condo" value="0" inputmode="decimal" min="0" />
              <small style="color:var(--muted);font-size:.7rem;margin-top:.25rem;display:block;">50 % inclus dans le calcul du coût total mensuel</small>
            </div>
          </div>
        </div>

      </form>

      <!-- Formulaire Netlify Forms invisible (détection au build pour la capture courriel AJAX) -->
      <form name="calculator-summary" data-netlify="true" data-netlify-honeypot="bot-field" hidden enctype="multipart/form-data">
        <input type="hidden" name="form-name" value="calculator-summary" />
        <input type="file" name="screenshot" />
      </form>

      <div class="calc-results fade-up" style="transition-delay:.2s">

        <div class="calc-warning" id="calc-warning" style="display:none;"></div>

        <div class="result-card main">
          <div class="result-label" id="label-freq">Versement mensuel</div>
          <div class="result-value" id="res-paiement">0 $</div>
          <div class="result-detail" id="res-detail-cap-int">Capital et intérêts — prime SCHL incluse (financée dans le prêt)</div>
          <div class="result-detail result-detail--micro" id="res-detail-prime-schl">Dont ≈ 0 $/mois pour la prime SCHL</div>
        </div>


        <!-- Coût mensuel total (avec taxes, chauffage, condo) -->
        <div class="result-card small result-card--total" id="card-cout-mensuel" style="display:none;">
          <div class="result-label">Coût mensuel total estimé</div>
          <div class="result-value" id="res-cout-mensuel">0 $</div>
          <div class="result-detail" id="res-cout-detail">Capital + intérêts + taxes + chauffage</div>
        </div>

        <div class="results-grid">
          <div class="result-card small">
            <div class="result-label">Montant du prêt</div>
            <div class="result-value" id="res-pret">0 $</div>
          </div>
          <div class="result-card small result-card--schl">
            <div class="result-label">Prime SCHL ajoutée au prêt</div>
            <div class="result-value" id="res-schl">0 $</div>
            <div class="result-detail" id="res-schl-detail" style="display:none;"></div>
          </div>
        </div>

        <div class="calc-cta-section" style="margin-top: 1.5rem; margin-bottom: 1.5rem;">
          <button type="button" id="calc-reveal-btn" class="btn-cta btn-cta--block" style="width: 100%;">
            <span>Recevoir mon estimation par courriel ou texto</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>

          <div class="email-capture" id="email-capture-section" style="display:none; border: 1px solid var(--border); border-radius: 16px; padding: 1.5rem; background: var(--sand);">
            <div class="email-capture-label" style="font-family: 'Lora', serif; font-size: 1.1rem; font-weight: 600; color: var(--ink); margin-bottom: 0.5rem;">Recevoir ce résumé par courriel ou texto</div>
            <div class="email-capture-note" style="font-size: .82rem; color: var(--muted); margin-bottom: 1rem; line-height: 1.6;">Je vous enverrai personnellement le résumé. Merci d'indiquer vos coordonnées.</div>
            <div class="email-capture-row">
              <div style="flex:1;min-width:0;">
                <label class="email-capture-field-label" for="calc-name">Nom complet</label>
                <input type="text" id="calc-name" placeholder="Marie Tremblay" class="email-capture-input" autocomplete="name" required />
              </div>
              <div style="flex:1;min-width:0;">
                <label class="email-capture-field-label" for="calc-phone">Téléphone</label>
                <input type="tel" id="calc-phone" placeholder="514 000-0000" class="email-capture-input" inputmode="tel" autocomplete="tel" />
              </div>
            </div>
            <div class="email-capture-row">
              <div style="flex:1;min-width:0;">
                <label class="email-capture-field-label" for="calc-email">Courriel</label>
                <input type="email" id="calc-email" placeholder="marie@exemple.com" class="email-capture-input" autocomplete="email" />
              </div>
            </div>
            <p class="email-capture-note-sub">
              En envoyant ce formulaire, vous acceptez d'être recontacté·e. Vos données ne sont jamais partagées — voir la <a href="/confidentialite">politique de confidentialité</a>.
            </p>
            <button type="button" id="calc-email-btn" class="penalite-capture-submit" style="width:100%;padding:.8rem;margin-top:.5rem;border-radius:12px;background:var(--clay);color:white;font-family:'DM Sans',sans-serif;font-size:.9rem;font-weight:600;cursor:pointer;">Envoyer →</button>
            <div id="calc-email-msg" class="email-capture-msg" style="display:none;"></div>
          </div>
        </div>

        <a id="lien-amortissement" href="/amortissement" target="_blank" rel="noopener" class="amort-link" style="display:none;">
          Voir le tableau d'amortissement complet →
        </a>

        <div class="calc-disclaimer">
          * Résultats indicatifs uniquement — ne constituent pas une pré-approbation.
          La prime assurance prêt hypothécaire est une estimation aux taux standards. Les frais de notaire,
          droits de mutation (taxe de bienvenue), inspection et évaluation ne sont pas inclus.
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { calculateSCHL, formatMoney, calcPaiement, miseMinimale } from '../utils/mortgageCalc';

  function saveSimulationResult(type: string, resultat: string) {
    try {
      const payload = JSON.stringify({
        type,
        resultat,
        date: new Date().toISOString()
      });
      sessionStorage.setItem('simulation-resultat:' + type, payload);
      sessionStorage.setItem('simulation-resultat', payload);
    } catch (e) { /* ignore */ }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('calc-form');
    if (!form) return;

    // --- Formatage français pour les champs montant ---
    function parsePrixVal(s: string): number {
      return parseFloat(s.replace(/\s/g, '').replace(',', '.')) || 0;
    }
    function fmtPrixEl(): void {
      const val = parsePrixVal(prixEl.value);
      if (val > 0) prixEl.value = Math.round(val).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '\u202F');
    }
    function fmtMiseEl(): void {
      if (miseEnPct) return;
      const val = parsePrixVal(miseEl.value);
      if (val > 0) miseEl.value = Math.round(val).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '\u202F');
    }

    const prixEl      = document.getElementById('prix') as HTMLInputElement;
    const miseEl      = document.getElementById('mise') as HTMLInputElement;
    const tauxEl      = document.getElementById('taux') as HTMLInputElement;
    const calcTauxNoteEl = document.getElementById('calc-taux-note')!;
    const amortEl     = document.getElementById('amort') as HTMLSelectElement;
    const freqEl      = document.getElementById('freq') as HTMLSelectElement;
    const misePctEl   = document.getElementById('mise-pct');
    const btnDollar   = document.getElementById('mise-btn-dollar') as HTMLButtonElement;
    const btnPct      = document.getElementById('mise-btn-pct') as HTMLButtonElement;
    const lienAmortEl = document.getElementById('lien-amortissement') as HTMLAnchorElement;

    // Advanced options fields
    const taxesEl    = document.getElementById('calc-taxes') as HTMLInputElement;
    const chauffageEl= document.getElementById('calc-chauffage') as HTMLInputElement;
    const condoEl    = document.getElementById('calc-condo') as HTMLInputElement;

    // Email capture
    const emailSection = document.getElementById('email-capture-section')!;
    const nameInput    = document.getElementById('calc-name') as HTMLInputElement;
    const phoneInput   = document.getElementById('calc-phone') as HTMLInputElement;
    const emailInput   = document.getElementById('calc-email') as HTMLInputElement;
    const emailBtn     = document.getElementById('calc-email-btn') as HTMLButtonElement;
    const emailMsg     = document.getElementById('calc-email-msg')!;
    const INPUT_DEBOUNCE_MS = 120;
    let calcDebounceTimer: number | undefined;

    let miseEnPct = false;

    // --- Toggle $ / % ---
    function switchToMode(toPct: boolean) {
      if (toPct === miseEnPct) return;
      const prix = parsePrixVal(prixEl.value);
      const miseVal = miseEnPct ? (parseFloat(miseEl.value) || 0) : (parsePrixVal(miseEl.value));
      miseEnPct = toPct;
      if (miseEnPct) {
        btnPct.classList.add('active');
        btnPct.setAttribute('aria-pressed', 'true');
        btnDollar.classList.remove('active');
        btnDollar.setAttribute('aria-pressed', 'false');
        if (prix > 0) miseEl.value = ((miseVal / prix) * 100).toFixed(1);
        miseEl.placeholder = '10';
        miseEl.max = '100';
        miseEl.step = '0.1';
      } else {
        btnDollar.classList.add('active');
        btnDollar.setAttribute('aria-pressed', 'true');
        btnPct.classList.remove('active');
        btnPct.setAttribute('aria-pressed', 'false');
        if (prix > 0) miseEl.value = Math.round(prix * (miseVal / 100)).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '\u202F');
        miseEl.placeholder = '45 000';
        miseEl.removeAttribute('max');
        miseEl.removeAttribute('step');
      }
      doCalculation();
    }

    btnDollar.addEventListener('click', () => switchToMode(false));
    btnPct.addEventListener('click', () => switchToMode(true));

    function updateMisePct() {
      const prix = parsePrixVal(prixEl.value);
      const miseVal = miseEnPct ? (parseFloat(miseEl.value) || 0) : parsePrixVal(miseEl.value);
      if (misePctEl && prix > 0) {
        if (miseEnPct) {
          misePctEl.textContent = `≈ ${formatMoney(Math.round(prix * miseVal / 100))}`;
        } else {
          misePctEl.textContent = `≈ ${((miseVal / prix) * 100).toFixed(1)} % du prix`;
        }
      }
    }

    // --- Messages de validation ---
    const calcWarningEl = document.getElementById('calc-warning')!;
    function showCalcWarning(msg: string | null) {
      if (msg) {
        calcWarningEl.textContent = '⚠️ ' + msg;
        calcWarningEl.style.display = 'block';
      } else {
        calcWarningEl.style.display = 'none';
      }
    }
    function updateCalcTauxNote() {
      const v = tauxEl.value.trim();
      if (v === '0') {
        calcTauxNoteEl.textContent = 'On aimerait tous ça… ✨';
        calcTauxNoteEl.style.display = 'block';
      } else if (parseFloat(v) === 69) {
        calcTauxNoteEl.textContent = 'noice';
        calcTauxNoteEl.style.display = 'block';
      } else {
        calcTauxNoteEl.style.display = 'none';
      }
    }
    tauxEl.addEventListener('input', updateCalcTauxNote);

    function clearResults() {
      document.getElementById('res-paiement')!.textContent = '0 $';
      document.getElementById('res-pret')!.textContent     = '0 $';
      document.getElementById('res-schl')!.textContent     = '0 $';
      document.getElementById('res-detail-cap-int')!.textContent = 'Capital et intérêts — prime SCHL incluse (financée dans le prêt)';
      document.getElementById('label-freq')!.textContent   = 'Versement mensuel';
      const schlDetail = document.getElementById('res-schl-detail')!;
      schlDetail.style.display = 'none';
      const primeSchlMicroEl = document.getElementById('res-detail-prime-schl');
      if (primeSchlMicroEl) {
        primeSchlMicroEl.textContent = 'Dont ≈ 0 $/mois pour la prime SCHL';
        primeSchlMicroEl.style.display = '';
      }
      document.getElementById('card-cout-mensuel')!.style.display = 'none';
      if (lienAmortEl) lienAmortEl.style.display = 'none';
      if (misePctEl) misePctEl.textContent = '';
    }

    function doCalculation() {
      const prix = parsePrixVal(prixEl.value);
      let mise: number;
      if (miseEnPct) {
        mise = Math.round(prix * (parseFloat(miseEl.value) || 0) / 100);
      } else {
        mise = parsePrixVal(miseEl.value);
      }
      const taux  = parseFloat(tauxEl.value) || 0;

      // Easter egg : taux à 0 %
      if (tauxEl.value.trim() === '0' && prix > 0 && mise > 0) {
        clearResults();
        return;
      }
      const amort = parseInt(amortEl.value) || 25;
      const freq  = parseInt(freqEl.value) || 12;

      // Advanced options
      const taxes    = parseFloat(taxesEl.value) || 0;
      const chauffage= parseFloat(chauffageEl.value) || 0;
      const condo    = parseFloat(condoEl.value) || 0;

      // --- Validation de la mise de fonds ---
      if (prix <= 0) { clearResults(); showCalcWarning(null); return; }

      // Règle 5 : mise supérieure ou égale au prix
      if (mise >= prix) {
        clearResults();
        showCalcWarning('La mise de fonds ne peut pas dépasser le prix de la propriété.');
        return;
      }

      // Règle 1 : mise absente ou nulle (règle 6 : valeurs négatives/non numériques filtrées par parsePrixVal → 0)
      if (mise <= 0 || isNaN(mise)) {
        clearResults();
        showCalcWarning('Veuillez entrer une mise de fonds.');
        return;
      }

      // Règle 3 : propriété ≥ 1,5 M$ — pas assurable, 20 % obligatoires
      if (prix >= 1_500_000 && (mise / prix) < 0.2) {
        clearResults();
        showCalcWarning('Pour une propriété de 1,5 M$ et plus, une mise de fonds d\u2019au moins 20 % est requise. Le prêt ne peut pas être assuré par la SCHL.');
        return;
      }

      // Règle 2 : mise inférieure au minimum légal
      const miseMin = miseMinimale(prix);
      if (mise < miseMin) {
        clearResults();
        const minFmt = formatMoney(Math.round(miseMin));
        const pctFmt = (miseMin / prix * 100).toFixed(1);
        showCalcWarning('La mise de fonds minimale requise est de ' + minFmt + ' (' + pctFmt + ' % du prix d\u2019achat).');
        return;
      }

      showCalcWarning(null);

      // 30-year amortization requires ≥ 20% down
      if (amort === 30 && (mise / prix) < 0.2) {
        amortEl.value = '25';
        return doCalculation();
      }

      const schl     = calculateSCHL(prix, mise);
      const pretTotal = (prix - mise) + schl;
      const schlRate  = schl > 0 ? ((schl / (prix - mise)) * 100).toFixed(2) : null;

      // Periodic payment (same formula used in /amortissement)
      const paiementMensuel = calcPaiement(pretTotal, taux, amort, 12);
      const paiementFinal   = calcPaiement(pretTotal, taux, amort, freq);

      // Part du versement mensuel attribuable à la prime SCHL (proportion du prêt total)
      const primeSchlMensuel = schl > 0 ? paiementMensuel * (schl / pretTotal) : 0;

      let labelTexte = 'Versement mensuel';
      if (freq === 26) labelTexte = 'Versement aux deux semaines';
      else if (freq === 52) labelTexte = 'Versement hebdomadaire';

      // Total monthly cost (always monthly, regardless of payment frequency)
      const fraisCondo   = condo * 0.5;
      const coutMensuel  = paiementMensuel + taxes + chauffage + fraisCondo;
      const hasAvanced   = taxes > 0 || chauffage > 0 || condo > 0;

      // --- Update DOM ---
      document.getElementById('res-paiement')!.textContent  = formatMoney(paiementFinal);
      document.getElementById('res-pret')!.textContent      = formatMoney(pretTotal);
      document.getElementById('label-freq')!.textContent    = labelTexte;

      // Règle 4 : mise ≥ 20 % → pas de prime SCHL (feedback positif)
      const schlEl     = document.getElementById('res-schl')!;
      const schlDetail = document.getElementById('res-schl-detail')!;
      if (schl > 0 && schlRate) {
        schlEl.textContent = formatMoney(schl);
        schlDetail.textContent = `Taux : ${schlRate} % du prêt de base`;
        schlDetail.style.display = 'block';
      } else if (mise / prix >= 0.2) {
        schlEl.textContent = 'Aucune prime SCHL applicable';
        schlDetail.style.display = 'none';
      } else {
        schlEl.textContent = 'Aucune';
        schlDetail.style.display = 'none';
      }

      const primeSchlMicroEl = document.getElementById('res-detail-prime-schl');
      if (primeSchlMicroEl) {
        if (schl > 0) {
          primeSchlMicroEl.textContent = `Dont ≈ ${formatMoney(primeSchlMensuel)}/mois pour la prime SCHL`;
          primeSchlMicroEl.style.display = '';
        } else {
          primeSchlMicroEl.textContent = 'Dont ≈ 0 $/mois pour la prime SCHL';
          primeSchlMicroEl.style.display = '';
        }
      }


      // Total mensuel
      const cardCout = document.getElementById('card-cout-mensuel')!;
      if (hasAvanced) {
        cardCout.style.display = '';
        document.getElementById('res-cout-mensuel')!.textContent = formatMoney(coutMensuel);
        const parts: string[] = ['Capital + intérêts'];
        if (taxes > 0)    parts.push(`taxes ${formatMoney(taxes)}/mois`);
        if (chauffage > 0)parts.push(`chauffage ${formatMoney(chauffage)}/mois`);
        if (condo > 0)    parts.push(`condo (50 %) ${formatMoney(fraisCondo)}/mois`);
        document.getElementById('res-cout-detail')!.textContent = parts.join(' · ');
      } else {
        cardCout.style.display = 'none';
      }

      updateMisePct();

      // Animate results
      const resultsDiv = document.querySelector('.calc-results');
      if (resultsDiv) {
        resultsDiv.classList.remove('fade-up');
        void (resultsDiv as HTMLElement).offsetWidth;
        resultsDiv.classList.add('fade-up', 'visible');
      }

      // Amortization link
      const params = new URLSearchParams({
        prix: prix.toString(),
        mise: mise.toString(),
        taux: taux.toString(),
        amort: amort.toString(),
        freq: freq.toString(),
      });
      lienAmortEl.href = `/amortissement?${params.toString()}`;
      lienAmortEl.style.display = '';

      // Sauvegarder dans sessionStorage pour le formulaire « On en parle »
      saveSimulationResult('calculateur',
        `Calculateur de versement — Prix : ${formatMoney(prix)}, ` +
        `Mise de fonds : ${formatMoney(mise)} (${(mise / prix * 100).toFixed(1)} %), ` +
        `Taux : ${taux.toFixed(2).replace('.', ',')} %, ` +
        `Amortissement : ${amort} ans, ` +
        `${labelTexte} : ${formatMoney(paiementFinal)}, ` +
        `Prêt total : ${formatMoney(pretTotal)}` +
        (schl > 0 ? `, Prime SCHL : ${formatMoney(schl)}` : '') +
        (hasAvanced ? `, Coût mensuel total : ${formatMoney(coutMensuel)}` : '')
      );
    }

    function scheduleCalculation() {
      if (calcDebounceTimer) {
        window.clearTimeout(calcDebounceTimer);
      }
      calcDebounceTimer = window.setTimeout(() => {
        doCalculation();
      }, INPUT_DEBOUNCE_MS);
    }

    // --- Email capture (send to Netlify Forms) ---
    emailBtn.addEventListener('click', async () => {
      const nom = nameInput.value.trim();
      const telephone = phoneInput.value.trim();
      const email = emailInput.value.trim();

      if (nom.length < 2) {
        emailMsg.textContent   = 'Veuillez entrer votre nom complet.';
        emailMsg.style.display = '';
        emailMsg.style.color   = '#c0392b';
        return;
      }

      if (!telephone && !email) {
        emailMsg.textContent   = 'Veuillez indiquer au moins un moyen de vous joindre (téléphone ou courriel).';
        emailMsg.style.display = '';
        emailMsg.style.color   = '#c0392b';
        return;
      }

      if (email && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        emailMsg.textContent   = 'Veuillez entrer une adresse courriel valide.';
        emailMsg.style.display = '';
        emailMsg.style.color   = '#c0392b';
        return;
      }

      const labelFrequence  = document.getElementById('label-freq')?.textContent?.trim() || 'Versement mensuel';
      const versement       = document.getElementById('res-paiement')?.textContent?.trim() || '-';
      const montantPret     = document.getElementById('res-pret')?.textContent?.trim() || '-';
      const primeSchl       = document.getElementById('res-schl')?.textContent?.trim() || '-';
      const coutMensuel     = document.getElementById('res-cout-mensuel')?.textContent?.trim() || '';
      const amortissementUrl= lienAmortEl?.href || '';

      emailBtn.textContent = 'Envoi...';
      emailBtn.disabled = true;
      emailMsg.style.display = 'none';

      const formData = new FormData();
      formData.append('form-name', 'calculator-summary');
      formData.append('nom', nom);
      formData.append('telephone', telephone);
      formData.append('email', email);
      formData.append('label_frequence', labelFrequence);
      formData.append('versement', versement);
      formData.append('montant_pret', montantPret);
      formData.append('prime_schl', primeSchl);
      formData.append('cout_mensuel_total', coutMensuel);
      formData.append('amortissement_url', amortissementUrl);
      formData.append('consentement', 'oui');

      const targetEl = document.querySelector('.calc-wrapper') as HTMLElement;
      if (targetEl) {
        try {
          const { default: html2canvas } = await import('html2canvas');
          const canvas = await html2canvas(targetEl, {
            backgroundColor: '#fdfaf6',
            scale: 1.5,
            useCORS: true,
            logging: false,
          });
          await new Promise<void>((resolve) => {
            canvas.toBlob((blob) => {
              if (blob) {
                formData.append('screenshot', blob, 'calculateur-screenshot.png');
              }
              resolve();
            }, 'image/png', 0.9);
          });
        } catch {
          // Ne pas bloquer si la capture échoue
        }
      }

      try {
        const response = await fetch('/', {
          method: 'POST',
          body: formData,
        });

        if (!response.ok) {
          throw new Error('Erreur serveur Netlify');
        }

        emailMsg.textContent   = 'Merci. Je vous enverrai votre résumé sous peu.';
        emailMsg.style.display = '';
        emailMsg.style.color   = 'var(--clay)';
        nameInput.value = '';
        phoneInput.value = '';
        emailInput.value = '';

        // Signaler la conversion au sticky CTA
        document.body.dataset.outilsConverted = 'true';
        localStorage.setItem('calc_email_sent', '1');
        window.dispatchEvent(new CustomEvent('outils:converted'));
      } catch {
        emailMsg.textContent   = 'Impossible d\'envoyer le résumé pour le moment. Veuillez réessayer.';
        emailMsg.style.display = '';
        emailMsg.style.color   = '#c0392b';
      } finally {
        emailBtn.textContent = 'Envoyer →';
        emailBtn.disabled = false;
      }
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();
    });

    const calcRevealBtn = document.getElementById('calc-reveal-btn') as HTMLButtonElement;

    calcRevealBtn.onclick = () => {
      doCalculation();
      calcRevealBtn.style.display = 'none';
      emailSection.style.display = 'block';
    };

    // Real-time recalculation while typing in numeric inputs
    document.querySelectorAll('#calculateur input, #calculateur select').forEach((el) => {
      const field = el as HTMLInputElement | HTMLSelectElement;

      // Email capture input is not part of mortgage calculations
      if (field.id === 'calc-name' || field.id === 'calc-phone' || field.id === 'calc-email') return;

      field.addEventListener('change', doCalculation);
      if (field.tagName === 'INPUT') {
        field.addEventListener('input', scheduleCalculation);
      }
    });

    // Formatage des champs montant : séparateurs de milliers au blur, retirés au focus
    prixEl.addEventListener('focus', () => {
      prixEl.value = prixEl.value.replace(/\s/g, '');
      prixEl.select();
    });
    prixEl.addEventListener('blur', fmtPrixEl);

    miseEl.addEventListener('focus', () => {
      if (!miseEnPct) {
        miseEl.value = miseEl.value.replace(/\s/g, '');
        miseEl.select();
      }
    });
    miseEl.addEventListener('blur', fmtMiseEl);

    doCalculation();
  });
</script>
