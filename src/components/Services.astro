---
// Liste des services. Chaque carte est entièrement cliquable et pointe vers sa sous-page dédiée.
// Sans `href`, on retombe sur l'ancre #contact (parcours de prise de rendez-vous).
import { House, Repeat, Lightbulb, LockKeyholeOpen, Briefcase, Globe } from '@lucide/astro';

interface ServiceItem {
  icon: any;
  title: string;
  description: string;
  cta: string;
  href?: string;
}

const services: ServiceItem[] = [
  {
    icon: House,
    title: "Premier achat",
    description: "Vous achetez votre première propriété ? Je vous guide à travers la mise de fonds, le test de résistance, et je négocie les meilleures conditions pour vous.",
    cta: "Calculer ma capacité",
    href: "/services/premier-achat"
  },
  {
    icon: Repeat,
    title: "Renouvellement",
    description: "Votre hypothèque arrive à terme ? C'est le meilleur moment de magasiner. Je compare les offres de 20+ prêteurs pour vous obtenir un meilleur taux que votre banque.",
    cta: "Comparer les taux",
    href: "/services/renouvellement"
  },
  {
    icon: Lightbulb,
    title: "Refinancement",
    description: "Consolidation de dettes, rénovations, achat locatif — le refinancement peut libérer des liquidités importantes. Analysons ensemble si c'est la bonne décision.",
    cta: "Découvrir mes options",
    href: "/services/refinancement"
  },
  {
    icon: LockKeyholeOpen,
    title: "Dossier refusé",
    description: "Votre banque vous a dit non ? Un refus bancaire, ce n'est pas une fin. J'ai accès à des prêteurs alternatifs adaptés aux situations complexes.",
    cta: "Trouver une solution",
    href: "/services/dossier-refuse"
  },
  {
    icon: Briefcase,
    title: "Travailleur autonome",
    description: "Revenus variables, contrats, incorporation — je sais comment présenter votre dossier pour maximiser vos chances.",
    cta: "Maximiser mon dossier",
    href: "/services/travailleur-autonome"
  },
  {
    icon: Globe,
    title: "Nouveaux arrivants",
    description: "Vous venez d'arriver au Canada ? Il existe des programmes spéciaux pour les résidents permanents et certains détenteurs de permis de travail.",
    cta: "Voir les programmes",
    href: "/services/nouveaux-arrivants"
  }
];
---

<section id="services">
  <div class="section-inner">

    <div class="fade-up">
      <h2 class="section-title">Ce que je peux<br />faire pour <em>vous</em></h2>
      <p class="section-sub">
        Du premier achat au renouvellement, du refinancement au dossier complexe — je vous accompagne à chaque étape, où que vous soyez au Québec.
      </p>
    </div>

    <div class="services-grid stagger-children" id="services-grid">
      {services.map((service) => (
        <a
          href={service.href ?? '#contact'}
          class="service-card"
          aria-label={`${service.cta} — ${service.title}`}
        >
          <div class="service-icon" aria-hidden="true">
            <service.icon size={28} stroke-width={1.8} />
          </div>

          <h3>{service.title}</h3>
          <p>{service.description}</p>

          <span class="learn">
            {service.cta}
          </span>
        </a>
      ))}
    </div>

  </div>
</section>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }
  .service-card:focus-visible {
    outline: 3px solid var(--clay);
    outline-offset: 4px;
  }
  .service-card * {
    text-decoration: none;
  }
  /* Remplacement du radial-gradient par un suivi souris fluide */
  .service-card::before {
    background: radial-gradient(800px circle at var(--mouse-x, 50%) var(--mouse-y, 0%), rgba(196, 122, 82, 0.08), transparent 40%);
  }
  .service-card h3 {
    font-family: "Lora", serif;
    font-size: 1.3rem;
    margin-bottom: 0.8rem;
    font-weight: 600;
    color: var(--ink);
  }
  .service-card .learn {
    margin-top: auto;
    padding-top: 1.2rem;
    color: var(--clay);
  }
  
  @media (max-width: 900px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  (function() {
    const grid = document.getElementById('services-grid');
    if (!grid) return;
    const cards = grid.querySelectorAll('.service-card');

    // Glow tracking mouse
    grid.addEventListener('mousemove', (e) => {
      for(const card of cards) {
        const rect = (card as HTMLElement).getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        (card as HTMLElement).style.setProperty('--mouse-x', `${x}px`);
        (card as HTMLElement).style.setProperty('--mouse-y', `${y}px`);
      }
    });
  })();
</script>