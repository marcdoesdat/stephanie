---
import type { HypothecaRates } from '../services/ratesService';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();

interface Props {
  hypothecaRates?: HypothecaRates;
}
const { hypothecaRates } = Astro.props;

function fmtRate(val: number | null | undefined): string {
  if (val == null) return '—';
  return val.toFixed(2).replace('.', ',') + ' %';
}
---

{hypothecaRates && (
  <section id="hypotheca-bandeau" aria-label="Aperçu des taux hypothécaires">
    <div class="taux-inner fade-up">
      
      <div class="taux-header">
        <div class="header-left">
          <div class="taux-title-tag">
            Taux du marché · 
            {hypothecaRates.source === 'live' ? 'Mis à jour en direct' : 'Taux indicatifs'}
          </div>
          <h2 class="taux-title">Aperçu des taux — {config.organisation}</h2>
        </div>
        <div class="header-right">
          Source : <strong>{config.organisation.toLowerCase()}.ca</strong><br />
          <span class="status-indicator">
            <span class={`dot ${hypothecaRates.source === 'live' ? 'live' : 'fallback'}`}></span>
            {hypothecaRates.source === 'fallback' ? 'Mode hors-ligne' : 'Synchronisé avec le marché'}
          </span>
        </div>
      </div>
      
      <div class="taux-grid">
        <div class="taux-cell accent">
          <div class="taux-label">5 ans fixe</div>
          <div class="taux-val">{fmtRate(hypothecaRates.fixe_5ans)}</div>
          <div class="taux-note">Le plus populaire</div>
        </div>
        
        <div class="taux-cell">
          <div class="taux-label">3 ans fixe</div>
          <div class="taux-val">{fmtRate(hypothecaRates.fixe_3ans)}</div>
          <div class="taux-note">Taux fixe 3 ans</div>
        </div>
        
        <div class="taux-cell">
          <div class="taux-label">2 ans fixe</div>
          <div class="taux-val">{fmtRate(hypothecaRates.fixe_2ans)}</div>
          <div class="taux-note">Taux fixe 2 ans</div>
        </div>
        
        <div class="taux-cell">
          <div class="taux-label">1 an fixe</div>
          <div class="taux-val">{fmtRate(hypothecaRates.fixe_1ans)}</div>
          <div class="taux-note">Taux fixe 1 an</div>
        </div>
      </div>
      
      <div class="taux-disclaimer">
        <span aria-hidden="true">⚠️</span> Les taux affichés sont <strong>indicatifs</strong>. Ils ne
        constituent pas une offre de financement. <br class="mobile-break" />
        <a href="#contact">Consultez {config.nom.split(' ')[0]} pour une analyse de votre dossier.</a>
      </div>
      
    </div>
  </section>
)}

<style>
  /* --- STYLES DU BANDEAU --- */
  
  #hypotheca-bandeau {
    padding: 4rem 1.5rem;
    background-color: var(--white);
  }

  .taux-inner {
    max-width: 1100px;
    margin: 0 auto;
    background: var(--sand);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 2.5rem;
    box-shadow: 0 10px 40px rgba(0,0,0,0.04);
  }

  .taux-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
  }

  .taux-title-tag {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--clay);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .taux-title {
    font-family: "Lora", serif;
    font-size: 1.6rem;
    color: var(--ink);
    margin: 0;
  }

  .header-right {
    font-size: 0.75rem;
    color: var(--muted);
    text-align: right;
    line-height: 1.6;
  }

  /* Le petit point lumineux de statut */
  .status-indicator {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.2rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .dot.live { 
    background-color: var(--forest); 
    box-shadow: 0 0 8px var(--forest); 
  }
  .dot.fallback { 
    background-color: #f59e0b; 
  }

  /* La grille des cartes de taux */
  .taux-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .taux-cell {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    text-align: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .taux-cell:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.06);
  }

  /* La carte mise en évidence */
  .taux-cell.accent {
    background: var(--clay);
    border-color: var(--clay);
    color: white;
  }

  .taux-cell.accent .taux-label,
  .taux-cell.accent .taux-note {
    color: rgba(255,255,255,0.8);
  }

  .taux-cell.accent .taux-val {
    color: white;
  }

  .taux-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .taux-val {
    font-family: "Lora", serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--forest);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .taux-note {
    font-size: 0.7rem;
    color: var(--muted);
  }

  .taux-disclaimer {
    font-size: 0.75rem;
    color: var(--muted);
    text-align: center;
    line-height: 1.8;
    background: rgba(0,0,0,0.02);
    padding: 1.2rem;
    border-radius: 12px;
  }

  .taux-disclaimer a {
    color: var(--clay);
    font-weight: 600;
    text-decoration: none;
    transition: color 0.2s;
  }

  .taux-disclaimer a:hover {
    color: var(--clay-dk);
    text-decoration: underline;
  }
  
  .mobile-break {
    display: none;
  }

  /* Ajustements pour les petits écrans (téléphones) */
  @media (max-width: 768px) {
    .taux-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }
    .header-right {
      text-align: left;
    }
    .taux-inner {
      padding: 1.5rem;
    }
    .mobile-break {
      display: block;
    }
  }
</style>