---
// Barre de navigation par ancres, collante, visible uniquement sur mobile.
// Permet de sauter directement à une section de la page d'accueil sans scroller.
// Les liens reflètent les sections principales de index.astro.
interface JumpLink {
  href: string;
  label: string;
  id: string;
}

const links: JumpLink[] = [
  { href: '#outils-teaser', label: 'Outils', id: 'outils-teaser' },
  { href: '#services', label: 'Services', id: 'services' },
  { href: '#taux-section', label: 'Taux', id: 'taux-section' },
  { href: '#apropos', label: 'À propos', id: 'apropos' },
  { href: '#temoignages', label: 'Avis', id: 'temoignages' },
  { href: '#faq', label: 'FAQ', id: 'faq' },
  { href: '#contact', label: 'Contact', id: 'contact' },
];
---

<nav id="mobile-jump-nav" aria-label="Navigation rapide par section">
  <ul class="jump-track">
    {links.map((l) => (
      <li>
        <a href={l.href} class="jump-link" data-jump-target={l.id}>{l.label}</a>
      </li>
    ))}
  </ul>
</nav>

<script>
  (function () {
    const bar = document.getElementById('mobile-jump-nav');
    if (!bar) return;
    const links = Array.from(bar.querySelectorAll<HTMLAnchorElement>('.jump-link'));
    const sections = links
      .map((a) => {
        const id = a.dataset.jumpTarget;
        return id ? document.getElementById(id) : null;
      })
      .filter((el): el is HTMLElement => !!el);

    // Scroll fiable vers la section (gère le décalage sous les barres collantes
    // via scroll-margin-top défini en CSS).
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    links.forEach((a) => {
      a.addEventListener('click', (e) => {
        const id = a.dataset.jumpTarget;
        const target = id ? document.getElementById(id) : null;
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
        history.replaceState(null, '', '#' + id);
      });
    });

    // Surligne le lien de la section actuellement visible.
    if ('IntersectionObserver' in window && sections.length) {
      const linkById = new Map<string, HTMLAnchorElement>();
      links.forEach((a) => { if (a.dataset.jumpTarget) linkById.set(a.dataset.jumpTarget, a); });

      let activeId: string | null = null;
      const setActive = (id: string) => {
        if (activeId === id) return;
        activeId = id;
        links.forEach((a) => a.classList.toggle('is-active', a.dataset.jumpTarget === id));
        // Garde le lien actif visible dans la barre scrollable.
        const active = linkById.get(id);
        if (active) active.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'smooth' });
      };

      const observer = new IntersectionObserver(
        (entries) => {
          // Choisit la section la plus proche du haut visible.
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible[0]) setActive(visible[0].target.id);
        },
        { rootMargin: '-120px 0px -55% 0px', threshold: 0 }
      );
      sections.forEach((s) => observer.observe(s));
    }
  })();
</script>
