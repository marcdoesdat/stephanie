---
import { loadSiteConfig } from '../config';
import type { GoogleReviews } from '../services/reviewsService';

const config = loadSiteConfig();

export interface Props {
  reviews: GoogleReviews;
}

const { reviews } = Astro.props;

const { rating, totalReviews, reviews: reviewItems } = reviews;

// Palette de 5 couleurs pour les avatars — cohérentes avec le design (vert sauge, violet, terracotta, bleu poudré, ocre)
const AVATAR_COLORS = ['#7a9e7e', '#8b7a9e', '#c47a52', '#5a7a8a', '#d4a88c'];

/** Hash simple d'une chaîne → nombre déterministe */
function hashStr(s: string): number {
  let h = 0;
  for (let i = 0; i < s.length; i++) {
    h = (h * 31 + s.charCodeAt(i)) | 0;
  }
  return Math.abs(h);
}

/** Extrait les initiales d'un nom : "Marie T." → "MT", "Jean" → "J" */
function initials(name: string): string {
  const parts = name.trim().split(/\s+/);
  const first = parts[0]?.[0] ?? '';
  const last = parts[parts.length - 1]?.[0] ?? '';
  return (first + (parts.length > 1 ? last : '')).toUpperCase();
}

// Lien Google Reviews
const googleReviewsUrl = config.google_place_id
  ? `https://search.google.com/local/reviews?placeid=${encodeURIComponent(config.google_place_id)}`
  : `https://www.google.com/search?q=${encodeURIComponent(config.nom + ' Hypotheca avis')}`;
---

<section id="temoignages">
  <div class="section-inner">
    <div class="fade-up" style="text-align:center">
      <div class="section-tag">Témoignages</div>
      <h2 class="section-title">Ce que disent<br />mes <em>clients</em></h2>
    </div>

    <!-- Social proof banner -->
    <div class="temoignages-social fade-up">
      <span class="temoignages-rating">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="#c47a52" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {rating.toFixed(1)} sur Google
      </span>
      <span class="temoignages-sep" aria-hidden="true">·</span>
      <span>{totalReviews} avis vérifiés</span>
    </div>

    <!-- Carrousel -->
    {
      reviewItems.length > 0 ? (
        <div class="temoignages-carousel fade-up" id="temoignages-carousel" aria-roledescription="carrousel" aria-label="Témoignages clients">
          <div class="temoignages-track" id="temoignages-track">
            {reviewItems.map((item, index) => {
              const color = AVATAR_COLORS[hashStr(item.author) % AVATAR_COLORS.length]!;
              return (
                <div
                  class="temoignage-card"
                  role="group"
                  aria-roledescription="diapositive"
                  aria-label={`Témoignage ${index + 1} sur ${reviewItems.length}`}
                >
                  <div class="stars" aria-label={`${item.rating} étoiles sur 5`}>
                    {Array.from({ length: 5 }).map((_, i) => (
                      <svg width="16" height="16" viewBox="0 0 24 24" fill={i < item.rating ? '#c47a52' : '#e0ddd7'} aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                  </div>
                  <blockquote>
                    «&nbsp;{item.text}&nbsp;»
                  </blockquote>
                  <div class="temoignage-author">
                    <div class="author-avatar" style={`background:${color}`} aria-hidden="true">{initials(item.author)}</div>
                    <div>
                      <div class="author-name">{item.author}</div>
                    </div>
                  </div>
                </div>
              );
            })}
          </div>

          <!-- Navigation dots -->
          <div class="temoignages-dots" id="temoignages-dots" aria-hidden="true"></div>
        </div>
      ) : (
        <div class="fade-up" style="text-align:center;padding:2rem;color:var(--ink-secondary)">
          <p>Aucun avis à afficher pour le moment. Revenez bientôt&nbsp;!</p>
        </div>
      )
    }

    <div class="fade-up" style="text-align: center; margin-top: 3rem; transition-delay: 0.3s;">
      <a href={googleReviewsUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary" style="display: inline-flex; align-items: center; gap: 0.5rem; font-size: .85rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="#c47a52" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Voir tous mes avis sur Google
      </a>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const track = document.getElementById('temoignages-track') as HTMLElement;
    const dotsContainer = document.getElementById('temoignages-dots') as HTMLElement;
    if (!track || !dotsContainer) return;

    const cards = track.querySelectorAll<HTMLElement>('.temoignage-card');
    const totalCards = cards.length;
    if (totalCards === 0) return;

    const VISIBLE_DESKTOP = 3;
    const VISIBLE_MOBILE = 1;
    const AUTOPLAY_MS = 5000;
    let currentIndex = 0;
    let autoplayTimer: ReturnType<typeof setInterval> | undefined;
    let isPaused = false;

    function getVisible(): number {
      return window.innerWidth < 900 ? VISIBLE_MOBILE : VISIBLE_DESKTOP;
    }

    function getMaxIndex(): number {
      return totalCards - getVisible();
    }

    // Build dots
    function buildDots() {
      const max = getMaxIndex() + 1;
      dotsContainer.innerHTML = '';
      for (let i = 0; i < max; i++) {
        const dot = document.createElement('button');
        dot.type = 'button';
        dot.className = 'temoignages-dot';
        dot.setAttribute('aria-label', `Aller au témoignage ${i + 1}`);
        dot.addEventListener('click', () => goTo(i));
        dotsContainer.appendChild(dot);
      }
      updateDots();
    }

    function updateDots() {
      const dots = dotsContainer.querySelectorAll<HTMLButtonElement>('.temoignages-dot');
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === currentIndex);
      });
    }

    function goTo(index: number) {
      const max = getMaxIndex();
      currentIndex = Math.max(0, Math.min(index, max));
      const visible = getVisible();
      const cardWidth = cards[0]?.offsetWidth ?? 0;
      const gap = 24; // matches CSS gap
      const offset = currentIndex * (cardWidth + gap);
      track.style.transform = `translateX(-${offset}px)`;
      updateDots();
    }

    function next() {
      const max = getMaxIndex();
      if (currentIndex >= max) {
        goTo(0);
      } else {
        goTo(currentIndex + 1);
      }
    }

    function prev() {
      if (currentIndex <= 0) {
        goTo(getMaxIndex());
      } else {
        goTo(currentIndex - 1);
      }
    }

    function startAutoplay() {
      stopAutoplay();
      autoplayTimer = setInterval(next, AUTOPLAY_MS);
    }

    function stopAutoplay() {
      if (autoplayTimer) {
        clearInterval(autoplayTimer);
        autoplayTimer = undefined;
      }
    }

    // Pause on hover
    const carousel = document.getElementById('temoignages-carousel')!;
    carousel.addEventListener('mouseenter', () => { isPaused = true; stopAutoplay(); });
    carousel.addEventListener('mouseleave', () => { isPaused = false; startAutoplay(); });
    carousel.addEventListener('focusin', () => { isPaused = true; stopAutoplay(); });
    carousel.addEventListener('focusout', () => { isPaused = false; startAutoplay(); });

    // Touch swipe support
    let touchStartX = 0;
    carousel.addEventListener('touchstart', (e) => {
      touchStartX = (e as TouchEvent).touches[0]?.clientX ?? 0;
      stopAutoplay();
    }, { passive: true });
    carousel.addEventListener('touchend', (e) => {
      const diff = touchStartX - ((e as TouchEvent).changedTouches[0]?.clientX ?? 0);
      if (Math.abs(diff) > 50) {
        if (diff > 0) next();
        else prev();
      }
      if (!isPaused) startAutoplay();
    });

    // Keyboard navigation
    carousel.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'ArrowLeft') { e.preventDefault(); prev(); }
      if ((e as KeyboardEvent).key === 'ArrowRight') { e.preventDefault(); next(); }
    });

    // Resize handling
    let resizeDebounce: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeDebounce);
      resizeDebounce = setTimeout(() => {
        buildDots();
        goTo(Math.min(currentIndex, getMaxIndex()));
      }, 200);
    });

    // Init
    buildDots();
    goTo(0);
    startAutoplay();
  });
</script>
