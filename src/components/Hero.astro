---
import { Image } from 'astro:assets';
import stephaniePhoto from '../assets/stephanie.jpg';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const { baseRate = 3.70 } = Astro.props;
function fmtRate(val: number | null | undefined): string {
  if (val == null) return '—';
  return val.toFixed(2).replace('.', ',') + ' %';
}
---

<section id="hero">
  <div class="hero-inner">
    <div class="hero-left fade-up">
      <div class="hero-badge">Courtière hypothécaire · {config.region}</div>
      
      <h1>Votre hypothèque,<br /><em>enfin expliquée</em><br />simplement.</h1>
      
      <p>
        Je vous accompagne dans l’un des projets les plus importants de votre vie — sans jargon,
        sans pression, avec des taux obtenus via un réseau de plus de 20&nbsp;prêteurs.
      </p>

      <div class="hero-btns">
        <a href="#contact" class="btn-cta">
          <span>Prendre rendez-vous</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/outils#simulateur" class="btn-secondary">Voir mes outils</a>
      </div>
      
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-num">20+</div>
          <div class="stat-label">Prêteurs</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">100&nbsp;%</div>
          <div class="stat-label">Gratuit</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">24&nbsp;h</div>
          <div class="stat-label">Premier contact garanti</div>
        </div>
      </div>
    </div>
    
    <div class="hero-right fade-up" style="transition-delay:.2s">
      <div class="photo-container">
        <div class="photo-frame">
          <Image
            src={stephaniePhoto}
            alt="Stéphanie Weyman"
            width={600}
            height={750}
            loading="eager" 
          />
        </div>
        
        <div class="hero-blob blob-1"></div>
        <div class="hero-blob blob-2"></div>
        
        <div class="floating-card card-tl">
          <div class="card-sm">Taux variable</div>
          <div class="card-val">Dès {fmtRate(baseRate)}</div>
        </div>
        
        <div class="floating-card card-tr">
          <img src="/images/bonlogohypotheca.svg" alt="Hypotheca" style="height:56px;width:auto;display:block;" loading="lazy" />
        </div>

        <div class="floating-card card-br">
          <div class="card-sm">Satisfaction</div>
          <div class="card-val">⭐ 5&nbsp;/&nbsp;5</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-btns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    max-width: 430px;
  }

  .hero-btns .btn-cta,
  .hero-btns .btn-secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0.65rem 1rem;
    text-align: center;
    min-width: 0;
    white-space: nowrap;
    line-height: 1.15;
    font-size: 0.92rem;
  }
  .hero-btns .btn-cta { gap: 0.45rem; }

  .hero-badge::before {
    display: none !important;
    content: none !important;
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
  }

  .blob-1 {
    width: 160px;
    height: 160px;
    background: radial-gradient(circle, rgba(196, 122, 82, 0.15) 0%, transparent 70%);
    bottom: 10%;
    right: 5%;
    animation: appear-blob 0.6s cubic-bezier(0.16, 1, 0.3, 1) both, float-idle 6s ease-in-out 0.6s infinite;
  }

  .blob-2 {
    width: 144px;
    height: 144px;
    background: radial-gradient(circle, rgba(61, 90, 74, 0.1) 0%, transparent 70%);
    top: 5%;
    right: 8%;
    animation: appear-blob 0.6s cubic-bezier(0.16, 1, 0.3, 1) both, float-idle 8s ease-in-out 2s infinite;
  }

  @keyframes appear-blob {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes float-idle {
    0%, 100% { transform: translateY(0px); }
    50%      { transform: translateY(-8px); }
  }

  @media (max-width: 900px) {
    @keyframes float-idle {
      0%, 100% { transform: translateY(0px); }
      50%      { transform: translateY(-12px); }
    }
  }

  /* Cartes flottantes — apparition cascadée puis flottement continu */
  .floating-card {
    animation:
      appear-card 0.55s cubic-bezier(0.16, 1, 0.3, 1) both,
      float 4s ease-in-out infinite;
  }

  .card-tl {
    animation-delay: 0.54s, 1.1s;
  }

  .card-tr {
    animation-delay: 0.67s, 1.3s;
  }

  .card-br {
    animation-delay: 0.8s, 1.5s;
  }

  .floating-card.card-tr {
    padding: 0.8rem;
  }

  @keyframes appear-card {
    0% {
      opacity: 0;
      transform: translateY(8px) scale(0.95);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 900px) {
    #hero {
      padding: 6rem 1.5rem;
      min-height: auto;
    }
    .hero-right {
      display: flex !important;
      justify-content: center;
      max-width: 320px;
      margin: 0 auto;
    }
    .photo-container {
      position: relative;
      width: 100%;
    }
    .hero-blob.blob-1 {
      width: 120px;
      height: 120px;
    }
    .hero-blob.blob-2 {
      width: 108px;
      height: 108px;
    }
    .floating-card.card-tl {
      left: -5%;
      top: -2%;
      transform: scale(0.85);
    }
    .floating-card.card-tr {
      right: -5%;
      top: -2%;
      transform: scale(0.85);
    }
    .floating-card.card-br {
      right: -5%;
      bottom: 8%;
      transform: scale(0.85);
    }
  }

  @media (max-width: 520px) {
    .hero-btns {
      gap: 0.65rem;
    }

    .hero-btns .btn-cta,
    .hero-btns .btn-secondary {
      min-height: 50px;
      font-size: 0.92rem;
    }

    .hero-right {
      max-width: 260px;
    }
    .hero-blob.blob-1 {
      width: 120px;
      height: 120px;
    }
    .hero-blob.blob-2 {
      width: 108px;
      height: 108px;
    }
    .floating-card.card-tl {
      left: -2%;
      top: -6%;
      transform: scale(0.75);
    }
    .floating-card.card-tr {
      right: -2%;
      top: -6%;
      transform: scale(0.75);
    }
    .floating-card.card-br {
      right: -2%;
      bottom: 5%;
      transform: scale(0.75);
    }
  }

  @media (max-width: 390px) {
    .hero-btns {
      grid-template-columns: 1fr;
    }
  }

  /* Photo en miroir */
  .photo-frame img {
    transform: scaleX(-1);
  }
</style>