---
import { Image } from 'astro:assets';
import stephaniePhoto from '../assets/stephanie.jpg';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const { baseRate = 4.99 } = Astro.props;
function fmtRate(val: number | null | undefined): string {
  if (val == null) return '—';
  return val.toFixed(2).replace('.', ',') + ' %';
}
---

<section id="hero">
  <div class="hero-inner">
    <div class="hero-left fade-up">
      <div class="hero-badge">Courtière hypothécaire agréée · {config.region}</div>
      <h1>Votre hypothèque,<br /><em>enfin expliquée</em><br />simplement.</h1>
      <p>
        Je vous accompagne dans l'un des projets les plus importants de votre vie — sans jargon,
        sans pression, avec les meilleurs taux parmi plus de 20 prêteurs.
      </p>
      <div class="hero-btns">
        <a href="#contact" class="btn-primary">Prendre rendez-vous →</a>
        <a href="#simulateur" class="btn-secondary">Calculateur</a>
      </div>
      
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-num">20+</div>
          <div class="stat-label">Prêteurs</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">100%</div>
          <div class="stat-label">Gratuit</div>
        </div>
      </div>
    </div>
    
    <div class="hero-right fade-up" style="transition-delay:.2s">
      <div class="photo-wrapper">
        <div class="photo-frame">
          <Image
            src={stephaniePhoto}
            alt="Stéphanie Weyman"
            width={600}
            height={750}
            loading="eager" 
          />
        </div>
        
        <div class="bubble bubble-tl"></div>
        <div class="bubble bubble-br"></div>
        <div class="bubble bubble-center"></div>
        
        <div class="floating-card card-tl">
          <div class="card-sm">Taux variable</div>
          <div class="card-val">Dès {fmtRate(baseRate)}</div>
        </div>
        <div class="floating-card card-br">
          <div class="card-sm">Satisfaction</div>
          <div class="card-val">⭐ 5 / 5</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #hero {
    overflow: hidden;
    padding: 80px 0 40px; /* Espace en haut pour la nav */
  }

  /* Configuration du conteneur principal */
  .hero-inner {
    display: flex;
    flex-direction: column; /* MOBILE : Texte en haut, Photo en bas */
    gap: 40px;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .hero-left {
    text-align: center;
    z-index: 5;
  }

  /* --- SECTION PHOTO --- */
  .hero-right {
    position: relative;
    width: 100%;
    display: flex !important; /* Force l'affichage */
    justify-content: center;
    padding: 40px 0;
  }

  .photo-wrapper {
    position: relative;
    width: 280px; /* Taille sur mobile */
  }

  .photo-frame {
    position: relative;
    z-index: 2;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
  }

  .photo-frame :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  /* --- BULLES --- */
  .bubble {
    position: absolute;
    border-radius: 50%;
    background: linear-gradient(135deg, #0077b6, #90e0ef);
    opacity: 0.2;
    filter: blur(8px);
    z-index: 1;
    animation: float 6s ease-in-out infinite;
  }

  .bubble-tl { width: 80px; height: 80px; top: -20px; left: -30px; }
  .bubble-br { width: 120px; height: 120px; bottom: -20px; right: -30px; animation-delay: 2s; }
  .bubble-center { width: 60px; height: 60px; top: 40%; left: -40px; animation-delay: 4s; }

  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(10px, -15px); }
  }

  /* --- CARTES FLOTTANTES --- */
  .floating-card {
    position: absolute;
    background: white;
    padding: 10px 15px;
    border-radius: 12px;
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    z-index: 3;
    min-width: 120px;
  }
  .card-tl { top: 10%; left: -20px; }
  .card-br { bottom: 10%; right: -20px; }
  .card-sm { font-size: 0.65rem; color: #666; text-transform: uppercase; }
  .card-val { font-weight: bold; color: #0077b6; font-size: 0.9rem; }

  /* --- VERSION TABLETTE / WEB --- */
  @media (min-width: 1024px) {
    .hero-inner {
      flex-direction: row; /* WEB : Texte à gauche, Photo à droite */
      text-align: left;
      justify-content: space-between;
      min-height: 80vh;
      gap: 0;
    }
    .hero-left {
      text-align: left;
      flex: 1;
    }
    .hero-right {
      flex: 1;
      justify-content: flex-end;
    }
    .photo-wrapper {
      width: 400px; /* Plus grand sur ordi */
    }
    .bubble-tl { width: 150px; height: 150px; top: -40px; left: -60px; }
    .bubble-br { width: 200px; height: 200px; bottom: -40px; right: -80px; }
  }
</style>