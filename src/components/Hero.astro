---
import { Image } from 'astro:assets';
import stephaniePhoto from '../assets/stephanie.webp';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const { baseRate = null } = Astro.props;
function fmtRate(val: number | null | undefined): string {
  if (val == null) return '—';
  return val.toFixed(2).replace('.', ',') + ' %*';
}
---

<section id="hero">
  <div class="hero-inner">
    <div class="hero-left fade-up">
      <div class="hero-badge">Courtière hypothécaire · {config.region}</div>
      
      <h1>Votre hypothèque,<br /><em>enfin expliquée</em><br />simplement.</h1>
      
      <p>
        Je vous accompagne dans l'un des projets les plus importants de votre vie — sans jargon,
        sans pression, avec des taux obtenus via un réseau de plus de 20&nbsp;prêteurs.
      </p>

      <div class="hero-btns">
        <a href={config.calendly_url} data-calendly class="btn-cta" target="_blank" rel="noopener">
          <span>Prendre rendez-vous</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a href="/outils#simulateur" class="btn-secondary">Voir mes outils</a>
      </div>
      
      <div class="hero-stats scale-in">
        <div class="stat-item">
          <div class="stat-num">20+</div>
          <div class="stat-label">Prêteurs</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">0&nbsp;$</div>
          <div class="stat-label">
            Sans frais de courtage
            <span class="fee-tooltip-wrap">
              <button
                class="fee-info-btn"
                aria-label="En savoir plus sur les frais de courtage"
                aria-expanded="false"
                type="button"
              >i</button>
              <span class="fee-tooltip" role="tooltip">
                Frais de courtage à 0&nbsp;$ pour la vaste majorité des dossiers. Certains financements alternatifs ou privés peuvent comporter des frais, dont je vous informe avant toute démarche.
              </span>
            </span>
          </div>
        </div>
        <div class="stat-item">
          <div class="stat-num">24&nbsp;h</div>
          <div class="stat-label">Premier contact</div>
        </div>
      </div>
    </div>
    
    <div class="hero-right fade-up" style="transition-delay:.2s">
      <div class="photo-container">
        <div class="photo-frame">
          <Image
            src={stephaniePhoto}
            alt="Stéphanie Weyman"
            width={600}
            height={750}
            loading="eager" 
          />
        </div>
        
        <div class="hero-blob blob-1"></div>
        <div class="hero-blob blob-2"></div>
        
        <div class="hero-cards-ribbon">
          <div class="ribbon-card">
            <span class="card-sm">Taux variable</span>
            {baseRate != null
              ? <span class="card-val">Dès {fmtRate(baseRate)}</span>
              : <a class="card-val card-val--link" href="https://hypotheca.ca/taux-hypothecaires" target="_blank" rel="noopener">hypotheca.ca</a>
            }
          </div>
          <div class="ribbon-card ribbon-card--logo">
            <img src="/images/hypotheca-couleur.svg" alt="Hypotheca" width="76" height="76" style="display:block;" loading="lazy" />
          </div>
          <div class="ribbon-card">
            <span class="card-sm">Satisfaction</span>
            <span class="card-val">⭐ 5&nbsp;/&nbsp;5</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-btns {
    display: flex;
    flex-direction: row;
    gap: 0.85rem;
    max-width: 430px;
  }

  .hero-btns .btn-cta,
  .hero-btns .btn-secondary {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0.75rem 1.75rem;
    text-align: center;
    min-width: 0;
    white-space: nowrap;
    line-height: 1.15;
    font-size: 0.85rem;
  }
  .hero-btns .btn-cta { gap: 0.6rem; border-radius: 50px; }

  .hero-badge::before {
    display: none !important;
    content: none !important;
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
  }

  .blob-1 {
    width: 160px;
    height: 160px;
    background: radial-gradient(circle, rgba(196, 122, 82, 0.15) 0%, transparent 70%);
    bottom: 10%;
    right: 5%;
    animation: appear-blob 0.6s cubic-bezier(0.16, 1, 0.3, 1) both, float-idle 6s ease-in-out 0.6s infinite;
  }

  .blob-2 {
    width: 144px;
    height: 144px;
    background: radial-gradient(circle, rgba(61, 90, 74, 0.1) 0%, transparent 70%);
    top: 5%;
    right: 8%;
    animation: appear-blob 0.6s cubic-bezier(0.16, 1, 0.3, 1) both, float-idle 8s ease-in-out 2s infinite;
  }

  @keyframes appear-blob {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes float-idle {
    0%, 100% { transform: translateY(0px); }
    50%      { transform: translateY(-8px); }
  }

  @media (max-width: 900px) {
    @keyframes float-idle {
      0%, 100% { transform: translateY(0px); }
      50%      { transform: translateY(-12px); }
    }
  }

  /* --- Ruban de cartes (glass ribbon) en bas de la photo --- */
  .hero-cards-ribbon {
    position: absolute;
    bottom: -6px;
    left: 8%;
    right: 8%;
    display: flex;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: 18px;
    padding: 0.55rem 0.65rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.07);
    z-index: 3;
    animation:
      appear-ribbon 0.55s cubic-bezier(0.16, 1, 0.3, 1) both,
      float-ribbon 5s ease-in-out 0.6s infinite;
  }

  @keyframes appear-ribbon {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes float-ribbon {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }

  .ribbon-card {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
    text-align: center;
    padding: 0.35rem 0.3rem;
  }

  .ribbon-card .card-sm {
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .ribbon-card .card-val {
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .ribbon-card .card-val--link {
    color: var(--clay);
    text-decoration: none;
    font-family: "Lora", serif;
    font-weight: 600;
  }
  .ribbon-card .card-val--link:hover { text-decoration: underline; }

  .ribbon-card--logo {
    flex: 0 0 auto;
    padding: 0.15rem 0.5rem;
  }

  @media (max-width: 900px) {
    #hero {
      padding: 6rem 1.5rem;
      min-height: auto;
    }
    .hero-right {
      display: flex !important;
      justify-content: center;
      max-width: 320px;
      margin: 0 auto;
    }
    .photo-container {
      position: relative;
      width: 100%;
    }
    .hero-blob.blob-1 {
      width: 120px;
      height: 120px;
    }
    .hero-blob.blob-2 {
      width: 108px;
      height: 108px;
    }
    .hero-cards-ribbon {
      left: 4%;
      right: 4%;
      border-radius: 14px;
      padding: 0.45rem 0.5rem;
      gap: 0.3rem;
    }
    .ribbon-card .card-sm { font-size: 0.6rem; }
    .ribbon-card .card-val { font-size: 0.8rem; }
    .ribbon-card--logo img { height: 60px; }
  }

  @media (max-width: 520px) {
    .hero-btns {
      flex-direction: column;
      gap: 0.65rem;
      max-width: 100%;
    }

    .hero-btns .btn-cta,
    .hero-btns .btn-secondary {
      width: 100%;
      min-height: 52px;
      font-size: 0.9rem;
    }

    .hero-right {
      max-width: 260px;
    }
    .hero-blob.blob-1 {
      width: 100px;
      height: 100px;
    }
    .hero-blob.blob-2 {
      width: 88px;
      height: 88px;
    }
    .hero-cards-ribbon {
      left: 0;
      right: 0;
      bottom: -4px;
      border-radius: 12px;
      padding: 0.4rem 0.4rem;
      gap: 0.2rem;
    }
    .ribbon-card .card-sm { font-size: 0.56rem; }
    .ribbon-card .card-val { font-size: 0.74rem; }
    .ribbon-card--logo img { height: 52px; }
  }



  /* Photo en miroir */
  .photo-frame img {
    transform: scaleX(-1);
  }

  /* Flottement de la photo (indépendant du scroll) */
  .photo-frame {
    animation: float-photo 6s ease-in-out infinite;
  }

  @keyframes float-photo {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-10px); }
  }
</style>

<script>
  // Parallaxe subtil : la photo se déplace plus lentement que le texte au scroll.
  // Désactivé sous 900px (layout empilé) pour éviter que la photo remonte sur le texte.
  (function() {
    const photoContainer = document.querySelector<HTMLElement>('.photo-container');
    const hero = document.getElementById('hero');
    if (!photoContainer || !hero) return;

    const mql = window.matchMedia('(max-width: 900px)');
    let ticking = false;

    function onScroll() {
      if (mql.matches) return;
      if (!ticking) {
        requestAnimationFrame(function() {
          const heroRect = hero!.getBoundingClientRect();
          const heroHeight = hero!.offsetHeight;
          const progress = Math.max(0, Math.min(1, -heroRect.top / (heroHeight - window.innerHeight)));
          const offset = progress * 40;
          photoContainer!.style.transform = 'translateY(-' + offset + 'px)';
          ticking = false;
        });
        ticking = true;
      }
    }

    function syncMode() {
      // Sur mobile, on neutralise tout décalage résiduel laissé par le desktop.
      if (mql.matches) photoContainer!.style.transform = '';
    }

    mql.addEventListener('change', syncMode);
    window.addEventListener('scroll', onScroll, { passive: true });
    syncMode();
  })();

</script>