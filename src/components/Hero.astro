---
import { Image } from 'astro:assets';
import stephaniePhoto from '../assets/stephanie.webp';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const { baseRate = null } = Astro.props;
function fmtRate(val: number | null | undefined): string {
  if (val == null) return '—';
  return val.toFixed(2).replace('.', ',') + ' %*';
}
---

<section id="hero">
  <div class="hero-inner">
    <div class="hero-left fade-up">
      <div class="hero-badge" aria-hidden="true">
        Courtière hypothécaire à {config.region}
      </div>

      <h1 class="hero-value-prop">
        <span class="sr-only">Courtière hypothécaire à {config.region} — </span>
        Acheter ou renouveler,<br /> <em>c'est stressant.</em><br /> Pas avec moi.
      </h1>
      
      <p>
        Je magasine parmi une panoplie de prêteurs à ta place et je t'explique tout — sans jargon,
        sans pression. On parle de ton projet quand t'es prêt.
      </p>

      <div class="hero-btns">
        <a href="/outils#simulateur" class="btn-tools">Calcule ta capacité d'emprunt — gratuit</a>
      </div>
      
      <div class="hero-stats scale-in">
        <div class="stat-item">
          <div class="stat-num">20+</div>
          <div class="stat-label">Prêteurs</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">0&nbsp;$</div>
          <div class="stat-label">
            Sans frais de courtage
            <span class="fee-tooltip-wrap">
              <button
                class="fee-info-btn"
                aria-label="En savoir plus sur les frais de courtage"
                aria-expanded="false"
                type="button"
              >i</button>
              <span class="fee-tooltip" role="tooltip">
                Frais de courtage à 0&nbsp;$ pour la vaste majorité des dossiers. Certains financements alternatifs ou privés peuvent comporter des frais, dont je vous informe avant toute démarche.
              </span>
            </span>
          </div>
        </div>
        <div class="stat-item">
          <div class="stat-num">24&nbsp;h</div>
          <div class="stat-label">Premier contact</div>
        </div>
      </div>
    </div>
    
    <div class="hero-right fade-up" style="transition-delay:.2s">
      <div class="photo-container">
        <div class="photo-frame" id="hero-photo">
          <Image
            src={stephaniePhoto}
            alt="Stéphanie Weyman"
            width={600}
            height={750}
            loading="eager" 
          />
        </div>
        
        <div class="hero-blob blob-1"></div>
        <div class="hero-blob blob-2"></div>
        
        <div class="hero-cards-ribbon">
          <div class="ribbon-card">
            <span class="card-sm">Taux variable</span>
            {baseRate != null
              ? <span class="card-val">Dès {fmtRate(baseRate)}</span>
              : <a class="card-val card-val--link" href="https://hypotheca.ca/taux-hypothecaires" target="_blank" rel="noopener">hypotheca.ca</a>
            }
          </div>
          <div class="ribbon-card ribbon-card--logo">
            <img src="/images/hypotheca-couleur.svg" alt="Hypotheca" width="76" height="76" style="display:block;" loading="lazy" />
          </div>
          <div class="ribbon-card">
            <span class="card-sm">Satisfaction</span>
            <span class="card-val">⭐ 5&nbsp;/&nbsp;5</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .hero-btns {
    display: flex;
    flex-wrap: wrap;
    max-width: 430px;
  }

  .hero-btns .btn-tools {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0.75rem 1.75rem;
    text-align: center;
    min-width: 0;
    white-space: nowrap;
    line-height: 1.15;
    font-size: 0.95rem;
    font-weight: 600;
    border-radius: 50px;
    background: var(--ink);
    color: #fff;
    text-decoration: none;
    border: 2px solid var(--ink);
    box-shadow: 6px 6px 0 var(--clay);
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.2s ease;
  }
  .hero-btns .btn-tools:hover {
    transform: translate(2px, 2px);
    box-shadow: 3px 3px 0 var(--clay);
    background: #000;
  }
  .hero-btns .btn-tools:active {
    transform: translate(4px, 4px);
    box-shadow: 1px 1px 0 var(--clay);
  }

  .hero-badge::before {
    display: none !important;
    content: none !important;
  }

  .hero-badge-sep {
    color: var(--clay);
    margin: 0 0.25rem;
    font-weight: bold;
  }

  .hero-blob {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    will-change: transform;
  }

  .blob-1 {
    width: 160px;
    height: 160px;
    background: radial-gradient(circle, rgba(196, 122, 82, 0.15) 0%, transparent 70%);
    bottom: 10%;
    right: 5%;
    animation: appear-blob 0.6s cubic-bezier(0.16, 1, 0.3, 1) both, float-idle 6s ease-in-out 0.6s infinite;
  }

  .blob-2 {
    width: 144px;
    height: 144px;
    background: radial-gradient(circle, rgba(61, 90, 74, 0.1) 0%, transparent 70%);
    top: 5%;
    right: 8%;
    animation: appear-blob 0.6s cubic-bezier(0.16, 1, 0.3, 1) both, float-idle 8s ease-in-out 2s infinite;
  }

  @keyframes appear-blob {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes float-idle {
    0%, 100% { transform: translateY(0px); }
    50%      { transform: translateY(-8px); }
  }

  @media (max-width: 900px) {
    @keyframes float-idle {
      0%, 100% { transform: translateY(0px); }
      50%      { transform: translateY(-12px); }
    }
  }

  /* --- Ruban de cartes (glass ribbon) en bas de la photo --- */
  .hero-cards-ribbon {
    position: absolute;
    bottom: -6px;
    left: 8%;
    right: 8%;
    display: flex;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: 18px;
    padding: 0.55rem 0.65rem;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.07);
    z-index: 3;
    animation:
      appear-ribbon 0.55s cubic-bezier(0.16, 1, 0.3, 1) both,
      float-ribbon 5s ease-in-out 0.6s infinite;
  }

  @keyframes appear-ribbon {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes float-ribbon {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }

  .ribbon-card {
    flex: 1 1 0;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.15rem;
    text-align: center;
    padding: 0.35rem 0.3rem;
  }

  .ribbon-card .card-sm {
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .ribbon-card .card-val {
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .ribbon-card .card-val--link {
    color: var(--clay);
    text-decoration: none;
    font-family: "Lora", serif;
    font-weight: 600;
  }
  .ribbon-card .card-val--link:hover { text-decoration: underline; }

  .ribbon-card--logo {
    flex: 0 0 auto;
    padding: 0.15rem 0.5rem;
  }

  @media (max-width: 900px) {
    #hero {
      padding: 6rem 1.5rem;
      min-height: auto;
    }
    .hero-right {
      display: flex !important;
      justify-content: center;
      max-width: 320px;
      margin: 0 auto;
    }
    .photo-container {
      position: relative;
      width: 100%;
    }
    .hero-blob.blob-1 {
      width: 120px;
      height: 120px;
    }
    .hero-blob.blob-2 {
      width: 108px;
      height: 108px;
    }
    .hero-cards-ribbon {
      left: 4%;
      right: 4%;
      bottom: -20px;
      border-radius: 14px;
      padding: 0.45rem 0.5rem;
      gap: 0.3rem;
    }
    .ribbon-card .card-sm { font-size: 0.6rem; }
    .ribbon-card .card-val { font-size: 0.8rem; }
    .ribbon-card--logo img { height: 60px; }
  }

  @media (max-width: 520px) {
    .hero-btns {
      flex-direction: column;
      gap: 0.65rem;
      max-width: 100%;
    }

    .hero-btns .btn-tools {
      width: 100%;
      min-height: 52px;
      font-size: 0.9rem;
    }

    .hero-right {
      max-width: 260px;
    }
    .hero-blob.blob-1 {
      width: 100px;
      height: 100px;
    }
    .hero-blob.blob-2 {
      width: 88px;
      height: 88px;
    }
    .hero-cards-ribbon {
      left: 0;
      right: 0;
      bottom: -18px;
      border-radius: 12px;
      padding: 0.4rem 0.4rem;
      gap: 0.2rem;
    }
    .ribbon-card .card-sm { font-size: 0.56rem; }
    .ribbon-card .card-val { font-size: 0.74rem; }
    .ribbon-card--logo img { height: 52px; }
  }



  /* Flottement de la photo (indépendant du scroll) */
  .photo-frame {
    animation: float-photo 6s ease-in-out infinite;
  }

  @keyframes float-photo {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-10px); }
  }
</style>

<script>
  // Parallaxe subtil : la photo se déplace plus lentement que le texte au scroll.
  // Désactivé sous 900px (layout empilé) pour éviter que la photo remonte sur le texte.
  (function() {
    const photoContainer = document.querySelector<HTMLElement>('.photo-container');
    const hero = document.getElementById('hero');
    if (!photoContainer || !hero) return;

    const mql = window.matchMedia('(max-width: 900px)');
    let ticking = false;

    function onScroll() {
      if (mql.matches) return;
      if (!ticking) {
        requestAnimationFrame(function() {
          const heroRect = hero!.getBoundingClientRect();
          const heroHeight = hero!.offsetHeight;
          const progress = Math.max(0, Math.min(1, -heroRect.top / (heroHeight - window.innerHeight)));
          const offset = progress * 40;
          photoContainer!.style.transform = 'translateY(-' + offset + 'px)';
          ticking = false;
        });
        ticking = true;
      }
    }

    function syncMode() {
      // Sur mobile, on neutralise tout décalage résiduel laissé par le desktop.
      if (mql.matches) photoContainer!.style.transform = '';
    }

    mql.addEventListener('change', syncMode);
    window.addEventListener('scroll', onScroll, { passive: true });
    syncMode();
  })();

  // Easter egg : 5 clics sur la photo → blagues hypothécaires
  (function() {
    const photo = document.getElementById('hero-photo');
    if (!photo) return;

    const blagues = [
      'Pourquoi le taux variable a consulté un psychologue? Parce qu\'il avait trop de hauts et de bas.',
      'Stéphanie m\'a dit : « Votre hypothèque est comme un bon mariage. » J\'ai répondu : « 25 ans, et impossible de partir sans pénalité? »',
      'C\'est quoi le comble pour un emprunteur? Trouver que sa maison vaut une fortune… mais devoir la garder 25 ans pour le prouver.',
      'Pourquoi les premiers acheteurs dorment mal? Parce qu\'ils calculent les moutons à 6,5 % d\'intérêt.',
      'Mon courtier m\'a dit que mon dossier était « solide ». J\'ai compris plus tard que c\'était pour le poids des documents à fournir.',
      'Quelle est la différence entre l\'amour et un taux fixe 5 ans? L\'amour, on espère que ça dure plus longtemps.',
      'Stéphanie dit au client : « Bonne nouvelle, vous êtes pré-approuvé! » Le client : « Et la mauvaise? » Le banquier : « Vous devez maintenant trouver une maison à ce prix-là. »',
      'Pourquoi l\'IRD (différentiel de taux) est le méchant des films d\'horreur hypothécaires? Parce qu\'on ne le voit jamais venir, mais il fait toujours mal à la fin.',
      'C\'est un emprunteur qui dit : « Je veux rembourser au plus vite! » Sa banque, les larmes aux yeux : « Mais pourquoi nous quitter si tôt? »',
      'Comment reconnaître quelqu\'un qui vient de renouveler son hypothèque en 2026? Il sourit beaucoup moins qu\'en 2021.',
    ];

    // Création du toast — en position fixed pour éviter le clipping par overflow:hidden du #hero
    const toast = document.createElement('div');
    toast.className = 'hero-joke-toast';
    toast.setAttribute('aria-live', 'polite');
    toast.style.cssText = 'display:none;position:fixed;z-index:9999;background:var(--ink);color:#fff;padding:.75rem 1.1rem;border-radius:12px;font-size:.82rem;line-height:1.5;max-width:260px;text-align:center;pointer-events:none;white-space:normal;box-shadow:0 8px 24px rgba(0,0,0,.25);';
    document.body.appendChild(toast);

    // Curseur pour indiquer que c'est cliquable
    photo.style.cursor = 'pointer';

    let clicks = 0;
    let jokeIndex = 0;
    let hideTimer: ReturnType<typeof setTimeout> | null = null;
    let resetTimer: ReturnType<typeof setTimeout> | null = null;

    photo.addEventListener('click', () => {
      clicks++;
      if (resetTimer) clearTimeout(resetTimer);
      resetTimer = setTimeout(() => { clicks = 0; }, 3000);

      if (clicks < 5) return;
      clicks = 0;

      if (hideTimer) clearTimeout(hideTimer);
      toast.textContent = blagues[jokeIndex] ?? blagues[0]!;

      // Positionner le toast juste au-dessus de la photo
      const rect = photo.getBoundingClientRect();
      toast.style.left = `${rect.left + rect.width / 2}px`;
      toast.style.top = `${rect.top - 12}px`;
      toast.style.transform = 'translate(-50%, -100%)';
      toast.style.display = 'block';
      jokeIndex = (jokeIndex + 1) % blagues.length;

      hideTimer = setTimeout(() => {
        toast.style.display = 'none';
      }, 5000);
    });
  })();

</script>