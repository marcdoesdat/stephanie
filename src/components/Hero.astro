---
import { Image } from 'astro:assets';
import stephaniePhoto from '../assets/stephanie.jpg';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const { baseRate = 3.70 } = Astro.props; // J'ai mis 3.70 pour matcher ta capture
function fmtRate(val: number | null | undefined): string {
  if (val == null) return '—';
  return val.toFixed(2).replace('.', ',') + ' %';
}
---

<section id="hero">
  <div class="hero-inner">
    <div class="hero-left fade-up">
      <div class="hero-badge">Courtière hypothécaire · {config.region}</div>
      
      <h1>Votre hypothèque,<br /><em>enfin expliquée</em><br />simplement.</h1>
      
      <p>
        Je vous accompagne dans l'un des projets les plus importants de votre vie — sans jargon,
        sans pression, avec les meilleurs taux parmi plus de 20 prêteurs.
      </p>

      <div class="hero-btns">
        <a href="#contact" class="btn-primary">Prendre rendez-vous</a>
        <a href="#simulateur" class="btn-secondary">Calculateur</a>
      </div>
      
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-num">20+</div>
          <div class="stat-label">Prêteurs</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">100%</div>
          <div class="stat-label">Gratuit</div>
        </div>
      </div>
    </div>
    
    <div class="hero-right fade-up" style="transition-delay:.2s">
      <div class="photo-container">
        <div class="photo-frame">
          <Image
            src={stephaniePhoto}
            alt="Stéphanie Weyman"
            width={600}
            height={750}
            loading="eager" 
          />
        </div>
        
        <div class="hero-blob blob-1"></div>
        <div class="hero-blob blob-2"></div>
        
        <div class="floating-card card-tl">
          <div class="card-sm">Taux variable</div>
          <div class="card-val">Dès {fmtRate(baseRate)}</div>
        </div>
        
        <div class="floating-card card-br">
          <div class="card-sm">Satisfaction</div>
          <div class="card-val">⭐ 5 / 5</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* --- AJUSTEMENTS POUR HARMONISER AVEC GLOBAL.CSS --- */

  /* Force la disparition du point du global.css pour ce badge spécifiquement */
  .hero-badge::before {
    display: none !important;
    content: none !important;
  }

  /* Force l'affichage de la photo sur mobile (ton global.css la cache) */
  @media (max-width: 900px) {
    #hero {
      padding: 6rem 1.5rem;
      min-height: auto;
    }
    .hero-right {
      display: flex !important; /* Force le display qui est à none dans global.css */
      justify