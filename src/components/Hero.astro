---
import { Image } from 'astro:assets';
import stephaniePhoto from '../assets/stephanie.jpg';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const { baseRate = 4.99 } = Astro.props;
function fmtRate(val: number | null | undefined): string {
  if (val == null) return '—';
  return val.toFixed(2).replace('.', ',') + ' %';
}
---

<section id="hero">
  <div class="hero-inner">
    <div class="hero-left fade-up">
      <div class="hero-badge">Courtière hypothécaire agréée · {config.region}</div>
      
      <h1>Votre hypothèque,<br /><em>enfin expliquée</em><br />simplement.</h1>
      <p>
        Je vous accompagne dans l'un des projets les plus importants de votre vie — sans jargon,
        sans pression, avec les meilleurs taux parmi plus de 20 prêteurs.
      </p>
      <div class="hero-btns">
        <a href="#contact" class="btn-primary">Prendre rendez-vous →</a>
        <a href="#simulateur" class="btn-secondary">Calculateur</a>
      </div>
      
      <div class="hero-stats">
        <div class="stat-item">
          <div class="stat-num">20+</div>
          <div class="stat-label">Prêteurs</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">100%</div>
          <div class="stat-label">Gratuit</div>
        </div>
      </div>
    </div>
    
    <div class="hero-right fade-up" style="transition-delay:.2s">
      <div class="photo-wrapper">
        <div class="photo-frame">
          <Image
            src={stephaniePhoto}
            alt="Stéphanie Weyman"
            width={600}
            height={750}
            loading="eager" 
          />
        </div>
        
        <div class="bubble bubble-tl"></div>
        <div class="bubble bubble-br"></div>
        <div class="bubble bubble-center"></div>
        
        <div class="floating-card card-tl">
          <div class="card-sm">Taux variable</div>
          <div class="card-val">Dès {fmtRate(baseRate)}</div>
        </div>
        <div class="floating-card card-br">
          <div class="card-sm">Satisfaction</div>
          <div class="card-val">⭐ 5 / 5</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #hero {
    overflow: hidden;
    padding: 80px 0 40px;
  }

  .hero-badge {
    display: inline-block;
    padding: 6px 16px;
    background-color: rgba(0, 119, 182, 0.08);
    color: #0077b6;
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 24px;
    border: 1px solid rgba(0, 119, 182, 0.2);
    list-style: none;
  }

  .hero-badge::before {
    content: none !important;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .hero-left {
    text-align: center;
    z-index: 5;
  }

  .hero-right {
    position: relative;
    width: 100%;
    display: flex !important;
    justify-content: center;
    padding: 40px 0;
  }

  .photo-wrapper {
    position: relative;
    width: 280px;
  }

  .photo-frame {
    position: relative;
    z-index: 2;
    border-radius: 24px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
  }

  .photo-frame :global(img) {
    width: 100%;
    height: auto;
    display: block;
  }

  .bubble {
    position: absolute;
    border-radius: 50%;
    background: linear-gradient(135deg, #0077b6, #90e0ef);
    opacity: 0.2;
    filter: blur(8px);
    z-index: 1;
    animation: float 6s ease-in-out infinite;
  }

  .bubble-tl { width: 80px; height: 80px; top: -20px; left: -30px; }
  .bubble-br { width: 120px; height: 120px; bottom: -20px; right: -30px; animation-delay: 2s; }
  .bubble-center { width: 60px; height: 60px; top: 40%; left: -40px; animation-delay: 4s; }

  @keyframes float {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(10px, -15px); }
  }

  .floating-card {
    position: absolute;
    background: white;
    padding: 10px 15px;
    border-radius: 12px;
    box-shadow: 0 10px 20px