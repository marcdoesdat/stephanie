---
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();

// On utilise m.me pour ouvrir directement une conversation Messenger
const chatUrl = config.messenger_chat_url || config.messenger_url;
const hasMessenger = Boolean(chatUrl && chatUrl.trim() !== '');
---

{hasMessenger && (
  <a
    href={chatUrl}
    class="messenger-btn"
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`Écrire à ${config.nom.split(' ')[0]} sur Messenger`}
  >
    <span class="messenger-tooltip" aria-hidden="true">Écrire sur Messenger</span>
    
    <svg 
      xmlns="http://www.w3.org/2000/svg" 
      viewBox="0 0 24 24" 
      fill="currentColor" 
      width="26" 
      height="26"
      aria-hidden="true"
    >
      <path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.908 1.438 5.504 3.686 7.199V22l3.371-1.85c.9.25 1.853.385 2.943.385 5.523 0 10-4.145 10-9.243S17.523 2 12 2zm1.043 12.454l-2.546-2.714-4.97 2.714 5.467-5.805 2.607 2.714 4.909-2.714-5.467 5.805z" />
    </svg>
  </a>
)}