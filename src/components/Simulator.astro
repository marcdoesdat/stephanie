---
interface Props {
  defaultRate?: number;
}
const { defaultRate = 3.79 } = Astro.props;
---

<section id="simulateur">
  <div class="section-inner">
    <div class="fade-up">
      <div class="section-tag">Simulateur</div>
      <div class="section-title">Combien puis-je<br /><em>emprunter ?</em></div>
      <p class="section-sub">Entrez vos informations pour obtenir une estimation de votre capacité d'emprunt en quelques secondes.</p>
    </div>
    <div class="sim-wrapper">
      <div class="sim-form fade-up">
        <div class="sim-group">
          <label for="sim-revenu">Revenu annuel brut ($)</label>
          <input type="number" id="sim-revenu" value="80000" />
        </div>
        <div class="sim-group">
          <label for="sim-dettes">Dettes mensuelles ($) <span style="font-weight:400;text-transform:none;letter-spacing:0">(auto, carte, prêt étudiant...)</span></label>
          <input type="number" id="sim-dettes" value="500" />
        </div>
        <div class="sim-group">
          <label for="sim-mise">Mise de fonds disponible ($)</label>
          <input type="number" id="sim-mise" value="50000" />
        </div>
        <div class="sim-group">
          <label for="sim-taux">Taux d'intérêt estimé (%)</label>
          <input type="number" id="sim-taux" value={defaultRate.toFixed(2)} step="0.01" />
        </div>
        <div class="sim-group">
          <label for="sim-amort">Amortissement</label>
          <select id="sim-amort">
            <option value="25">25 ans</option>
            <option value="30">30 ans</option>
            <option value="20">20 ans</option>
          </select>
        </div>
        <button class="sim-btn" id="sim-btn">Calculer ma capacité →</button>
      </div>
      <div class="sim-results fade-up" style="transition-delay:.2s">
        <div class="sim-result-main">
          <div class="sr-label">Prix d'achat maximal estimé</div>
          <div class="sr-val" id="sim-max">—</div>
          <div class="sr-sub" id="sim-sub">Entrez vos informations</div>
        </div>
        <div class="sim-cards">
          <div class="sim-card"><div class="sc-label">Prêt hypothécaire max</div><div class="sc-val" id="sim-pret">—</div></div>
          <div class="sim-card"><div class="sc-label">Paiement mensuel</div><div class="sc-val" id="sim-pmt">—</div></div>
          <div class="sim-card"><div class="sc-label">Ratio ABD</div><div class="sc-val" id="sim-abd">—</div></div>
          <div class="sim-card"><div class="sc-label">Ratio ATD</div><div class="sc-val" id="sim-atd">—</div></div>
        </div>
        <div class="sim-note">
          💡 <strong>ABD</strong> (amortissement brut de la dette) : maximum 39% ·
          <strong>ATD</strong> (amortissement total de la dette) : maximum 44%.
          Ces ratios sont utilisés par les prêteurs pour approuver votre hypothèque.
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function fmtSim(n: number): string {
    return Math.round(n).toLocaleString('fr-CA') + ' $';
  }

  function simuler() {
    const revenu = parseFloat((document.getElementById('sim-revenu') as HTMLInputElement).value) || 0;
    const dettes = parseFloat((document.getElementById('sim-dettes') as HTMLInputElement).value) || 0;
    const mise = parseFloat((document.getElementById('sim-mise') as HTMLInputElement).value) || 0;
    const taux = parseFloat((document.getElementById('sim-taux') as HTMLInputElement).value) || 3.79;
    const amort = parseInt((document.getElementById('sim-amort') as HTMLSelectElement).value) || 25;

    if (!revenu) return;

    const revMensuel = revenu / 12;
    const tauxStress = Math.max(taux + 2, 5.25);
    const r = tauxStress / 100 / 12;
    const n = amort * 12;
    const pmtMaxABD = revMensuel * 0.39;
    const pmtMaxATD = revMensuel * 0.44 - dettes;
    const pmtMax = Math.min(pmtMaxABD, pmtMaxATD);

    if (pmtMax <= 0) {
      document.getElementById('sim-max')!.textContent = 'Dettes trop élevées';
      return;
    }

    const pretMax = pmtMax * (Math.pow(1 + r, n) - 1) / (r * Math.pow(1 + r, n));
    const prixMax = pretMax + mise;
    const rReel = taux / 100 / 12;
    const pmtReel = pretMax * (rReel * Math.pow(1 + rReel, n)) / (Math.pow(1 + rReel, n) - 1);
    const abd = (pmtReel / revMensuel) * 100;
    const atd = ((pmtReel + dettes) / revMensuel) * 100;

    document.getElementById('sim-max')!.textContent = fmtSim(prixMax);
    document.getElementById('sim-sub')!.textContent = 'Mise de fonds de ' + fmtSim(mise) + ' incluse';
    document.getElementById('sim-pret')!.textContent = fmtSim(pretMax);
    document.getElementById('sim-pmt')!.textContent = fmtSim(pmtReel) + '/mois';

    const abdEl = document.getElementById('sim-abd')!;
    abdEl.textContent = abd.toFixed(1) + '%';
    abdEl.style.color = abd > 39 ? '#c0392b' : 'var(--clay)';

    const atdEl = document.getElementById('sim-atd')!;
    atdEl.textContent = atd.toFixed(1) + '%';
    atdEl.style.color = atd > 44 ? '#c0392b' : 'var(--clay)';
  }

  // Bind events
  ['sim-revenu', 'sim-dettes', 'sim-mise', 'sim-taux'].forEach((id) => {
    document.getElementById(id)!.addEventListener('input', simuler);
  });
  document.getElementById('sim-amort')!.addEventListener('change', simuler);
  document.getElementById('sim-btn')!.addEventListener('click', simuler);

  // Initial calculation
  simuler();
</script>
