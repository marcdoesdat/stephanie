---
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();

interface Props {
  defaultRate?: number;
}
const { defaultRate = 3.79 } = Astro.props;
---

<section id="simulateur">
  <div class="section-inner">

    <div class="fade-up">
      <div class="section-tag">Simulateur</div>
      <h2 class="section-title">Combien puis-je<br /><em>emprunter ?</em></h2>
      <p class="section-sub">
        Entrez vos informations pour obtenir une estimation de votre capacité d'emprunt au Québec en quelques secondes.
      </p>
    </div>

    <div class="sim-wrapper">

      <div class="sim-form fade-up">
        <div class="sim-group">
          <label for="sim-revenu">Revenu annuel brut de votre ménage ($)</label>
          <input type="number" id="sim-revenu" value="80000" inputmode="decimal" min="0" />
        </div>

        <div class="sim-group">
          <label for="sim-dettes">Dettes mensuelles ($) <span style="font-weight:400;text-transform:none;letter-spacing:0">(auto, cartes, prêts...)</span></label>
          <input type="number" id="sim-dettes" value="500" inputmode="decimal" min="0" />
        </div>

        <div class="sim-group">
          <label for="sim-mise">Mise de fonds disponible ($)</label>
          <input type="number" id="sim-mise" value="50000" inputmode="decimal" min="0" />
        </div>

        <div class="sim-group">
          <label for="sim-taux">Taux d'intérêt estimé (%)</label>
          <input type="number" id="sim-taux" value={defaultRate.toFixed(2)} step="0.01" inputmode="decimal" min="0" />
        </div>

        <div class="sim-group">
          <label for="sim-amort">Amortissement</label>
          <select id="sim-amort">
            <option value="25">25 ans</option>
            <option value="30">30 ans (mise de fonds ≥ 20 % requise)</option>
            <option value="20">20 ans</option>
          </select>
        </div>

        <!-- Options avancées -->
        <div class="sim-adv-options">
          <button type="button" class="sim-adv-btn" id="sim-adv-btn" aria-expanded="false" aria-controls="sim-adv-panel">
            Options avancées <span class="adv-arrow" aria-hidden="true">▾</span>
          </button>
          <div class="sim-adv-panel" id="sim-adv-panel" hidden>
            <div class="sim-group">
              <label for="sim-taxes">Taxes municipales et scolaires ($/mois)</label>
              <input type="number" id="sim-taxes" value="250" inputmode="decimal" min="0" />
            </div>
            <div class="sim-group">
              <label for="sim-chauffage">Frais de chauffage ($/mois)</label>
              <input type="number" id="sim-chauffage" value="100" inputmode="decimal" min="0" />
            </div>
            <div class="sim-group">
              <label for="sim-condo">Frais de copropriété / condo ($/mois)</label>
              <input type="number" id="sim-condo" value="0" inputmode="decimal" min="0" />
              <small style="color:var(--muted);font-size:.7rem;margin-top:.25rem;display:block;">50 % de ce montant est inclus dans le calcul des ratios ABD/ATD</small>
            </div>
          </div>
        </div>

        <button class="sim-btn" id="sim-btn">Calculer ma capacité →</button>
      </div>

      <div class="sim-results fade-up" style="transition-delay:.2s" aria-live="polite">
        <div class="sim-warning" id="sim-warning" style="display:none"></div>

        <!-- Résultat principal : basé sur la mise de fonds de l'utilisateur -->
        <div class="sim-result-main">
          <div class="sr-label">Prix d'achat maximal estimé</div>
          <div class="sr-val" id="sim-max">—</div>
          <div class="sr-sub" id="sim-sub">Entrez vos informations</div>
        </div>

        <div class="sim-cards">
          <div class="sim-card">
            <div class="sc-label">Prêt hypothécaire</div>
            <div class="sc-val" id="sim-pret">—</div>
          </div>
          <div class="sim-card">
            <div class="sc-label">Paiement mensuel</div>
            <div class="sc-val" id="sim-pmt">—</div>
          </div>
          <div class="sim-card">
            <div class="sc-label">Ratio ABD</div>
            <div class="sc-val" id="sim-abd">—</div>
          </div>
          <div class="sim-card">
            <div class="sc-label">Ratio ATD</div>
            <div class="sc-val" id="sim-atd">—</div>
          </div>
        </div>

        <!-- Nouvelle carte : scenario alternatif a l'achat -->
        <div class="sim-absolute-max" id="sim-absolute-card" style="display:none;">
          <div class="sam-header">
            <span class="sam-tag">SCÉNARIO ALTERNATIF À L'ACHAT</span>
            <span class="sam-info" title="Capacité calculée uniquement sur vos revenus et dettes, sans tenir compte de votre mise de fonds actuelle.">ℹ</span>
          </div>
          <div class="sam-label">Achat avec mise de fonds minimale</div>
          <div class="sam-val" id="sim-abs-prix">—</div>
          <div class="sam-sub" id="sim-abs-sub">Nécessite une mise de fonds minimale de</div>
          <div class="sam-mise" id="sim-abs-mise">—</div>
        </div>

        <div class="sim-note">
          <strong>Stress test :</strong> Capacité calculée au taux de qualification canadien (taux + 2 % ou 5,25 %, le plus élevé).<br/>
          * Inclut taxes, chauffage et 50 % des frais de condo dans les ratios d'endettement.<br/>
          * Prime SCHL ajoutée au prêt si la mise de fonds est inférieure à 20 %.
        </div>

        <!-- CTA principal -->
        <a href="#contact" class="sim-cta-btn">
          Obtenir ma pré-approbation maintenant
        </a>
      </div>

    </div>
  </div>
</section>

<script>
  import {
    formatMoney,
    tauxMensuel,
    pvFromPmt,
    tauxPrimeSCHL,
    miseMinimale,
    prixMaxParMise,
    droitsMutation,
    calcAbsoluteMax,
  } from '../utils/mortgageCalc';

  document.addEventListener('DOMContentLoaded', () => {
    const INPUT_DEBOUNCE_MS = 120;
    let simDebounceTimer: number | undefined;

    function fmt(n: number): string {
      return Math.round(n).toLocaleString('fr-CA') + ' $';
    }

    // --- Accordion ---
    const advBtn   = document.getElementById('sim-adv-btn') as HTMLButtonElement;
    const advPanel = document.getElementById('sim-adv-panel') as HTMLDivElement;
    advBtn.addEventListener('click', () => {
      const isOpen = !advPanel.hidden;
      advPanel.hidden = isOpen;
      advBtn.setAttribute('aria-expanded', String(!isOpen));
      advBtn.querySelector('.adv-arrow')!.textContent = isOpen ? '▾' : '▴';
    });

    function showWarning(msg: string | null) {
      const el = document.getElementById('sim-warning')!;
      if (msg) {
        el.textContent = '⚠️ ' + msg;
        el.style.display = 'block';
      } else {
        el.style.display = 'none';
      }
    }

    function resetDisplay() {
      document.getElementById('sim-max')!.textContent = '—';
      document.getElementById('sim-max')!.style.fontSize = '';
      document.getElementById('sim-sub')!.textContent = '';
      ['sim-pret', 'sim-pmt', 'sim-abd', 'sim-atd'].forEach(id => {
        const el = document.getElementById(id)!;
        el.textContent = '—';
        el.style.color = '';
      });
      document.getElementById('sim-absolute-card')!.style.display = 'none';
    }

    /** Return a CSS color based on ABD or ATD ratio value vs thresholds */
    function ratioColor(value: number, greenMax: number, orangeMax: number): string {
      if (value <= greenMax)  return '#3d8a57'; // vert
      if (value <= orangeMax) return '#b07a20'; // orange/ambre
      return '#c0392b';                          // rouge
    }

    function simuler() {
      const revenu = parseFloat((document.getElementById('sim-revenu') as HTMLInputElement).value) || 0;
      const dettes = parseFloat((document.getElementById('sim-dettes') as HTMLInputElement).value) || 0;
      let mise     = parseFloat((document.getElementById('sim-mise') as HTMLInputElement).value) || 0;
      const taux   = parseFloat((document.getElementById('sim-taux') as HTMLInputElement).value) || 3.79;
      const amort  = parseInt((document.getElementById('sim-amort') as HTMLSelectElement).value) || 25;

      // Advanced options
      const taxes    = parseFloat((document.getElementById('sim-taxes') as HTMLInputElement).value) || 0;
      const chauffage= parseFloat((document.getElementById('sim-chauffage') as HTMLInputElement).value) || 0;
      const condo    = parseFloat((document.getElementById('sim-condo') as HTMLInputElement).value) || 0;

      if (!revenu) { resetDisplay(); showWarning(null); return; }

      const revMensuel  = revenu / 12;
      const tauxStress  = Math.max(taux + 2, 5.25);
      const rStress     = tauxMensuel(tauxStress);
      const rReel       = tauxMensuel(taux);
      const n           = amort * 12;

      // fraisProp = taxes + chauffage + 50% condo (included in ABD/ATD ratios)
      const fraisProp = taxes + chauffage + condo * 0.5;

      // --- Max loan capacity (at stress-test rate) ---
      function maxPret(abdR: number, atdR: number): number {
        const pmtABD = revMensuel * abdR - fraisProp;
        const pmtATD = revMensuel * atdR - dettes - fraisProp;
        return pvFromPmt(Math.min(pmtABD, pmtATD), rStress, n);
      }

      const pretMaxAssure = maxPret(0.39, 0.44);
      const pretMaxConv   = maxPret(0.35, 0.42);

      // --- Insured scenario: iterate to include SCHL prime (with user's mise) ---
      let prixAssure = 0, baseAssure = 0, primeAssure = 0;
      if (pretMaxAssure > 0) {
        let prix = pretMaxAssure + mise;
        for (let i = 0; i < 10; i++) {
          const ltv = (prix - mise) / prix;
          const pt  = tauxPrimeSCHL(ltv);
          const base = pretMaxAssure / (1 + pt);
          prix = base + mise;
        }
        prixAssure  = prix;
        baseAssure  = prixAssure - mise;
        primeAssure = baseAssure * tauxPrimeSCHL(baseAssure / prixAssure);
      }

      const prixConv = pretMaxConv + mise;

      // --- Determine scenario ---
      let isAssure: boolean, prixMax: number, pretBase: number, primeSCHL: number;

      if (amort > 25) {
        isAssure  = false;
        prixMax   = prixConv;
        pretBase  = pretMaxConv;
        primeSCHL = 0;
        if (pretBase <= 0 || mise / prixMax < 0.20) {
          showWarning('L\'amortissement de 30 ans requiert une mise de fonds d\'au moins 20 % du prix d\'achat.');
          resetDisplay();
          return;
        }
      } else {
        const assurePossible = prixAssure > 0 && prixAssure < 1_000_000 && (mise / prixAssure) < 0.20;
        if (assurePossible) {
          isAssure  = true;
          prixMax   = prixAssure;
          pretBase  = baseAssure;
          primeSCHL = primeAssure;
        } else {
          isAssure  = false;
          prixMax   = prixConv;
          pretBase  = pretMaxConv;
          primeSCHL = 0;
        }
      }

      const abdLimit  = isAssure ? 0.39 : 0.35;
      const atdLimit  = isAssure ? 0.44 : 0.42;
      const typeLabel = isAssure ? 'assuré' : 'conventionnel';

      const maxEl = document.getElementById('sim-max')!;
      if (pretBase <= 0) {
        maxEl.textContent = 'Dettes trop élevées';
        maxEl.style.fontSize = '1.8rem';
        showWarning(null);
        document.getElementById('sim-absolute-card')!.style.display = 'none';
        return;
      }
      maxEl.style.fontSize = '';

      // --- Validate minimum down payment ---
      let warning: string | null = null;
      const miseMin = miseMinimale(prixMax);
      if (mise < miseMin) {
        const cap = prixMaxParMise(mise);
        if (cap < prixMax) {
          prixMax  = cap;
          pretBase = prixMax - mise;
          const ltv = pretBase / prixMax;
          primeSCHL = isAssure ? pretBase * tauxPrimeSCHL(ltv) : 0;
          warning = 'Mise de fonds insuffisante pour la capacité maximale. Prix limité à ' + fmt(cap) + '.';
        }
      }

      // Total loan and real monthly payment
      const pretTotal = pretBase + primeSCHL;
      const pmtReel   = pretTotal * (rReel * Math.pow(1 + rReel, n)) / (Math.pow(1 + rReel, n) - 1);

      // ABD / ATD at stress rate
      const pmtStress = pretTotal * (rStress * Math.pow(1 + rStress, n)) / (Math.pow(1 + rStress, n) - 1);
      const abd = ((pmtStress + fraisProp) / revMensuel) * 100;
      const atd = ((pmtStress + fraisProp + dettes) / revMensuel) * 100;

      // --- Update DOM ---
      showWarning(warning);

      document.getElementById('sim-max')!.textContent = fmt(prixMax);
      document.getElementById('sim-sub')!.textContent =
        'Prêt ' + typeLabel + ' · Mise de fonds de ' + fmt(mise) + ' (' + (mise / prixMax * 100).toFixed(1) + ' %)';
      document.getElementById('sim-pret')!.textContent = fmt(pretTotal);
      document.getElementById('sim-pmt')!.textContent  = fmt(pmtReel) + ' / mois';

      const abdEl = document.getElementById('sim-abd')!;
      abdEl.textContent = abd.toFixed(1) + ' %';
      // Green < 32%, Orange 32–39%, Red > 39%
      abdEl.style.color = ratioColor(abd, 32, abdLimit * 100);

      const atdEl = document.getElementById('sim-atd')!;
      atdEl.textContent = atd.toFixed(1) + ' %';
      // Green < 40%, Orange 40–44%, Red > 44%
      atdEl.style.color = ratioColor(atd, 40, atdLimit * 100);

      // --- Capacité maximale absolue ---
      // Uses ABD 39% / ATD 44% (insured limits = most permissive)
      const pmtAbsABD = revMensuel * 0.39 - fraisProp;
      const pmtAbsATD = revMensuel * 0.44 - dettes - fraisProp;
      const pmtAbsMax = Math.min(pmtAbsABD, pmtAbsATD);
      const pretAbsMax = pvFromPmt(pmtAbsMax, rStress, n);

      const absCard = document.getElementById('sim-absolute-card')!;
      if (pretAbsMax > 0) {
        const { prix: absPrix, miseMin: absMise } = calcAbsoluteMax(pretAbsMax);
        if (absPrix > 0) {
          absCard.style.display = '';
          document.getElementById('sim-abs-prix')!.textContent = fmt(absPrix);
          document.getElementById('sim-abs-mise')!.textContent = fmt(absMise);
          document.getElementById('sim-abs-sub')!.textContent =
            absPrix >= 1_000_000
              ? 'Prêt conventionnel · Mise de fonds minimale de'
              : 'Prêt assuré (SCHL) · Mise de fonds minimale de';
        } else {
          absCard.style.display = 'none';
        }
      } else {
        absCard.style.display = 'none';
      }
    }

    function scheduleSimulation() {
      if (simDebounceTimer) {
        window.clearTimeout(simDebounceTimer);
      }
      simDebounceTimer = window.setTimeout(() => {
        simuler();
      }, INPUT_DEBOUNCE_MS);
    }

    ['sim-revenu', 'sim-dettes', 'sim-mise', 'sim-taux', 'sim-taxes', 'sim-chauffage', 'sim-condo'].forEach(id => {
      document.getElementById(id)!.addEventListener('input', scheduleSimulation);
    });
    document.getElementById('sim-amort')!.addEventListener('change', simuler);

    document.getElementById('sim-btn')!.addEventListener('click', (e) => {
      e.preventDefault();
      simuler();
      const btn = document.getElementById('sim-btn')!;
      btn.style.transform = 'scale(0.98)';
      setTimeout(() => btn.style.transform = 'none', 150);
    });

    simuler();
  });
</script>
