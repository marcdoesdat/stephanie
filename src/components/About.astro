---
import { Image } from 'astro:assets';
import stephaniePhoto from '../assets/stephanie.webp';
import { loadSiteConfig } from '../config';
import { Handshake, Zap, BadgeCheck } from '@lucide/astro';

const config = loadSiteConfig();
const prenom = config.nom.split(' ')[0];
---

<section id="apropos">
  <div class="section-inner">
    <div class="apropos-grid">
      
      <div class="apropos-img fade-left">
        <Image
          src={stephaniePhoto}
          alt={`${config.nom}, ${config.titre} chez ${config.organisation} à Repentigny`}
          width={500}
          height={500}
          loading="lazy"
          decoding="async"
        />
      </div>
      
      <div class="fade-right" style="transition-delay:.15s">
        <div class="section-tag">À propos</div>
        <div class="apropos-text">
          <h2>Bonjour, moi c'est {prenom}.</h2>
          
          <p>
            Courtière hypothécaire chez <strong>Hypotheca</strong> depuis quatre ans, j'accompagne des clients partout au <strong>Québec</strong>, à partir de <strong>Repentigny</strong>, au cœur de <strong>Lanaudière</strong> — pour l'une des décisions financières les plus importantes de leur vie.
          </p>
          <p>
            Mon approche est simple : je prends le temps de comprendre votre situation, vos
            objectifs et vos contraintes avant même de parler de taux. Parce qu'une bonne
            hypothèque, c'est d'abord une hypothèque qui vous ressemble.
          </p>
          <p>
            Première propriété, renouvellement, ou un non de votre banque? Chaque situation
            mérite qu'on explore toutes les options ensemble — et c'est exactement mon rôle.
          </p>
          
          <ul class="apropos-values">
            <li class="val-item">
              <span class="val-icon" aria-hidden="true"><Handshake size={18} stroke-width={1.8} /></span>
              <span>Transparence sur les taux et les conditions, du début à la fin</span>
            </li>
            <li class="val-item">
              <span class="val-icon" aria-hidden="true"><Zap size={18} stroke-width={1.8} /></span>
              <span>Réponse rapide et accompagnement jusqu'à la signature</span>
            </li>
            <li class="val-item">
              <span class="val-icon" aria-hidden="true"><BadgeCheck size={18} stroke-width={1.8} /></span>
              <span>Dans la plupart des cas, mes services ne vous coûtent rien : je suis rémunérée par le prêteur</span>
            </li>
          </ul>

          <div class="apropos-credentials">
            <a
              href={config.hypotheca_profile_url ?? 'https://hypotheca.ca/sweyman'}
              target="_blank"
              rel="noopener"
              class="cred-link"
            >
              <img
                src="/images/logo-hypotheca.svg"
                alt="Hypotheca"
                class="cred-logo"
                loading="lazy"
                width="140"
                height="24"
              />
              <span>{config.nom}, courtière hypothécaire affiliée à {config.organisation}</span>
            </a>
            <div class="cred-amf">
              <span class="val-icon" aria-hidden="true"><BadgeCheck size={16} stroke-width={1.8} /></span>
              <span>Certificat AMF n° {config.amf}</span>
            </div>
          </div>
        </div>
      </div>
      
    </div>
  </div>
</section>

<style>
  .apropos-text h2 {
    font-family: "Lora", serif;
    font-size: 2rem;
    font-style: italic;
    color: var(--clay);
    margin-bottom: 1.2rem;
  }

  .apropos-credentials {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.5rem;
  }

  .cred-link {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--ink);
    font-size: 0.82rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .cred-link:hover,
  .cred-link:focus-visible {
    color: var(--clay);
  }

  .cred-logo {
    height: 1.5rem;
    width: auto;
    flex-shrink: 0;
  }

  .cred-amf {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.78rem;
    color: var(--muted);
    font-weight: 500;
  }

  .cred-amf .val-icon {
    color: var(--forest);
    display: inline-flex;
  }
</style>