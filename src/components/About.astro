---
import { Image } from 'astro:assets';
import stephaniePhoto from '../assets/stephanie.jpg';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const prenom = config.nom.split(' ')[0];
---

<section id="apropos">
  <div class="section-inner">
    <div class="apropos-grid">
      
      <div class="apropos-img fade-up">
        <Image
          src={stephaniePhoto}
          alt={`${config.nom}, ${config.titre} chez ${config.organisation} à Repentigny`}
          width={500}
          height={500}
          loading="lazy"
          decoding="async"
        />
      </div>
      
      <div class="fade-up" style="transition-delay:.15s">
        <div class="section-tag">À propos</div>
        <div class="apropos-text">
          <h2>Bonjour, je suis {prenom}.</h2>
          
          <p>
            Courtière hypothécaire chez <strong>Hypotheca</strong> depuis 4 ans, j'accompagne mes clients de <strong>Repentigny</strong> et de partout au <strong>Québec</strong> à travers l'une des décisions financières les plus importantes de leur vie.
          </p>
          <p>
            Mon approche est simple : je prends le temps de comprendre votre situation, vos
            objectifs et vos contraintes — avant même de parler de taux. Parce qu'une bonne
            hypothèque, c'est d'abord une hypothèque qui vous correspond.
          </p>
          <p>
            Que vous achetiez votre première propriété, que vous renouveliez, ou que votre banque
            vous ait dit non — il y a toujours une solution. Mon rôle, c'est de la trouver.
          </p>
          
          <ul class="apropos-values">
            <li class="val-item">
              <span class="val-icon" aria-hidden="true">🤝</span>
              <span>Transparence totale sur les taux et les conditions</span>
            </li>
            <li class="val-item">
              <span class="val-icon" aria-hidden="true">⚡</span>
              <span>Réponse rapide, accompagnement jusqu'à la signature</span>
            </li>
            <li class="val-item">
              <span class="val-icon" aria-hidden="true">🆓</span>
              <span>Mes services sont gratuits pour vous — payés par le prêteur</span>
            </li>
          </ul>

          <a href="#contact" class="btn-primary" style="margin-top:2rem;display:inline-block;font-size:.85rem;padding:.7rem 1.6rem;">Prendre rendez-vous →</a>
        </div>
      </div>
      
    </div>
  </div>
</section>

<style>
  .apropos-text h2 {
    font-family: "Lora", serif;
    font-size: 2rem;
    font-style: italic;
    color: var(--clay);
    margin-bottom: 1.2rem;
  }
</style>