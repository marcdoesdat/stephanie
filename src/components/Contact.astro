---
import { loadSiteConfig } from '../config';
const config = loadSiteConfig();
---

<section id="contact">
  <div class="section-inner">
    <div class="contact-grid">
      
      <div class="fade-up">
        <div class="section-tag">Contact</div>
        <div class="section-title">Parlons de<br />votre <em>projet</em></div>
        <div class="contact-info">
          <p>
            Gratuit. Sans engagement. À votre heure — en personne, par téléphone ou en appel vidéo.
          </p>
          <div class="contact-details">
            <div class="contact-item">
              <div class="contact-icon" aria-hidden="true">📞</div>
              <span><strong>{config.telephone}</strong></span>
            </div>
            <div class="contact-item">
              <div class="contact-icon" aria-hidden="true">✉️</div>
              <span><strong>{config.courriel}</strong></span>
            </div>
            <div class="contact-item">
              <div class="contact-icon" aria-hidden="true">📍</div>
              <span>{config.region}</span>
            </div>
            <div class="contact-item">
              <div class="contact-icon" aria-hidden="true">🏢</div>
              <span>{config.organisation}</span>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-form fade-up" style="transition-delay:.15s">
        <form id="netlify-contact-form" name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field">
          
          <input type="hidden" name="form-name" value="contact" />
          <div style="display:none;" aria-hidden="true">
            <label>Ne pas remplir : <input name="bot-field" tabindex="-1" /></label>
          </div>

          <div id="form-content">
            <div class="form-row">
              <div>
                <label class="cform-label" for="contact-prenom">Prénom</label>
                <input type="text" id="contact-prenom" name="prenom" placeholder="Marie" required autocomplete="given-name" />
              </div>
              <div>
                <label class="cform-label" for="contact-nom">Nom</label>
                <input type="text" id="contact-nom" name="nom" placeholder="Tremblay" required autocomplete="family-name" />
              </div>
            </div>
            
            <label class="cform-label" for="contact-email">Courriel</label>
            <input type="email" id="contact-email" name="email" placeholder="marie@exemple.com" required autocomplete="email" />
            
            <label class="cform-label" for="contact-tel">Téléphone</label>
            <input type="tel" id="contact-tel" name="telephone" placeholder="514 000-0000" autocomplete="tel" />
            
            <label class="cform-label" for="contact-situation">Votre situation</label>
            <select id="contact-situation" name="situation" required>
              <option value="">Sélectionnez...</option>
              <option value="Premier achat">Premier achat</option>
              <option value="Renouvellement">Renouvellement</option>
              <option value="Refinancement">Refinancement</option>
              <option value="Dossier refusé">Dossier refusé par ma banque</option>
              <option value="Travailleur autonome">Travailleur autonome</option>
              <option value="Autre">Autre</option>
            </select>
            
            <label class="cform-label" for="contact-message">Message (optionnel)</label>
            <textarea id="contact-message" name="message" placeholder="Décrivez brièvement votre situation..."></textarea>
            
            <div class="form-error" id="form-error">Une erreur s'est produite. Veuillez réessayer.</div>
            
            <button type="submit" class="contact-submit" id="contact-submit-btn">Envoyer ma demande →</button>
            <div style="font-size:.68rem;color:var(--muted);margin-top:.8rem;text-align:center;">
              🔒 Vos informations sont confidentielles et ne seront jamais partagées.
            </div>
          </div>
        </form>

        <div class="form-success" id="form-success">
          <span class="check" aria-hidden="true">✅</span>
          <strong>Merci, votre message a bien été envoyé !</strong><br />
          {config.nom.split(' ')[0]} vous recontacte dans les 24 heures ouvrables.<br /><br />
          <a href={config.messenger_url} target="_blank" rel="noopener noreferrer" style="color:var(--forest);font-weight:600;">
            💬 Ou écrire sur Messenger maintenant →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('netlify-contact-form') as HTMLFormElement;
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault(); 

      // 1. Validation HTML5 Native
      if (!form.checkValidity()) {
        form.reportValidity(); // Affiche les bulles d'erreur natives du navigateur
        return;
      }

      const btn = document.getElementById('contact-submit-btn') as HTMLButtonElement;
      const errEl = document.getElementById('form-error') as HTMLElement;

      errEl.style.display = 'none';
      btn.textContent = 'Envoi en cours...';
      btn.disabled = true;

      // 2. Préparation des données pour Netlify
      const formData = new FormData(form);
      const data = new URLSearchParams(formData as any).toString();

      try {
        // 3. Envoi Ajax
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: data
        });

        if (response.ok) {
          document.getElementById('form-content')!.style.display = 'none';
          document.getElementById('form-success')!.style.display = 'block';
        } else {
          throw new Error('Erreur serveur Netlify');
        }
      } catch (error) {
        errEl.textContent = "Une erreur de connexion est survenue. Veuillez vérifier votre réseau et réessayer.";
        errEl.style.display = 'block';
        btn.textContent = 'Envoyer ma demande →';
        btn.disabled = false;
      }
    });
  });
</script>