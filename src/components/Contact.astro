---
import { Image } from 'astro:assets';
import stephaniePhoto from '../assets/stephanie.webp';
import { loadSiteConfig } from '../config';
import { Mail, MapPin, Contact as ContactIcon, Clock, Zap } from '@lucide/astro';
import PhoneLink from './PhoneLink.astro';
const config = loadSiteConfig();
const telephoneHref = `tel:+1${config.telephone.replace(/\D/g, '')}`;
const courrielHref = `mailto:${config.courriel}`;
const prenomCourtiere = config.nom.split(' ')[0];
---

<section id="contact" data-prenom={prenomCourtiere}>
  <div class="section-inner">

    <div class="contact-grid" id="contact-form-anchor">

      <!-- ======== COLONNE GAUCHE : Présentation & confiance ======== -->
      <div class="fade-up">
        <h2 class="section-title">Parlons de <br />ton <em>projet</em></h2>
        <div class="contact-info">
          <p>
            Gratuit. Sans engagement. À ton heure — en personne, par téléphone ou en appel vidéo.
          </p>
          <div class="contact-details">
            <!-- 1. Bookings — friction minimale -->
            <div class="contact-item">
              <div class="contact-icon" aria-hidden="true">📅</div>
              <a class="contact-link" href={config.calendly_url} target="_blank" rel="noopener">
                <strong>Réserve un appel de 15 min</strong><br/>
                <span style="font-size:0.82rem;color:var(--muted);">Choisis ton moment</span>
              </a>
            </div>

            <!-- 2. Téléphone + urgent -->
            <div class="contact-item">
              <div class="contact-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.55a16 16 0 0 0 6.29 6.29l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <PhoneLink
                  variant="text"
                  trackId="tel_click_contact"
                  class="contact-link"
                  aria-label={`Appeler ${config.nom}`}
                />
                <span style="display:block;font-size:0.8rem;color:var(--muted);">Appelle ou texte</span>
              </div>
            </div>

            <div class="contact-item" style="background: rgba(196, 122, 82, 0.08); padding: 0.85rem 1rem; border-radius: 12px; margin: 0.25rem 0 0.5rem; align-items: flex-start;">
              <div class="contact-icon" style="background: transparent; border: none; width: auto; height: auto; margin-top: 0.1rem;" aria-hidden="true"><Zap size={18} stroke-width={2} style="color: var(--clay)" /></div>
              <span style="font-size: 0.85rem; line-height: 1.5; color: var(--ink);"><strong>Offre d'achat acceptée ?</strong><br/><span style="color: var(--muted);">Appelle-moi ou texte-moi pour une réponse prioritaire.</span></span>
            </div>

            <!-- 3. Courriel -->
            <div class="contact-item">
              <div class="contact-icon" aria-hidden="true"><Mail size={18} stroke-width={1.8} /></div>
              <a class="contact-link" href={courrielHref}><strong>{config.courriel}</strong></a>
            </div>

            <!-- 4. Heures -->
            <div class="contact-item">
              <div class="contact-icon" aria-hidden="true"><Clock size={18} stroke-width={1.8} /></div>
              <span style="font-size: 0.85rem; line-height: 1.45;"><strong>Lundi au Vendredi</strong> : 9h00 - 20h00<br/><span style="color: var(--muted);">Week-ends sur rendez-vous</span></span>
            </div>

            <!-- 5. Zone -->
            <div class="contact-item">
              <div class="contact-icon" aria-hidden="true"><MapPin size={18} stroke-width={1.8} /></div>
              <span>{config.region}</span>
            </div>

            <!-- Séparateur visuel -->
            <div style="border-top:1px solid var(--border);margin:0.5rem 0;"></div>

            <!-- 6. Secondaire : contacts + réseaux -->
            <div class="contact-item">
              <div class="contact-icon" aria-hidden="true"><ContactIcon size={18} stroke-width={1.8} /></div>
              <a
                class="contact-link"
                href="/stephanie-weyman.vcf"
                download="stephanie-weyman.vcf"
                type="text/vcard"
                aria-label={`Télécharger la fiche contact de ${prenomCourtiere} (vCard)`}
              >
                <strong>Ajouter à mes contacts</strong>
              </a>
            </div>
            <div class="contact-item">
              <div class="contact-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12S0 5.446 0 12.073c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </div>
              <a
                class="contact-link"
                href={config.messenger_url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Suivre ${config.nom} sur Facebook`}
              >
                <strong>Suivre sur Facebook</strong>
              </a>
            </div>
            <div class="contact-item">
              <div class="contact-icon" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </div>
              <a
                class="contact-link"
                href="https://www.linkedin.com/in/st%C3%A9phanie-weyman-12208b3bb/"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Profil LinkedIn de ${config.nom}`}
              >
                <strong>Suivre sur LinkedIn</strong>
              </a>
            </div>
          </div>

        </div>
      </div>

      <!-- ======== COLONNE DROITE : Questionnaire interactif ======== -->
      <div class="contact-form quiz fade-up" style="transition-delay:.15s">

        <!-- Bandeau humain (toujours visible — c'est l'argument de vente n°1) -->
        <div class="quiz-trust">
          <Image
            src={stephaniePhoto}
            alt={`${prenomCourtiere} Weyman`}
            width={48}
            height={48}
            loading="lazy"
            decoding="async"
            class="quiz-trust-photo"
          />
          <div class="quiz-trust-text">
            <strong>Je réponds moi-même.</strong>
            <span>Réponse dans les meilleurs délais.</span>
          </div>
        </div>

        <!-- Barre de progression -->
        <div class="quiz-progress" aria-hidden="true">
          <div class="quiz-progress-meta">
            <span class="quiz-progress-label">Étape <span data-quiz-step-num>1</span> sur <span data-quiz-step-total>5</span></span>
            <button type="button" class="quiz-back" data-quiz-back hidden>← Retour</button>
          </div>
          <div class="quiz-progress-bar"><div class="quiz-progress-fill" data-quiz-fill></div></div>
        </div>

        <form
          id="netlify-contact-form"
          name="contact"
          method="POST"
          data-netlify="true"
          data-netlify-honeypot="bot-field"
          novalidate
        >
          <input type="hidden" name="form-name" value="contact" />
          <div style="display:none;" aria-hidden="true">
            <label>Ne pas remplir : <input name="bot-field" tabindex="-1" /></label>
          </div>

          <!-- Champs cachés alimentés par le quiz -->
          <input type="hidden" name="parcours" data-quiz-field="parcours" value="" />
          <input type="hidden" name="q1" data-quiz-field="q1" value="" />
          <input type="hidden" name="q2" data-quiz-field="q2" value="" />
          <input type="hidden" name="delai" data-quiz-field="delai" value="" />
          <input type="hidden" name="situation" data-quiz-field="situation" value="" />
          <!-- Compat avec l'ancienne notif Netlify : on conserve les noms historiques -->
          <input type="hidden" name="prefcontact" data-quiz-field="prefcontact" value="" />
          <!-- Champs spécifiques au parcours Premier achat (qualification financière) -->
          <input type="hidden" name="pa_timing" data-quiz-field="pa_timing" value="" />
          <input type="hidden" name="pa_revenus" data-quiz-field="pa_revenus" value="" />
          <input type="hidden" name="pa_mise" data-quiz-field="pa_mise" value="" />

          <!-- ============ ÉTAPE 1 : Choix du parcours ============ -->
          <div class="quiz-step" data-step="1">
            <h3 class="quiz-q">Quel est votre projet aujourd'hui ?</h3>
            <p class="quiz-q-sub">Un seul choix — vous pourrez préciser à l'étape suivante.</p>
            <div class="quiz-options" data-quiz-group="parcours">
              <button type="button" class="quiz-card" data-value="Premier achat" data-next-step="2">
                <span class="quiz-card-icon" aria-hidden="true">🏡</span>
                <span class="quiz-card-text">
                  <strong>Premier achat</strong>
                  <span>Acheter ou se faire pré-approuver</span>
                </span>
              </button>
              <button type="button" class="quiz-card" data-value="Renouvellement / Refinancement" data-next-step="2">
                <span class="quiz-card-icon" aria-hidden="true">🔄</span>
                <span class="quiz-card-text">
                  <strong>Renouvellement / Refinancement</strong>
                  <span>Mon terme arrive à échéance ou je veux libérer de l'équité</span>
                </span>
              </button>
              <button type="button" class="quiz-card" data-value="Travailleur autonome / Dossier complexe" data-next-step="2">
                <span class="quiz-card-icon" aria-hidden="true">🧾</span>
                <span class="quiz-card-text">
                  <strong>Travailleur autonome ou dossier complexe</strong>
                  <span>Revenus non-traditionnels, refus d'une banque, situation atypique</span>
                </span>
              </button>
              <button type="button" class="quiz-card" data-value="Investissement / Autre" data-next-step="2">
                <span class="quiz-card-icon" aria-hidden="true">🏘️</span>
                <span class="quiz-card-text">
                  <strong>Investissement ou autre</strong>
                  <span>Immeuble à revenus, chalet, ou autre projet</span>
                </span>
              </button>
            </div>
          </div>

          <!-- ============ ÉTAPE 2 : Q1 (dépend du parcours) ============ -->
          <div class="quiz-step" data-step="2" data-step-for="Premier achat" hidden>
            <h3 class="quiz-q">Où en êtes-vous avec votre mise de fonds ?</h3>
            <div class="quiz-options" data-quiz-group="q1">
              <button type="button" class="quiz-card" data-value="Mise de fonds prête" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">✅</span>
                <span class="quiz-card-text"><strong>Elle est prête, en compte</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Mise en accumulation" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">📈</span>
                <span class="quiz-card-text"><strong>En cours d'accumulation</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Mise indéterminée" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">🤔</span>
                <span class="quiz-card-text"><strong>Je ne sais pas combien il me faut</strong></span>
              </button>
            </div>
          </div>

          <div class="quiz-step" data-step="2" data-step-for="Renouvellement / Refinancement" hidden>
            <h3 class="quiz-q">Votre terme actuel se termine quand ?</h3>
            <div class="quiz-options" data-quiz-group="q1">
              <button type="button" class="quiz-card" data-value="Terme < 6 mois" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">🔴</span>
                <span class="quiz-card-text"><strong>Dans les 6 prochains mois</strong><span>(ou déjà échu)</span></span>
              </button>
              <button type="button" class="quiz-card" data-value="Terme 6–12 mois" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">🟡</span>
                <span class="quiz-card-text"><strong>Dans 6 à 12 mois</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Terme > 12 mois" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">🟢</span>
                <span class="quiz-card-text"><strong>Dans plus de 12 mois</strong><span>j'anticipe</span></span>
              </button>
            </div>
          </div>

          <div class="quiz-step" data-step="2" data-step-for="Travailleur autonome / Dossier complexe" hidden>
            <h3 class="quiz-q">Quelle est votre situation ?</h3>
            <div class="quiz-options" data-quiz-group="q1">
              <button type="button" class="quiz-card" data-value="Travailleur autonome / incorporé" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">🛠️</span>
                <span class="quiz-card-text"><strong>Travailleur autonome ou incorporé</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Refus de banque" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">❌</span>
                <span class="quiz-card-text"><strong>Dossier déjà refusé par une banque</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Revenus variables" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">📊</span>
                <span class="quiz-card-text"><strong>Revenus variables</strong><span>commissions, pourboires, etc.</span></span>
              </button>
              <button type="button" class="quiz-card" data-value="Co-emprunteurs / atypique" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">🤝</span>
                <span class="quiz-card-text"><strong>Plusieurs co-emprunteurs ou situation atypique</strong></span>
              </button>
            </div>
          </div>

          <div class="quiz-step" data-step="2" data-step-for="Investissement / Autre" hidden>
            <h3 class="quiz-q">De quel type de projet s'agit-il ?</h3>
            <div class="quiz-options" data-quiz-group="q1">
              <button type="button" class="quiz-card" data-value="Plex / immeuble à revenus" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">🏢</span>
                <span class="quiz-card-text"><strong>Immeuble à revenus (plex)</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Résidence secondaire" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">🏖️</span>
                <span class="quiz-card-text"><strong>Résidence secondaire / chalet</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Transfert de prêteur" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">🔁</span>
                <span class="quiz-card-text"><strong>Transfert / changement de prêteur</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Autre" data-next-step="3">
                <span class="quiz-card-icon" aria-hidden="true">✏️</span>
                <span class="quiz-card-text"><strong>Autre — je précise par message</strong></span>
              </button>
            </div>
          </div>

          <!-- ============ ÉTAPE 3 : Q2 (dépend du parcours) ============ -->
          <div class="quiz-step" data-step="3" data-step-for="Premier achat" hidden>
            <h3 class="quiz-q">Connaissez-vous les programmes pour acheteurs d'une première propriété ?</h3>
            <div class="quiz-options" data-quiz-group="q2">
              <button type="button" class="quiz-card" data-value="RAP/CELIAPP connus" data-next-step="4">
                <span class="quiz-card-icon" aria-hidden="true">✅</span>
                <span class="quiz-card-text"><strong>Oui</strong><span>RAP, CELIAPP ou les deux</span></span>
              </button>
              <button type="button" class="quiz-card" data-value="RAP/CELIAPP à découvrir" data-next-step="4">
                <span class="quiz-card-icon" aria-hidden="true">👀</span>
                <span class="quiz-card-text"><strong>J'en ai entendu parler</strong><span>j'aimerais comprendre</span></span>
              </button>
              <button type="button" class="quiz-card" data-value="RAP/CELIAPP inconnus" data-next-step="4">
                <span class="quiz-card-icon" aria-hidden="true">❌</span>
                <span class="quiz-card-text"><strong>Non, jamais entendu</strong></span>
              </button>
            </div>
          </div>

          <div class="quiz-step" data-step="3" data-step-for="Renouvellement / Refinancement" hidden>
            <h3 class="quiz-q">Votre objectif principal ?</h3>
            <div class="quiz-options" data-quiz-group="q2">
              <button type="button" class="quiz-card" data-value="Réduire mensualités" data-next-step="4">
                <span class="quiz-card-icon" aria-hidden="true">💰</span>
                <span class="quiz-card-text"><strong>Réduire mes versements mensuels</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Libérer équité" data-next-step="4">
                <span class="quiz-card-icon" aria-hidden="true">🏗️</span>
                <span class="quiz-card-text"><strong>Libérer de l'équité</strong><span>rénos, projet, consolidation</span></span>
              </button>
              <button type="button" class="quiz-card" data-value="Meilleur taux" data-next-step="4">
                <span class="quiz-card-icon" aria-hidden="true">📉</span>
                <span class="quiz-card-text"><strong>Simplement obtenir le meilleur taux</strong></span>
              </button>
            </div>
          </div>

          <div class="quiz-step" data-step="3" data-step-for="Travailleur autonome / Dossier complexe" hidden>
            <h3 class="quiz-q">Vos documents fiscaux sont-ils à jour ?</h3>
            <div class="quiz-options" data-quiz-group="q2">
              <button type="button" class="quiz-card" data-value="Avis de cotisation à jour" data-next-step="4">
                <span class="quiz-card-icon" aria-hidden="true">✅</span>
                <span class="quiz-card-text"><strong>Oui</strong><span>avis de cotisation des 2 dernières années en main</span></span>
              </button>
              <button type="button" class="quiz-card" data-value="Documents en cours" data-next-step="4">
                <span class="quiz-card-icon" aria-hidden="true">📝</span>
                <span class="quiz-card-text"><strong>En cours / à compléter</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="À clarifier" data-next-step="4">
                <span class="quiz-card-icon" aria-hidden="true">🤔</span>
                <span class="quiz-card-text"><strong>Pas certain — j'aimerais en parler</strong></span>
              </button>
            </div>
          </div>

          <div class="quiz-step" data-step="3" data-step-for="Investissement / Autre" hidden>
            <h3 class="quiz-q">Êtes-vous déjà propriétaire ?</h3>
            <div class="quiz-options" data-quiz-group="q2">
              <button type="button" class="quiz-card" data-value="Déjà propriétaire" data-next-step="4">
                <span class="quiz-card-icon" aria-hidden="true">✅</span>
                <span class="quiz-card-text"><strong>Oui, d'une ou plusieurs propriétés</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Non propriétaire" data-next-step="4">
                <span class="quiz-card-icon" aria-hidden="true">❌</span>
                <span class="quiz-card-text"><strong>Non, ce serait ma première</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Vente + achat" data-next-step="4">
                <span class="quiz-card-icon" aria-hidden="true">🔄</span>
                <span class="quiz-card-text"><strong>J'en vends une, j'en achète une autre</strong></span>
              </button>
            </div>
          </div>

          <!-- ============ PARCOURS PREMIER ACHAT — 4 étapes dédiées ============ -->
          <!-- Activé quand l'utilisateur arrive depuis /services/premier-achat avec ?parcours=premier-achat.
               Saute le quiz générique et lance ce flow de qualification financière. -->

          <!-- pa1 : Timing -->
          <div class="quiz-step" data-step="pa1" hidden>
            <h3 class="quiz-q">Idéalement, quand aimeriez-vous avoir les clés de votre nouvelle propriété ?</h3>
            <div class="quiz-options" data-quiz-group="pa_timing">
              <button type="button" class="quiz-card" data-value="Dès que possible" data-next-step="pa2">
                <span class="quiz-card-icon" aria-hidden="true">🔑</span>
                <span class="quiz-card-text"><strong>Dès que possible</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="3 à 6 mois" data-next-step="pa2">
                <span class="quiz-card-icon" aria-hidden="true">📅</span>
                <span class="quiz-card-text"><strong>Dans 3 à 6 mois</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="6 à 12 mois" data-next-step="pa2">
                <span class="quiz-card-icon" aria-hidden="true">🗓️</span>
                <span class="quiz-card-text"><strong>Dans 6 à 12 mois</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Je m'informe" data-next-step="pa2">
                <span class="quiz-card-icon" aria-hidden="true">💭</span>
                <span class="quiz-card-text"><strong>Je m'informe pour plus tard</strong></span>
              </button>
            </div>
          </div>

          <!-- pa2 : Revenus -->
          <div class="quiz-step" data-step="pa2" hidden>
            <h3 class="quiz-q">Quel est le revenu annuel brut combiné des futurs acheteurs ?</h3>
            <p class="quiz-q-explain">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
              <span>
                <strong>Pourquoi cette question ?</strong>
                Pour estimer une fourchette d'achat réaliste avant l'appel. Aucun pointage de crédit, aucun partage à un tiers.
              </span>
            </p>
            <div class="quiz-options" data-quiz-group="pa_revenus">
              <button type="button" class="quiz-card" data-value="< 70 000 $" data-next-step="pa3">
                <span class="quiz-card-icon" aria-hidden="true">💵</span>
                <span class="quiz-card-text"><strong>Moins de 70 000 $</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="70 000 à 100 000 $" data-next-step="pa3">
                <span class="quiz-card-icon" aria-hidden="true">💵</span>
                <span class="quiz-card-text"><strong>70 000 $ à 100 000 $</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="100 000 à 150 000 $" data-next-step="pa3">
                <span class="quiz-card-icon" aria-hidden="true">💵</span>
                <span class="quiz-card-text"><strong>100 000 $ à 150 000 $</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="> 150 000 $" data-next-step="pa3">
                <span class="quiz-card-icon" aria-hidden="true">💵</span>
                <span class="quiz-card-text"><strong>Plus de 150 000 $</strong></span>
              </button>
            </div>
          </div>

          <!-- pa3 : Mise de fonds -->
          <div class="quiz-step" data-step="pa3" hidden>
            <h3 class="quiz-q">Approximativement, combien avez-vous accumulé pour votre mise de fonds ?</h3>
            <p class="quiz-q-sub">Incluant REER pour le RAP ou CELIAPP.</p>
            <div class="quiz-options" data-quiz-group="pa_mise">
              <button type="button" class="quiz-card" data-value="< 15 000 $" data-next-step="5">
                <span class="quiz-card-icon" aria-hidden="true">🪙</span>
                <span class="quiz-card-text"><strong>Moins de 15 000 $</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="15 000 à 30 000 $" data-next-step="5">
                <span class="quiz-card-icon" aria-hidden="true">💰</span>
                <span class="quiz-card-text"><strong>Entre 15 000 $ et 30 000 $</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="> 30 000 $" data-next-step="5">
                <span class="quiz-card-icon" aria-hidden="true">💎</span>
                <span class="quiz-card-text"><strong>Plus de 30 000 $</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="Je ne sais pas encore" data-next-step="5">
                <span class="quiz-card-icon" aria-hidden="true">🤔</span>
                <span class="quiz-card-text"><strong>Je ne sais pas encore</strong></span>
              </button>
            </div>
          </div>

          <!-- ============ ÉTAPE 4 : Timing (universel — autres parcours seulement) ============ -->
          <div class="quiz-step" data-step="4" hidden>
            <h3 class="quiz-q">Quand souhaitez-vous avancer ?</h3>
            <div class="quiz-options" data-quiz-group="delai">
              <button type="button" class="quiz-card" data-value="URGENT" data-next-step="5">
                <span class="quiz-card-icon" aria-hidden="true">🔴</span>
                <span class="quiz-card-text"><strong>Urgent</strong><span>j'ai une offre d'achat ou une échéance imminente</span></span>
              </button>
              <button type="button" class="quiz-card" data-value="30 jours ou moins" data-next-step="5">
                <span class="quiz-card-icon" aria-hidden="true">🟠</span>
                <span class="quiz-card-text"><strong>Dans les 30 prochains jours</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="6 mois ou moins" data-next-step="5">
                <span class="quiz-card-icon" aria-hidden="true">🟡</span>
                <span class="quiz-card-text"><strong>Dans les 6 prochains mois</strong></span>
              </button>
              <button type="button" class="quiz-card" data-value="6 mois ou plus" data-next-step="5">
                <span class="quiz-card-icon" aria-hidden="true">🟢</span>
                <span class="quiz-card-text"><strong>J'explore, sans pression</strong></span>
              </button>
            </div>
          </div>

          <!-- ============ ÉTAPE 5 : Mini-formulaire contact ============ -->
          <div class="quiz-step quiz-step--final" data-step="5" hidden>
            <div class="quiz-value" data-quiz-value>
              <!-- Phrase de valeur dynamique injectée par JS -->
            </div>

            <h3 class="quiz-q quiz-q--final">Comment préférez-vous que {prenomCourtiere} vous contacte ?</h3>

            <div class="quiz-fields">
              <div class="quiz-row">
                <div class="quiz-field">
                  <label class="cform-label" for="contact-prenom">Prénom</label>
                  <input type="text" id="contact-prenom" name="prenom" placeholder="Marie" required autocomplete="given-name" />
                </div>
                <div class="quiz-field">
                  <label class="cform-label" for="contact-nom">Nom</label>
                  <input type="text" id="contact-nom" name="nom" placeholder="Tremblay" required autocomplete="family-name" />
                </div>
              </div>

              <div class="quiz-field">
                <label class="cform-label" for="contact-email">Courriel</label>
                <input type="email" id="contact-email" name="email" placeholder="marie@exemple.com" autocomplete="email" />
              </div>

              <div class="quiz-field">
                <label class="cform-label" for="contact-tel">
                  Téléphone
                  <span class="cform-optional" data-tel-optional>(facultatif)</span>
                  <span class="cform-required" data-tel-required hidden>(requis)</span>
                </label>
                <input type="tel" id="contact-tel" name="telephone" placeholder="514 000-0000" inputmode="tel" autocomplete="tel" />
              </div>

              <div class="quiz-field">
                <span class="cform-label">Préférence de contact</span>
                <div class="quiz-pref-group" role="group" aria-label="Préférence de contact">
                  <button type="button" class="quiz-pref active" data-pref="Téléphone" aria-pressed="true">
                    <span aria-hidden="true">☎️</span> Téléphone
                  </button>
                  <button type="button" class="quiz-pref" data-pref="Courriel" aria-pressed="false">
                    <span aria-hidden="true">✉️</span> Courriel
                  </button>
                  <button type="button" class="quiz-pref" data-pref="Messenger" aria-pressed="false">
                    <span aria-hidden="true">💬</span> Messenger
                  </button>
                </div>
              </div>

              <div class="quiz-field">
                <label class="cform-label" for="contact-message">
                  Quelque chose à ajouter ? <span class="cform-optional">(facultatif)</span>
                </label>
                <textarea id="contact-message" name="message" placeholder="Une précision, une question, un détail utile…"></textarea>
              </div>
            </div>

            <div class="form-error" id="form-error">Une erreur s'est produite. Veuillez réessayer.</div>

            <label class="cform-consent" for="contact-lcap">
              <input type="checkbox" id="contact-lcap" name="lcap_consent" value="oui" />
              <span>
                Je consens à recevoir des communications électroniques de {config.nom}
                (conseils hypothécaires, guides et ressources) — conformément à la
                <strong>LCAP</strong> (Loi canadienne anti-pourriel).
              </span>
            </label>

            <button type="submit" class="btn-cta btn-cta--block" id="contact-submit-btn">
              <span>Envoyer ma demande</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>

            <p class="quiz-final-note">
              En envoyant ce formulaire, vous acceptez d'être recontacté·e au sujet de votre demande. Vos données ne sont jamais partagées — voir la <a href="/confidentialite">politique de confidentialité</a>.
            </p>
            <p class="quiz-final-note">
              Gratuit · Sans engagement · Réponse dans les meilleurs délais
            </p>
          </div>
        </form>

        <!-- Échappatoire pour les utilisateurs qui n'aiment pas les questionnaires -->
        <div class="quiz-escape">
          <button type="button" class="quiz-escape-link" data-quiz-escape>
            Préférez écrire un message libre ?
          </button>
        </div>

        <div class="form-success" id="form-success">
          <span class="check" aria-hidden="true">✅</span>
          <strong>Merci, votre demande est envoyée !</strong><br />
          {prenomCourtiere} vous recontacte dès que possible.<br /><br />
          <a href={config.messenger_url} target="_blank" rel="noopener noreferrer" style="color:var(--forest);font-weight:600;">
            💬 Ou écrire sur Messenger maintenant →
          </a>
        </div>

        <noscript>
          <div class="quiz-noscript">
            <p><strong>Le questionnaire interactif nécessite JavaScript.</strong> Vous pouvez nous joindre directement :</p>
            <p>
              <a href={telephoneHref}>{config.telephone}</a> · <a href={courrielHref}>{config.courriel}</a>
            </p>
          </div>
        </noscript>
      </div>
    </div>
  </div>
</section>

<style>
  .cform-consent {
    display: flex;
    gap: .55rem;
    align-items: flex-start;
    margin: 1.1rem 0 .6rem;
    font-size: .78rem;
    line-height: 1.5;
    color: var(--ink);
  }
  .cform-consent input[type="checkbox"] {
    margin-top: .15rem;
    flex: 0 0 auto;
    width: 1rem;
    height: 1rem;
    accent-color: var(--clay, #c47a52);
  }
  .cform-consent a { color: var(--clay, #c47a52); text-decoration: underline; }
</style>

<script>
  type Parcours =
    | 'Premier achat'
    | 'Renouvellement / Refinancement'
    | 'Travailleur autonome / Dossier complexe'
    | 'Investissement / Autre';

  // Step IDs : numbers (1..5) pour le quiz générique, strings (pa1, pa2, pa3) pour le parcours
  // Premier achat dédié. L'étape 5 (contact) est partagée.
  type StepId = number | string;

  interface QuizState {
    parcours: Parcours | '';
    q1: string;
    q2: string;
    delai: string;
    prefcontact: string;
    // Champs spécifiques Premier achat
    pa_timing: string;
    pa_revenus: string;
    pa_mise: string;
  }

  const STORAGE_KEY = 'sw_quiz_state_v2';
  const STORAGE_TTL_MS = 24 * 60 * 60 * 1000;

  // Définition des flows : ordre des étapes pour la progress bar et la navigation back.
  const FLOW_GENERIC: StepId[] = [1, 2, 3, 4, 5];
  const FLOW_PA: StepId[] = [1, 'pa1', 'pa2', 'pa3', 5];

  function flowFor(parcours: Parcours | '', currentHistory: StepId[]): StepId[] {
    // Si l'utilisateur est dans le flow PA dédié (pa1/pa2/pa3), utiliser FLOW_PA.
    // Sinon (quiz générique avec étapes numériques), utiliser FLOW_GENERIC.
    if (parcours === 'Premier achat' && currentHistory.some((s) => typeof s === 'string' && s.startsWith('pa'))) {
      return FLOW_PA;
    }
    return FLOW_GENERIC;
  }

  // Phrases de valeur dynamiques. Pour Premier achat, on utilise les nouveaux champs (revenus + mise).
  function valuePhrase(state: QuizState, prenomCourtiere: string): string {
    const { parcours, q1, q2, pa_revenus, pa_mise, pa_timing } = state;

    if (parcours === 'Premier achat') {
      const lowMise = pa_mise === '< 15 000 $' || pa_mise === 'Je ne sais pas encore';
      const midMise = pa_mise === '15 000 à 30 000 $';
      const highMise = pa_mise === '> 30 000 $';
      const lowIncome = pa_revenus === '< 70 000 $';
      const highIncome = pa_revenus === '> 150 000 $';
      const exploring = pa_timing === 'Je m\'informe';
      const urgent = pa_timing === 'Dès que possible';

      if (urgent && highMise) {
        return `Avec une mise sérieuse et un échéancier serré, on prépare votre pré-approbation rapidement pour que vous puissiez magasiner avec confiance dès cette semaine.`;
      }
      if (highMise && (highIncome || pa_revenus === '100 000 à 150 000 $')) {
        return `Avec votre mise et vos revenus, on est dans une zone très intéressante. ${prenomCourtiere} structurera votre dossier pour viser le maximum réaliste — et négocier le taux qui va avec.`;
      }
      if (lowMise) {
        return `Le CELIAPP combiné au RAP peut presque doubler votre vitesse d'accumulation. ${prenomCourtiere} vous montrera le scénario chiffré sur votre situation — et un plan concret pour atteindre votre objectif.`;
      }
      if (midMise) {
        return `Votre mise actuelle ouvre déjà plusieurs scénarios. On regarde ensemble comment les leviers RAP + CELIAPP peuvent maximiser votre capacité d'achat sans toucher à votre coussin.`;
      }
      if (exploring) {
        return `Parfait — le meilleur moment pour s'informer, c'est avant d'avoir besoin d'agir. ${prenomCourtiere} vous donnera un portrait clair pour planifier sereinement.`;
      }
      if (lowIncome) {
        return `Plusieurs programmes existent pour maximiser votre accès à la propriété. ${prenomCourtiere} vous expliquera lesquels s'appliquent à votre situation, en toute simplicité.`;
      }
      // Q1/Q2 anciens (visiteurs venant du parcours générique)
      if (q1 === 'Mise de fonds prête' && q2 === 'RAP/CELIAPP connus') {
        return `Avec votre mise de fonds et l'optimisation de vos leviers (RAP + CELIAPP), on structure votre dossier pour maximiser votre capacité d'achat dès la pré-approbation.`;
      }
      return `Parler à ${prenomCourtiere}, c'est obtenir une stratégie claire. Découvrez exactement quel montant vous pouvez viser et comment maximiser votre mise de fonds. Simple et sans engagement.`;
    }

    if (parcours === 'Renouvellement / Refinancement') {
      if (q1 === 'Terme < 6 mois') {
        return `On a encore le temps de comparer avant que votre banque ne vous envoie son offre de renouvellement. Beaucoup de propriétaires acceptent la première offre par défaut — magasiner vous permet de prendre une décision éclairée.`;
      }
      if (q2 === 'Libérer équité') {
        return `Une simulation comparative refinancement vs. marge hypothécaire vous sera préparée avant l'appel — vous saurez quelle option coûte le moins cher sur 5 ans.`;
      }
      if (q1 === 'Terme > 12 mois') {
        return `Parfait, on a tout le temps. ${prenomCourtiere} vous donnera la stratégie de timing pour ne pas manquer la fenêtre de taux.`;
      }
      return `${prenomCourtiere} préparera une comparaison avec les taux du jour avant votre appel.`;
    }

    if (parcours === 'Travailleur autonome / Dossier complexe') {
      if (q1 === 'Refus de banque') {
        return `Un refus de banque ne veut pas dire un refus du marché. ${prenomCourtiere} a accès à 20+ prêteurs, incluant des prêteurs alternatifs spécialisés dans votre profil.`;
      }
      if (q1 === 'Travailleur autonome / incorporé' && q2 === 'Avis de cotisation à jour') {
        return `C'est exactement le type de dossier où ${prenomCourtiere} fait la différence : elle saura quel prêteur valorise vos revenus nets vs. brut, et négocier en conséquence.`;
      }
      if (q2 === 'À clarifier' || q2 === 'Documents en cours') {
        return `Pas de souci — on commencera par un appel pour cartographier ce qu'il vous faut. Aucune pré-condition pour parler.`;
      }
      return `${prenomCourtiere} se spécialise dans les dossiers que les banques refusent — vous êtes au bon endroit.`;
    }

    if (parcours === 'Investissement / Autre') {
      if (q1 === 'Plex / immeuble à revenus') {
        return `Le calcul des revenus locatifs admissibles varie énormément d'un prêteur à l'autre — ${prenomCourtiere} identifiera ceux qui maximisent votre capacité d'emprunt.`;
      }
      return `Décrivez votre projet en quelques mots à l'étape suivante — ${prenomCourtiere} vous reviendra avec une approche sur mesure.`;
    }

    return `${prenomCourtiere} vous prépare une réponse personnalisée.`;
  }

  document.addEventListener('DOMContentLoaded', () => {
    const rootEl = document.querySelector('.contact-form.quiz') as HTMLElement | null;
    if (!rootEl) return;
    const root: HTMLElement = rootEl;

    const PRENOM_COURTIERE = root.getAttribute('data-prenom') || 'Stéphanie';

    const form = root.querySelector<HTMLFormElement>('#netlify-contact-form');
    if (!form) return;

    const fillEl = root.querySelector<HTMLElement>('[data-quiz-fill]');
    const stepNumEl = root.querySelector<HTMLElement>('[data-quiz-step-num]');
    const backBtn = root.querySelector<HTMLButtonElement>('[data-quiz-back]');
    const valueEl = root.querySelector<HTMLElement>('[data-quiz-value]');
    const escapeBtn = root.querySelector<HTMLButtonElement>('[data-quiz-escape]');
    const successEl = document.getElementById('form-success');
    const errEl = document.getElementById('form-error');

    const fields: Record<string, HTMLInputElement> = {};
    root.querySelectorAll<HTMLInputElement>('[data-quiz-field]').forEach((input) => {
      const key = input.dataset.quizField;
      if (key) fields[key] = input;
    });

    const state: QuizState = {
      parcours: '',
      q1: '',
      q2: '',
      delai: '',
      prefcontact: 'Téléphone',
      pa_timing: '',
      pa_revenus: '',
      pa_mise: '',
    };

    const history: StepId[] = [1];
    let currentStep: StepId = 1;

    // --- localStorage : reprise ---
    function persist() {
      try {
        sessionStorage.setItem(STORAGE_KEY, JSON.stringify({ ts: Date.now(), state, currentStep, history }));
      } catch {}
    }
    function restore(): boolean {
      try {
        const raw = sessionStorage.getItem(STORAGE_KEY);
        if (!raw) return false;
        const data = JSON.parse(raw);
        if (!data || typeof data.ts !== 'number' || Date.now() - data.ts > STORAGE_TTL_MS) {
          sessionStorage.removeItem(STORAGE_KEY);
          return false;
        }
        Object.assign(state, data.state);
        history.length = 0;
        history.push(...(data.history || [1]));
        currentStep = data.currentStep || 1;
        return true;
      } catch {
        return false;
      }
    }
    function clearPersist() {
      try { sessionStorage.removeItem(STORAGE_KEY); } catch {}
    }

    // --- Affichage d'une étape ---
    function showStep(step: StepId, scrollOnMobile = true) {
      currentStep = step;
      const allSteps = root.querySelectorAll<HTMLElement>('.quiz-step');
      allSteps.forEach((el) => el.setAttribute('hidden', ''));

      let visible: HTMLElement | null = null;
      // Étapes 2/3 du flow générique : tag par parcours
      if (step === 2 || step === 3) {
        visible = root.querySelector<HTMLElement>(`.quiz-step[data-step="${step}"][data-step-for="${state.parcours}"]`);
      } else {
        visible = root.querySelector<HTMLElement>(`.quiz-step[data-step="${step}"]:not([data-step-for])`);
      }
      if (visible) visible.removeAttribute('hidden');

      // Progress bar : position = index du step courant dans le flow actif (1-based)
      const flow = flowFor(state.parcours, history);
      const idx = flow.indexOf(step);
      const totalSteps = flow.length;
      const positionInFlow = idx >= 0 ? idx + 1 : 1;
      if (fillEl) fillEl.style.width = `${(positionInFlow / totalSteps) * 100}%`;
      if (stepNumEl) stepNumEl.textContent = String(positionInFlow);
      const totalEl = root.querySelector<HTMLElement>('[data-quiz-step-total]');
      if (totalEl) totalEl.textContent = String(totalSteps);

      // Bouton retour : visible dès qu'on n'est pas sur la 1re position du flow
      if (backBtn) {
        if (positionInFlow > 1) backBtn.removeAttribute('hidden');
        else backBtn.setAttribute('hidden', '');
      }

      // Phrase de valeur (étape 5 = contact final)
      if (step === 5 && valueEl) {
        valueEl.innerHTML = `
          <span class="quiz-value-eyebrow">Voici ce qui vous attend à l'appel</span>
          <p>${valuePhrase(state, PRENOM_COURTIERE)}</p>
        `;
      }

      // Focus management : focus le premier choix ou le premier input
      const firstFocusable = visible?.querySelector<HTMLElement>('button, input, textarea');
      if (firstFocusable) {
        window.setTimeout(() => firstFocusable.focus({ preventScroll: true }), 60);
      }

      // Maintien du focus visuel : ramener le formulaire en haut sur mobile
      if (window.innerWidth < 900 && scrollOnMobile) {
        root.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      persist();
    }

    // --- Sélection d'une option ---
    function parseStep(raw: string | undefined): StepId | null {
      if (!raw) return null;
      const asNum = parseInt(raw, 10);
      if (!isNaN(asNum) && String(asNum) === raw) return asNum;
      return raw; // ex. "pa1", "pa2", "pa3"
    }

    root.querySelectorAll<HTMLButtonElement>('.quiz-card').forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = btn;
        const parent = card.closest<HTMLElement>('.quiz-options');
        const group = parent?.dataset.quizGroup as keyof QuizState | undefined;
        const value = card.dataset.value || '';
        const next = parseStep(card.dataset.nextStep);

        if (group) {
          (state as unknown as Record<string, string>)[group] = value;
          // Le champ envoyé à Netlify inclut la question posée (ex. "q1" et "q2" sont
          // partagés entre plusieurs parcours — sans ça, le courriel de notification
          // affiche juste "q1: <réponse>" au lieu du contexte de la question).
          const stepEl = card.closest<HTMLElement>('.quiz-step');
          const questionText = stepEl?.querySelector<HTMLElement>('.quiz-q')?.textContent?.trim() || '';
          if (fields[group]) fields[group].value = questionText ? `${questionText} → ${value}` : value;
          // Compat champ "situation"
          if (group === 'parcours' && fields.situation) fields.situation.value = value;
        }

        // Confirmation visuelle (flash) puis avance
        parent?.querySelectorAll<HTMLButtonElement>('.quiz-card').forEach((c) => c.classList.remove('selected'));
        card.classList.add('selected');

        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const delay = reduceMotion ? 0 : 220;
        window.setTimeout(() => {
          if (next !== null && next !== currentStep) {
            history.push(next);
            showStep(next);
          }
        }, delay);
      });
    });

    // --- Préférence de contact (étape 5) ---
    const telInput = root.querySelector<HTMLInputElement>('#contact-tel');
    const telOptionalLabel = root.querySelector<HTMLElement>('[data-tel-optional]');
    const telRequiredLabel = root.querySelector<HTMLElement>('[data-tel-required]');

    function updateTelRequirement(pref: string) {
      // Téléphone et Messenger nécessitent un numéro joignable.
      const mustHaveTel = pref === 'Téléphone' || pref === 'Messenger';
      if (telInput) {
        if (mustHaveTel) {
          telInput.setAttribute('required', '');
          telInput.setAttribute('aria-required', 'true');
        } else {
          telInput.removeAttribute('required');
          telInput.removeAttribute('aria-required');
        }
      }
      if (telOptionalLabel) {
        if (mustHaveTel) telOptionalLabel.setAttribute('hidden', '');
        else telOptionalLabel.removeAttribute('hidden');
      }
      if (telRequiredLabel) {
        if (mustHaveTel) telRequiredLabel.removeAttribute('hidden');
        else telRequiredLabel.setAttribute('hidden', '');
      }
    }

    root.querySelectorAll<HTMLButtonElement>('.quiz-pref').forEach((btn) => {
      btn.addEventListener('click', () => {
        root.querySelectorAll<HTMLButtonElement>('.quiz-pref').forEach((b) => {
          b.classList.remove('active');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.classList.add('active');
        btn.setAttribute('aria-pressed', 'true');
        state.prefcontact = btn.dataset.pref || 'Téléphone';
        if (fields.prefcontact) fields.prefcontact.value = state.prefcontact;
        updateTelRequirement(state.prefcontact);
        persist();
      });
    });
    if (fields.prefcontact) fields.prefcontact.value = state.prefcontact;
    updateTelRequirement(state.prefcontact);

    // --- Retour ---
    backBtn?.addEventListener('click', () => {
      if (history.length <= 1) return;
      history.pop();
      const prev = history[history.length - 1] ?? 1;
      showStep(prev);
    });

    // --- Échappatoire : aller direct à l'étape 5 ---
    escapeBtn?.addEventListener('click', () => {
      if (!state.parcours) {
        state.parcours = 'Investissement / Autre';
        if (fields.parcours) fields.parcours.value = state.parcours;
        if (fields.situation) fields.situation.value = state.parcours;
      }
      history.push(5);
      showStep(5);
    });

    // --- Submit ---
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      // Validation : au moins un moyen de contact (courriel ou téléphone)
      const emailVal = (document.getElementById('contact-email') as HTMLInputElement)?.value.trim() || '';
      const telVal = (document.getElementById('contact-tel') as HTMLInputElement)?.value.trim() || '';
      if (!emailVal && !telVal) {
        alert('Veuillez indiquer au moins un moyen de vous joindre (courriel ou téléphone).');
        return;
      }
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      const btn = document.getElementById('contact-submit-btn') as HTMLButtonElement;
      if (errEl) errEl.style.display = 'none';
      const originalHtml = btn.innerHTML;
      btn.textContent = 'Envoi en cours...';
      btn.disabled = true;

      const formData = new FormData(form);
      const params = new URLSearchParams();
      formData.forEach((value, key) => {
        params.append(key, typeof value === 'string' ? value : value.name);
      });

      try {
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: params.toString(),
        });
        if (!response.ok) throw new Error('Erreur serveur Netlify');
        clearPersist();
        form.style.display = 'none';
        const escapeWrap = root.querySelector<HTMLElement>('.quiz-escape');
        if (escapeWrap) escapeWrap.style.display = 'none';
        if (successEl) {
          successEl.style.display = 'block';
          successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      } catch {
        if (errEl) {
          errEl.textContent = "Une erreur de connexion est survenue. Veuillez vérifier votre réseau et réessayer.";
          errEl.style.display = 'block';
        }
        btn.innerHTML = originalHtml;
        btn.disabled = false;
      }
    });

    // --- Pré-sélection via paramètre URL (?parcours=premier-achat etc.) ---
    // Permet à une sous-page service d'envoyer le visiteur directement à l'étape 2.
    const URL_PARCOURS_MAP: Record<string, Parcours> = {
      'premier-achat': 'Premier achat',
      'renouvellement': 'Renouvellement / Refinancement',
      'refinancement': 'Renouvellement / Refinancement',
      'travailleur-autonome': 'Travailleur autonome / Dossier complexe',
      'dossier-complexe': 'Travailleur autonome / Dossier complexe',
      'dossier-refuse': 'Travailleur autonome / Dossier complexe',
      'nouveaux-arrivants': 'Travailleur autonome / Dossier complexe',
      'investissement': 'Investissement / Autre',
    };

    function readUrlParcours(): Parcours | null {
      try {
        const params = new URLSearchParams(window.location.search);
        const raw = (params.get('parcours') || '').toLowerCase().trim();
        return URL_PARCOURS_MAP[raw] ?? null;
      } catch {
        return null;
      }
    }

    const urlParcours = readUrlParcours();

    if (urlParcours) {
      // Le param URL prime : on initialise un parcours frais.
      // - Premier achat : on lance le flow dédié à pa1 (timing → revenus → mise → contact).
      // - Autres parcours : on saute à l'étape 2 du flow générique (q1 du parcours).
      clearPersist();
      state.parcours = urlParcours;
      if (fields.parcours) fields.parcours.value = urlParcours;
      if (fields.situation) fields.situation.value = urlParcours;
      const firstStep: StepId = urlParcours === 'Premier achat' ? 'pa1' : 2;
      history.length = 0;
      history.push(1, firstStep);
      updateTelRequirement(state.prefcontact);
      showStep(firstStep, false);
    } else if (restore() && state.parcours) {
      // Recâbler les valeurs hidden
      if (fields.parcours) fields.parcours.value = state.parcours;
      if (fields.situation) fields.situation.value = state.parcours;
      if (fields.q1) fields.q1.value = state.q1;
      if (fields.q2) fields.q2.value = state.q2;
      if (fields.delai) fields.delai.value = state.delai;
      if (fields.prefcontact) fields.prefcontact.value = state.prefcontact;
      // Synchroniser le bouton actif de préférence et le required du téléphone
      root.querySelectorAll<HTMLButtonElement>('.quiz-pref').forEach((b) => {
        const isActive = b.dataset.pref === state.prefcontact;
        b.classList.toggle('active', isActive);
        b.setAttribute('aria-pressed', String(isActive));
      });
      updateTelRequirement(state.prefcontact);
      showStep(currentStep, false);
    } else {
      showStep(1, false);
    }
  });
</script>
