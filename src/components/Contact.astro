---
---

<section id="contact">
  <div class="section-inner">
    <div class="contact-grid">
      <div class="fade-up">
        <div class="section-tag">Contact</div>
        <div class="section-title">Parlons de<br />votre <em>projet</em></div>
        <div class="contact-info">
          <p>
            La consultation est gratuite, sans engagement et se fait à votre convenance — en
            personne, par téléphone ou en visio.
          </p>
          <div class="contact-details">
            <div class="contact-item">
              <div class="contact-icon">📞</div>
              <span><strong>VOTRE NUMÉRO</strong></span>
            </div>
            <div class="contact-item">
              <div class="contact-icon">✉️</div>
              <span><strong>stephanie@stephanieweyman.ca</strong></span>
            </div>
            <div class="contact-item">
              <div class="contact-icon">📍</div>
              <span>Montréal et grand Montréal</span>
            </div>
            <div class="contact-item">
              <div class="contact-icon">🏢</div>
              <span>Hypotheca</span>
            </div>
          </div>
        </div>
      </div>
      <div class="contact-form fade-up" style="transition-delay:.15s">
        <div id="form-content">
          <div class="form-row">
            <div>
              <label class="cform-label">Prénom</label>
              <input type="text" placeholder="Marie" />
            </div>
            <div>
              <label class="cform-label">Nom</label>
              <input type="text" placeholder="Tremblay" />
            </div>
          </div>
          <label class="cform-label">Courriel</label>
          <input type="email" placeholder="marie@exemple.com" />
          <label class="cform-label">Téléphone</label>
          <input type="tel" placeholder="514 000-0000" />
          <label class="cform-label">Votre situation</label>
          <select>
            <option value="">Sélectionnez...</option>
            <option>Premier achat</option>
            <option>Renouvellement</option>
            <option>Refinancement</option>
            <option>Dossier refusé par ma banque</option>
            <option>Travailleur autonome</option>
            <option>Autre</option>
          </select>
          <label class="cform-label">Message (optionnel)</label>
          <textarea placeholder="Décrivez brièvement votre situation..."></textarea>
          <button class="contact-submit" id="contact-submit-btn">Envoyer ma demande →</button>
        </div>
        <div class="form-success" id="form-success">
          <span class="check">✅</span>
          <strong>Merci, votre message a bien été envoyé !</strong><br />
          Je vous recontacte dans les 24 heures ouvrables.
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('contact-submit-btn')!.addEventListener('click', () => {
    document.getElementById('form-content')!.style.display = 'none';
    document.getElementById('form-success')!.style.display = 'block';
  });
</script>
