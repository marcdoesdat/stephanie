---
import { loadSiteConfig } from '../config';
const config = loadSiteConfig();
---

<section id="contact">
  <div class="section-inner">
    <div class="contact-grid">
      <div class="fade-up">
        <div class="section-tag">Contact</div>
        <div class="section-title">Parlons de<br />votre <em>projet</em></div>
        <div class="contact-info">
          <p>
            La consultation est gratuite, sans engagement et se fait à votre convenance — en
            personne, par téléphone ou en visio.
          </p>
          <div class="contact-details">
            <div class="contact-item">
              <div class="contact-icon">📞</div>
              <span><strong>{config.telephone}</strong></span>
            </div>
            <div class="contact-item">
              <div class="contact-icon">✉️</div>
              <span><strong>{config.courriel}</strong></span>
            </div>
            <div class="contact-item">
              <div class="contact-icon">📍</div>
              <span>{config.region}</span>
            </div>
            <div class="contact-item">
              <div class="contact-icon">🏢</div>
              <span>{config.organisation}</span>
            </div>
          </div>
        </div>
      </div>
      <div class="contact-form fade-up" style="transition-delay:.15s">
        <div id="form-content">
          <div class="form-row">
            <div>
              <label class="cform-label" for="contact-prenom">Prénom</label>
              <input type="text" id="contact-prenom" placeholder="Marie" />
            </div>
            <div>
              <label class="cform-label" for="contact-nom">Nom</label>
              <input type="text" id="contact-nom" placeholder="Tremblay" />
            </div>
          </div>
          <label class="cform-label" for="contact-email">Courriel</label>
          <input type="email" id="contact-email" placeholder="marie@exemple.com" />
          <label class="cform-label" for="contact-tel">Téléphone</label>
          <input type="tel" id="contact-tel" placeholder="514 000-0000" />
          <label class="cform-label" for="contact-situation">Votre situation</label>
          <select id="contact-situation">
            <option value="">Sélectionnez...</option>
            <option>Premier achat</option>
            <option>Renouvellement</option>
            <option>Refinancement</option>
            <option>Dossier refusé par ma banque</option>
            <option>Travailleur autonome</option>
            <option>Autre</option>
          </select>
          <label class="cform-label" for="contact-message">Message (optionnel)</label>
          <textarea id="contact-message" placeholder="Décrivez brièvement votre situation..."></textarea>
          <div class="form-error" id="form-error">Veuillez remplir tous les champs obligatoires.</div>
          <button type="button" class="contact-submit" id="contact-submit-btn">Envoyer ma demande →</button>
          <div style="font-size:.68rem;color:var(--muted);margin-top:.8rem;text-align:center;">🔒 Vos informations sont confidentielles et ne seront jamais partagées.</div>
        </div>
        <div class="form-success" id="form-success">
          <span class="check">✅</span>
          <strong>Merci, votre message a bien été envoyé !</strong><br />
          Stéphanie vous recontacte dans les 24 heures ouvrables.<br /><br />
          <a href={config.messenger_url} style="color:var(--forest);font-weight:600;">💬 Ou écrire sur Messenger maintenant →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.getElementById('contact-submit-btn')!.addEventListener('click', () => {
    const prenom = (document.getElementById('contact-prenom') as HTMLInputElement).value.trim();
    const email = (document.getElementById('contact-email') as HTMLInputElement).value.trim();
    const errEl = document.getElementById('form-error')!;
    if (!prenom || !email) {
      errEl.style.display = 'block';
      return;
    }
    errEl.style.display = 'none';
    const btn = document.getElementById('contact-submit-btn') as HTMLButtonElement;
    btn.textContent = 'Envoi en cours...';
    btn.disabled = true;
    document.getElementById('form-content')!.style.display = 'none';
    document.getElementById('form-success')!.style.display = 'block';
  });
</script>
