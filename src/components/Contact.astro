---
import { loadSiteConfig } from '../config';
const config = loadSiteConfig();
---

<section id="contact">
  <div class="section-inner">
    <div class="contact-grid">
      <div class="fade-up">
        <div class="section-tag">Contact</div>
        <div class="section-title">Parlons de<br />votre <em>projet</em></div>
        <div class="contact-info">
          <p>
            La consultation est gratuite, sans engagement et se fait à votre convenance — en
            personne, par téléphone ou en visio.
          </p>
          <div class="contact-details">
            <div class="contact-item">
              <div class="contact-icon">📞</div>
              <span><strong>{config.telephone}</strong></span>
            </div>
            <div class="contact-item">
              <div class="contact-icon">✉️</div>
              <span><strong>{config.courriel}</strong></span>
            </div>
            <div class="contact-item">
              <div class="contact-icon">📍</div>
              <span>{config.region}</span>
            </div>
            <div class="contact-item">
              <div class="contact-icon">🏢</div>
              <span>{config.organisation}</span>
            </div>
          </div>
        </div>
      </div>

      <div class="contact-form fade-up" style="transition-delay:.15s">
        <form id="netlify-contact-form" name="contact" method="POST" data-netlify="true" data-netlify-honeypot="bot-field">
          
          <input type="hidden" name="form-name" value="contact" />

          <div style="display:none;">
            <label>Ne pas remplir : <input name="bot-field" /></label>
          </div>

          <div id="form-content">
            <div class="form-row">
              <div>
                <label class="cform-label" for="contact-prenom">Prénom</label>
                <input type="text" id="contact-prenom" name="prenom" placeholder="Marie" required />
              </div>
              <div>
                <label class="cform-label" for="contact-nom">Nom</label>
                <input type="text" id="contact-nom" name="nom" placeholder="Tremblay" required />
              </div>
            </div>
            
            <label class="cform-label" for="contact-email">Courriel</label>
            <input type="email" id="contact-email" name="email" placeholder="marie@exemple.com" required />
            
            <label class="cform-label" for="contact-tel">Téléphone</label>
            <input type="tel" id="contact-tel" name="telephone" placeholder="514 000-0000" />
            
            <label class="cform-label" for="contact-situation">Votre situation</label>
            <select id="contact-situation" name="situation">
              <option value="">Sélectionnez...</option>
              <option value="Premier achat">Premier achat</option>
              <option value="Renouvellement">Renouvellement</option>
              <option value="Refinancement">Refinancement</option>
              <option value="Dossier refusé">Dossier refusé par ma banque</option>
              <option value="Travailleur autonome">Travailleur autonome</option>
              <option value="Autre">Autre</option>
            </select>
            
            <label class="cform-label" for="contact-message">Message (optionnel)</label>
            <textarea id="contact-message" name="message" placeholder="Décrivez brièvement votre situation..."></textarea>
            
            <div class="form-error" id="form-error" style="display:none; color:red; margin-bottom:1rem;">Veuillez remplir tous les champs obligatoires.</div>
            
            <button type="submit" class="contact-submit" id="contact-submit-btn">Envoyer ma demande →</button>
            <div style="font-size:.68rem;color:var(--muted);margin-top:.8rem;text-align:center;">🔒 Vos informations sont confidentielles et ne seront jamais partagées.</div>
          </div>
        </form>

        <div class="form-success" id="form-success" style="display:none;">
          <span class="check">✅</span>
          <strong>Merci, votre message a bien été envoyé !</strong><br />
          Stéphanie vous recontacte dans les 24 heures ouvrables.<br /><br />
          <a href={config.messenger_url} style="color:var(--forest);font-weight:600;">💬 Ou écrire sur Messenger maintenant →</a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('netlify-contact-form') as HTMLFormElement;
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault(); // Empêche le rechargement classique de la page

    const prenom = (document.getElementById('contact-prenom') as HTMLInputElement).value.trim();
    const email = (document.getElementById('contact-email') as HTMLInputElement).value.trim();
    const errEl = document.getElementById('form-error')!;
    const btn = document.getElementById('contact-submit-btn') as HTMLButtonElement;

    if (!prenom || !email) {
      errEl.style.display = 'block';
      return;
    }
    
    errEl.style.display = 'none';
    btn.textContent = 'Envoi en cours...';
    btn.disabled = true;

    // Récupère toutes les données du formulaire, incluant le champ caché 'form-name'
    const formData = new FormData(form);

    try {
      // 3. NOUVEAU : Envoi silencieux des données à Netlify avec la méthode recommandée
      await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(formData as any).toString()
      });

      // Affiche le message de succès
      document.getElementById('form-content')!.style.display = 'none';
      document.getElementById('form-success')!.style.display = 'block';
    } catch (error) {
      alert('Une erreur est survenue lors de l\'envoi. Veuillez réessayer.');
      btn.textContent = 'Envoyer ma demande →';
      btn.disabled = false;
    }
  });
</script>