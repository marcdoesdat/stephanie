---
import { Phone } from '@lucide/astro';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const telephoneHref = `tel:${config.telephone.replace(/[^\d+]/g, '')}`;

// On sépare le prénom et le nom
const [prenom, ...nomArr] = config.nom.split(' ');
const nomDeFamille = nomArr.join(' ');
---

<nav id="navbar">
  <div class="nav-container">
    <a href="/" class="nav-logo">
      <div class="brand-wrapper">
        <div class="broker-identity">
          <div class="broker-name">{prenom} <span>{nomDeFamille}</span></div>
          <div class="cabinet-name">Courtière hypothécaire - Hypotheca</div>
        </div>
      </div>
    </a>
    
    <ul class="nav-links" id="nav-menu">
      <li><a href="/outils">Outils</a></li>
      <li><a href="/#services">Services</a></li>
      <li><a href="/#taux-section">Taux</a></li>
      <li><a href="/#apropos">À propos</a></li>
      <li><a href="/#temoignages">Témoignages</a></li>
      <li><a href="/#faq">FAQ</a></li>
      <li><a href="/#contact">Contact</a></li>
      <li><a href={config.calendly_url} data-calendly class="nav-cta" target="_blank" rel="noopener">Consultation gratuite</a></li>
    </ul>
    
    <a href={telephoneHref} class="nav-phone" aria-label="Appeler Stéphanie Weyman">
      <Phone size={20} stroke-width={2} />
    </a>
    
    <button
      class="hamburger"
      id="hamburger-btn"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<style>
  /* --- AJUSTEMENTS POUR LE LOGO --- */
  
  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1300px;
    margin: 0 auto;
    width: 100%;
    padding: 0 1.5rem;
    gap: 1.25rem;
  }

  .nav-logo {
    text-decoration: none;
    z-index: 201;
    flex: 0 1 auto;
    min-width: 0;
  }

  .brand-wrapper {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    min-width: 0;
  }

  .broker-identity {
    font-family: 'Lora', serif;
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--ink);
    min-width: 0;
  }

  .broker-name {
    white-space: nowrap;
  }

  .broker-identity span {
    font-weight: 400;
    color: var(--clay);
  }

  .cabinet-name {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    color: var(--clay);
    letter-spacing: 0.04em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav-phone {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    padding: 0.75rem;
    min-width: 44px;
    min-height: 44px;
    border-radius: 50%;
    transition: color 0.2s, background 0.2s;
    text-decoration: none;
    z-index: 201;
    flex-shrink: 0;
  }

  .nav-phone:hover {
    color: var(--clay);
    background: rgba(0, 0, 0, 0.04);
  }

  .nav-separator {
    width: 1px;
    height: 20px;
    background-color: rgba(0, 0, 0, 0.15);
  }

  .agency-logo {
    width: auto;
    height: 56px;
    display: block;
    object-fit: contain;
  }

  /* --- STYLES SPÉCIFIQUES POUR LE MENU MOBILE --- */

  @media (max-width: 1180px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
  }

  @media (max-width: 860px) {
    .cabinet-name {
      white-space: normal;
      overflow: visible;
      max-width: 28ch;
    }
  }

  @media (max-width: 600px) {
    .nav-separator {
      display: none;
    }
    .broker-identity {
      font-size: 1rem;
    }
    .agency-logo {
      height: 44px;
    }
    .brand-wrapper {
      gap: 0.5rem;
    }
    .cabinet-name {
      font-size: 0.58rem;
      letter-spacing: 0.03em;
      white-space: normal;
      overflow: visible;
      max-width: 24ch;
      line-height: 1.3;
    }
  }

  @media (max-width: 380px) {
    .cabinet-name {
      font-size: 0.54rem;
      max-width: 20ch;
    }
  }

  .hamburger span {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }
  
  .hamburger.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger.open span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1180px) {
    .nav-links.open {
      display: flex !important;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      height: calc(100vh - 68px);
      background: var(--white);
      overflow-x: hidden;
      overflow-y: auto;
      padding: 2rem 1.5rem;
      gap: 2.2rem;
      z-index: 199;
      animation: slideDown 0.3s ease forwards;
    }

    .nav-links.open li {
      width: 100%;
      text-align: center;
    }

    .nav-links.open a {
      font-size: 1.4rem;
      font-weight: 600;
      white-space: normal;
      color: var(--ink);
      text-decoration: none;
    }

    .nav-links.open a:hover {
      color: var(--clay);
    }

    .nav-links.open .nav-cta {
      display: inline-block;
      font-size: 1rem;
      font-weight: 700;
      padding: 0.85rem 2rem;
      margin-top: 0.5rem;
    }
  }

  @media (max-width: 1180px) and (prefers-reduced-motion: reduce) {
    .nav-links.open { animation: none; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const navbar = document.getElementById('navbar');
    const btn = document.getElementById('hamburger-btn');
    const menu = document.getElementById('nav-menu');
    const links = menu?.querySelectorAll('a');
    
    let menuOpen = false;

    window.addEventListener('scroll', () => {
      if (window.scrollY > 40) {
        navbar?.classList.add('scrolled');
      } else {
        navbar?.classList.remove('scrolled');
      }
    });

    const messengerBtn = document.querySelector<HTMLElement>('.messenger-btn');

    function toggleMenu() {
      menuOpen = !menuOpen;
      btn?.setAttribute('aria-expanded', String(menuOpen));
      btn?.setAttribute('aria-label', menuOpen ? 'Fermer le menu' : 'Ouvrir le menu');
      menu?.classList.toggle('open', menuOpen);
      btn?.classList.toggle('open', menuOpen);

      // Verrouille le scroll du body quand le menu est ouvert
      document.body.style.overflow = menuOpen ? 'hidden' : '';

      // Masque le bouton Messenger quand le menu est ouvert
      if (messengerBtn) {
        messengerBtn.setAttribute('aria-hidden', String(menuOpen));
        messengerBtn.style.display = menuOpen ? 'none' : '';
      }
    }

    btn?.addEventListener('click', toggleMenu);

    links?.forEach(link => {
      link.addEventListener('click', () => {
        if (menuOpen) toggleMenu();
      });
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth > 1180 && menuOpen) {
        toggleMenu();
      }
    });

    // Fermer avec Escape, en redonnant le focus au bouton
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuOpen) {
        toggleMenu();
        (btn as HTMLElement | null)?.focus();
      }
    });
  });
</script>