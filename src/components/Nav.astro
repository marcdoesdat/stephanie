---
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();

// On sépare le prénom et le nom
const [prenom, ...nomArr] = config.nom.split(' ');
const nomDeFamille = nomArr.join(' ');
---

<nav id="navbar">
  <div class="nav-container">
    <a href="/" class="nav-logo">
      <div class="brand-wrapper">
        <div class="broker-identity">
          <div class="broker-name">{prenom} <span>{nomDeFamille}</span></div>
          <div class="cabinet-name">Hypotheca — Cabinet en courtage hypothécaire</div>
        </div>
      </div>
    </a>
    
    <ul class="nav-links" id="nav-menu">
      <li><a href="/#simulateur">Capacité d'emprunt</a></li>
      <li><a href="/#calculateur">Calculer un versement</a></li>
      <li><a href="/#services">Services</a></li>
      <li><a href="/#taux-section">Taux</a></li>
      <li><a href="/#apropos">À propos</a></li>
      <li><a href="/#temoignages">Témoignages</a></li>
      <li><a href="/#faq">FAQ</a></li>
      <li><a href="/#contact" class="nav-cta">Consultation gratuite</a></li>
    </ul>
    
    <button
      class="hamburger"
      id="hamburger-btn"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="nav-menu"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<style>
  /* --- AJUSTEMENTS POUR LE LOGO --- */
  
  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1300px;
    margin: 0 auto;
    width: 100%;
    padding: 0 1.5rem;
    gap: 1.25rem;
  }

  .nav-logo {
    text-decoration: none;
    z-index: 201;
    flex: 0 1 auto;
    min-width: 0;
  }

  .brand-wrapper {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    min-width: 0;
  }

  .broker-identity {
    font-family: 'Lora', serif;
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--ink);
    min-width: 0;
  }

  .broker-name {
    white-space: nowrap;
  }

  .broker-identity span {
    font-weight: 400;
    color: var(--clay);
  }

  .cabinet-name {
    font-family: 'Inter', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    color: var(--clay);
    letter-spacing: 0.04em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .nav-separator {
    width: 1px;
    height: 20px;
    background-color: rgba(0, 0, 0, 0.15);
  }

  .agency-logo {
    width: auto;
    height: 56px;
    display: block;
    object-fit: contain;
  }

  /* --- STYLES SPÉCIFIQUES POUR LE MENU MOBILE --- */

  @media (max-width: 1180px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
  }

  @media (max-width: 860px) {
    .cabinet-name {
      max-width: 22ch;
    }
  }

  @media (max-width: 600px) {
    .nav-separator {
      display: none;
    }
    .broker-identity {
      font-size: 1rem;
    }
    .agency-logo {
      height: 44px;
    }
    .brand-wrapper {
      gap: 0.5rem;
    }
    .cabinet-name {
      font-size: 0.58rem;
      letter-spacing: 0.03em;
      max-width: 18ch;
    }
  }

  @media (max-width: 420px) {
    .cabinet-name {
      display: none;
    }
  }

  .hamburger span {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }
  
  .hamburger.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger.open span:nth-child(2) {
    opacity: 0;
  }
  .hamburger.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 1180px) {
    .nav-links.open {
      display: flex !important;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--white);
      padding: 2rem 1.5rem;
      border-bottom: 1px solid var(--border);
      gap: 1.5rem;
      z-index: 199;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      animation: slideDown 0.3s ease forwards;
    }

    .nav-links.open a {
      white-space: normal;
    }
    
    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const navbar = document.getElementById('navbar');
    const btn = document.getElementById('hamburger-btn');
    const menu = document.getElementById('nav-menu');
    const links = menu?.querySelectorAll('a');
    
    let menuOpen = false;

    window.addEventListener('scroll', () => {
      if (window.scrollY > 40) {
        navbar?.classList.add('scrolled');
      } else {
        navbar?.classList.remove('scrolled');
      }
    });

    function toggleMenu() {
      menuOpen = !menuOpen;
      btn?.setAttribute('aria-expanded', String(menuOpen));
      btn?.setAttribute('aria-label', menuOpen ? 'Fermer le menu' : 'Ouvrir le menu');
      menu?.classList.toggle('open', menuOpen);
      btn?.classList.toggle('open', menuOpen);
    }

    btn?.addEventListener('click', toggleMenu);

    links?.forEach(link => {
      link.addEventListener('click', () => {
        if (menuOpen) toggleMenu();
      });
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth > 1180 && menuOpen) {
        toggleMenu();
      }
    });
  });
</script>