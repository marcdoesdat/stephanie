---
import type { HypothecaRates } from '../services/ratesService';

interface Props {
  hypothecaRates: HypothecaRates;
}
const { hypothecaRates } = Astro.props;

function fmtRate(val: number | null | undefined): string {
  if (val == null) return '—';
  return val.toFixed(2).replace('.', ',') + ' %';
}

// Build the ordered rows for display
const displayRows = hypothecaRates.rows.length > 0
  ? hypothecaRates.rows
  : [
    { terme: '5 ans variable', hypotheca: hypothecaRates.variable, affiche: hypothecaRates.affiche_variable, type: 'variable' as const, populaire: true },
    { terme: '1 an fixe', hypotheca: hypothecaRates.fixe_1ans, affiche: hypothecaRates.affiche_fixe_1ans, type: 'fixe' as const },
    { terme: '2 ans fixe', hypotheca: hypothecaRates.fixe_2ans, affiche: hypothecaRates.affiche_fixe_2ans, type: 'fixe' as const },
    { terme: '3 ans fixe', hypotheca: hypothecaRates.fixe_3ans, affiche: hypothecaRates.affiche_fixe_3ans, type: 'fixe' as const },
    { terme: '4 ans fixe', hypotheca: hypothecaRates.fixe_4ans, affiche: hypothecaRates.affiche_fixe_4ans, type: 'fixe' as const },
    { terme: '5 ans fixe', hypotheca: hypothecaRates.fixe_5ans, affiche: hypothecaRates.affiche_fixe_5ans, type: 'fixe' as const, populaire: true },
    { terme: '6 ans fixe', hypotheca: hypothecaRates.fixe_6ans, affiche: hypothecaRates.affiche_fixe_6ans, type: 'fixe' as const },
    { terme: '7 ans fixe', hypotheca: hypothecaRates.fixe_7ans, affiche: hypothecaRates.affiche_fixe_7ans, type: 'fixe' as const },
    { terme: '10 ans fixe', hypotheca: hypothecaRates.fixe_10ans, affiche: hypothecaRates.affiche_fixe_10ans, type: 'fixe' as const },
  ];
---

<section id="taux-section">
  <div class="section-inner">
    <div class="fade-up" style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;margin-bottom:3rem;">
      <div>
        <div class="section-tag">Taux en vigueur</div>
        <div class="section-title">Nos meilleurs<br /><em>taux hypothécaires</em></div>
        <p class="section-sub">
          Taux négociés exclusivement pour nos clients.
          {hypothecaRates.source === 'live' ? ' Mis à jour automatiquement.' : ' Taux indicatifs.'}
        </p>
      </div>
      <div style="background:var(--sand);border:1px solid var(--border);border-radius:16px;padding:1rem 1.5rem;font-size:.75rem;color:var(--muted);line-height:1.8;text-align:right;">
        <strong style="color:var(--ink);display:block;">Taux directeur BdC</strong>
        <span id="tv-directeur" style="font-family:Lora,serif;font-size:1.4rem;font-weight:700;color:var(--clay);">—</span><br />
        <span id="tv-date" style="font-size:.65rem;">Chargement...</span>
      </div>
    </div>
    <div class="taux-table-wrap fade-up">
      <table>
        <thead>
          <tr>
            <th>Terme</th>
            <th>Taux affiché</th>
            <th style="color:#a8c5b5;">Taux Hypotheca</th>
          </tr>
        </thead>
        <tbody>
          {displayRows.map((row) => (
            <tr class={`taux-row${row.populaire ? ' featured' : ''}`}>
              <td>
                {row.populaire && (
                  <span class={`badge-pop${row.type === 'fixe' ? ' green' : ''}`}>POPULAIRE</span>
                )}
                {row.terme}
              </td>
              <td class="td-affiche">{fmtRate(row.affiche)}</td>
              <td class={`td-hypotheca${row.type === 'variable' ? ' variable' : ''}`}>
                {fmtRate(row.hypotheca)}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <div class="taux-footer">
      <div class="taux-note-text">* Certaines conditions s'appliquent. Taux sujets à changement sans préavis.</div>
      <a href="#contact" class="btn-primary" style="font-size:.82rem;padding:.7rem 1.6rem;">Obtenir ce taux →</a>
    </div>
    <div class="bdc-bar">
      <strong style="color:var(--ink);">Taux directeur BdC :</strong>
      <span id="tv-preferentiel-inline"></span> (préférentiel) ·
      Mis à jour le <span id="tv-date-inline">—</span> ·
      <span style="color:var(--clay);">Source : bankofcanada.ca</span>
    </div>
  </div>
</section>

<script>
  async function fetchTauxBdC() {
    try {
      const res = await fetch('https://www.bankofcanada.ca/valet/observations/V39079/json?recent=1');
      const data = await res.json();
      const ob = data.observations[0];
      const directeur = parseFloat(ob.V39079.v);
      const preferentiel = +(directeur + 2.20).toFixed(2);
      const dateStr = new Date(ob.d + 'T12:00:00').toLocaleDateString('fr-CA', {
        year: 'numeric', month: 'long', day: 'numeric'
      });
      const f = (n: number) => n.toFixed(2).replace('.', ',') + ' %';

      const tvDirecteur = document.getElementById('tv-directeur');
      if (tvDirecteur) tvDirecteur.textContent = f(directeur);

      const tvDate = document.getElementById('tv-date');
      if (tvDate) tvDate.textContent = dateStr;

      const tvPref = document.getElementById('tv-preferentiel-inline');
      if (tvPref) tvPref.textContent = f(preferentiel);

      const tvDateInline = document.getElementById('tv-date-inline');
      if (tvDateInline) tvDateInline.textContent = dateStr;
    } catch {
      const tvDate = document.getElementById('tv-date');
      if (tvDate) tvDate.textContent = 'Données indisponibles';
    }
  }
  fetchTauxBdC();
</script>
