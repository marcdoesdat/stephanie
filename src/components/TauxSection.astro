---
import type { HypothecaRates } from '../services/ratesService';

interface Props {
  hypothecaRates: HypothecaRates | null;
}
const { hypothecaRates } = Astro.props;

function fmtRate(val: number | null | undefined): string {
  if (val == null) return '—';
  return val.toFixed(2).replace('.', ',') + ' %';
}

// Construction sécurisée des lignes (évite un crash si .rows est undefined)
const displayRows = hypothecaRates?.rows?.length
  ? hypothecaRates.rows
  : hypothecaRates
    ? [
        { terme: '5 ans variable', hypotheca: hypothecaRates.variable, affiche: hypothecaRates.affiche_variable, type: 'variable' as const, populaire: true },
        { terme: '1 an fixe', hypotheca: hypothecaRates.fixe_1ans, affiche: hypothecaRates.affiche_fixe_1ans, type: 'fixe' as const },
        { terme: '2 ans fixe', hypotheca: hypothecaRates.fixe_2ans, affiche: hypothecaRates.affiche_fixe_2ans, type: 'fixe' as const },
        { terme: '3 ans fixe', hypotheca: hypothecaRates.fixe_3ans, affiche: hypothecaRates.affiche_fixe_3ans, type: 'fixe' as const },
        { terme: '4 ans fixe', hypotheca: hypothecaRates.fixe_4ans, affiche: hypothecaRates.affiche_fixe_4ans, type: 'fixe' as const },
        { terme: '5 ans fixe', hypotheca: hypothecaRates.fixe_5ans, affiche: hypothecaRates.affiche_fixe_5ans, type: 'fixe' as const, populaire: true },
        { terme: '6 ans fixe', hypotheca: hypothecaRates.fixe_6ans, affiche: hypothecaRates.affiche_fixe_6ans, type: 'fixe' as const },
        { terme: '7 ans fixe', hypotheca: hypothecaRates.fixe_7ans, affiche: hypothecaRates.affiche_fixe_7ans, type: 'fixe' as const },
        { terme: '10 ans fixe', hypotheca: hypothecaRates.fixe_10ans, affiche: hypothecaRates.affiche_fixe_10ans, type: 'fixe' as const },
      ]
    : [];
---

<section id="taux-section">
  <div class="section-inner">
    
    {hypothecaRates ? (
    <Fragment>
    <div class="fade-up" style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;margin-bottom:3rem;">
      <div>
        <div class="section-tag">Taux en vigueur</div>
        <h2 class="section-title">Consulter les meilleurs taux hypothécaires<br />du moment <em>via notre réseau</em></h2>
        <p class="section-sub">
          Taux obtenus via notre réseau de 20+ prêteurs.
          {hypothecaRates?.source === 'live' ? ' Mis à jour automatiquement.' : ' Taux indicatifs.'}
        </p>
        <p id="tv-freshness" data-updated-at={hypothecaRates.fetchedAt} style="margin:.45rem 0 0;font-size:.78rem;color:var(--clay);font-weight:600;">Mise à jour en cours…</p>
      </div>
      
      <div aria-live="polite" style="background:var(--sand);border:1px solid var(--border);border-radius:16px;padding:1.2rem 1.8rem;font-size:.75rem;color:var(--muted);line-height:1.8;text-align:right;min-width: 200px;">
        <strong style="color:var(--ink);display:block;text-transform:uppercase;letter-spacing:0.05em;font-size:0.7rem;">Taux directeur BdC</strong>
        <span id="tv-directeur" style="font-family:'Lora',serif;font-size:1.8rem;font-weight:700;color:var(--clay);">...</span><br />
        <span id="tv-date" style="font-size:.7rem;">Chargement en cours</span>
      </div>
    </div>
    
    <div class="taux-table-wrap fade-up" style="overflow-x: auto; -webkit-overflow-scrolling: touch;">
      <table class="taux-table" style="min-width: 660px;">
        <thead>
          <tr>
            <th scope="col" style="min-width: 110px; width: 1%; white-space: nowrap;">Terme</th>
            <th scope="col" class="th-hypotheca" style="color:var(--forest);">
              <div class="th-hypotheca-inner">
                 <img src="/images/logo-hypotheca.svg" alt="Hypotheca" style="height:6.7em;vertical-align:middle;" loading="lazy" />
                <span class="th-hypotheca-label">Votre taux</span>
              </div>
            </th>
            <th scope="col" style="border-left:1px solid rgba(255,255,255,0.15);">Taux affiché</th>
          </tr>
        </thead>
        <tbody>
          {displayRows.map((row) => (
            <tr class={`taux-row${row.populaire ? ' featured' : ''}`}>
              <td>
                {row.populaire && (
                  <span class={`badge-pop${row.type === 'fixe' ? ' green' : ''}`}>POPULAIRE</span>
                )}
                {row.terme}
              </td>
              <td class={`td-hypotheca${row.type === 'variable' ? ' variable' : ''}`}>
                {fmtRate(row.hypotheca)}
              </td>
              <td class="td-affiche" style="border-left:1px solid rgba(0,0,0,0.06);">{fmtRate(row.affiche)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    
    <div class="taux-footer fade-up" style="transition-delay: 0.1s;">
      <div class="taux-note-text">* Certaines conditions s'appliquent. Taux sujets à changement sans préavis.</div>
      <a href="#contact" class="btn-primary" style="font-size:.82rem;padding:.7rem 1.6rem;">Obtenir ce taux →</a>
    </div>
    
    <div class="bdc-bar fade-up" style="transition-delay: 0.2s;" aria-live="polite">
      <strong style="color:var(--ink);">Taux directeur BdC :</strong>
      <span id="tv-preferentiel-inline" style="font-weight:600;">...</span> (Taux préférentiel estimé) ·
      Mis à jour le <span id="tv-date-inline">—</span> ·
      <a href="https://www.bankofcanada.ca" target="_blank" rel="noopener noreferrer" style="color:var(--clay);text-decoration:none;">Source : bankofcanada.ca</a>
    </div>
    </Fragment>
    ) : (
    <div class="fade-up">
      <div class="section-tag">Taux en vigueur</div>
      <h2 class="section-title">Consulter les meilleurs taux hypothécaires<br />du moment <em>via notre réseau</em></h2>
      <div class="taux-unavailable">
        <p>Les taux ne sont pas disponibles pour le moment.</p>
        <a href="https://hypotheca.ca/taux-hypothecaires" target="_blank" rel="noopener noreferrer" class="btn-primary">
          Voir les taux sur hypotheca.ca →
        </a>
      </div>
    </div>
    )}
    
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    let freshnessTimer: ReturnType<typeof setInterval> | undefined;

    function relativeLabel(iso: string): string {
      const diff = Math.max(0, Date.now() - new Date(iso).getTime());
      const mins = Math.floor(diff / 60000);
      if (mins < 1) return 'Taux mis à jour il y a moins d\'une minute.';
      if (mins < 60) return `Taux mis à jour il y a ${mins} minute${mins > 1 ? 's' : ''}.`;
      const hrs = Math.floor(mins / 60);
      if (hrs < 24) return `Taux mis à jour il y a ${hrs} heure${hrs > 1 ? 's' : ''}.`;
      const days = Math.floor(hrs / 24);
      return `Taux mis à jour il y a ${days} jour${days > 1 ? 's' : ''}.`;
    }

    function startFreshnessClock() {
      const freshnessEl = document.getElementById('tv-freshness');
      if (!freshnessEl) return;
      const iso = freshnessEl.getAttribute('data-updated-at');
      if (!iso) return;

      const render = () => { freshnessEl.textContent = relativeLabel(iso); };

      render();
      if (freshnessTimer) clearInterval(freshnessTimer);
      freshnessTimer = setInterval(render, 60000);
    }

    startFreshnessClock();

    async function fetchTauxBdC() {
      try {
        const res = await fetch('/api/bdc-rate', { headers: { Accept: 'application/json' } });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);

        const data = await res.json();
        const directeur = Number(data?.directeur);
        const preferentiel = Number(data?.preferentiel);
        const obsDate = String(data?.date ?? '');

        if (!Number.isFinite(directeur) || !obsDate) throw new Error('Bad payload');

        const dateStr = new Date(obsDate + 'T12:00:00').toLocaleDateString('fr-CA', {
          year: 'numeric', month: 'long', day: 'numeric'
        });

        const f = (n: number) => n.toFixed(2).replace('.', ',') + ' %';

        const tvDirecteur = document.getElementById('tv-directeur');
        if (tvDirecteur) tvDirecteur.textContent = f(directeur);

        const tvDate = document.getElementById('tv-date');
        if (tvDate) tvDate.textContent = dateStr;

        const tvPref = document.getElementById('tv-preferentiel-inline');
        if (tvPref) tvPref.textContent = f(preferentiel);

        const tvDateInline = document.getElementById('tv-date-inline');
        if (tvDateInline) tvDateInline.textContent = dateStr;

      } catch (_error) {
        const tvDirecteur = document.getElementById('tv-directeur');
        if (tvDirecteur) tvDirecteur.textContent = "—";

        const tvDate = document.getElementById('tv-date');
        if (tvDate) tvDate.textContent = 'Données temporairement indisponibles';

        const freshnessEl = document.getElementById('tv-freshness');
        if (freshnessEl) freshnessEl.textContent = 'Taux en attente de synchronisation.';
      }
    }
    
    fetchTauxBdC();
  });
</script>

<style>
  .taux-unavailable {
    text-align: center;
    padding: 3rem 1.5rem;
    background: var(--sand);
    border: 1px solid var(--border);
    border-radius: 16px;
    margin-top: 2rem;
  }
  .taux-unavailable p {
    font-size: 1.1rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }
</style>