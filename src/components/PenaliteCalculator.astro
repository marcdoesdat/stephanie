---
import type { Preteur } from '../lib/penalite';

export interface Props {
  config: {
    nom: string;
    titre: string;
    organisation: string;
    amf: string;
  };
  tauxMarcheDefaut: Record<string, string>;
  dateMaj: string | null;
  groupes: Record<string, Preteur[]>;
}

const { config, tauxMarcheDefaut, dateMaj, groupes } = Astro.props;
const prenom = config.nom.split(' ')[0] ?? config.nom;
---

<section id="penalite-calculator">
  <div class="section-inner">
    <form class="penalite-form fade-up" id="penalite-form" novalidate>
      <fieldset class="penalite-fieldset">
        <legend class="penalite-legend">Votre prêteur</legend>
        <div class="penalite-field">
          <label for="pen-preteur" class="penalite-label">
            Institution financière
            <button type="button" class="penalite-tooltip" aria-describedby="pen-pret-tip" data-tip="Sélectionnez l'institution qui détient votre prêt. Si vous n'êtes pas certain, choisissez « Autre / Je ne sais pas ».">?</button>
            <span id="pen-pret-tip" class="sr-only" role="tooltip">Sélectionnez l'institution qui détient votre prêt. Si vous n'êtes pas certain, choisissez « Autre / Je ne sais pas ».</span>
          </label>
          <select id="pen-preteur" class="penalite-select" required>
            {Object.entries(groupes).map(([groupe, preteurs]) => (
              groupe ? (
                <optgroup label={groupe}>
                  {preteurs.map((p: Preteur) => (
                    <option value={p.id} data-methode={p.methode_ird} data-notes={p.notes ?? ''}>{p.nom}</option>
                  ))}
                </optgroup>
              ) : (
                preteurs.map((p: Preteur) => (
                  <option value={p.id} data-methode={p.methode_ird} data-notes={p.notes ?? ''}>{p.nom}</option>
                ))
              )
            ))}
          </select>
          <small class="penalite-hint" id="pen-preteur-hint"></small>
        </div>
        <div class="penalite-field">
          <span class="penalite-label">Méthode de calcul IRD détectée</span>
          <span class="penalite-methode-badge" id="pen-methode-badge">
            <svg class="penalite-badge-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            <span id="pen-methode-badge-text">—</span>
          </span>
        </div>
      </fieldset>

      <fieldset class="penalite-fieldset">
        <legend class="penalite-legend">Type de taux</legend>
        <div class="penalite-toggle-group" role="radiogroup" aria-label="Type de taux">
          <button type="button" class="penalite-toggle active" id="pen-type-fixe" role="radio" aria-checked="true" data-value="fixe">
            <span class="penalite-toggle-label">Fixe</span>
            <span class="penalite-toggle-sub">IRD + 3 mois</span>
          </button>
          <button type="button" class="penalite-toggle" id="pen-type-variable" role="radio" aria-checked="false" data-value="variable">
            <span class="penalite-toggle-label">Variable</span>
            <span class="penalite-toggle-sub">3 mois seulement</span>
          </button>
        </div>
      </fieldset>

      <fieldset class="penalite-fieldset">
        <legend class="penalite-legend">Détails de votre prêt</legend>
        <div class="penalite-row">
          <div class="penalite-field">
            <label for="pen-solde" class="penalite-label">
              Solde hypothécaire ($)
              <button type="button" class="penalite-tooltip" aria-describedby="pen-solde-tip" data-tip="Le solde actuel restant à payer, pas le prix d'achat original.">?</button>
              <span id="pen-solde-tip" class="sr-only" role="tooltip">Le solde actuel restant à payer, pas le prix d'achat original.</span>
            </label>
            <input type="number" id="pen-solde" class="penalite-input" value="300000" inputmode="decimal" min="0" max="5000000" required />
            <small class="penalite-error" id="pen-solde-err"></small>
          </div>
          <div class="penalite-field">
            <label for="pen-taux" class="penalite-label">
              Taux contractuel (%)
              <button type="button" class="penalite-tooltip" aria-describedby="pen-taux-tip" data-tip="Le taux d'intérêt écrit sur votre contrat hypothécaire actuel.">?</button>
              <span id="pen-taux-tip" class="sr-only" role="tooltip">Le taux d'intérêt écrit sur votre contrat hypothécaire actuel.</span>
            </label>
            <div class="penalite-rate-wrap">
              <input type="number" id="pen-taux" class="penalite-input penalite-input--rate" value="5.49" step="0.01" inputmode="decimal" min="0.01" max="20" required />
              <span class="penalite-rate-suffix">%</span>
            </div>
            <small class="penalite-error" id="pen-taux-err"></small>
          </div>
        </div>
        <div class="penalite-row">
          <div class="penalite-field">
            <label for="pen-date-debut" class="penalite-label">
              Date de début du terme actuel
              <button type="button" class="penalite-tooltip" aria-describedby="pen-date-tip" data-tip="La date du début de votre terme courant (pas la date d'achat). Ex. : 2023-06-01.">?</button>
              <span id="pen-date-tip" class="sr-only" role="tooltip">La date du début de votre terme courant (pas la date d'achat). Ex. : 2023-06-01.</span>
            </label>
            <input type="date" id="pen-date-debut" class="penalite-input" value="2023-06-01" required />
            <small class="penalite-error" id="pen-date-debut-err"></small>
          </div>
          <div class="penalite-field">
            <label for="pen-duree" class="penalite-label">Durée du terme</label>
            <select id="pen-duree" class="penalite-select" required>
              <option value="12">1 an</option>
              <option value="24">2 ans</option>
              <option value="36">3 ans</option>
              <option value="48">4 ans</option>
              <option value="60" selected>5 ans</option>
              <option value="84">7 ans</option>
              <option value="120">10 ans</option>
            </select>
          </div>
        </div>
      </fieldset>

      <fieldset class="penalite-fieldset" id="pen-fieldset-affiche">
        <legend class="penalite-legend">
          Taux affiché à l'origine
          <button type="button" class="penalite-tooltip" aria-describedby="pen-tao-tip" data-tip="Si votre prêteur utilise les taux affichés, le contrat mentionne parfois le taux affiché à la signature. Laissez vide si inconnu.">?</button>
          <span id="pen-tao-tip" class="sr-only" role="tooltip">Si votre prêteur utilise les taux affichés, le contrat mentionne parfois le taux affiché à la signature. Laissez vide si inconnu.</span>
        </legend>
        <div class="penalite-field">
          <label for="pen-taux-affiche" class="penalite-label">Taux affiché à la signature (%)</label>
          <div class="penalite-rate-wrap">
            <input type="number" id="pen-taux-affiche" class="penalite-input penalite-input--rate" value="" placeholder="Ex. 7,04 — laissez vide si inconnu" step="0.01" inputmode="decimal" min="0" max="20" />
            <span class="penalite-rate-suffix">%</span>
          </div>
          <small class="penalite-hint">Optionnel. Sans cette valeur, le taux contractuel sert de référence.</small>
        </div>
      </fieldset>

      <fieldset class="penalite-fieldset">
        <legend class="penalite-legend">
          Taux actuels du marché
          {dateMaj && <small style="font-weight:400;font-size:.7rem;color:var(--muted);margin-left:.5rem;">Mise à jour : {dateMaj}</small>}
        </legend>
        <div class="penalite-rates-grid">
          {Object.entries(tauxMarcheDefaut).map(([mois, taux]) => (
            <div class="penalite-field penalite-field--rate">
              <label for={`pen-marche-${mois}`} class="penalite-label">
                {Number(mois) < 12 ? `${mois} mois` : `${Number(mois) / 12} an${Number(mois) > 12 ? 's' : ''}`}
              </label>
              <div class="penalite-rate-wrap">
                <input type="number" id={`pen-marche-${mois}`} class="penalite-input penalite-input--rate" value={taux} step="0.01" inputmode="decimal" min="0" max="20" />
                <span class="penalite-rate-suffix">%</span>
              </div>
            </div>
          ))}
        </div>
      </fieldset>

      <div class="penalite-actions">
        <button type="button" id="pen-reset" class="penalite-btn penalite-btn--secondary">Réinitialiser</button>
        <button type="button" id="pen-share" class="penalite-btn penalite-btn--secondary">📋 Partager ce scénario</button>
      </div>
    </form>

    <div class="penalite-results fade-up" id="penalite-results" style="transition-delay:.2s" aria-live="polite">
      <!-- Bande sticky mobile -->
      <div class="penalite-sticky-mobile" id="pen-sticky-mobile" style="display:none;">
        <span class="penalite-sticky-mobile-label">Pénalité estimée</span>
        <span class="penalite-sticky-mobile-value" id="pen-sticky-value">—</span>
      </div>
      <div id="penalite-placeholder" class="penalite-placeholder">
        <div class="penalite-placeholder-icon">📊</div>
        <h3 class="penalite-placeholder-title">Votre estimation apparaîtra ici</h3>
        <p class="penalite-placeholder-sub">Remplissez les champs à gauche pour obtenir une estimation instantanée.</p>
      </div>

      <div id="penalite-results-content" style="display:none;">
        <div class="penalite-result-hero">
          <div class="penalite-result-hero-label">Pénalité estimée</div>
          <div class="penalite-result-hero-value" id="pen-total">—</div>
          <div class="penalite-result-hero-sub" id="pen-total-sub"></div>
        </div>

        <div class="penalite-decomposition">
          <div class="penalite-decomp-card">
            <div class="penalite-decomp-label">3 mois d'intérêts</div>
            <div class="penalite-decomp-value" id="pen-val-3mois">—</div>
          </div>
          <div class="penalite-decomp-card">
            <div class="penalite-decomp-label">Pénalité IRD</div>
            <div class="penalite-decomp-value" id="pen-val-ird">—</div>
          </div>
          <div class="penalite-decomp-card penalite-decomp-card--retenue">
            <div class="penalite-decomp-label">Méthode retenue</div>
            <div class="penalite-decomp-value" id="pen-val-retenue">—</div>
          </div>
        </div>

        <div class="penalite-contexte" id="pen-contexte"></div>

        <div class="penalite-barres" id="pen-barres" style="display:none;">
          <div class="penalite-barre-row">
            <span class="penalite-barre-label">3 mois</span>
            <div class="penalite-barre-track">
              <div class="penalite-barre-fill penalite-barre-fill--secondaire" id="pen-barre-3mois" style="width:0%"></div>
            </div>
            <span class="penalite-barre-value" id="pen-barre-val-3mois">—</span>
          </div>
          <div class="penalite-barre-row penalite-barre-row--retenue">
            <span class="penalite-barre-label penalite-barre-label--retenue">IRD ✓</span>
            <div class="penalite-barre-track">
              <div class="penalite-barre-fill penalite-barre-fill--retenue" id="pen-barre-ird" style="width:0%"></div>
            </div>
            <span class="penalite-barre-value penalite-barre-value--retenue" id="pen-barre-val-ird">—</span>
          </div>
          <p class="penalite-barre-note">Le prêteur applique le montant le plus élevé.</p>
        </div>

        <div class="penalite-comparaison" id="pen-comparaison" style="display:none;">
          <div class="penalite-comparaison-icon">💡</div>
          <div class="penalite-comparaison-text" id="pen-comparaison-text"></div>
        </div>

        <details class="penalite-details" id="pen-details">
          <summary class="penalite-details-summary">Détail complet du calcul <span class="penalite-details-arrow">▾</span></summary>
          <pre class="penalite-details-content" id="pen-detail-text"></pre>
        </details>

        <div class="penalite-avertissements" id="pen-avertissements" style="display:none;">
          <details class="penalite-avertissement-details" id="pen-avertissement-details">
            <summary class="penalite-avertissement-summary">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              Précisions sur le calcul
            </summary>
            <div class="penalite-avertissement-content" id="pen-avertissement-content"></div>
          </details>
        </div>

        <div class="penalite-cta-section">
          <button type="button" id="pen-cta-btn" class="btn-cta btn-cta--block">
            <span>Recevoir mon rapport complet par courriel</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>

          <div class="penalite-capture" id="pen-capture" style="display:none;">
            <form name="penalite-lead" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="penalite-capture-form">
              <input type="hidden" name="form-name" value="penalite-lead" />
              <p class="sr-only"><label>Ne remplissez pas ce champ <input name="bot-field" /></label></p>
              <div class="penalite-capture-label">Recevoir ce rapport par courriel</div>
              <p class="penalite-capture-note">{prenom} vous enverra personnellement votre rapport détaillé.</p>

              <details class="penalite-rapport-contenu">
                <summary class="penalite-rapport-contenu-summary">Que contient le rapport ?</summary>
                <ul class="penalite-rapport-contenu-list">
                  <li>Le détail complet du calcul de pénalité (3 mois + IRD)</li>
                  <li>L'estimation selon la méthode de votre prêteur</li>
                  <li>La date de fin de votre terme actuel</li>
                  <li>Les coordonnées de {prenom} pour une analyse personnalisée</li>
                </ul>
              </details>

              <div class="penalite-capture-fields">
                <label for="pen-cap-prenom" class="sr-only">Votre prénom</label>
                <input type="text" id="pen-cap-prenom" name="prenom" placeholder="Votre prénom" class="penalite-capture-input" autocomplete="given-name" required />
                <label for="pen-cap-email" class="sr-only">Votre courriel</label>
                <input type="email" id="pen-cap-email" name="email" placeholder="votre@courriel.com" class="penalite-capture-input" autocomplete="email" required />
                <label for="pen-cap-tel" class="sr-only">Téléphone (optionnel)</label>
                <input type="tel" id="pen-cap-tel" name="telephone" placeholder="Téléphone (optionnel)" class="penalite-capture-input" autocomplete="tel" />
              </div>
              <input type="hidden" name="scenario" id="pen-cap-scenario" value="" />
              <input type="hidden" name="penalite" id="pen-cap-penalite" value="" />
              <label class="penalite-capture-consent" for="pen-cap-consent">
                <input type="checkbox" id="pen-cap-consent" name="consentement" required />
                <span>J'accepte de recevoir ce rapport et de partager mes coordonnées avec {config.nom}, {config.titre}. Aucun partage sans mon consentement — <a href="/confidentialite">politique de confidentialité</a>.</span>
              </label>
              <button type="submit" id="pen-cap-submit" class="penalite-capture-submit" disabled>Envoyer mon rapport →</button>
              <div id="pen-cap-msg" class="penalite-capture-msg" style="display:none;"></div>
            </form>
          </div>
        </div>
      </div>

      <div class="penalite-disclaimer">
        <strong>Avis important.</strong> Cette <strong>estimation</strong> est fournie à titre <strong>indicatif</strong> seulement. La pénalité réelle peut varier selon les clauses spécifiques de votre contrat, les rabais d'origine, les conditions du marché et la méthode exacte de calcul de votre institution. Pour connaître votre pénalité exacte, demandez un <strong>relevé écrit à votre prêteur</strong>. Pour une analyse personnalisée, communiquez avec {config.nom}, {config.titre} affiliée à {config.organisation}, certification AMF n° <strong>{config.amf}</strong>. Cet outil ne constitue pas un conseil financier, fiscal ou juridique.
      </div>
    </div>
  </div>
</section>

<script>
  import { calculerPenalite, comparerMethodes, validerInputs, formatArgent, formaterDate, type PenaliteInput, type MethodeIRD, type TypeTaux } from '../lib/penalite';
  import { tousLesPreteurs } from '../data/preteurs';

  document.addEventListener('DOMContentLoaded', () => {
    const INPUT_DEBOUNCE_MS = 200;
    let debounceTimer: number | undefined;

    const preteurSelect = document.getElementById('pen-preteur') as HTMLSelectElement;
    const preteurHint = document.getElementById('pen-preteur-hint')!;
    const methodeBadge = document.getElementById('pen-methode-badge')!;
    const methodeBadgeText = document.getElementById('pen-methode-badge-text')!;
    const typeFixeBtn = document.getElementById('pen-type-fixe') as HTMLButtonElement;
    const typeVariableBtn = document.getElementById('pen-type-variable') as HTMLButtonElement;
    const fieldsetAffiche = document.getElementById('pen-fieldset-affiche')!;
    const soldeEl = document.getElementById('pen-solde') as HTMLInputElement;
    const tauxEl = document.getElementById('pen-taux') as HTMLInputElement;
    const dateDebutEl = document.getElementById('pen-date-debut') as HTMLInputElement;
    const dureeEl = document.getElementById('pen-duree') as HTMLSelectElement;
    const tauxAfficheEl = document.getElementById('pen-taux-affiche') as HTMLInputElement;

    const placeholder = document.getElementById('penalite-placeholder')!;
    const resultsContent = document.getElementById('penalite-results-content')!;
    const totalEl = document.getElementById('pen-total')!;
    const totalSubEl = document.getElementById('pen-total-sub')!;
    const val3moisEl = document.getElementById('pen-val-3mois')!;
    const valIrdEl = document.getElementById('pen-val-ird')!;
    const valRetenueEl = document.getElementById('pen-val-retenue')!;
    const contexteEl = document.getElementById('pen-contexte')!;
    const comparaisonEl = document.getElementById('pen-comparaison')!;
    const comparaisonText = document.getElementById('pen-comparaison-text')!;
    const detailTextEl = document.getElementById('pen-detail-text')!;
    const avertissementsEl = document.getElementById('pen-avertissements')!;
    const avertissementContent = document.getElementById('pen-avertissement-content')!;

    const ctaBtn = document.getElementById('pen-cta-btn') as HTMLButtonElement;
    const captureDiv = document.getElementById('pen-capture')!;
    const capScenario = document.getElementById('pen-cap-scenario') as HTMLInputElement;
    const capPenalite = document.getElementById('pen-cap-penalite') as HTMLInputElement;
    const capConsent = document.getElementById('pen-cap-consent') as HTMLInputElement;
    const capSubmit = document.getElementById('pen-cap-submit') as HTMLButtonElement;

    // Consent checkbox enables submit button
    capConsent.addEventListener('change', () => {
      capSubmit.disabled = !capConsent.checked;
    });

    let typeTaux: TypeTaux = 'fixe';
    let dernierResultat: ReturnType<typeof calculerPenalite> | null = null;
    let dernierInput: PenaliteInput | null = null;

    function updatePreteurInfo() {
      const preteur = tousLesPreteurs.find((p) => p.id === preteurSelect.value);
      if (preteur) {
        const labels: Record<string, string> = {
          taux_affiche: 'Taux affichés (grandes banques)',
          taux_reel: 'Taux réels / contractuels',
          taux_obligataire: 'Taux obligataire',
        };
        methodeBadgeText.textContent = labels[preteur.methode_ird] ?? preteur.methode_ird;
        methodeBadge.className = `penalite-methode-badge penalite-methode-badge--${preteur.methode_ird}`;
        preteurHint.textContent = preteur.notes ?? '';
        fieldsetAffiche.style.display = preteur.methode_ird === 'taux_affiche' ? '' : 'none';
      }
    }

    preteurSelect.addEventListener('change', () => { updatePreteurInfo(); scheduleRecalc(); });

    function setTypeTaux(valeur: TypeTaux) {
      typeTaux = valeur;
      if (valeur === 'fixe') {
        typeFixeBtn.classList.add('active'); typeFixeBtn.setAttribute('aria-checked', 'true');
        typeVariableBtn.classList.remove('active'); typeVariableBtn.setAttribute('aria-checked', 'false');
        fieldsetAffiche.style.display = preteurSelect.selectedOptions[0]?.dataset.methode === 'taux_affiche' ? '' : 'none';
      } else {
        typeVariableBtn.classList.add('active'); typeVariableBtn.setAttribute('aria-checked', 'true');
        typeFixeBtn.classList.remove('active'); typeFixeBtn.setAttribute('aria-checked', 'false');
        fieldsetAffiche.style.display = 'none';
      }
      scheduleRecalc();
    }

    typeFixeBtn.addEventListener('click', () => setTypeTaux('fixe'));
    typeVariableBtn.addEventListener('click', () => setTypeTaux('variable'));

    [soldeEl, tauxEl, dateDebutEl, dureeEl, tauxAfficheEl].forEach((el) => el.addEventListener('input', scheduleRecalc));
    document.querySelectorAll<HTMLInputElement>('[id^="pen-marche-"]').forEach((el) => el.addEventListener('input', scheduleRecalc));

    function getInputs(): PenaliteInput {
      const methode = (preteurSelect.selectedOptions[0]?.dataset.methode ?? 'taux_affiche') as MethodeIRD;
      const tauxMarche: Record<number, number> = {};
      document.querySelectorAll<HTMLInputElement>('[id^="pen-marche-"]').forEach((el) => {
        const mois = parseInt(el.id.replace('pen-marche-', ''), 10);
        const val = parseFloat(el.value);
        if (!isNaN(val)) tauxMarche[mois] = val;
      });
      const tauxAfficheVal = parseFloat(tauxAfficheEl.value);
      return {
        solde: parseFloat(soldeEl.value) || 0,
        tauxContractuel: parseFloat(tauxEl.value) || 0,
        dateDebutTerme: dateDebutEl.value,
        dureeTermeMois: parseInt(dureeEl.value, 10) || 60,
        typeTaux,
        methodeIRD: methode,
        tauxAfficheOrigine: isNaN(tauxAfficheVal) ? undefined : tauxAfficheVal,
        tauxMarche,
      };
    }

    function scheduleRecalc() { clearTimeout(debounceTimer); debounceTimer = window.setTimeout(doCalculation, INPUT_DEBOUNCE_MS); }

    function clearErrors() {
      document.querySelectorAll('.penalite-error').forEach((el) => { el.textContent = ''; });
      document.querySelectorAll('.penalite-input').forEach((el) => el.classList.remove('penalite-input--error'));
    }

    function showFieldError(fieldId: string, message: string) {
      const errEl = document.getElementById(`${fieldId}-err`);
      const inputEl = document.getElementById(fieldId);
      if (errEl) errEl.textContent = message;
      if (inputEl) inputEl.classList.add('penalite-input--error');
    }

    function doCalculation() {
      clearErrors();
      const input = getInputs();
      const erreurs = validerInputs(input);
      if (erreurs.solde) showFieldError('pen-solde', erreurs.solde);
      if (erreurs.tauxContractuel) showFieldError('pen-taux', erreurs.tauxContractuel);
      if (erreurs.dateDebutTerme) showFieldError('pen-date-debut', erreurs.dateDebutTerme);
      if (Object.keys(erreurs).length > 0) return;

      dernierInput = input;
      const result = calculerPenalite(input);
      dernierResultat = result;

      placeholder.style.display = 'none';
      resultsContent.style.display = '';

      totalEl.textContent = formatArgent(Math.round(result.penaliteTotale));
      totalEl.style.color = result.penaliteTotale > 0 ? 'var(--clay)' : 'var(--forest)';

      // Sticky mobile
      const stickyMobile = document.getElementById('pen-sticky-mobile')!;
      const stickyValue = document.getElementById('pen-sticky-value')!;
      stickyMobile.style.display = '';
      stickyValue.textContent = formatArgent(Math.round(result.penaliteTotale));
      stickyValue.style.color = result.penaliteTotale > 0 ? 'var(--clay)' : 'var(--forest)';
      totalSubEl.textContent = result.penaliteTotale > 0
        ? `Environ ${formatArgent(Math.round(result.penaliteTotale))} si vous brisez votre hypothèque aujourd'hui`
        : 'Aucune pénalité applicable dans ce scénario';

      val3moisEl.textContent = formatArgent(Math.round(result.penalite3Mois));
      valIrdEl.textContent = result.penaliteIRD > 0 ? formatArgent(Math.round(result.penaliteIRD)) : '0 $ (non applicable)';
      valIrdEl.style.color = result.penaliteIRD > 0 ? 'var(--ink)' : 'var(--muted)';

      const labelsMethodes: Record<string, string> = { taux_affiche: 'Taux affichés', taux_reel: 'Taux réels', taux_obligataire: 'Taux obligataire', trois_mois: '3 mois d\'intérêts', non_applicable: 'Aucune' };
      valRetenueEl.textContent = labelsMethodes[result.methodeRetenue] ?? result.methodeRetenue;

      // --- Barres comparatives 3 mois vs IRD ---
      const barresEl = document.getElementById('pen-barres')!;
      const barre3mois = document.getElementById('pen-barre-3mois')!;
      const barreIrd = document.getElementById('pen-barre-ird')!;
      const barreVal3mois = document.getElementById('pen-barre-val-3mois')!;
      const barreValIrd = document.getElementById('pen-barre-val-ird')!;
      const maxPenalite = Math.max(result.penalite3Mois, result.penaliteIRD, 1);
      if (result.penalite3Mois > 0 || result.penaliteIRD > 0) {
        barresEl.style.display = '';
        const pct3mois = (result.penalite3Mois / maxPenalite) * 100;
        const pctIrd = (result.penaliteIRD / maxPenalite) * 100;
        barre3mois.style.width = `${pct3mois}%`;
        barreIrd.style.width = `${pctIrd}%`;
        barreVal3mois.textContent = formatArgent(Math.round(result.penalite3Mois));
        barreValIrd.textContent = formatArgent(Math.round(result.penaliteIRD));
      } else {
        barresEl.style.display = 'none';
      }

      contexteEl.innerHTML = `<span>📅 <strong>${result.moisRestants} mois</strong> restants au terme</span><span>🏁 Fin du terme : <strong>${formaterDate(result.dateFinTerme)}</strong></span>`;

      if (input.typeTaux === 'fixe' && input.methodeIRD === 'taux_affiche' && input.tauxAfficheOrigine) {
        const comparaison = comparerMethodes(input, input.tauxAfficheOrigine);
        if (comparaison && comparaison.ecart > 0) {
          comparaisonEl.style.display = '';
          comparaisonText.innerHTML = comparaison.message.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
        } else { comparaisonEl.style.display = 'none'; }
      } else { comparaisonEl.style.display = 'none'; }

      detailTextEl.textContent = result.detailCalcul;

      if (result.avertissements.length > 0) {
        avertissementsEl.style.display = '';
        avertissementContent.innerHTML = result.avertissements.map((a) => `<div class="penalite-avertissement">${a}</div>`).join('');
      } else { avertissementsEl.style.display = 'none'; }

      capScenario.value = JSON.stringify({ solde: input.solde, taux: input.tauxContractuel, type: input.typeTaux, dateDebut: input.dateDebutTerme, dureeMois: input.dureeTermeMois, preteur: preteurSelect.selectedOptions[0]?.textContent ?? '' });
      capPenalite.value = formatArgent(Math.round(result.penaliteTotale));

      // Rend la pénalité disponible pour le simulateur de refinancement
      sessionStorage.setItem('penalite-resultat', String(Math.round(result.penaliteTotale)));
    }

    ctaBtn.addEventListener('click', () => {
      if (!dernierResultat || dernierResultat.penaliteTotale <= 0) return;
      captureDiv.style.display = captureDiv.style.display === 'none' ? '' : 'none';
      if (captureDiv.style.display !== 'none') captureDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });

    document.getElementById('pen-reset')?.addEventListener('click', () => {
      soldeEl.value = '300000'; tauxEl.value = '5.49'; dateDebutEl.value = '2023-06-01'; dureeEl.value = '60'; tauxAfficheEl.value = '';
      setTypeTaux('fixe'); preteurSelect.value = 'rbc'; updatePreteurInfo();
      const defauts: Record<string, string> = { '6': '5.64', '12': '5.49', '24': '5.09', '36': '4.69', '48': '4.79', '60': '4.89' };
      document.querySelectorAll<HTMLInputElement>('[id^="pen-marche-"]').forEach((el) => {
        const mois = el.id.replace('pen-marche-', '');
        if (defauts[mois]) el.value = defauts[mois]!;
      });
      placeholder.style.display = ''; resultsContent.style.display = 'none'; captureDiv.style.display = 'none';
      document.getElementById('pen-sticky-mobile')!.style.display = 'none';
      dernierResultat = null; clearErrors();
      window.scrollTo({ top: (document.getElementById('penalite-calculator')?.offsetTop ?? 0) - 120, behavior: 'smooth' });
    });

    document.getElementById('pen-share')?.addEventListener('click', () => {
      if (!dernierInput) return;
      const params = new URLSearchParams();
      params.set('s', String(dernierInput.solde)); params.set('t', String(dernierInput.tauxContractuel));
      params.set('d', dernierInput.dateDebutTerme); params.set('dm', String(dernierInput.dureeTermeMois));
      params.set('tt', dernierInput.typeTaux); params.set('p', preteurSelect.value);
      if (dernierInput.tauxAfficheOrigine !== undefined) params.set('ta', String(dernierInput.tauxAfficheOrigine));
      for (const [mois, taux] of Object.entries(dernierInput.tauxMarche)) params.set(`m${mois}`, String(taux));
      const url = `${window.location.origin}${window.location.pathname}?${params.toString()}`;
      navigator.clipboard.writeText(url).then(() => {
        const btn = document.getElementById('pen-share')!;
        const prev = btn.textContent; btn.textContent = '✅ Lien copié !';
        setTimeout(() => { btn.textContent = prev; }, 2000);
      }).catch(() => { alert(`Voici le lien à partager :\n${url}`); });
    });

    function restoreFromParams() {
      const params = new URLSearchParams(window.location.search);
      if (!params.has('s')) return;
      const s = params.get('s'); if (s) soldeEl.value = s;
      const t = params.get('t'); if (t) tauxEl.value = t;
      const d = params.get('d'); if (d) dateDebutEl.value = d;
      const dm = params.get('dm'); if (dm) dureeEl.value = dm;
      if (params.get('tt') === 'variable') setTypeTaux('variable');
      const p = params.get('p'); if (p) preteurSelect.value = p;
      const ta = params.get('ta'); if (ta) tauxAfficheEl.value = ta;
      for (const [key, val] of params.entries()) {
        if (key.startsWith('m')) { const el = document.getElementById(`pen-marche-${key.slice(1)}`) as HTMLInputElement | null; if (el) el.value = val; }
      }
      updatePreteurInfo(); scheduleRecalc();
    }

    updatePreteurInfo(); restoreFromParams();
    window.setTimeout(doCalculation, 100);

    // Mobile sticky setup
    function handleMobileSticky() {
      const sticky = document.getElementById('pen-sticky-mobile')!;
      const hero = document.getElementById('penalite-results-content')!.querySelector('.penalite-result-hero') as HTMLElement | null;
      const isMobile = window.matchMedia('(max-width: 768px)').matches;
      if (isMobile && hero) {
        sticky.classList.add('js-visible');
        hero.classList.add('js-hidden-mobile');
      } else {
        sticky.classList.remove('js-visible');
        if (hero) hero.classList.remove('js-hidden-mobile');
      }
    }
    handleMobileSticky();
    window.addEventListener('resize', handleMobileSticky);

    const fadeEls = document.querySelectorAll('.fade-up');
    const obs = new IntersectionObserver((entries) => entries.forEach((x) => { if (x.isIntersecting) { x.target.classList.add('visible'); obs.unobserve(x.target); } }), { threshold: 0.12 });
    fadeEls.forEach((el) => obs.observe(el));
    window.setTimeout(() => { fadeEls.forEach((el) => el.classList.add('visible')); }, 1000);

    // Signaler la conversion au sticky CTA lors de la soumission du formulaire de capture
    const captureForm = document.querySelector('.penalite-capture-form');
    if (captureForm) {
      captureForm.addEventListener('submit', () => {
        document.body.dataset.outilsConverted = 'true';
        localStorage.setItem('penalite_email_sent', '1');
      });
    }
  });
</script>

<style>
  #penalite-calculator{background:var(--warm);padding:3rem 4rem 6rem;}
