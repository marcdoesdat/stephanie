  .penalite-avertissements{margin-bottom:1.5rem;}
  .penalite-avertissement-details{border:1px solid rgba(196,122,82,.2);border-radius:12px;overflow:hidden;background:#fffaf2;}
  .penalite-avertissement-summary{display:flex;align-items:center;gap:.5rem;padding:.75rem 1rem;font-size:.78rem;font-weight:600;color:var(--clay);cursor:pointer;list-style:none;user-select:none;}
  .penalite-avertissement-summary::-webkit-details-marker{display:none;}
  .penalite-avertissement-summary::after{content:'▸';font-size:.7rem;margin-left:auto;transition:transform .2s;}
  .penalite-avertissement-details[open] .penalite-avertissement-summary::after{transform:rotate(90deg);}
  .penalite-avertissement-content{padding:0 1rem .75rem;}
  .penalite-avertissement{font-size:.75rem;color:var(--muted);line-height:1.6;padding:.4rem 0;}

  .penalite-cta-section{margin-bottom:1.5rem;}

  .penalite-capture{margin-top:1.25rem;padding:1.5rem;border:1px solid var(--border);border-radius:16px;background:var(--sand);}
  .penalite-capture-label{font-family:"Lora",serif;font-size:1.1rem;font-weight:600;color:var(--ink);margin-bottom:.5rem;}
  .penalite-capture-note{font-size:.82rem;color:var(--muted);margin-bottom:1rem;line-height:1.6;}

  .penalite-rapport-contenu{margin-bottom:.85rem;border:1px solid var(--border);border-radius:10px;overflow:hidden;}
  .penalite-rapport-contenu-summary{padding:.6rem .85rem;font-size:.75rem;font-weight:600;color:var(--muted);cursor:pointer;list-style:none;user-select:none;display:flex;align-items:center;gap:.35rem;}
