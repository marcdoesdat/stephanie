  .penalite-capture-consent{display:flex;gap:.65rem;align-items:flex-start;font-size:.75rem;color:var(--muted);line-height:1.5;cursor:pointer;}
  .penalite-capture-consent input{margin-top:.15rem;flex-shrink:0;accent-color:var(--clay);}
