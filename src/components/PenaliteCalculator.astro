  .penalite-capture-submit{width:100%;padding:.8rem;margin-top:1rem;border:none;border-radius:12px;background:var(--clay);color:white;font-family:"DM Sans",sans-serif;font-size:.9rem;font-weight:600;cursor:pointer;transition:background .2s;}
  .penalite-capture-submit:hover{background:var(--clay-dk);}
  .penalite-capture-submit:disabled{opacity:.6;cursor:not-allowed;}
  .penalite-capture-msg{margin-top:.75rem;font-size:.8rem;text-align:center;}

  .penalite-disclaimer{margin-top:2rem;padding:1.25rem 1.5rem;background:#fff9e6;border:1px solid rgba(196,122,82,.25);border-radius:14px;font-size:.75rem;color:var(--muted);line-height:1.7;}

  @media (max-width:768px){
    #penalite-calculator{padding-left:1.5rem;padding-right:1.5rem;}
    #penalite-calculator .section-inner{grid-template-columns:1fr;gap:0;}
    .penalite-results{position:static;}
    .penalite-sticky-mobile{display:none !important;}
    .penalite-sticky-mobile.js-visible{display:flex !important;}
    .penalite-result-hero.js-hidden-mobile{display:none;}
  }
</style>
