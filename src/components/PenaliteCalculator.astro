  .penalite-comparaison{display:flex;gap:1rem;align-items:flex-start;background:rgba(61,90,74,.05);border:1px solid rgba(61,90,74,.15);border-radius:14px;padding:1.25rem;margin-bottom:1.5rem;}
  .penalite-comparaison-icon{font-size:1.4rem;flex-shrink:0;}
