  .penalite-details{border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:1.5rem;}
  .penalite-details-summary{padding:.9rem 1.25rem;font-size:.82rem;font-weight:600;color:var(--ink);cursor:pointer;background:var(--sand);display:flex;justify-content:space-between;align-items:center;user-select:none;}
  .penalite-details-summary:hover{background:var(--warm);}
  .penalite-details-arrow{font-size:.7rem;transition:transform .2s;color:var(--muted);}
