    .rsim-dette-field-libelle { grid-column: 1 / 3; grid-row: 1; }
    .rsim-dette-remove { grid-column: 3; grid-row: 1; align-self: end; }
    /* Montant dû — pleine largeur */
    .rsim-dette-row > .rsim-field:nth-child(2) { grid-column: 1 / 3; grid-row: 2; }
    /* Paiement + Taux côte à côte */
    .rsim-dette-row > .rsim-field:nth-child(3) { grid-column: 1; grid-row: 3; }
