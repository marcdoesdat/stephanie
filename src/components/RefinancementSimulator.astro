---
import { loadSiteConfig } from '../config';
const siteConfig = loadSiteConfig();
const telHref = `tel:+1${siteConfig.telephone.replace(/\D/g, '')}`;

interface Props {
  /** Meilleur taux fixe 5 ans live (Hypotheca) — sert de valeur par défaut au nouveau taux. */
  defaultRate?: number;
}
const { defaultRate } = Astro.props;
// Taux offert par défaut : taux live si disponible et plausible, sinon 4.29.
const nouveauTauxDefaut =
  typeof defaultRate === 'number' && defaultRate >= 0.5 && defaultRate <= 20
    ? defaultRate.toFixed(2)
    : '4.29';
---

<section id="refinancement-simulator" data-nouveau-taux-defaut={nouveauTauxDefaut}>
  <div class="section-inner">
    <form class="rsim-form" id="rsim-form" novalidate>

      <fieldset class="rsim-fieldset">
        <legend class="rsim-legend">Votre prêt actuel</legend>

        <div class="rsim-row">
          <div class="rsim-field">
            <label for="rsim-solde" class="rsim-label">Solde hypothécaire</label>
            <div class="rsim-money-wrap">
              <span class="rsim-money-prefix" aria-hidden="true">$</span>
              <input type="text" id="rsim-solde" class="rsim-input rsim-input--money" value="300 000"
                inputmode="numeric" autocomplete="off" aria-describedby="rsim-solde-err" />
            </div>
            <small class="rsim-error" id="rsim-solde-err"></small>
          </div>
          <div class="rsim-field">
            <label for="rsim-valeur" class="rsim-label">Valeur actuelle de la propriété
              <span class="rsim-opt">(optionnel)</span></label>
            <div class="rsim-money-wrap">
              <span class="rsim-money-prefix" aria-hidden="true">$</span>
              <input type="text" id="rsim-valeur" class="rsim-input rsim-input--money" value=""
                inputmode="numeric" autocomplete="off" placeholder="500 000"
                aria-describedby="rsim-valeur-err" />
            </div>
            <small class="rsim-error" id="rsim-valeur-err"></small>
          </div>
        </div>

        <div class="rsim-row">
          <div class="rsim-field">
            <label for="rsim-taux-actuel" class="rsim-label">Taux contractuel actuel (%)</label>
            <div class="rsim-rate-wrap">
              <input type="number" id="rsim-taux-actuel" class="rsim-input rsim-input--rate"
                value="5.49" step="0.01" inputmode="decimal" min="0.01" max="20"
                aria-describedby="rsim-taux-actuel-err" />
              <span class="rsim-rate-suffix">%</span>
            </div>
            <small class="rsim-error" id="rsim-taux-actuel-err"></small>
          </div>
          <div class="rsim-field">
            <label for="rsim-annees-restantes" class="rsim-label">Années restantes à votre prêt</label>
            <input type="number" id="rsim-annees-restantes" class="rsim-input"
              value="22" min="1" max="35" step="1" inputmode="numeric"
              aria-describedby="rsim-annees-err" />
            <small class="rsim-error" id="rsim-annees-err"></small>
            <small class="rsim-hint">Durée restante avant la fin de votre amortissement.</small>
          </div>
        </div>
      </fieldset>

      <fieldset class="rsim-fieldset">
        <legend class="rsim-legend">Nouveau prêt</legend>

        <div class="rsim-row">
          <div class="rsim-field">
            <label for="rsim-taux-nouveau" class="rsim-label">
              Nouveau taux offert (%)
              <span class="rsim-taux-live-badge" id="rsim-taux-live-badge">Taux Hypotheca du jour</span>
            </label>
            <div class="rsim-rate-wrap">
              <input type="number" id="rsim-taux-nouveau" class="rsim-input rsim-input--rate"
                value="4.29" step="0.01" inputmode="decimal" min="0.01" max="20"
                aria-describedby="rsim-taux-nouveau-err" />
              <span class="rsim-rate-suffix">%</span>
            </div>
            <small class="rsim-error" id="rsim-taux-nouveau-err"></small>
          </div>
          <div class="rsim-field">
            <label for="rsim-amort-nouveau" class="rsim-label">
              Nouvel amortissement (ans)
              <span class="rsim-opt">(défaut = restant)</span>
            </label>
            <input type="number" id="rsim-amort-nouveau" class="rsim-input"
              value="22" min="1" max="30" step="1" inputmode="numeric" />
            <small class="rsim-hint rsim-amort-avert" id="rsim-amort-avert" style="display:none"></small>
          </div>
        </div>

        <div class="rsim-field">
          <label for="rsim-montant-additionnel" class="rsim-label">
            Montant à retirer en cash ($)
            <span class="rsim-opt">(optionnel)</span>
          </label>
          <div class="rsim-money-wrap">
            <span class="rsim-money-prefix" aria-hidden="true">$</span>
            <input type="text" id="rsim-montant-additionnel" class="rsim-input rsim-input--money" value="0"
              inputmode="numeric" autocomplete="off" aria-describedby="rsim-add-err" />
          </div>
          <small class="rsim-error" id="rsim-add-err"></small>
          <small class="rsim-hint">Laissez à 0 si vous ne retirez pas d'équité. Le retrait est limité à 80 % de la valeur de la propriété.</small>
        </div>
      </fieldset>

      <!-- Consolidation de dettes (bloc dépliable) -->
      <fieldset class="rsim-fieldset rsim-conso-fieldset">
        <legend class="rsim-legend">Consolidation de dettes <span class="rsim-opt">(optionnel)</span></legend>
        <button type="button" class="rsim-conso-toggle" id="rsim-conso-toggle"
          aria-expanded="false" aria-controls="rsim-conso-panel">
          <span class="rsim-conso-toggle-text">Vous avez des dettes à regrouper&nbsp;? Calculons-le.</span>
          <svg class="rsim-conso-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"
            aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>
        <div class="rsim-conso-panel" id="rsim-conso-panel">
          <div class="rsim-conso-panel-inner">
            <p class="rsim-fieldset-intro">
              Regroupez vos dettes à taux élevé (cartes de crédit, marges, prêts auto…) dans votre
              hypothèque pour réduire vos paiements mensuels.
            </p>
            <div class="rsim-dettes-list" id="rsim-dettes-list"></div>
            <button type="button" class="rsim-dette-add-btn" id="rsim-dette-add">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              Ajouter une dette
            </button>

            <!-- Résultat consolidation (conditionnel) -->
            <div class="rsim-conso" id="rsim-conso" style="display:none">
              <div class="rsim-conso-title">Consolidation de dettes</div>
              <div class="rsim-conso-hero" id="rsim-conso-hero">
                <div class="rsim-conso-eyebrow">Montant libéré chaque mois</div>
                <div class="rsim-conso-amount" id="rsim-conso-cashflow">—</div>
                <div class="rsim-conso-sub" id="rsim-conso-sub"></div>
              </div>
              <dl class="rsim-conso-dl">
                <div>
                  <dt>Total des dettes intégrées au prêt</dt>
                  <dd id="rsim-conso-total">—</dd>
                </div>
                <div>
                  <dt>Paiements de dettes actuels</dt>
                  <dd id="rsim-conso-paiements-actuels">—</dd>
                </div>
                <div>
                  <dt>Coût ajouté à l'hypothèque</dt>
                  <dd id="rsim-conso-cout-hypo">—</dd>
                </div>
              </dl>
            </div>
          </div>
        </div>
      </fieldset>

      <fieldset class="rsim-fieldset">
        <legend class="rsim-legend">Coûts du refinancement</legend>

        <div class="rsim-field">
          <label for="rsim-penalite" class="rsim-label">
            Pénalité estimée ($)
            <span class="rsim-penalite-badge" id="rsim-penalite-badge">Reprise depuis l'onglet Pénalité</span>
          </label>
          <div class="rsim-money-wrap">
            <span class="rsim-money-prefix" aria-hidden="true">$</span>
            <input type="text" id="rsim-penalite" class="rsim-input rsim-input--money" value="0"
              inputmode="numeric" autocomplete="off" />
          </div>
          <a href="#penalite" class="rsim-penalite-link" id="rsim-penalite-link">
            → Calculer ma pénalité dans l'outil dédié
          </a>
        </div>

        <div class="rsim-field">
          <label for="rsim-frais" class="rsim-label">Frais notaire pour refinancement et +</label>
          <div class="rsim-money-wrap">
            <span class="rsim-money-prefix" aria-hidden="true">$</span>
            <input type="text" id="rsim-frais" class="rsim-input rsim-input--money" value="1 500"
              inputmode="numeric" autocomplete="off" />
          </div>
        </div>
      </fieldset>

    </form>

    <!-- Gabarit d'une ligne de dette (cloné par JS) -->
    <template id="rsim-dette-template">
      <div class="rsim-dette-row">
        <div class="rsim-field rsim-dette-field-libelle">
          <label class="rsim-label">Dette <span class="rsim-opt">(libellé)</span></label>
          <input type="text" class="rsim-input rsim-dette-libelle"
            placeholder="ex. Carte Visa" autocomplete="off" maxlength="40" />
        </div>
        <div class="rsim-field">
          <label class="rsim-label">Montant dû ($)</label>
          <div class="rsim-money-wrap">
            <span class="rsim-money-prefix" aria-hidden="true">$</span>
            <input type="text" class="rsim-input rsim-input--money rsim-dette-montant"
              inputmode="numeric" autocomplete="off" placeholder="0" />
          </div>
        </div>
        <div class="rsim-field">
          <label class="rsim-label">Paiement ($/mois)</label>
          <div class="rsim-money-wrap">
            <span class="rsim-money-prefix" aria-hidden="true">$</span>
            <input type="text" class="rsim-input rsim-input--money rsim-dette-paiement"
              inputmode="numeric" autocomplete="off" placeholder="0" />
          </div>
        </div>
        <div class="rsim-field">
          <label class="rsim-label">Taux (%)</label>
          <div class="rsim-rate-wrap">
            <input type="number" class="rsim-input rsim-input--rate rsim-dette-taux"
              value="19.99" step="0.01" inputmode="decimal" min="0.5" max="40" />
            <span class="rsim-rate-suffix">%</span>
          </div>
        </div>
        <button type="button" class="rsim-dette-remove" aria-label="Retirer cette dette">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </template>

    <!-- ===== Résultats ===== -->
    <div class="rsim-results" id="rsim-results" aria-live="polite" aria-atomic="false">

      <div id="rsim-placeholder" class="rsim-placeholder">
        <div class="rsim-placeholder-icon" aria-hidden="true">🏠</div>
        <h3>Votre analyse apparaîtra ici</h3>
        <p>Remplissez les champs pour savoir si le refinancement en vaut la peine.</p>
      </div>

      <div id="rsim-content" style="display:none">

        <!-- Bande sticky mobile : verdict + économie mensuelle -->
        <div class="rsim-sticky-mobile" id="rsim-sticky-mobile">
          <div class="rsim-sticky-mobile-left">
            <span class="rsim-sticky-mobile-badge" id="rsim-sticky-badge">—</span>
            <span class="rsim-sticky-mobile-label">Refinancement</span>
          </div>
          <span class="rsim-sticky-mobile-value" id="rsim-sticky-value">—</span>
          <a href={telHref} class="rsim-sticky-tel" aria-label="Appeler Stéphanie Weyman">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.41 2 2 0 0 1 3.59 1.24h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6.27 6.27l1.14-1.14a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </a>
        </div>

        <!-- Verdict principal -->
        <div class="rsim-verdict" id="rsim-verdict">
          <div class="rsim-verdict-badge" id="rsim-verdict-badge">—</div>
          <div class="rsim-verdict-title" id="rsim-verdict-title">—</div>
          <div class="rsim-verdict-sub" id="rsim-verdict-sub"></div>
        </div>

        <!-- Hero -->
        <div class="rsim-hero" id="rsim-hero">
          <div class="rsim-hero-eyebrow" id="rsim-hero-eyebrow">Économie mensuelle (effet taux)</div>
          <div class="rsim-hero-amount" id="rsim-hero-amount">—</div>
          <div class="rsim-hero-sub" id="rsim-hero-sub"></div>
          <div class="rsim-amort-warning" id="rsim-amort-warning" style="display:none">
            <span id="rsim-amort-warning-text"></span>
          </div>
        </div>

        <!-- Comparaison côte à côte -->
        <div class="rsim-compare-grid">
          <div class="rsim-compare-card rsim-compare-card--current">
            <div class="rsim-compare-tag">Situation actuelle</div>
            <dl class="rsim-compare-dl">
              <div>
                <dt>Versement</dt>
                <dd id="rsim-pmt-actuel">—</dd>
              </div>
              <div>
                <dt id="rsim-interet-label-actuel">Intérêts sur la période</dt>
                <dd id="rsim-interet-actuel">—</dd>
              </div>
            </dl>
          </div>
          <div class="rsim-compare-card rsim-compare-card--new">
            <div class="rsim-compare-tag">Après refinancement</div>
            <dl class="rsim-compare-dl">
              <div>
                <dt>Versement</dt>
                <dd id="rsim-pmt-nouveau">—</dd>
              </div>
              <div>
                <dt id="rsim-interet-label-nouveau">Intérêts sur la période</dt>
                <dd id="rsim-interet-nouveau">—</dd>
              </div>
              <div>
                <dt>Coût du refinancement</dt>
                <dd id="rsim-cout-refi">—</dd>
              </div>
            </dl>
          </div>
        </div>

        <!-- Point mort -->
        <div class="rsim-pointmort" id="rsim-pointmort">
          <div class="rsim-pointmort-label" id="rsim-pointmort-label">Point mort</div>
          <div class="rsim-pointmort-value" id="rsim-pointmort-value">—</div>
          <div class="rsim-pointmort-sub" id="rsim-pointmort-sub"></div>
          <div class="rsim-pointmort-bar" aria-hidden="true">
            <div class="rsim-pointmort-fill" id="rsim-pointmort-fill"></div>
          </div>
          <div class="rsim-pointmort-axis" aria-hidden="true">
            <span>0</span>
            <span id="rsim-pointmort-axis-mid"></span>
            <span id="rsim-pointmort-axis-max"></span>
          </div>
        </div>

        <!-- Équité disponible (conditionnel) -->
        <div class="rsim-equite" id="rsim-equite" style="display:none">
          <div class="rsim-equite-title">Équité disponible</div>
          <dl class="rsim-equite-dl">
            <div>
              <dt>Maximum refinançable (80 % de la valeur − solde)</dt>
              <dd id="rsim-equite-max">—</dd>
            </div>
            <div id="rsim-equite-additionnel-row" style="display:none">
              <dt>Nouveau solde (dégagement + dettes inclus)</dt>
              <dd id="rsim-equite-nouveau-solde">—</dd>
            </div>
          </dl>
          <div class="rsim-ltv-alert" id="rsim-ltv-alert" style="display:none">
            <span id="rsim-ltv-alert-text"></span>
          </div>
        </div>

        <!-- Économie nette -->
        <div class="rsim-net" id="rsim-net">
          <div class="rsim-net-label" id="rsim-net-label">Économie nette sur la période</div>
          <div class="rsim-net-value" id="rsim-net-value">—</div>
          <div class="rsim-net-sub" id="rsim-net-sub"></div>
        </div>

        <!-- CTA expert — discuter avec Stéphanie -->
        <div class="rsim-cta-expert" id="rsim-cta-expert">
          <div class="rsim-cta-expert-content">
            <p class="rsim-cta-expert-msg" id="rsim-cta-expert-msg">Vos chiffres sont prêts.</p>
            <p class="rsim-cta-expert-sub">Stéphanie peut étudier votre dossier gratuitement, sans engagement.</p>
          </div>
          <a href="#outils-contact" class="rsim-cta-expert-link" id="rsim-cta-expert-link">
            Discuter avec Stéphanie
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>

        <!-- CTA -->
        <div class="rsim-cta">
          <button type="button" class="rsim-print-btn" id="rsim-print-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="6 9 6 2 18 2 18 9"/>
              <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
              <rect x="6" y="14" width="12" height="8"/>
            </svg>
            Imprimer / enregistrer mon analyse
          </button>
          <button type="button" class="rsim-print-btn" id="rsim-reset-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polyline points="1 4 1 10 7 10"/>
              <path d="M3.5 17.5A9 9 0 1 0 12 3"/>
            </svg>
            Réinitialiser le simulateur
          </button>
        </div>

        <!-- Disclaimer AMF -->
        <div class="rsim-disclaimer">
          <strong>Avis important.</strong> Cette estimation est fournie à titre <strong>indicatif</strong> seulement.
          Les résultats sont basés sur les données saisies et ne tiennent pas compte des clauses
          spécifiques de votre contrat ni des conditions réelles du marché. Consultez
          <strong>Stéphanie Weyman</strong>, courtière hypothécaire affiliée à Hypotheca,
          certification AMF n° <strong>255885</strong>, pour une analyse complète de votre dossier.
          Cet outil ne constitue pas un conseil financier, fiscal ou juridique.
        </div>

      </div><!-- /rsim-content -->
    </div><!-- /rsim-results -->
  </div><!-- /section-inner -->
</section>

<script>
  import { calcPaiement, formatMoney, tauxPeriodique } from '../utils/mortgageCalc';

  document.addEventListener('DOMContentLoaded', () => {
    const DEBOUNCE_MS = 150;
    let debounceTimer: number | undefined;

    // --- Formatage canadien-français des champs montants ($) ---
    // Extrait la valeur numérique brute (accepte espaces et virgule décimale).
    function parseVal(s: string): number {
      return parseFloat(s.replace(/\s/g, '').replace(',', '.')) || 0;
    }
    // Formate un entier avec espace fine comme séparateur de milliers (fr-CA).
    function fmtThousands(n: number): string {
      if (isNaN(n) || n <= 0) return '';
      return Math.round(n).toString().replace(/\B(?=(\d{3})+(?!\d))/g, '\u202F');
    }
    // Applique le formatage sur un <input type=text> en conservant le curseur.
    function fmtInputEl(el: HTMLInputElement): void {
      const val = parseVal(el.value);
      if (val > 0) el.value = fmtThousands(val);
    }

    // --- Form elements ---
    const sectionEl      = document.getElementById('refinancement-simulator')!;
    const soldeEl        = document.getElementById('rsim-solde') as HTMLInputElement;
    const valeurEl       = document.getElementById('rsim-valeur') as HTMLInputElement;
    const tauxActuelEl   = document.getElementById('rsim-taux-actuel') as HTMLInputElement;
    const anneesEl       = document.getElementById('rsim-annees-restantes') as HTMLInputElement;
    const penaliteEl     = document.getElementById('rsim-penalite') as HTMLInputElement;
    const penaliteBadge  = document.getElementById('rsim-penalite-badge')!;
    const fraisEl        = document.getElementById('rsim-frais') as HTMLInputElement;
    const tauxNouveauEl  = document.getElementById('rsim-taux-nouveau') as HTMLInputElement;
    const tauxLiveBadge  = document.getElementById('rsim-taux-live-badge')!;
    const amortNouveauEl = document.getElementById('rsim-amort-nouveau') as HTMLInputElement;
    const amortAvertEl   = document.getElementById('rsim-amort-avert')!;
    const montantAddEl   = document.getElementById('rsim-montant-additionnel') as HTMLInputElement;
    const printBtn       = document.getElementById('rsim-print-btn')!;
    const dettesListEl   = document.getElementById('rsim-dettes-list')!;
    const detteAddBtn    = document.getElementById('rsim-dette-add')!;
    const detteTemplate  = document.getElementById('rsim-dette-template') as HTMLTemplateElement;

    // --- Error elements ---
    const errEls: Record<string, HTMLElement> = {
      solde:      document.getElementById('rsim-solde-err')!,
      valeur:     document.getElementById('rsim-valeur-err')!,
      tauxActuel: document.getElementById('rsim-taux-actuel-err')!,
      annees:     document.getElementById('rsim-annees-err')!,
      tauxNouveau:document.getElementById('rsim-taux-nouveau-err')!,
      add:        document.getElementById('rsim-add-err')!,
    };

    // --- Result elements ---
    const placeholder   = document.getElementById('rsim-placeholder')!;
    const content       = document.getElementById('rsim-content')!;
    const stickyBar     = document.getElementById('rsim-sticky-mobile')!;
    const stickyBadge   = document.getElementById('rsim-sticky-badge')!;
    const stickyValue   = document.getElementById('rsim-sticky-value')!;
    const verdictEl     = document.getElementById('rsim-verdict')!;
    const verdictBadge  = document.getElementById('rsim-verdict-badge')!;
    const verdictTitle  = document.getElementById('rsim-verdict-title')!;
    const verdictSub    = document.getElementById('rsim-verdict-sub')!;
    const heroEl        = document.getElementById('rsim-hero')!;
    const heroEyebrow   = document.getElementById('rsim-hero-eyebrow')!;
    const heroAmount    = document.getElementById('rsim-hero-amount')!;
    const heroSub       = document.getElementById('rsim-hero-sub')!;
    const amortWarning  = document.getElementById('rsim-amort-warning')!;
    const amortWarnText = document.getElementById('rsim-amort-warning-text')!;

    const pmtActuelEl        = document.getElementById('rsim-pmt-actuel')!;
    const pmtNouveauEl       = document.getElementById('rsim-pmt-nouveau')!;
    const interetActuelEl    = document.getElementById('rsim-interet-actuel')!;
    const interetNouveauEl   = document.getElementById('rsim-interet-nouveau')!;
    const interetLabelActuel = document.getElementById('rsim-interet-label-actuel')!;
    const interetLabelNouv   = document.getElementById('rsim-interet-label-nouveau')!;
    const coutRefiEl         = document.getElementById('rsim-cout-refi')!;

    const pointMortEl    = document.getElementById('rsim-pointmort')!;
    const pmortValueEl   = document.getElementById('rsim-pointmort-value')!;
    const pmortSubEl     = document.getElementById('rsim-pointmort-sub')!;
    const pmortFillEl    = document.getElementById('rsim-pointmort-fill') as HTMLElement;
    const pmortLabelEl   = document.getElementById('rsim-pointmort-label')!;

    const equiteEl            = document.getElementById('rsim-equite')!;
    const equiteMaxEl         = document.getElementById('rsim-equite-max')!;
    const equiteAddRow        = document.getElementById('rsim-equite-additionnel-row')!;
    const equiteNouveauSolde  = document.getElementById('rsim-equite-nouveau-solde')!;
    const ltvAlertEl          = document.getElementById('rsim-ltv-alert')!;
    const ltvAlertText        = document.getElementById('rsim-ltv-alert-text')!;

    const consoEl             = document.getElementById('rsim-conso')!;
    const consoCashflowEl     = document.getElementById('rsim-conso-cashflow')!;
    const consoSubEl          = document.getElementById('rsim-conso-sub')!;
    const consoTotalEl        = document.getElementById('rsim-conso-total')!;
    const consoPaiementsEl    = document.getElementById('rsim-conso-paiements-actuels')!;
    const consoCoutHypoEl     = document.getElementById('rsim-conso-cout-hypo')!;

    const netEl      = document.getElementById('rsim-net')!;
    const netLabelEl = document.getElementById('rsim-net-label')!;
    const netValueEl = document.getElementById('rsim-net-value')!;
    const netSubEl   = document.getElementById('rsim-net-sub')!;
    const ctaExpertMsg  = document.getElementById('rsim-cta-expert-msg')!;
    const hiddenDonnees = document.getElementById('hidden-simulateur-donnees') as HTMLInputElement | null;

    // --- State ---
    let penaliteManuelle = false; // true when user manually edited the penalty field
    let lastLoadedPenalite: number | null = null; // dernière valeur chargée depuis sessionStorage

    // --- Consolidation de dettes ---
    const consoToggle = document.getElementById('rsim-conso-toggle') as HTMLButtonElement;
    const consoPanel  = document.getElementById('rsim-conso-panel')!;
    let consoOuvert = false;
    interface DetteLigne { montant: number; paiementMensuel: number; taux: number; }
    interface DettesTotaux { montant: number; paiementMensuel: number; nb: number; dettes: DetteLigne[]; }

    // Agrège toutes les lignes de dettes saisies (montant dû + paiement/mois + taux).
    // Si le bloc consolidation est replié, on ignore les dettes.
    function lireDettes(): DettesTotaux {
      if (!consoOuvert) return { montant: 0, paiementMensuel: 0, nb: 0, dettes: [] };
      let montant = 0;
      let paiementMensuel = 0;
      let nb = 0;
      const lignes: DetteLigne[] = [];
      const rows = dettesListEl.querySelectorAll('.rsim-dette-row');
      rows.forEach((row) => {
        const montantEl = row.querySelector('.rsim-dette-montant') as HTMLInputElement | null;
        const paiementEl = row.querySelector('.rsim-dette-paiement') as HTMLInputElement | null;
        const tauxEl = row.querySelector('.rsim-dette-taux') as HTMLInputElement | null;
        const m = montantEl ? Math.max(0, parseVal(montantEl.value)) : 0;
        const p = paiementEl ? Math.max(0, parseVal(paiementEl.value)) : 0;
        const t = tauxEl ? Math.max(0.5, Math.min(40, parseFloat(tauxEl.value) || 19.99)) : 19.99;
        if (m > 0) {
          montant += m;
          paiementMensuel += p;
          nb++;
          lignes.push({ montant: m, paiementMensuel: p, taux: t });
        }
      });
      return { montant, paiementMensuel, nb, dettes: lignes };
    }

    // Ajoute une nouvelle ligne de dette à partir du gabarit.
    function ajouterDette(): void {
      const frag = detteTemplate.content.cloneNode(true) as DocumentFragment;
      const row = frag.querySelector('.rsim-dette-row') as HTMLElement;
      const montantEl = row.querySelector('.rsim-dette-montant') as HTMLInputElement;
      const paiementEl = row.querySelector('.rsim-dette-paiement') as HTMLInputElement;
      const tauxEl = row.querySelector('.rsim-dette-taux') as HTMLInputElement;
      const removeBtn = row.querySelector('.rsim-dette-remove') as HTMLButtonElement;

      // Pré-remplir le paiement à 5 % du montant dû tant que l'utilisateur ne l'a pas édité manuellement
      let paiementManuel = false;
      paiementEl.addEventListener('input', () => { paiementManuel = true; });

      montantEl.addEventListener('input', () => {
        if (!paiementManuel) {
          const m = parseVal(montantEl.value);
          paiementEl.value = m > 0 ? fmtThousands(Math.round(m * 0.05)) : '';
        }
        scheduleRecalc();
      });
      montantEl.addEventListener('blur', () => fmtInputEl(montantEl));

      paiementEl.addEventListener('blur', () => fmtInputEl(paiementEl));
      paiementEl.addEventListener('input', scheduleRecalc);
      tauxEl.addEventListener('input', scheduleRecalc);
      // Suppression en deux étapes pour éviter les clics accidentels.
      let dettesRemoveTimer: number | undefined;
      removeBtn.addEventListener('click', () => {
        if (removeBtn.classList.contains('rsim-dette-remove--confirm')) {
          clearTimeout(dettesRemoveTimer);
          row.remove();
          scheduleRecalc();
          return;
        }
        // Premier clic : passage en mode confirmation (4 s).
        removeBtn.classList.add('rsim-dette-remove--confirm');
        removeBtn.setAttribute('aria-label', 'Confirmer la suppression');
        dettesRemoveTimer = window.setTimeout(() => {
          removeBtn.classList.remove('rsim-dette-remove--confirm');
          removeBtn.setAttribute('aria-label', 'Retirer cette dette');
        }, 4000);
      });

      dettesListEl.appendChild(frag);
      const ajout = dettesListEl.lastElementChild as HTMLElement | null;
      const focusEl = ajout?.querySelector('.rsim-dette-montant') as HTMLInputElement | null;
      focusEl?.focus();
      scheduleRecalc();
    }

    detteAddBtn.addEventListener('click', ajouterDette);

    // Bloc consolidation dépliable (replié par défaut).
    consoToggle.addEventListener('click', () => {
      consoOuvert = !consoOuvert;
      consoToggle.setAttribute('aria-expanded', consoOuvert ? 'true' : 'false');
      consoPanel.classList.toggle('is-open', consoOuvert);
      scheduleRecalc();
    });

    // --- Pré-remplissage du nouveau taux depuis le taux live Hypotheca ---
    const tauxLiveDefaut = sectionEl.dataset.nouveauTauxDefaut;
    if (tauxLiveDefaut) {
      tauxNouveauEl.value = tauxLiveDefaut;
    } else {
      tauxLiveBadge.style.display = 'none';
    }
    // Si l'utilisateur modifie le taux, on masque le badge "taux du jour".
    tauxNouveauEl.addEventListener('input', () => { tauxLiveBadge.style.display = 'none'; });

    // --- Années restantes → mois ---
    function moisRestants(): number {
      const ans = parseFloat(anneesEl.value);
      if (isNaN(ans) || ans <= 0) return 0;
      return Math.round(ans * 12);
    }

    function syncAmortNouveau() {
      // Aligne le nouvel amortissement sur le restant si l'utilisateur ne l'a pas personnalisé.
      if (amortNouveauEl.dataset.userEdited) return;
      const ans = parseFloat(anneesEl.value);
      if (isNaN(ans) || ans <= 0) return;
      amortNouveauEl.value = String(Math.max(1, Math.min(30, Math.round(ans))));
    }

    ['input', 'change'].forEach((evt) => {
      anneesEl.addEventListener(evt, () => {
        syncAmortNouveau();
        scheduleRecalc();
      });
      amortNouveauEl.addEventListener(evt, () => {
        amortNouveauEl.dataset.userEdited = '1';
        scheduleRecalc();
      });
    });

    // --- Bouton imprimer ---
    printBtn.addEventListener('click', () => window.print());

    // --- Bouton réinitialiser ---
    const resetBtn = document.getElementById('rsim-reset-btn')!;
    resetBtn.addEventListener('click', () => {
      if (!confirm('Voulez-vous vraiment réinitialiser le simulateur ? Toutes vos données seront perdues.')) return;
      // Champs prêt actuel
      soldeEl.value = '300\u202F000';
      valeurEl.value = '';
      tauxActuelEl.value = '5.49';
      anneesEl.value = '22';
      // Coûts
      penaliteEl.value = '0';
      penaliteManuelle = false;
      penaliteBadge.style.display = 'none';
      lastLoadedPenalite = null;
      fraisEl.value = '1\u202F500';
      // Nouveau prêt
      tauxNouveauEl.value = tauxLiveDefaut || '4.29';
      tauxLiveBadge.style.display = tauxLiveDefaut ? '' : 'none';
      delete amortNouveauEl.dataset.userEdited;
      amortNouveauEl.value = '22';
      montantAddEl.value = '0';
      // Dettes
      dettesListEl.innerHTML = '';
      if (consoOuvert) {
        consoOuvert = false;
        consoToggle.setAttribute('aria-expanded', 'false');
        consoPanel.classList.remove('is-open');
      }
      // Recalcul
      clearErrors();
      syncAmortNouveau();
      doCalculation();
    });

    // --- Validation : affichage des messages d'erreur ---
    const errInputs: Record<string, HTMLInputElement> = {
      solde: soldeEl, valeur: valeurEl, tauxActuel: tauxActuelEl,
      annees: anneesEl, tauxNouveau: tauxNouveauEl, add: montantAddEl,
    };
    function setError(key: string, msg: string) {
      const el = errEls[key];
      if (el) el.textContent = msg;
      errInputs[key]?.classList.toggle('rsim-input--invalid', !!msg);
    }
    function clearErrors() {
      Object.keys(errEls).forEach((k) => setError(k, ''));
    }

    // --- SessionStorage — pré-remplissage pénalité ---
    function tryLoadPenaliteFromSession() {
      const saved = sessionStorage.getItem('penalite-resultat');
      if (!saved) return;
      const montant = parseFloat(saved);
      if (isNaN(montant) || montant <= 0) return;

      // Charge si c'est un nouveau résultat (même si l'utilisateur avait édité manuellement).
      if (penaliteManuelle && montant === lastLoadedPenalite) return;

      penaliteEl.value = fmtThousands(montant);
      penaliteBadge.style.display = '';
      lastLoadedPenalite = montant;
      penaliteManuelle = false; // réinitialise : un prochain calcul sera repris automatiquement
    }

    penaliteEl.addEventListener('input', () => {
      penaliteManuelle = true;
      penaliteBadge.style.display = 'none';
      scheduleRecalc();
    });

    // Re-check sessionStorage when tab becomes visible (user came back from Pénalité tab)
    document.addEventListener('visibilitychange', () => {
      if (!document.hidden) tryLoadPenaliteFromSession();
    });
    window.addEventListener('hashchange', () => {
      if (window.location.hash === '#refinancement') tryLoadPenaliteFromSession();
    });

    // --- Interest paid over a period (loop-based, same horizon both scenarios) ---
    function interetsPayesSurPeriode(
      solde: number,
      tauxAnnuel: number,
      amortAns: number,
      nbMois: number
    ): number {
      if (solde <= 0 || tauxAnnuel <= 0 || amortAns <= 0 || nbMois <= 0) return 0;
      const r = tauxPeriodique(tauxAnnuel, 12); // effective monthly rate
      const pmt = calcPaiement(solde, tauxAnnuel, amortAns, 12);
      let bal = solde;
      let totalInteret = 0;
      for (let i = 0; i < nbMois && bal > 0.01; i++) {
        const interet = bal * r;
        totalInteret += interet;
        bal = Math.max(0, bal - (pmt - interet));
      }
      return totalInteret;
    }

    function formatMoisDuree(mois: number): string {
      if (mois <= 0) return '—';
      if (mois < 24) return `${mois} mois`;
      const ans = Math.floor(mois / 12);
      const reste = mois % 12;
      if (reste === 0) return `${ans} an${ans > 1 ? 's' : ''}`;
      return `${ans} an${ans > 1 ? 's' : ''} ${reste} mois`;
    }

    // --- Validation des champs (messages visibles + retour booléen) ---
    function validate(): boolean {
      clearErrors();
      let ok = true;
      const solde = parseVal(soldeEl.value);
      const tauxActuel = parseFloat(tauxActuelEl.value);
      const tauxNouveau = parseFloat(tauxNouveauEl.value);
      const annees = parseFloat(anneesEl.value);
      const valeur = parseVal(valeurEl.value);
      const montantAdd = parseVal(montantAddEl.value);

      if (isNaN(solde) || solde <= 0) { setError('solde', 'Entrez votre solde hypothécaire.'); ok = false; }
      if (isNaN(tauxActuel) || tauxActuel < 0.5 || tauxActuel > 20) {
        setError('tauxActuel', 'Taux entre 0,5 % et 20 %.'); ok = false;
      }
      if (isNaN(tauxNouveau) || tauxNouveau < 0.5 || tauxNouveau > 20) {
        setError('tauxNouveau', 'Taux entre 0,5 % et 20 %.'); ok = false;
      }
      if (isNaN(annees) || annees <= 0 || annees > 35) {
        setError('annees', 'Entrez les années restantes (1 à 35).'); ok = false;
      }
      // Dégagement > équité disponible (uniquement si valeur fournie)
      if (!isNaN(valeur) && valeur > 0 && !isNaN(montantAdd) && montantAdd > 0 && !isNaN(solde) && solde > 0) {
        const maxRefi = valeur * 0.80 - solde;
        if (montantAdd > maxRefi) {
          setError('add', `Dépasse l'équité disponible (max ${formatMoney(Math.max(0, Math.round(maxRefi)))}).`);
          // Non bloquant pour le calcul, mais signalé.
        }
      }
      return ok;
    }

    // --- Main calculation ---
    function doCalculation() {
      const solde = parseVal(soldeEl.value);
      const tauxActuel = parseFloat(tauxActuelEl.value) || 0;
      const tauxNouveau = parseFloat(tauxNouveauEl.value) || 0;
      const penalite = Math.max(0, parseVal(penaliteEl.value));
      const frais = Math.max(0, parseVal(fraisEl.value));
      const montantAdd = Math.max(0, parseVal(montantAddEl.value));
      const valeur = Math.max(0, parseVal(valeurEl.value));
      const dettes = lireDettes();

      // Validation visible
      const valide = validate();
      const moisR = moisRestants();
      if (!valide || solde <= 0 || tauxActuel <= 0 || tauxNouveau <= 0 || moisR <= 0) {
        placeholder.style.display = '';
        content.style.display = 'none';
        stickyBar.classList.remove('js-visible');
        sectionEl.classList.remove('rsim-bar-visible');
        return;
      }

      const amortRestantAns = moisR / 12;
      const amortNouveauAns = Math.max(1, Math.min(30, parseFloat(amortNouveauEl.value) || amortRestantAns));
      const horizonMois = moisR; // toujours le même pour les deux scénarios
      const horizonAns = Math.round(amortRestantAns * 10) / 10;

      // --- Payments (mensuel) ---
      // baseNouveauSolde : pret seul + degagement, sans dettes — sert pour l'effet taux pur.
      const baseNouveauSolde = solde + montantAdd;
      // nouveauSolde : capital reel du nouveau pret (inclut les dettes consolidees).
      const nouveauSolde = baseNouveauSolde + dettes.montant;
      const pmtActuelMensuel = calcPaiement(solde, tauxActuel, amortRestantAns, 12);
      const pmtNouveauMensuel = calcPaiement(nouveauSolde, tauxNouveau, amortNouveauAns, 12);

      // Coût mensuel d'intégrer les dettes dans l'hypothèque (au taux + amort. du nouveau prêt).
      const coutHypoDettes = dettes.montant > 0
        ? calcPaiement(dettes.montant, tauxNouveau, amortNouveauAns, 12)
        : 0;
      // Cash-flow libéré : paiements de dettes remplacés − coût ajouté à l'hypothèque.
      const cashflowDettes = dettes.paiementMensuel - coutHypoDettes;

      // Effet taux pur : compare baseNouveauSolde (sans dettes) au meme amort., taux seul change.
      const pmtNouveauRateSeulement = calcPaiement(baseNouveauSolde, tauxNouveau, amortRestantAns, 12);
      const effetTauxMensuel  = pmtActuelMensuel - pmtNouveauRateSeulement;        // >0 = baisse due au taux
      // Effet amortissement : changement d'amort. sur baseNouveauSolde (isole de la consolidation).
      const pmtNouveauBaseAmortNouveau = calcPaiement(baseNouveauSolde, tauxNouveau, amortNouveauAns, 12);
      const effetAmortMensuel = pmtNouveauRateSeulement - pmtNouveauBaseAmortNouveau; // >0 allonge, <0 raccourci

      // Interets sur base coherente (baseNouveauSolde, sans dettes) = comparaison taux seul.
      const interetActuel            = interetsPayesSurPeriode(solde, tauxActuel, amortRestantAns, horizonMois);
      const interetNouveauDureeEgale = interetsPayesSurPeriode(baseNouveauSolde, tauxNouveau, amortRestantAns, horizonMois);
      // Interets reels du nouveau pret (avec dettes, amort. choisi) = pour les tuiles comparatives.
      const interetNouveauReel       = interetsPayesSurPeriode(nouveauSolde, tauxNouveau, amortNouveauAns, horizonMois);
      // Interets au meme amort. restant (pour l'economie due au choix d'amortissement).
      const interetNouveauBaseAmortRestant = interetsPayesSurPeriode(nouveauSolde, tauxNouveau, amortRestantAns, horizonMois);

      const coutTotal     = penalite + frais;
      const economieTaux  = interetActuel - interetNouveauDureeEgale;              // du au taux seul (base coherente)
      const economieAmort = interetNouveauBaseAmortRestant - interetNouveauReel;   // du au choix d'amort.

      // Économie sur les dettes consolidées : intérêts évités vs taux hypothécaire.
      // Chaque dette utilise son propre taux (défaut 19,99 % — carte de crédit).
      let economieConsolidation = 0;
      if (dettes.montant > 0) {
        for (const d of dettes.dettes) {
          if (d.montant > 0 && d.taux > 0) {
            const interetHautTaux = interetsPayesSurPeriode(d.montant, d.taux, amortRestantAns, horizonMois);
            const interetTauxHypo = interetsPayesSurPeriode(d.montant, tauxNouveau, amortRestantAns, horizonMois);
            economieConsolidation += interetHautTaux - interetTauxHypo;
          }
        }
      }

      // Point mort : toujours comparer à durée d'amortissement égale pour isoler l'effet taux.
      // Sans dettes : effetTauxMensuel (baseNouveauSolde @ même amort.).
      // Avec dettes : cashflow à durée égale = (pmt actuel + paiements dettes) − pmt nouveau @ même amort.
      const pmtNouveauDureeEgale = calcPaiement(nouveauSolde, tauxNouveau, amortRestantAns, 12);
      const cashflowDureeEgale = (pmtActuelMensuel + dettes.paiementMensuel) - pmtNouveauDureeEgale;
      const pointMortMois = dettes.montant > 0
        ? (cashflowDureeEgale > 0.01 ? Math.ceil(coutTotal / cashflowDureeEgale) : null)
        : (effetTauxMensuel > 0.01 ? Math.ceil(coutTotal / effetTauxMensuel) : null);

      // VERDICT basé sur l'effet taux net (l'amortissement est un choix, pas un gain gratuit).
      const economieNetteTaux = economieTaux - coutTotal;
      // Économie nette totale : inclut les intérêts évités sur les dettes consolidées.
      const economieNetteTotale = economieNetteTaux + economieConsolidation;
      // Vrai écart de versement (taux + amort. choisi) — affiché dans le hero.
      const deltaVersementReel = pmtActuelMensuel - pmtNouveauMensuel;

      // --- DOM updates ---
      placeholder.style.display = 'none';
      content.style.display = 'flex';

      const unitStr = '/mois';
      const horizonLabel = `sur ≈ ${horizonAns} an${horizonAns !== 1 ? 's' : ''} restant${horizonAns !== 1 ? 's' : ''}`;

      // --- Verdict principal ---
      verdictEl.className = 'rsim-verdict';
      const pointMortCourt = pointMortMois !== null && pointMortMois > 0 && pointMortMois <= 48;
      let verdictKey: 'oui' | 'evaluer' | 'non';
      if (economieNetteTotale > 0 && (coutTotal === 0 || pointMortCourt)) {
        verdictKey = 'oui';
        verdictEl.classList.add('rsim-verdict--oui');
        verdictBadge.textContent = 'OUI';
        verdictTitle.textContent = 'Les conditions sont favorables pour un refinancement.';
        if (dettes.montant > 0 && economieConsolidation > 0) {
          verdictSub.textContent = `Vous épargnez ${formatMoney(Math.round(economieNetteTotale))} net ${horizonLabel} (dont ${formatMoney(Math.round(economieConsolidation))} grâce à la consolidation de dettes).`;
        } else {
          verdictSub.textContent = `Vous épargnez ${formatMoney(Math.round(economieNetteTotale))} net ${horizonLabel}, coûts inclus.`;
        }
      } else if (economieNetteTotale > 0) {
        verdictKey = 'evaluer';
        verdictEl.classList.add('rsim-verdict--evaluer');
        verdictBadge.textContent = 'À ÉVALUER';
        verdictTitle.textContent = 'Rentable, mais sur un long horizon';
        verdictSub.textContent = `Économie nette de ${formatMoney(Math.round(economieNetteTotale))}, mais le point mort est long — votre durée de détention compte.`;
      } else {
        verdictKey = 'non';
        verdictEl.classList.add('rsim-verdict--non');
        verdictBadge.textContent = 'NON';
        verdictTitle.textContent = 'Moins avantageux selon ces chiffres';
        if (dettes.montant > 0 && economieConsolidation > 0) {
          verdictSub.textContent = `Même avec ${formatMoney(Math.round(economieConsolidation))} d'économies sur les dettes, les coûts (${formatMoney(Math.round(coutTotal))}) dépassent les économies.`;
        } else {
          verdictSub.textContent = `Les coûts dépassent les économies d'intérêts (${formatMoney(Math.round(Math.abs(economieNetteTotale)))} de perte nette).`;
        }
      }

      // --- Sticky mobile bar ---
      stickyBar.className = 'rsim-sticky-mobile rsim-sticky-mobile--' + verdictKey;
      stickyBadge.textContent = verdictBadge.textContent;
      if (effetTauxMensuel > 5) {
        stickyValue.textContent = `${formatMoney(Math.round(effetTauxMensuel))}/mois`;
      } else if (effetTauxMensuel < -5) {
        stickyValue.textContent = `+${formatMoney(Math.round(Math.abs(effetTauxMensuel)))}/mois`;
      } else {
        stickyValue.textContent = '≈ 0 $/mois';
      }
      handleMobileSticky();

      // Hero
      heroEl.className = 'rsim-hero';
      if (deltaVersementReel > 5) {
        heroEl.classList.add('rsim-hero--positive');
        heroEyebrow.textContent = 'Baisse du versement mensuel';
        heroAmount.textContent = `${formatMoney(Math.round(deltaVersementReel))}/mois`;
      } else if (deltaVersementReel < -5) {
        heroEl.classList.add('rsim-hero--negative');
        heroEyebrow.textContent = 'Hausse du versement mensuel';
        heroAmount.textContent = `+${formatMoney(Math.round(-deltaVersementReel))}/mois`;
      } else {
        heroEl.classList.add('rsim-hero--neutral');
        heroEyebrow.textContent = 'Versement quasi inchangé';
        heroAmount.textContent = '≈ 0 $';
      }
      heroSub.textContent =
        `Dont ${effetTauxMensuel >= 0 ? '' : '+'}${formatMoney(Math.round(Math.abs(effetTauxMensuel)))} d'effet taux`
        + (dettes.montant > 0 ? ' (prêt seul)' : '')
        + ` et ${effetAmortMensuel >= 0 ? '' : '+'}${formatMoney(Math.round(Math.abs(effetAmortMensuel)))} `
        + `d'amortissement ${effetAmortMensuel >= 0 ? 'allongé' : 'raccourci'}.`;

      // Bloc amortissement — explique l'écart durée égale vs amort. CHOISI (les deux sens).
      const deltaMois = Math.round((amortNouveauAns - amortRestantAns) * 12);
      const amortDiffere = Math.abs(amortNouveauAns - amortRestantAns) > 0.5;
      if (amortDiffere && Math.abs(effetAmortMensuel) > 5) {
        amortWarning.style.display = '';
        if (effetAmortMensuel > 0) {
          amortWarnText.textContent = `Avec l'amortissement de ${Math.round(amortNouveauAns)} ans, votre versement réel est ${formatMoney(Math.round(pmtNouveauMensuel))}/mois (${formatMoney(Math.round(effetAmortMensuel))}/mois de moins) — c'est l'allongement, pas le taux. Intérêts totaux : ${formatMoney(Math.round(interetNouveauReel))}.`;
          amortAvertEl.textContent = `⚠ Amortissement prolongé de ${deltaMois} mois vs le restant actuel`;
        } else {
          amortWarnText.textContent = `Avec l'amortissement de ${Math.round(amortNouveauAns)} ans, votre versement réel grimpe à ${formatMoney(Math.round(pmtNouveauMensuel))}/mois (+${formatMoney(Math.round(-effetAmortMensuel))}/mois) : vous remboursez plus vite. L'économie d'intérêts qui en découle (${formatMoney(Math.round(economieAmort))}) vient du remboursement accéléré, pas du taux.`;
          amortAvertEl.textContent = `⚠ Amortissement raccourci de ${Math.abs(deltaMois)} mois vs le restant actuel`;
        }
        amortAvertEl.style.display = '';
      } else {
        amortWarning.style.display = 'none';
        amortAvertEl.style.display = 'none';
      }

      // Comparison cards
      pmtActuelEl.textContent = `${formatMoney(Math.round(pmtActuelMensuel))}${unitStr}`;
      pmtNouveauEl.textContent = `${formatMoney(Math.round(pmtNouveauMensuel))}${unitStr}`;   // versement réel (amort. choisi)
      interetActuelEl.textContent = formatMoney(Math.round(interetActuel));
      interetNouveauEl.textContent = formatMoney(Math.round(interetNouveauReel));              // intérêts réels (amort. choisi)
      interetLabelActuel.textContent = `Intérêts sur ${Math.round(amortRestantAns)} ans`;
      interetLabelNouv.textContent   = `Intérêts sur ${Math.round(amortNouveauAns)} ans`;
      coutRefiEl.textContent = formatMoney(Math.round(coutTotal));

      // Point mort
      pointMortEl.className = 'rsim-pointmort';
      pmortLabelEl.textContent = dettes.montant > 0 ? 'Point mort (cashflow)' : 'Point mort';
      if (pointMortMois === null) {
        pmortValueEl.textContent = '-';
        const aucunGain = dettes.montant > 0 ? cashflowDureeEgale <= 0 : effetTauxMensuel <= 0;
        if (coutTotal === 0) {
          pmortSubEl.textContent = 'Aucun coût de refinancement — rentable immédiatement.';
        } else if (aucunGain) {
          pmortSubEl.textContent = 'Aucun gain mensuel — les coûts ne sont pas récupérés sur cette période.';
        } else {
          pmortSubEl.textContent = 'L\u2019effet global ne récupère pas les coûts dans la période restante.';
        }
        pmortFillEl.style.width = '0%';
        const axisMidEl = document.getElementById('rsim-pointmort-axis-mid')!;
        const axisMaxEl = document.getElementById('rsim-pointmort-axis-max')!;
        axisMidEl.textContent = '';
        axisMaxEl.textContent = '';
      } else if (pointMortMois === 0) {
        pmortValueEl.textContent = 'Immédiat';
        pmortSubEl.textContent = 'Aucun coût — rentable dès le premier mois.';
        pointMortEl.classList.add('rsim-pointmort--vert');
        pmortFillEl.style.width = '0%';
        (document.getElementById('rsim-pointmort-axis-mid') as HTMLElement).textContent = '';
        (document.getElementById('rsim-pointmort-axis-max') as HTMLElement).textContent = '';
      } else {
        pmortValueEl.textContent = formatMoisDuree(pointMortMois);
        if (pointMortMois < 24) {
          pointMortEl.classList.add('rsim-pointmort--vert');
          pmortSubEl.textContent = 'Excellent — les coûts sont récupérés rapidement.';
        } else if (pointMortMois < 48) {
          pointMortEl.classList.add('rsim-pointmort--orange');
          pmortSubEl.textContent = 'Acceptable — pensez à votre horizon de propriété.';
        } else {
          pointMortEl.classList.add('rsim-pointmort--rouge');
          pmortSubEl.textContent = 'Long — évaluez si vous resterez dans la propriété assez longtemps.';
        }
        const barMax = Math.min(horizonMois, 48);
        pmortFillEl.style.width = `${Math.min((pointMortMois / barMax) * 100, 100)}%`;
        const axisMid = document.getElementById('rsim-pointmort-axis-mid')!;
        const axisMax = document.getElementById('rsim-pointmort-axis-max')!;
        axisMid.textContent = formatMoisDuree(Math.round(barMax / 2));
        axisMax.textContent = barMax < horizonMois ? formatMoisDuree(barMax) + '+' : formatMoisDuree(barMax);
      }

      // Équité
      if (valeur > 0) {
        equiteEl.style.display = '';
        const maxRefi = Math.max(0, valeur * 0.80 - solde);
        equiteMaxEl.textContent = formatMoney(Math.round(maxRefi));

        if (montantAdd > 0 || dettes.montant > 0) {
          equiteAddRow.style.display = '';
          equiteNouveauSolde.textContent = formatMoney(Math.round(nouveauSolde));
        } else {
          equiteAddRow.style.display = 'none';
        }

        // Alerte ratio prêt-valeur (LTV) — inclut dégagement + dettes consolidées
        const ltv = nouveauSolde / valeur;
        if (ltv > 0.80 + 1e-9) {
          const surplus = Math.round(nouveauSolde - valeur * 0.80);
          ltvAlertEl.style.display = '';
          ltvAlertText.textContent =
            `⚠ Le nouveau solde (${formatMoney(Math.round(nouveauSolde))}) représente ${Math.round(ltv * 100)} % de la valeur. `
            + `Le refinancement conventionnel est limité à 80 % (max ${formatMoney(Math.max(0, Math.round(valeur * 0.80)))}). `
            + `Réduisez le dégagement et/ou les dettes consolidées d'environ ${formatMoney(Math.max(0, surplus))}.`;
        } else {
          ltvAlertEl.style.display = 'none';
        }
      } else if (montantAdd > 0 || dettes.montant > 0) {
        // Dégagement ou consolidation demandé mais valeur de propriété manquante.
        equiteEl.style.display = '';
        equiteMaxEl.textContent = '—';
        equiteAddRow.style.display = 'none';
        ltvAlertEl.style.display = '';
        ltvAlertText.textContent =
          `⚠ Vous avez demandé un dégagement d'équité ou une consolidation de dettes, `
          + `mais la valeur de la propriété n'est pas renseignée. `
          + `Entrez la valeur actuelle pour vérifier que le nouveau prêt respecte le ratio maximal de 80 %.`;
      } else {
        equiteEl.style.display = 'none';
        ltvAlertEl.style.display = 'none';
      }

      // Consolidation de dettes
      if (dettes.montant > 0) {
        consoEl.style.display = '';
        consoTotalEl.textContent = formatMoney(Math.round(dettes.montant));
        consoPaiementsEl.textContent = `${formatMoney(Math.round(dettes.paiementMensuel))}/mois`;
        consoCoutHypoEl.textContent = `${formatMoney(Math.round(coutHypoDettes))}/mois`;

        const consoHero = document.getElementById('rsim-conso-hero')!;
        consoHero.className = 'rsim-conso-hero';
        if (cashflowDettes > 5) {
          consoHero.classList.add('rsim-conso-hero--positive');
          consoCashflowEl.textContent = `${formatMoney(Math.round(cashflowDettes))}/mois`;
          consoSubEl.textContent =
            `En intégrant ${dettes.nb} dette${dettes.nb > 1 ? 's' : ''} au taux hypothécaire `
            + `(${tauxNouveau} %), vous remplacez ${formatMoney(Math.round(dettes.paiementMensuel))}/mois `
            + `de paiements par ${formatMoney(Math.round(coutHypoDettes))}/mois. `
            + `Économie d'intérêts estimée à ${formatMoney(Math.round(economieConsolidation))} sur la période.`;
        } else if (cashflowDettes < -5) {
          consoHero.classList.add('rsim-conso-hero--negative');
          consoCashflowEl.textContent = `−${formatMoney(Math.round(Math.abs(cashflowDettes)))}/mois`;
          consoSubEl.textContent =
            'Vos paiements de dettes actuels sont déjà bas — les intégrer à l\'hypothèque '
            + 'augmente votre versement. La consolidation n\'améliore pas votre cash-flow ici.';
        } else {
          consoHero.classList.add('rsim-conso-hero--neutral');
          consoCashflowEl.textContent = '≈ 0 $/mois';
          consoSubEl.textContent =
            'L\'intégration des dettes a peu d\'effet sur votre cash-flow mensuel.';
        }
      } else {
        consoEl.style.display = 'none';
      }

      // Économie nette
      netEl.className = 'rsim-net';
      netLabelEl.textContent = `Économie nette ${horizonLabel}`;
      if (economieNetteTotale > 0) {
        netEl.classList.add('rsim-net--positive');
        netValueEl.textContent = formatMoney(Math.round(economieNetteTotale));
        if (dettes.montant > 0 && economieConsolidation > 0) {
          netSubEl.textContent = `Économies d'intérêts hypothécaires ${formatMoney(Math.round(economieTaux))} + consolidation ${formatMoney(Math.round(economieConsolidation))} − coûts ${formatMoney(Math.round(coutTotal))}.`;
        } else {
          netSubEl.textContent = `Économies d'intérêts ${formatMoney(Math.round(economieTaux))} moins les coûts ${formatMoney(Math.round(coutTotal))}.`;
        }
      } else {
        netEl.classList.add('rsim-net--negative');
        netValueEl.textContent = `−${formatMoney(Math.round(Math.abs(economieNetteTotale)))}`;
        netSubEl.textContent = `Les coûts (${formatMoney(Math.round(coutTotal))}) dépassent les économies d'intérêts (${formatMoney(Math.round(economieTaux))}) sur cette période.`;
      }

      // Mise à jour CTA expert et données cachées du formulaire contact
      ctaExpertMsg.textContent = verdictKey === 'oui'
        ? 'Les conditions sont favorables — passons à l\'action !'
        : verdictKey === 'evaluer'
        ? 'Rentable sur le long terme — parlons de votre horizon.'
        : 'Stéphanie peut aussi explorer d\'autres pistes avec vous.';
      if (hiddenDonnees) {
        hiddenDonnees.value = [
          'Simulateur de refinancement',
          `Solde : ${formatMoney(solde)}`,
          `Taux actuel : ${tauxActuel} % → Nouveau : ${tauxNouveau} %`,
          `Versement : ${formatMoney(Math.round(pmtActuelMensuel))}/mois → ${formatMoney(Math.round(pmtNouveauMensuel))}/mois`,
          `Économie nette : ${formatMoney(Math.round(economieNetteTotale))}`,
          `Point mort : ${pointMortMois !== null ? formatMoisDuree(pointMortMois) : 'n/a'}`,
          dettes.montant > 0 ? `Dettes consolidées : ${formatMoney(Math.round(dettes.montant))}` : '',
        ].filter(Boolean).join(' | ');
      }
    }

    function scheduleRecalc() {
      clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(doCalculation, DEBOUNCE_MS);
    }

    // Bind inputs
    // Champs dollar : formatage au blur + recalcul à l'input
    // (penaliteEl a son propre écouteur pour penaliteManuelle, on ajoute juste le blur ici)
    const moneyEls = [soldeEl, valeurEl, fraisEl, montantAddEl];
    moneyEls.forEach((el) => {
      el.addEventListener('blur', () => fmtInputEl(el));
      el.addEventListener('input', scheduleRecalc);
    });
    penaliteEl.addEventListener('blur', () => fmtInputEl(penaliteEl));
    // Champs taux
    [tauxActuelEl, tauxNouveauEl].forEach(
      (el) => el.addEventListener('input', scheduleRecalc)
    );
    // années + amort + pénalité ont leurs propres écouteurs ci-dessus

    // Mobile sticky verdict bar
    function handleMobileSticky() {
      const isMobile = window.matchMedia('(max-width: 768px)').matches;
      if (isMobile) {
        stickyBar.classList.add('js-visible');
        sectionEl.classList.add('rsim-bar-visible');
        verdictEl.classList.add('js-hidden-mobile');
        heroEl.classList.add('js-hidden-mobile');
      } else {
        stickyBar.classList.remove('js-visible');
        sectionEl.classList.remove('rsim-bar-visible');
        verdictEl.classList.remove('js-hidden-mobile');
        heroEl.classList.remove('js-hidden-mobile');
      }
    }
    window.addEventListener('resize', handleMobileSticky);

    // Initial setup
    syncAmortNouveau();
    tryLoadPenaliteFromSession();
    doCalculation();
  });
</script>

<style>
  #refinancement-simulator {
    background: var(--warm);
    padding: 3rem 4rem 6rem;
  }

  #refinancement-simulator .section-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* ---- Form ---- */
  .rsim-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .rsim-fieldset {
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .rsim-legend {
    font-family: "Lora", serif;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--ink);
    padding: 0 .5rem;
  }

  .rsim-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .75rem;
  }

  .rsim-field {
    display: flex;
    flex-direction: column;
    gap: .3rem;
  }

  .rsim-label {
    font-size: .78rem;
    font-weight: 600;
    color: var(--muted);
    letter-spacing: .02em;
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: .3rem;
    line-height: 1.3;
  }

  /* Dans une rangée 2 colonnes, on réserve la hauteur de deux lignes de
     label pour que les inputs des deux colonnes s'alignent même si un seul
     libellé déborde sur une deuxième ligne. */
  .rsim-row .rsim-label {
    min-height: 3.25rem;
  }

  .rsim-opt {
    font-weight: 400;
    font-size: .72rem;
    color: var(--muted);
    opacity: .75;
  }

  .rsim-input {
    padding: .75rem 1rem;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    font-family: "DM Sans", sans-serif;
    font-size: .92rem;
    color: var(--ink);
    background: var(--sand);
    width: 100%;
    transition: border-color .2s, background .2s;
  }

  .rsim-input:focus {
    outline: none;
    border-color: var(--clay);
    background: white;
  }

  .rsim-input::placeholder { color: var(--muted); }

  .rsim-rate-wrap,
  .rsim-money-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .rsim-input--rate { padding-right: 2.5rem; }
  .rsim-input--money { padding-left: 1.75rem; }

  .rsim-rate-suffix,
  .rsim-money-prefix {
    position: absolute;
    font-size: .8rem;
    font-weight: 600;
    color: var(--muted);
    pointer-events: none;
    user-select: none;
  }

  .rsim-rate-suffix { right: .85rem; }
  .rsim-money-prefix { left: .75rem; }

  .rsim-error {
    font-size: .75rem;
    color: #c0392b;
    min-height: 1em;
  }

  .rsim-input--invalid {
    border-color: #c0392b;
    background: rgba(192, 57, 43, .04);
  }

  /* Badge "taux du jour" */
  .rsim-taux-live-badge {
    font-size: .6rem;
    font-weight: 700;
    letter-spacing: .04em;
    text-transform: uppercase;
    background: rgba(61, 90, 74, .1);
    color: var(--forest);
    border: 1px solid rgba(61, 90, 74, .2);
    border-radius: 6px;
    padding: .12rem .4rem;
  }

  .rsim-hint {
    font-size: .75rem;
    color: var(--muted);
    line-height: 1.4;
  }

  .rsim-amort-avert {
    color: var(--clay);
    font-weight: 600;
  }

  /* Penalty link and badge */
  .rsim-penalite-badge {
    display: none;
    font-size: .65rem;
    font-weight: 600;
    letter-spacing: .05em;
    text-transform: uppercase;
    background: rgba(61, 90, 74, .1);
    color: var(--forest);
    border: 1px solid rgba(61, 90, 74, .2);
    border-radius: 6px;
    padding: .15rem .4rem;
    vertical-align: middle;
  }

  .rsim-penalite-link {
    display: inline-block;
    margin-top: .35rem;
    font-size: .78rem;
    font-weight: 600;
    /* #8a4820 sur fond --sand (#f7f2eb) = ratio ~5.6:1, passe WCAG AA */
    color: #8a4820;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .rsim-penalite-link:hover { color: var(--ink); }

  /* ---- Results column ---- */
  .rsim-results {
    position: sticky;
    top: 100px;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  #rsim-content {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }

  /* Placeholder */
  .rsim-placeholder {
    background: white;
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 3rem 2rem;
    text-align: center;
  }

  .rsim-placeholder-icon { font-size: 2.5rem; margin-bottom: 1rem; }

  .rsim-placeholder h3 {
    font-family: "Lora", serif;
    font-size: 1.2rem;
    color: var(--ink);
    margin: 0 0 .5rem;
  }

  .rsim-placeholder p {
    font-size: .85rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.6;
  }

  /* Verdict principal */
  .rsim-verdict {
    border-radius: 18px;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: .35rem;
    border: 1.5px solid var(--border);
    background: var(--sand);
  }

  .rsim-verdict--oui     { border-color: rgba(61,90,74,.4);  background: rgba(61,90,74,.06); }
  .rsim-verdict--evaluer { border-color: rgba(196,122,52,.4); background: rgba(196,122,52,.06); }
  .rsim-verdict--non     { border-color: rgba(180,60,50,.35); background: rgba(180,60,50,.05); }

  .rsim-verdict-badge {
    align-self: flex-start;
    font-size: .68rem;
    font-weight: 800;
    letter-spacing: .1em;
    text-transform: uppercase;
    padding: .25rem .6rem;
    border-radius: 999px;
    color: white;
  }

  .rsim-verdict--oui .rsim-verdict-badge     { background: var(--forest); }
  .rsim-verdict--evaluer .rsim-verdict-badge { background: var(--clay); }
  .rsim-verdict--non .rsim-verdict-badge     { background: #b43c32; }

  .rsim-verdict-title {
    font-family: "Lora", serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.25;
  }

  .rsim-verdict-sub { font-size: .82rem; color: var(--muted); line-height: 1.5; }

  /* Hero */
  .rsim-hero {
    border-radius: 20px;
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }

  .rsim-hero--positive {
    background: linear-gradient(135deg, #3d5a4a 0%, #2e4538 100%);
    box-shadow: 0 8px 32px rgba(61, 90, 74, .25);
  }

  .rsim-hero--negative {
    background: linear-gradient(135deg, #7a3a2a 0%, #5a2518 100%);
  }

  .rsim-hero--neutral {
    background: var(--sand);
    border: 1px solid var(--border);
  }

  .rsim-hero-eyebrow {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  .rsim-hero--positive .rsim-hero-eyebrow,
  .rsim-hero--negative .rsim-hero-eyebrow { color: rgba(255,255,255,.7); }

  .rsim-hero--neutral .rsim-hero-eyebrow { color: var(--muted); }

  .rsim-hero-amount {
    font-family: "Lora", serif;
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -.02em;
  }

  .rsim-hero--positive .rsim-hero-amount,
  .rsim-hero--negative .rsim-hero-amount { color: white; }

  .rsim-hero--neutral .rsim-hero-amount { color: var(--ink); }

  .rsim-hero-sub {
    font-size: .82rem;
    line-height: 1.5;
  }

  .rsim-hero--positive .rsim-hero-sub,
  .rsim-hero--negative .rsim-hero-sub { color: rgba(255,255,255,.8); }

  .rsim-hero--neutral .rsim-hero-sub { color: var(--muted); }

  .rsim-amort-warning {
    margin-top: .5rem;
    background: rgba(196, 122, 82, .12);
    border: 1px solid rgba(196, 122, 82, .3);
    border-radius: 10px;
    padding: .6rem .85rem;
    font-size: .75rem;
    color: #7a4010;
    line-height: 1.5;
  }

  .rsim-hero--positive .rsim-amort-warning,
  .rsim-hero--negative .rsim-amort-warning {
    background: rgba(255,255,255,.12);
    border-color: rgba(255,255,255,.2);
    color: rgba(255,255,255,.9);
  }

  /* Comparison cards */
  .rsim-compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .75rem;
  }

  .rsim-compare-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .75rem;
  }

  .rsim-compare-card--new {
    border-color: rgba(61, 90, 74, .25);
    background: linear-gradient(180deg, rgba(61, 90, 74, .04), white 60%);
  }

  .rsim-compare-tag {
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: .09em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .rsim-compare-card--new .rsim-compare-tag { color: var(--forest); }

  .rsim-compare-dl { display: flex; flex-direction: column; gap: .4rem; margin: 0; }

  .rsim-compare-dl > div {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: .4rem;
    border-top: 1px solid var(--border);
    padding-top: .4rem;
