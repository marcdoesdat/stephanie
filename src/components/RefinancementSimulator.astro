    /* Rend le <form> transparent côté layout : ses fieldsets deviennent
       des enfants directs de la grille et peuvent être réordonnés. */
    .rsim-form { display: contents; }

    /* Flux linéaire : tous les champs d'abord, résultats + CTA tout en bas. */
    .rsim-form .rsim-fieldset:nth-child(1) { order: 1; }
    .rsim-form .rsim-fieldset:nth-child(2) { order: 2; }
    .rsim-form .rsim-fieldset:nth-child(3) { order: 3; }
    .rsim-form .rsim-fieldset:nth-child(4) { order: 4; }
    .rsim-form .rsim-disclaimer            { order: 5; }
    .rsim-results                           { order: 6; }

    /* Grille de dette — layout 2 colonnes : libellé + montant pleine largeur, paiement/taux côte à côte */
    .rsim-dette-row {
      grid-template-columns: 1fr 1fr auto;
