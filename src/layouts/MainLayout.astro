---
import SEO from '../components/SEO.astro';
import { loadSiteConfig } from '../config';
import '../styles/global.css';

const config = loadSiteConfig();

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    
    <SEO title={title} description={description} ogImage={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <link 
      rel="preload" 
      as="style" 
      href="https://fonts.googleapis.com/css2?family=Lora:wght@600;700&family=DM+Sans:wght@400;500&display=swap" 
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <script 
      defer 
      src="https://cloud.umami.is/script.js" 
      data-website-id="9a2bb5e1-afd5-4d94-a89f-5584d5c44b12"
      data-domains={config.site_url.replace(/^https?:\/\//, '')}
    ></script>
  </head>
  <body>
    <a href="#main-content" class="sr-only">Passer au contenu principal</a>
    
    <main id="main-content">
      <slot />
    </main>

    <a href="#contact" class="mobile-sticky-cta" aria-label="Prendre rendez-vous">Prendre rendez-vous</a>
  </body>
</html>

<style is:global>
  /* --- RÉGLAGES GLOBAUX --- */
  
  html {
    scroll-behavior: smooth;
    /* Empêche le décalage horizontal sur mobile */
    overflow-x: hidden;
  }
  
  body {
    margin: 0;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    /* Couleur de fond par défaut pour éviter le flash blanc en mode sombre */
    background-color: var(--white, #ffffff);
  }

  /* Classe utilitaire pour cacher des éléments visuellement mais les garder pour les lecteurs d'écran */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Focus visible pour l'accessibilité au clavier */
  :focus-visible {
    outline: 2px solid var(--clay, #c47a52);
    outline-offset: 4px;
  }

  .mobile-sticky-cta {
    display: none;
  }

  @media (max-width: 900px) {
    body {
      padding-bottom: calc(4.7rem + env(safe-area-inset-bottom));
    }

    .mobile-sticky-cta {
      position: fixed;
      display: flex;
      align-items: center;
      justify-content: center;
      left: 0.9rem;
      right: 0.9rem;
      max-width: 28rem;
      margin: 0 auto;
      bottom: calc(0.75rem + env(safe-area-inset-bottom));
      z-index: 1000;
      min-height: 2.95rem;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: #fff;
      background: linear-gradient(135deg, var(--clay), #b56f4c);
      box-shadow: 0 14px 32px rgba(0, 0, 0, 0.22);
    }
  }

  @media (max-width: 420px) {
    .mobile-sticky-cta {
      font-size: 0.92rem;
      min-height: 2.85rem;
      left: 0.7rem;
      right: 0.7rem;
    }
  }
</style>