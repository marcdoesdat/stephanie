---
import SEO from '../components/SEO.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import { loadSiteConfig } from '../config';
import '../styles/global.css';

const config = loadSiteConfig();

interface Props {
  title?: string;
  fullTitle?: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, fullTitle, description, ogImage, noindex } = Astro.props;
---

<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <SEO title={title} fullTitle={fullTitle} description={description} ogImage={ogImage} noindex={noindex} />
    <slot name="head" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap"
      />
    </noscript>

    <script
      is:inline
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="9a2bb5e1-afd5-4d94-a89f-5584d5c44b12"
      data-domains={config.site_url.replace(/^https?:\/\//, '')}
    ></script>

    <!-- Calendly : la feuille de styles est dépourvue de cookies, donc chargée sans consentement.
         Les scripts Google Analytics + Calendly sont chargés conditionnellement par /js/consent.js
         après acceptation explicite (conformité Loi 25). -->
    <link rel="stylesheet" href="https://assets.calendly.com/assets/external/widget.css" />

    <!-- Bannière de consentement Loi 25 : gère le chargement conditionnel de GA + Calendly -->
    <script is:inline defer src="/js/consent.js"></script>
  </head>
  <body data-calendly-url={config.calendly_url}>
    <a href="#main-content" class="skip-link">Passer au contenu principal</a>
    <slot />
    <a href={config.calendly_url} data-calendly class="mobile-sticky-cta" target="_blank" rel="noopener" aria-label="Prendre rendez-vous">
      <span class="sticky-label">Prendre rendez-vous</span>
    </a>
    <ConsentBanner />

    <!-- Sticky scroll-aware + état conversion -->
    <script is:inline>
      (function() {
        const sticky = document.querySelector('.mobile-sticky-cta');
        if (!sticky) return;

        // --- Scroll-aware: hide on scroll down, show on scroll up ---
        let lastY = window.scrollY;
        let ticking = false;
        const SCROLL_THRESHOLD = 8; // px minimum pour déclencher

        function onScroll() {
          const y = window.scrollY;
          const delta = y - lastY;
          if (Math.abs(delta) < SCROLL_THRESHOLD) return;

          if (delta > 0) {
            // scrolling down → hide
            sticky.classList.add('sticky-hidden');
          } else {
            // scrolling up → show
            sticky.classList.remove('sticky-hidden');
          }
          lastY = y;
        }

        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              onScroll();
              ticking = false;
            });
            ticking = true;
          }
        }, { passive: true });

        // --- État de conversion /outils/ : discret → plein gaz ---
        // Si l'utilisateur a déjà déverrouillé une simulation (localStorage) ou
        // si un composant a marqué body[data-outils-converted], on passe en mode "converti".
        function checkConverted() {
          if (
            document.body.dataset.outilsConverted === 'true' ||
            localStorage.getItem('sim_unlocked') === '1' ||
            localStorage.getItem('calc_email_sent') === '1' ||
            localStorage.getItem('penalite_email_sent') === '1'
          ) {
            sticky.classList.add('sticky-converted');
          }
        }

        // Vérifie au chargement
        checkConverted();

        // Observe les changements d'attribut sur body (quand un composant marque la conversion)
        const observer = new MutationObserver(() => {
          checkConverted();
        });
        observer.observe(document.body, { attributes: true, attributeFilter: ['data-outils-converted'] });

        // Écoute aussi un event custom pour être plus réactif
        window.addEventListener('outils:converted', () => {
          sticky.classList.add('sticky-converted');
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  /* --- RÉGLAGES GLOBAUX --- */
  
  html {
    scroll-behavior: smooth;
    /* Empêche le décalage horizontal sur mobile */
    overflow-x: hidden;
  }
  
  body {
    margin: 0;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    /* Couleur de fond par défaut pour éviter le flash blanc en mode sombre */
    background-color: var(--white, #ffffff);
  }

  /* Classe utilitaire pour cacher des éléments visuellement mais les garder pour les lecteurs d'écran */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Lien d'évitement vers le contenu principal — visible au focus clavier */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0.5rem;
    z-index: 10000;
    padding: 0.6rem 1rem;
    background: var(--ink, #1a1a1a);
    color: #fff;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    transition: top .15s ease-in;
  }
  .skip-link:focus,
  .skip-link:focus-visible {
    top: 0.5rem;
    outline: 2px solid var(--clay, #c47a52);
    outline-offset: 2px;
  }

  /* Focus visible pour l'accessibilité au clavier */
  :focus-visible {
    outline: 2px solid var(--clay, #c47a52);
    outline-offset: 4px;
  }

  .mobile-sticky-cta {
    display: none;
  }

  @media (max-width: 900px) {
    body {
      /* Hauteur de la sticky bar + safe area */
      padding-bottom: calc(3.4rem + env(safe-area-inset-bottom));
    }

    .mobile-sticky-cta {
      position: fixed;
      display: flex;
      align-items: center;
      justify-content: center;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 1000;
      height: 52px;
      text-decoration: none;
      font-family: "DM Sans", sans-serif;
      font-size: 0.88rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      color: var(--clay);
      background: rgba(253, 250, 246, 0.97);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-top: 1.5px solid var(--border);
      box-shadow: 0 -2px 16px rgba(0, 0, 0, 0.06);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                  background 0.3s,
                  color 0.3s,
                  box-shadow 0.3s,
                  border-color 0.3s;
      padding: 0 1rem;
      padding-bottom: env(safe-area-inset-bottom);
      gap: 0.5rem;
    }

    /* Scroll-aware : caché au scroll vers le bas */
    .mobile-sticky-cta.sticky-hidden {
      transform: translateY(calc(100% + env(safe-area-inset-bottom)));
    }

    /* --- État converti (après capture courriel sur /outils/) : plein gaz --- */
    .mobile-sticky-cta.sticky-converted {
      color: #fff;
      background: linear-gradient(135deg, var(--clay), #b56f4c);
      border-top-color: transparent;
      box-shadow: 0 -4px 24px rgba(196, 122, 82, 0.35);
      font-weight: 700;
    }

    /* Effet hover subtil */
    .mobile-sticky-cta:active {
      background: rgba(240, 232, 218, 0.97);
    }
    .mobile-sticky-cta.sticky-converted:active {
      background: linear-gradient(135deg, var(--clay-dk), #9e5f3e);
    }
  }

  @media (max-width: 420px) {
    .mobile-sticky-cta {
      font-size: 0.82rem;
      height: 48px;
    }
    body {
      padding-bottom: calc(3.1rem + env(safe-area-inset-bottom));
    }
  }
</style>