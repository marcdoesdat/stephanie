---
import SEO from '../components/SEO.astro';
import { loadSiteConfig } from '../config';
import '../styles/global.css';

const config = loadSiteConfig();

interface Props {
  title?: string;
  fullTitle?: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, fullTitle, description, ogImage, noindex } = Astro.props;
---

<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <SEO title={title} fullTitle={fullTitle} description={description} ogImage={ogImage} noindex={noindex} />
    <slot name="head" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap"
    />

    <script
      is:inline
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="9a2bb5e1-afd5-4d94-a89f-5584d5c44b12"
      data-domains={config.site_url.replace(/^https?:\/\//, '')}
    ></script>

    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-KFGH2CR8SJ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-KFGH2CR8SJ');
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Passer au contenu principal</a>
    <slot />
    <a href="#contact" class="mobile-sticky-cta" aria-label="Prendre rendez-vous">Prendre rendez-vous</a>
  </body>
</html>

<style is:global>
  /* --- RÉGLAGES GLOBAUX --- */
  
  html {
    scroll-behavior: smooth;
    /* Empêche le décalage horizontal sur mobile */
    overflow-x: hidden;
  }
  
  body {
    margin: 0;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    /* Couleur de fond par défaut pour éviter le flash blanc en mode sombre */
    background-color: var(--white, #ffffff);
  }

  /* Classe utilitaire pour cacher des éléments visuellement mais les garder pour les lecteurs d'écran */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Lien d'évitement vers le contenu principal — visible au focus clavier */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0.5rem;
    z-index: 10000;
    padding: 0.6rem 1rem;
    background: var(--ink, #1a1a1a);
    color: #fff;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    transition: top .15s ease-in;
  }
  .skip-link:focus,
  .skip-link:focus-visible {
    top: 0.5rem;
    outline: 2px solid var(--clay, #c47a52);
    outline-offset: 2px;
  }

  /* Focus visible pour l'accessibilité au clavier */
  :focus-visible {
    outline: 2px solid var(--clay, #c47a52);
    outline-offset: 4px;
  }

  .mobile-sticky-cta {
    display: none;
  }

  @media (max-width: 900px) {
    body {
      padding-bottom: calc(4.7rem + env(safe-area-inset-bottom));
    }

    .mobile-sticky-cta {
      position: fixed;
      display: flex;
      align-items: center;
      justify-content: center;
      left: 0.9rem;
      right: 0.9rem;
      max-width: 28rem;
      margin: 0 auto;
      bottom: calc(0.75rem + env(safe-area-inset-bottom));
      z-index: 1000;
      min-height: 2.95rem;
      border-radius: 999px;
      text-decoration: none;
      font-weight: 700;
      letter-spacing: 0.02em;
      color: #fff;
      background: linear-gradient(135deg, var(--clay), #b56f4c);
      box-shadow: 0 14px 32px rgba(0, 0, 0, 0.22);
    }
  }

  @media (max-width: 420px) {
    .mobile-sticky-cta {
      font-size: 0.92rem;
      min-height: 2.85rem;
      left: 0.7rem;
      right: 0.7rem;
    }
  }
</style>