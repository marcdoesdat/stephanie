---
import SEO from '../components/SEO.astro';
import ConsentBanner from '../components/ConsentBanner.astro';
import { loadSiteConfig } from '../config';
import '../styles/global.css';

const config = loadSiteConfig();

interface Props {
  title?: string;
  fullTitle?: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, fullTitle, description, ogImage, noindex } = Astro.props;
---

<!doctype html>
<html lang="fr-CA">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <SEO title={title} fullTitle={fullTitle} description={description} ogImage={ogImage} noindex={noindex} />
    <slot name="head" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;0,700;1,400;1,600&family=DM+Sans:wght@300;400;500;600&display=swap"
      />
    </noscript>

    <script
      is:inline
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="9a2bb5e1-afd5-4d94-a89f-5584d5c44b12"
      data-domains={config.site_url.replace(/^https?:\/\//, '')}
    ></script>

    <!-- Calendly : la feuille de styles est dépourvue de cookies, donc chargée sans consentement.
         Les scripts Google Analytics + Calendly sont chargés conditionnellement par /js/consent.js
         après acceptation explicite (conformité Loi 25). -->
    <link rel="stylesheet" href="https://assets.calendly.com/assets/external/widget.css" />

    <!-- Bannière de consentement Loi 25 : gère le chargement conditionnel de GA + Calendly -->
    <script is:inline defer src="/js/consent.js"></script>

    <!-- Critical CSS : fondations above-the-fold (variables, reset, nav, hero).
         Le chargement asynchrone de la CSS complète est géré par Astro. -->
    <style>
      :root{--sand:#f7f2eb;--warm:#f0e8da;--clay:#c47a52;--clay-dk:#a85f38;--forest:#3d5a4a;--ink:#1f1e1c;--muted:#6a5f50;--border:#e3d9cc;--white:#fdfaf6;--shadow-sm:0 4px 16px rgba(0,0,0,.06);--shadow-clay:0 8px 24px rgba(196,122,82,.4);--radius-sm:12px;--radius-md:20px}
      *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
      [hidden]{display:none!important}
      html{scroll-behavior:smooth}body{font-family:"DM Sans",sans-serif;background:var(--white);color:var(--ink);font-size:16px;line-height:1.65;overflow-x:clip;-webkit-font-smoothing:antialiased}
      @media(prefers-reduced-motion:reduce){html{scroll-behavior:auto}*,*::before,*::after{animation-duration:.01ms!important;animation-iteration-count:1!important;transition:none!important}}
      .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border-width:0}
      .skip-link{position:absolute;top:-40px;left:.5rem;z-index:10000;padding:.6rem 1rem;background:var(--ink);color:#fff;font-weight:600;border-radius:6px;text-decoration:none;transition:top .15s}
      .skip-link:focus,.skip-link:focus-visible{top:.5rem;outline:2px solid var(--clay);outline-offset:2px}
      nav{position:fixed;top:0;left:0;right:0;z-index:200;background:rgba(253,250,246,.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 clamp(1rem,3vw,4rem);display:flex;align-items:center;justify-content:space-between;min-height:68px}
      nav.scrolled{box-shadow:var(--shadow-sm)}
      .nav-logo{font-family:"Lora",serif;font-size:1.15rem;font-weight:600;color:var(--ink);text-decoration:none}
      .nav-logo span,.nav-logo .cabinet-name{color:var(--clay)}
      .nav-links{display:flex;gap:clamp(1rem,1.8vw,2.5rem);list-style:none;align-items:center;flex-wrap:wrap;min-width:0}
      .nav-links a{font-size:clamp(.8rem,.18vw + .7rem,.9rem);font-weight:500;color:var(--muted);text-decoration:none;white-space:nowrap}
      .nav-cta{display:inline-flex!important;align-items:center;justify-content:center;background:var(--clay);color:#fff!important;padding:.62rem clamp(.95rem,1.4vw,1.4rem);border-radius:50px;white-space:nowrap;line-height:1;text-decoration:none}
      .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;background:none;border:none;padding:4px}
      .hamburger span{display:block;width:22px;height:2px;background:var(--ink);border-radius:2px}
      #hero{min-height:100vh;background:var(--sand);display:flex;align-items:center;padding:8rem 4rem 4rem;position:relative;overflow:hidden}
      .hero-inner{max-width:1100px;margin:0 auto;width:100%;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center}
      .hero-badge{display:inline-flex;align-items:center;gap:.5rem;background:#fff;border:1px solid var(--border);padding:.4rem 1rem;border-radius:50px;font-size:.72rem;color:var(--muted);margin-bottom:1.8rem;font-weight:500}
      .hero-left h1{font-family:"Lora",serif;font-size:3.6rem;font-weight:700;line-height:1.12;color:var(--ink);margin-bottom:1.5rem}
      .hero-left h1 em{font-style:italic;color:var(--clay)}
      .hero-left p{font-size:1.05rem;color:var(--muted);line-height:1.8;max-width:480px;margin-bottom:2.5rem}
      .btn-cta{display:inline-flex;align-items:center;justify-content:center;gap:.55rem;background:var(--clay);color:#fff;padding:1.05rem 1.6rem;border-radius:14px;font-weight:700;text-decoration:none;box-shadow:var(--shadow-clay)}
      .btn-secondary{background:transparent;color:var(--ink);padding:.9rem 2rem;border-radius:50px;border:1.5px solid var(--border);font-size:.9rem;font-weight:500;text-decoration:none}
      .hero-right{position:relative} .photo-frame{width:100%;aspect-ratio:4/5;border-radius:30% 70% 70% 30%/30% 30% 70% 70%;overflow:hidden;border:3px solid var(--border)}
      .photo-frame img{width:100%;height:100%;object-fit:cover;object-position:center top}
      .photo-container{will-change:transform}
      .hero-stats{display:flex;gap:2rem;margin-top:3rem;padding-top:2rem;border-top:1px solid var(--border);justify-content:center;text-align:center}
      .stat-num{font-family:"Lora",serif;font-size:2rem;font-weight:700;color:var(--clay);line-height:1}
      .stat-label{font-size:.75rem;color:var(--muted);margin-top:.2rem}
      .card-sm{font-size:.75rem;color:var(--muted)}.card-val{font-family:"Lora",serif;font-size:1.1rem;font-weight:600;color:var(--forest)}
      @media(max-width:1280px){.nav-links{gap:.85rem}.nav-links a{font-size:.74rem}.nav-cta{padding:.5rem 1rem}}
      @media(max-width:1180px){.nav-links{display:none}.hamburger{display:flex}}
      @media(max-width:900px){nav{padding:0 1.5rem}#hero{padding:6rem 1.5rem 3rem;min-height:auto}.hero-inner{grid-template-columns:1fr;gap:2rem}.hero-left h1{font-size:2.6rem}.hero-right{display:none}}
    </style>
  </head>
  <body data-calendly-url={config.calendly_url}>
    <a href="#main-content" class="skip-link">Passer au contenu principal</a>
    <slot />
    <a href={config.calendly_url} data-calendly class="mobile-sticky-cta sticky-hidden" target="_blank" rel="noopener" aria-label="Prendre rendez-vous">
      <span class="sticky-label">Prendre rendez-vous</span>
    </a>
    <ConsentBanner />

    <!-- Sticky scroll-aware + état conversion -->
    <script is:inline>
      (function() {
        const sticky = document.querySelector('.mobile-sticky-cta');
        if (!sticky) return;

        // --- Scroll-aware: hide on scroll down, show on scroll up ---
        let lastY = window.scrollY;
        let ticking = false;
        const SCROLL_THRESHOLD = 8; // px minimum pour déclencher
        const IDLE_DELAY = 3000; // ms sans scroll → réafficher le bouton
        let idleTimer = null;

        function resetIdleTimer() {
          clearTimeout(idleTimer);
          idleTimer = setTimeout(() => {
            sticky.classList.remove('sticky-hidden');
          }, IDLE_DELAY);
        }

        function onScroll() {
          const y = window.scrollY;
          const delta = y - lastY;
          if (Math.abs(delta) < SCROLL_THRESHOLD) return;

          if (delta > 0) {
            // scrolling down → hide
            sticky.classList.add('sticky-hidden');
          } else {
            // scrolling up → show
            sticky.classList.remove('sticky-hidden');
          }
          lastY = y;
        }

        window.addEventListener('scroll', () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              onScroll();
              ticking = false;
            });
            ticking = true;
          }
          resetIdleTimer();
        }, { passive: true });

        // Lance le timer dès le chargement : bouton caché par défaut, apparaît après 3 s sans scroll
        resetIdleTimer();

        // --- État de conversion /outils/ : discret → plein gaz ---
        // Si l'utilisateur a déjà déverrouillé une simulation (localStorage) ou
        // si un composant a marqué body[data-outils-converted], on passe en mode "converti".
        function checkConverted() {
          if (
            document.body.dataset.outilsConverted === 'true' ||
            localStorage.getItem('sim_unlocked') === '1' ||
            localStorage.getItem('calc_email_sent') === '1' ||
            localStorage.getItem('penalite_email_sent') === '1'
          ) {
            sticky.classList.add('sticky-converted');
          }
        }

        // Vérifie au chargement
        checkConverted();

        // Observe les changements d'attribut sur body (quand un composant marque la conversion)
        const observer = new MutationObserver(() => {
          checkConverted();
        });
        observer.observe(document.body, { attributes: true, attributeFilter: ['data-outils-converted'] });

        // Écoute aussi un event custom pour être plus réactif
        window.addEventListener('outils:converted', () => {
          sticky.classList.add('sticky-converted');
        });
      })();
    </script>

    <!-- Tooltips frais de courtage (global) -->
    <script is:inline>
      (function() {
        function initFeeTooltips() {
          document.querySelectorAll('.fee-info-btn').forEach(function(btn) {
            var wrap = btn.closest('.fee-tooltip-wrap');
            if (!wrap) return;
            btn.addEventListener('click', function(e) {
              e.stopPropagation();
              var open = wrap.classList.toggle('is-open');
              btn.setAttribute('aria-expanded', String(open));
            });
          });
          document.addEventListener('click', function() {
            document.querySelectorAll('.fee-tooltip-wrap.is-open').forEach(function(wrap) {
              wrap.classList.remove('is-open');
              var b = wrap.querySelector('.fee-info-btn');
              if (b) b.setAttribute('aria-expanded', 'false');
            });
          });
          document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
              document.querySelectorAll('.fee-tooltip-wrap.is-open').forEach(function(wrap) {
                wrap.classList.remove('is-open');
                var b = wrap.querySelector('.fee-info-btn');
                if (b) b.setAttribute('aria-expanded', 'false');
              });
            }
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initFeeTooltips);
        } else {
          initFeeTooltips();
        }
      })();
    </script>

  </body>
</html>

<style is:global>
  /* --- RÉGLAGES GLOBAUX --- */
  
  html {
    scroll-behavior: smooth;
    /* Empêche le décalage horizontal sur mobile */
    overflow-x: hidden;
  }
  
  body {
    margin: 0;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    /* Couleur de fond par défaut pour éviter le flash blanc en mode sombre */
    background-color: var(--white, #ffffff);
  }

  /* Classe utilitaire pour cacher des éléments visuellement mais les garder pour les lecteurs d'écran */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Lien d'évitement vers le contenu principal — visible au focus clavier */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0.5rem;
    z-index: 10000;
    padding: 0.6rem 1rem;
    background: var(--ink, #1a1a1a);
    color: #fff;
    font-weight: 600;
    border-radius: 6px;
    text-decoration: none;
    transition: top .15s ease-in;
  }
  .skip-link:focus,
  .skip-link:focus-visible {
    top: 0.5rem;
    outline: 2px solid var(--clay, #c47a52);
    outline-offset: 2px;
  }

  /* Focus visible pour l'accessibilité au clavier */
  :focus-visible {
    outline: 2px solid var(--clay, #c47a52);
    outline-offset: 4px;
  }

  .mobile-sticky-cta {
    display: none;
  }

  @media (max-width: 900px) {
    body {
      /* Hauteur de la sticky bar + safe area */
      padding-bottom: calc(3.4rem + env(safe-area-inset-bottom));
    }

    .mobile-sticky-cta {
      position: fixed;
      display: flex;
      align-items: center;
      justify-content: center;
      left: 0;
      right: 0;
      bottom: 0;
      z-index: 1000;
      height: 58px;
      text-decoration: none;
      font-family: "DM Sans", sans-serif;
      font-size: 0.92rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      color: var(--clay);
      background: rgba(253, 250, 246, 0.97);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-top: 1.5px solid var(--border);
      box-shadow: 0 -2px 16px rgba(0, 0, 0, 0.06);
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
                  background 0.3s,
                  color 0.3s,
                  box-shadow 0.3s,
                  border-color 0.3s;
      padding: 0 1rem;
      padding-bottom: env(safe-area-inset-bottom);
      gap: 0.5rem;
    }

    /* Scroll-aware : caché au scroll vers le bas */
    .mobile-sticky-cta.sticky-hidden {
      transform: translateY(calc(100% + env(safe-area-inset-bottom)));
    }

    /* --- État converti (après capture courriel sur /outils/) : plein gaz --- */
    .mobile-sticky-cta.sticky-converted {
      color: #fff;
      background: linear-gradient(135deg, var(--clay), #b56f4c);
      border-top-color: transparent;
      box-shadow: 0 -4px 24px rgba(196, 122, 82, 0.35);
      font-weight: 700;
    }

    /* Effet hover subtil */
    .mobile-sticky-cta:active {
      background: rgba(240, 232, 218, 0.97);
    }
    .mobile-sticky-cta.sticky-converted:active {
      background: linear-gradient(135deg, var(--clay-dk), #9e5f3e);
    }
  }

  @media (max-width: 420px) {
    .mobile-sticky-cta {
      font-size: 0.88rem;
      height: 54px;
    }
    body {
      padding-bottom: calc(3.4rem + env(safe-area-inset-bottom));
    }
  }
</style>