---
export const prerender = true;

import MainLayout from '../layouts/MainLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Simulator from '../components/Simulator.astro';
import TauxSection from '../components/TauxSection.astro';
import Calculator from '../components/Calculator.astro';
import Faq from '../components/Faq.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import MessengerBtn from '../components/MessengerBtn.astro';
import { fetchHypothecaRates } from '../services/ratesService';

const hypothecaRates = await fetchHypothecaRates();
// Use 5-year fixed as the calculator default; fall back to 4.99 if unavailable.
const defaultRate = hypothecaRates?.fixe_5ans ?? 4.99;
const hypothecaVariable = hypothecaRates?.variable ?? 5.99;

// CDN cache: serve cached HTML for 6 h, revalidate in background for 1 h after expiry
Astro.response.headers.set('Cache-Control', 's-maxage=21600, stale-while-revalidate=3600');

---

<MainLayout
  title="Courtière hypothécaire Repentigny | Pré-approbation Québec"
  description="Obtenez une pré-approbation hypothécaire à Repentigny. Accompagnement pour achat, renouvellement, refinancement et travailleurs autonomes partout au Québec."
>
  <MessengerBtn />
  <Nav />
  <main id="main-content">
    <Hero baseRate={hypothecaVariable} />
    <Simulator defaultRate={defaultRate} />
    <Calculator defaultRate={defaultRate} />
    <Services />
    <TauxSection hypothecaRates={hypothecaRates} />
    <About />
    <Testimonials />
    <Faq />
    <Contact />
  </main>
  <Footer />

  <script>
    document.documentElement.classList.add('js-enabled');

    const fadeEls = document.querySelectorAll('.fade-up');
    const obs = new IntersectionObserver(
      (entries) =>
        entries.forEach((x) => {
          if (x.isIntersecting) {
            x.target.classList.add('visible');
            obs.unobserve(x.target);
          }
        }),
      { threshold: 0.12 }
    );
    fadeEls.forEach((el) => obs.observe(el));

    // Fallback: si l'observer ne déclenche pas (p. ex. éléments hors-fold avec layout figé),
    // forcer la visibilité après 1 s.
    window.setTimeout(() => {
      fadeEls.forEach((el) => el.classList.add('visible'));
    }, 1000);
  </script>
</MainLayout>
