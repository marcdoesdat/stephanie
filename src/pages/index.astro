---
export const prerender = false;

import MainLayout from '../layouts/MainLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Simulator from '../components/Simulator.astro';
import TauxSection from '../components/TauxSection.astro';
import Calculator from '../components/Calculator.astro';
import Faq from '../components/Faq.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import MessengerBtn from '../components/MessengerBtn.astro';
import { fetchHypothecaRates } from '../services/ratesService';
import { loadSiteConfig } from '../config';

const hypothecaRates = await fetchHypothecaRates();
const config = loadSiteConfig();
// Use 5-year fixed as the calculator default; fall back to 4.99 if unavailable.
const defaultRate = hypothecaRates?.fixe_5ans ?? 4.99;
const hypothecaVariable = hypothecaRates?.variable ?? 5.99;

// CDN cache: serve cached HTML for 6 h, revalidate in background for 1 h after expiry
Astro.response.headers.set('Cache-Control', 's-maxage=21600, stale-while-revalidate=3600');

---

<MainLayout
  title={config.meta_title}
  description={config.meta_description}
>
  <MessengerBtn />
  <Nav />
  <Hero baseRate={hypothecaVariable} />
  <Services />
  <TauxSection hypothecaRates={hypothecaRates} />
  <Simulator defaultRate={defaultRate} />
  <Calculator defaultRate={defaultRate} />
  <About />
  <Testimonials />
  <Faq />
  <Contact />
  <Footer />

  <script>
    // Enable JS-based fade-up animations
    document.documentElement.classList.add('js-enabled');

    // Fade-up animation observer
    const obs = new IntersectionObserver(
      (entries) =>
        entries.forEach((x) => {
          if (x.isIntersecting) x.target.classList.add('visible');
        }),
      { threshold: 0.12 }
    );
    document.querySelectorAll('.fade-up').forEach((el) => obs.observe(el));
  </script>
</MainLayout>
