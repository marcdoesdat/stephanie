---
import MainLayout from '../layouts/MainLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import Calculator from '../components/Calculator.astro';
import RatesBanner from '../components/RatesBanner.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { fetchHypothecaRates } from '../services/ratesService';

const hypothecaRates = await fetchHypothecaRates();
// Use 5-year fixed as the calculator default; fall back to 4.99 if unavailable.
const defaultRate = hypothecaRates.fixe_5ans ?? 4.99;
const hypothecaVariable = hypothecaRates.variable ?? 5.99;

---

<MainLayout
  title="Stéphanie Weyman — Courtière Hypothécaire · Montréal"
  description="Courtière hypothécaire agréée à Montréal. Je vous accompagne dans l'achat, le renouvellement ou le refinancement de votre hypothèque — sans jargon, sans pression, avec les meilleurs taux parmi plus de 20 prêteurs."
>
  <Nav />
  <Hero baseRate={hypothecaVariable}/>
  <About />
  <Services />
  <Calculator defaultRate={defaultRate} />
  <RatesBanner hypothecaRates={hypothecaRates} />
  <Testimonials />
  <Contact />
  <Footer />

  <script>
    // Enable JS-based fade-up animations
    document.documentElement.classList.add('js-enabled');

    // Fade-up animation observer
    const obs = new IntersectionObserver(
      (entries) =>
        entries.forEach((x) => {
          if (x.isIntersecting) x.target.classList.add('visible');
        }),
      { threshold: 0.12 }
    );
    document.querySelectorAll('.fade-up').forEach((el) => obs.observe(el));
  </script>
</MainLayout>
