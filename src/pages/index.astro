---
import MainLayout from '../layouts/MainLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Services from '../components/Services.astro';
import TauxSection from '../components/TauxSection.astro';
import Faq from '../components/Faq.astro';
import Testimonials from '../components/Testimonials.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import MessengerBtn from '../components/MessengerBtn.astro';
import RappelCTA from '../components/RappelCTA.astro';
import { fetchHypothecaRates } from '../services/ratesService';
import { getReviews } from '../services/reviewsService';
import { loadSiteConfig } from '../config';
import { House, Calculator, Scale, ClipboardList, TrendingUp, Landmark } from '@lucide/astro';

const config = loadSiteConfig();

const hypothecaRates = await fetchHypothecaRates();
const hypothecaVariable = hypothecaRates?.variable ?? null;

const googleReviews = await getReviews();

// CDN cache: serve cached HTML for 6 h, revalidate in background for 1 h after expiry
Astro.response.headers.set('Cache-Control', 's-maxage=21600, stale-while-revalidate=3600');

---

<MainLayout
  fullTitle="Courtière hypothécaire Repentigny – Stéphanie Weyman"
  description="Pré-approbation hypothécaire à Repentigny. Achat, renouvellement, refinancement, travailleurs autonomes. Réponse rapide – Stéphanie Weyman, AMF."
>
  <!-- JSON-LD : AggregateRating (émis seulement si les avis sont live/cache, pas fallback) -->
  {googleReviews.source !== 'fallback' && (
    <Fragment slot="head">
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'FinancialService',
        'name': `${config.nom} — ${config.titre}`,
        'telephone': '+1' + config.telephone.replace(/\D/g, '').replace(/^1/, ''),
        'email': config.courriel,
        'url': config.site_url,
        'areaServed': config.region,
        'aggregateRating': {
          '@type': 'AggregateRating',
          'ratingValue': googleReviews.rating,
          'reviewCount': googleReviews.totalReviews,
          'bestRating': '5',
          'worstRating': '1'
        }
      })} />
    </Fragment>
  )}

  <MessengerBtn />
  <Nav />
  <main id="main-content">
    <Hero baseRate={hypothecaVariable} />

    <section id="outils-teaser">
      <div class="section-inner">
        <div class="fade-up">
          <h2 class="section-title">Préparez votre projet<br />avec mes <em>outils</em></h2>
          <p class="section-sub">
            Six outils clairs pour planifier votre financement : capacité d'emprunt, versement estimé,
            comparaison des taux, pénalité hypothécaire, simulation de refinancement et droits de mutation (taxe de bienvenue).
          </p>
          <p class="outils-trust">Sans inscription · Résultats instantanés</p>
        </div>

        <div class="outils-teaser-grid stagger-children">
          <a href="/outils#simulateur" class="outils-card" aria-label="Simulateur d'emprunt — Estimez votre capacité d'achat">
            <div class="service-icon" aria-hidden="true"><House size={22} stroke-width={1.8} /></div>
            <div class="outils-card-title">Simulateur d'emprunt</div>
            <p>Estimez votre capacité réelle selon vos revenus, dettes, mise de fonds et taux de qualification.</p>
            <span class="outils-card-arrow" aria-hidden="true">Ouvrir l'outil →</span>
          </a>
          <a href="/outils#calculateur" class="outils-card" aria-label="Calculateur de versement — Calculez vos mensualités">
            <div class="service-icon" aria-hidden="true"><Calculator size={22} stroke-width={1.8} /></div>
            <div class="outils-card-title">Calculateur de versement</div>
            <p>Calculez des mensualités précises avec le taux, l'amortissement et les frais qui comptent vraiment.</p>
            <span class="outils-card-arrow" aria-hidden="true">Ouvrir l'outil →</span>
          </a>
          <a href="/outils#comparateur" class="outils-card" aria-label="Comparateur de taux — Comparez les taux affichés en succursale et les taux négociés par un courtier">
            <div class="service-icon" aria-hidden="true"><Scale size={22} stroke-width={1.8} /></div>
            <div class="outils-card-title">Comparateur de taux</div>
            <p>Comparez un taux affiché en succursale et mon taux négocié pour visualiser l'écart potentiel sur 5 ans.</p>
            <span class="outils-card-arrow" aria-hidden="true">Ouvrir l'outil →</span>
          </a>
          <a href="/outils#penalite" class="outils-card" aria-label="Calculateur de pénalité — Estimez vos frais de remboursement anticipé">
            <div class="service-icon" aria-hidden="true"><ClipboardList size={22} stroke-width={1.8} /></div>
            <div class="outils-card-title">Calculateur de pénalité</div>
            <p>Estimez les frais de remboursement anticipé (IRD ou 3 mois d'intérêts) selon votre prêteur et votre contrat.</p>
            <span class="outils-card-arrow" aria-hidden="true">Ouvrir l'outil →</span>
          </a>
          <a href="/outils#refinancement" class="outils-card" aria-label="Simulateur de refinancement — Évaluez l'impact d'un refinancement">
            <div class="service-icon" aria-hidden="true"><TrendingUp size={22} stroke-width={1.8} /></div>
            <div class="outils-card-title">Simulateur de refinancement</div>
            <p>Évaluez l'impact d'un refinancement : liquidités dégagées, nouveau versement et comparaison avec votre situation actuelle.</p>
            <span class="outils-card-arrow" aria-hidden="true">Ouvrir l'outil →</span>
          </a>
          <a href="/outils#droits-mutation" class="outils-card" aria-label="Calculateur de droits de mutation — Estimez votre taxe de bienvenue">
            <div class="service-icon" aria-hidden="true"><Landmark size={22} stroke-width={1.8} /></div>
            <div class="outils-card-title">Droits de mutation</div>
            <p>Estimez la taxe de bienvenue applicable à votre propriété selon le prix d'achat, tranche par tranche.</p>
            <span class="outils-card-arrow" aria-hidden="true">Ouvrir l'outil →</span>
          </a>
        </div>
      </div>
    </section>

    <Services />

    <section id="rappel-renouvellement" aria-label="Demande de rappel pour renouvellement">
      <div class="section-inner">
        <div class="fade-up">
          <RappelCTA
            titre="Ton renouvellement est encore loin ? Tant mieux."
            texte="C'est justement quand on n'y pense pas que les banques en profitent : le papier de renouvellement arrive par la poste, on signe sans magasiner, pis on paie plus cher pendant des années. Laisse-moi tes coordonnées une seule fois. Je te recontacte 4 à 6 mois avant ton échéance — le moment idéal pour magasiner. D'ici là, t'as rien à faire."
            cta="Être rappelé·e au bon moment"
          />
        </div>
      </div>
    </section>

    <TauxSection hypothecaRates={hypothecaRates} />
    <About />
    <Testimonials reviews={googleReviews} />
    <Faq />
    <Contact />
  </main>
  <Footer />

  <style>
    /* Tuiles cliquables — style cohérent avec les cartes Services */
    .outils-trust {
      margin: 0.25rem 0 0;
      font-size: 0.78rem;
      color: var(--clay, #c47a52);
      font-weight: 500;
    }
    #outils-teaser .outils-card {
      display: flex;
      flex-direction: column;
      text-decoration: none;
      color: inherit;
      border-radius: 20px;
      padding: 1.8rem 1.6rem;
      box-shadow: 0 2px 12px rgba(0,0,0,.04);
      transition: transform 0.25s, box-shadow 0.25s;
    }
    #outils-teaser .outils-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 36px rgba(0,0,0,.10);
    }
    #outils-teaser .outils-card-title {
      font-size: 1.1rem;
      font-weight: 600;
    }
    #outils-teaser .outils-card p {
      font-size: 0.85rem;
      flex: 1;
    }
    #outils-teaser .outils-card-arrow {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      margin-top: 0.75rem;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--clay, #c47a52);
      transition: transform 0.2s;
    }
    #outils-teaser .outils-card:hover .outils-card-arrow {
      transform: translateX(4px);
    }
    #outils-teaser .outils-card--coming-soon {
      border-style: dashed;
    }
  </style>

  <script>
    document.documentElement.classList.add('js-enabled');

    const animClasses = ['.fade-up', '.fade-left', '.fade-right', '.scale-in', '.stagger-children'];
    const animEls = document.querySelectorAll(animClasses.join(','));
    const obs = new IntersectionObserver(
      (entries) =>
        entries.forEach((x) => {
          if (x.isIntersecting) {
            x.target.classList.add('visible');
            obs.unobserve(x.target);
          }
        }),
      { threshold: 0.12 }
    );
    animEls.forEach((el) => obs.observe(el));

    // Fallback: si l'observer ne déclenche pas (p. ex. éléments hors-fold avec layout figé),
    // forcer la visibilité après 1.2 s.
    window.setTimeout(() => {
      animEls.forEach((el) => el.classList.add('visible'));
    }, 1200);
  </script>
</MainLayout>
