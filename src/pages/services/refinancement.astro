---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import MessengerBtn from '../../components/MessengerBtn.astro';
import Contact from '../../components/Contact.astro';
import { Image } from 'astro:assets';
import stephaniePhoto from '../../assets/stephanie.webp';
import { loadSiteConfig } from '../../config';

const config = loadSiteConfig();
const prenom = config.nom.split(' ')[0];

Astro.response.headers.set('Cache-Control', 's-maxage=21600, stale-while-revalidate=3600');
---

<MainLayout
  title="Refinancement hypothécaire au Québec | Débloquez l'équité de votre maison"
  description="Votre maison vaut probablement plus que vous pensez. Découvrez en 60 secondes combien d'équité vous pouvez débloquer pour consolider vos dettes, rénover ou acheter une 2e propriété — analyse gratuite avec une courtière hypothécaire au Québec."
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Comment le refinancement peut-il m'aider à consolider mes dettes au Québec ?",
          "acceptedAnswer": { "@type": "Answer", "text": "30 000 $ de cartes et de marges à 19,99 % coûtent environ 500 $ d'intérêts par mois. Intégrés à votre hypothèque vers 5 %, c'est plutôt 125 $ d'intérêts — près de 4 500 $ par année qui restent dans votre compte au lieu de partir aux émetteurs de cartes." }
        },
        {
          "@type": "Question",
          "name": "Puis-je utiliser mon équité hypothécaire pour financer des rénovations ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Oui. Une cuisine refaite, un sous-sol fini, une thermopompe : ces rénovations stratégiques augmentent la valeur de revente de votre propriété. Vous financez à taux hypothécaire ce qui autrement finirait sur une marge à 9 % ou plus." }
        },
        {
          "@type": "Question",
          "name": "Comment acheter un immeuble locatif en utilisant l'équité de ma résidence principale ?",
          "acceptedAnswer": { "@type": "Answer", "text": "La mise de fonds minimale pour un immeuble à revenus est de 20 %. Refinancer votre résidence principale peut générer cette mise de fonds sans toucher à vos liquidités — le levier le plus discret pour bâtir un patrimoine immobilier." }
        }
      ]
    })} />
  </Fragment>
  <MessengerBtn />
  <Nav />

  <main id="main-content">

    <!-- ============ HERO ============ -->
    <section class="sp-hero">
      <div class="sp-inner">
        <div class="sp-hero-grid">
          <div class="sp-hero-text">
            <a href="/#services" class="sp-breadcrumb">← Tous les services</a>

            <h1 class="sp-h1">
              Votre maison vaut une fortune.<br />Et si vous arrêtiez <em>de la regarder dormir</em> ?
            </h1>

            <h2 class="sp-h2">
              Une simple réévaluation peut financer vos rénovations,
              effacer le stress des dettes à 20 % d'intérêt, ou devenir la mise de fonds
              de votre prochaine propriété — sans vendre une seule brique.
            </h2>

            <div class="sp-hero-ctas">
              <a href="/?parcours=refinancement#contact" class="btn-cta sp-cta-primary" data-track="sp_refinancement_hero_cta">
                <span>Évaluer mon équité gratuitement</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <a href="/outils#simulateur" class="btn-secondary sp-cta-secondary">Estimer mes économies</a>
            </div>

            <ul class="sp-hero-proof">
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Frais de courtage&nbsp;: 0&nbsp;$<span class="fee-tooltip-wrap"><button class="fee-info-btn" aria-label="En savoir plus sur les frais de courtage" aria-expanded="false" type="button">i</button><span class="fee-tooltip" role="tooltip">Frais de courtage à 0&nbsp;$ pour la vaste majorité des dossiers. Certains financements alternatifs ou privés peuvent comporter des frais, dont je vous informe avant toute démarche.</span></span>, sans engagement
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Analyse rapide
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Pénalités calculées avant tout
              </li>
            </ul>
          </div>

          <aside class="sp-hero-trust" aria-label="Votre courtière">
            <Image
              src={stephaniePhoto}
              alt={`${prenom} ${config.nom.split(' ').slice(1).join(' ')}, courtière hypothécaire`}
              width={140}
              height={140}
              loading="eager"
              decoding="async"
              class="sp-trust-photo"
            />
            <div class="sp-trust-name">{prenom} Weyman</div>
            <div class="sp-trust-role">Courtière hypothécaire · Hypotheca</div>
            <p class="sp-trust-quote">
              « Refinancer, c'est une décision de chiffres — pas d'émotion.
              Mon job : vous montrer les vrais chiffres, avant de bouger quoi que ce soit. »
            </p>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============ EMPATHIE / OPPORTUNITÉ ============ -->
    <section class="sp-empathy">
      <div class="sp-inner">
        <h2 class="sp-section-title">Vous payez 20 % d'intérêt sur vos cartes…<br /><em>pendant que votre maison prend de la valeur.</em></h2>
        <p class="sp-empathy-text">
          Au Québec, la valeur médiane des propriétés a bondi de plus de 40 % depuis 2020.
          Vous avez peut-être 100 000 $, 200 000 $, parfois plus, en équité dormante dans vos murs —
          un actif qui travaille pour la banque, pas pour vous.
        </p>
        <p class="sp-empathy-text">
          Pendant ce temps, vous repoussez la cuisine, vous payez le minimum sur les cartes,
          ou vous regardez passer le plex à vendre dans le quartier. <strong>Le problème n'est pas que vous n'avez pas l'argent.
          C'est qu'il est verrouillé au mauvais endroit.</strong>
        </p>
      </div>
    </section>

    <!-- ============ ÉDUCATION EXPRESS — LES 3 LEVIERS ============ -->
    <section class="sp-education">
      <div class="sp-inner">
        <h2 class="sp-section-title">Trois façons concrètes de faire travailler <em>l'argent qui dort dans vos murs</em>.</h2>

        <div class="sp-steps">
          <article class="sp-step">
            <div class="sp-step-num" aria-hidden="true">1</div>
            <h3 class="sp-step-title">Consolidation de dettes : réduire votre coût mensuel d'intérêts</h3>
            <p class="sp-step-text">
              30 000 $ de cartes et de marges à 19,99 %, c'est environ 500 $ d'intérêts par mois.
              Intégrés à votre hypothèque vers 5 %, c'est plutôt 125 $ — soit près de 4 500 $ par année
              qui restent dans votre compte. Il faut cependant avoir suffisamment d'équité dans votre
              propriété (le refinancement est limité à 80 % de sa valeur), et tenir compte d'une
              éventuelle pénalité de bris de terme. Ce n'est pas la bonne solution pour tout le monde —
              mais quand les conditions sont réunies, l'impact est immédiat.
            </p>
          </article>

          <article class="sp-step">
            <div class="sp-step-num" aria-hidden="true">2</div>
            <h3 class="sp-step-title">Rénovations : financer vos travaux au taux hypothécaire</h3>
            <p class="sp-step-text">
              Une cuisine refaite, un sous-sol fini, une thermopompe : certaines rénovations
              stratégiques augmentent la valeur de votre propriété. Plutôt que de les financer sur
              une marge à 9 % ou plus, il est possible de les intégrer à votre hypothèque au moment
              de l'achat ou d'un refinancement — à taux hypothécaire, amorti sur 25 à 30 ans.
              Des conditions s'appliquent : montants admissibles limités selon le prêteur, débours
              en étapes avec inspection, et non disponible pour les locatifs et les chalets.
              Je vous indique dès le départ ce qui est faisable dans votre situation.
            </p>
          </article>

          <article class="sp-step">
            <div class="sp-step-num" aria-hidden="true">3</div>
            <h3 class="sp-step-title">Achat locatif ou chalet : votre équité comme mise de fonds</h3>
            <p class="sp-step-text">
              Pour un immeuble locatif pur, la mise de fonds minimale est de 20 %. Pour un chalet,
              elle est de 20 % en financement conventionnel — mais peut descendre à 5 % si la
              propriété est admissible au financement assuré. Dans tous les cas, refinancer votre
              résidence principale peut générer cette mise de fonds sans puiser dans vos liquidités :
              c'est l'un des leviers les plus efficaces pour bâtir un patrimoine immobilier sans
              immobiliser votre épargne.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- ============ AUTORITÉ — L'APPROCHE ============ -->
    <section class="sp-approach">
      <div class="sp-inner">
        <div class="sp-approach-grid">
          <div class="sp-approach-text">
            <h2 class="sp-section-title sp-section-title--light">Avant de signer quoi que ce soit, on calcule <em>si c'est vraiment payant</em>.</h2>
            <p class="sp-approach-para">
              Refinancer en plein milieu d'un terme déclenche une pénalité — parfois 3 mois d'intérêts,
              parfois beaucoup plus selon la formule de votre prêteur. Mon premier travail&nbsp;:
              calculer cette pénalité et la mettre dans la balance avec l'économie projetée.
              Si les chiffres ne sont pas franchement à votre avantage, je vous le dis — et on attend le bon moment.
            </p>
            <p class="sp-approach-para">
              Mon service est <strong>sans frais de courtage (0&nbsp;$)</strong><span class="fee-tooltip-wrap"><button class="fee-info-btn" aria-label="En savoir plus sur les frais de courtage" aria-expanded="false" type="button">i</button><span class="fee-tooltip" role="tooltip">Frais de courtage à 0&nbsp;$ pour la vaste majorité des dossiers. Certains financements alternatifs ou privés peuvent comporter des frais, dont je vous informe avant toute démarche.</span></span>&nbsp;: ce sont les prêteurs qui me rémunèrent
              quand votre dossier se finalise. Pas de frais cachés, pas de pression, pas de discours commercial.
              Juste les chiffres, expliqués clairement.
            </p>
          </div>

          <ul class="sp-approach-list" aria-label="Ce que vous obtenez">
            <li>
              <span class="sp-check" aria-hidden="true">✓</span>
              <div>
                <strong>Calcul des pénalités d'avance</strong>
                <span>On chiffre le coût réel avant toute décision.</span>
              </div>
            </li>
            <li>
              <span class="sp-check" aria-hidden="true">✓</span>
              <div>
                <strong>Comparaison de 20+ prêteurs</strong>
                <span>Banques, caisses, prêteurs alternatifs.</span>
              </div>
            </li>
            <li>
              <span class="sp-check" aria-hidden="true">✓</span>
              <div>
                <strong>Frais de courtage&nbsp;: 0&nbsp;$</strong><span class="fee-tooltip-wrap"><button class="fee-info-btn" aria-label="En savoir plus sur les frais de courtage" aria-expanded="false" type="button">i</button><span class="fee-tooltip" role="tooltip">Frais de courtage à 0&nbsp;$ pour la vaste majorité des dossiers. Certains financements alternatifs ou privés peuvent comporter des frais, dont je vous informe avant toute démarche.</span></span>
                <span>Aucun frais à vous, ni avant, ni après.</span>
              </div>
            </li>
            <li>
              <span class="sp-check" aria-hidden="true">✓</span>
              <div>
                <strong>Réponse claire, rapidement</strong>
                <span>Une analyse chiffrée, pas un argumentaire.</span>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ============ LEAD MAGNET / CTA FINAL ============ -->
    <section class="sp-magnet">
      <div class="sp-inner">
        <div class="sp-magnet-card">
          <h2 class="sp-magnet-title">
            Découvrez combien vous pouvez débloquer.
          </h2>
          <p class="sp-magnet-sub">
            Quatre questions simples — valeur estimée, solde hypothécaire actuel, prêteur, objectif —
            et je vous reviens rapidement avec votre <strong>équité disponible chiffrée</strong>,
            le calcul de la pénalité éventuelle, et un scénario adapté à votre objectif.
            <strong>Aucun engagement, aucun pointage de crédit.</strong>
          </p>

          <ul class="sp-magnet-proof">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Aucun pointage de crédit
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Réponse rapide
            </li>
          </ul>
        </div>
      </div>
    </section>

  </main>

  <Contact />
  <Footer />
</MainLayout>

<script>
  document.querySelectorAll<HTMLAnchorElement>('[data-track]').forEach((el) => {
    el.addEventListener('click', () => {
      const name = el.dataset.track;
      if (!name) return;
      // @ts-ignore
      if (typeof window.umami?.track === 'function') window.umami.track(name);
      // @ts-ignore
      if (typeof window.gtag === 'function') window.gtag('event', name);
    });
  });
</script>
