---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import MessengerBtn from '../../components/MessengerBtn.astro';
import Contact from '../../components/Contact.astro';
import { Image } from 'astro:assets';
import stephaniePhoto from '../../assets/stephanie.webp';
import { loadSiteConfig } from '../../config';

const config = loadSiteConfig();
const prenom = config.nom.split(' ')[0];

Astro.response.headers.set('Cache-Control', 's-maxage=21600, stale-while-revalidate=3600');
---

<MainLayout
  title="Hypothèque pour travailleur autonome au Québec | Stéphanie Weyman"
  description="Travailleur autonome, incorporé ou à commissions ? Vos revenus sont solides — ils ne rentrent juste pas dans la case standard des banques. Je sais comment présenter votre dossier pour obtenir le oui qu'il mérite. Évaluation gratuite."
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Comment un travailleur autonome peut-il obtenir une hypothèque au Québec ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Chaque prêteurca lcule vos revenus différemment. Certaines banques exigent 2 ans d'avis de cotisation. D'autres acceptent un seul avis ou des programmes stated income qui valorisent vos dépôts bancaires. Une cortière identifie le prêteurdo nt la formule vous rend justice." }
        },
        {
          "@type": "Question",
          "name": "Mon revenu net déclaré est faible — puis-je quand même obtenir un bon financement hypothécaire ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Plusieurs dépenses déductibles (amortissement, kilométrage, bureau à domicile) peuvent être réajoutées au revenu admissible pour le calcul hypothécaire. Sur un revenu net de 65 000 $, on peut souvent justifier 80 000 $ ou plus, ce qui peut représenter 60 000 $ à 100 000 $ de plus en capacité d'achat." }
        },
        {
          "@type": "Question",
          "name": "Je suis incorporé : comment maximiser ma capacité d'emprunt hypothécaire ?",
          "acceptedAnswer": { "@type": "Answer", "text": "Avec les bons états financiers de votre société, il est possible de faire reconnaître vos dividendes et les bénéfices retenus par les prêteursa cceptant cette structure — au lieu d'être limité à votre petit salaire." }
        }
      ]
    })} />
  </Fragment>
  <MessengerBtn />
  <Nav />

  <main id="main-content">

    <!-- ============ HERO ============ -->
    <section class="sp-hero">
      <div class="sp-inner">
        <div class="sp-hero-grid">
          <div class="sp-hero-text">
            <a href="/#services" class="sp-breadcrumb">← Tous les services</a>

            <h1 class="sp-h1">
              Vous gagnez bien votre vie.<br />Faites en sorte que <em>votre banque le voie aussi.</em>
            </h1>

            <h2 class="sp-h2">
              Travailleur autonome, incorporé, à commissions ou à contrats —
              vos revenus sont solides. Ils ne rentrent juste pas dans la case standard des banques.
              Ma job&nbsp;: présenter votre dossier de la bonne façon, au bon prêteur.
            </h2>

            <div class="sp-hero-ctas">
              <a href="/?parcours=travailleur-autonome#contact" class="btn-cta sp-cta-primary" data-track="sp_ta_hero_cta">
                <span>Évaluer mon dossier gratuitement</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <a href="#approche" class="btn-secondary sp-cta-secondary">Voir comment je travaille</a>
            </div>

            <ul class="sp-hero-proof">
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                0&nbsp;$ sans frais de courtage<span class="fee-tooltip-wrap"><button class="fee-info-btn" aria-label="En savoir plus sur les frais de courtage" aria-expanded="false" type="button">i</button><span class="fee-tooltip" role="tooltip">Frais de courtage à 0&nbsp;$ pour la vaste majorité des dossiers. Certains financements alternatifs ou privés peuvent comporter des frais, dont je vous informe avant toute démarche.</span></span>, sans engagement
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                20+ prêteurs comparés
              </li>
              <li>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                Spécialisée travailleurs autonomes
              </li>
            </ul>
          </div>

          <aside class="sp-hero-trust" aria-label="Votre courtière">
            <Image
              src={stephaniePhoto}
              alt={`${prenom} ${config.nom.split(' ').slice(1).join(' ')}, courtière hypothécaire`}
              width={140}
              height={140}
              loading="eager"
              decoding="async"
              class="sp-trust-photo"
            />
            <div class="sp-trust-name">{prenom} Weyman</div>
            <div class="sp-trust-role">Courtière hypothécaire · Hypotheca</div>
            <p class="sp-trust-quote">
              « Vos revenus nets, c'est la version banque de votre histoire.
              Mon rôle, c'est d'écrire la version complète. »
            </p>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============ EMPATHIE ============ -->
    <section class="sp-empathy">
      <div class="sp-inner">
        <h2 class="sp-section-title">Vous êtes pénalisé·e <em>pour avoir bien optimisé vos impôts</em>.</h2>
        <p class="sp-empathy-text">
          Vous facturez 150 000 $ par année, mais vos avis de cotisation montrent 65 000 $ après dépenses.
          Votre comptable a fait son travail — sauf que la banque, elle, ne regarde que la dernière ligne.
          Résultat&nbsp;: une capacité d'achat ridiculement basse, ou pire, un refus net.
        </p>
        <p class="sp-empathy-text">
          Et c'est encore plus fragile si vous êtes incorporé, à commissions, à pourboires,
          ou si vous venez de finir votre première année à votre compte.
          <strong>Le problème n'est pas votre revenu. C'est la façon dont il est lu.</strong>
        </p>
      </div>
    </section>

    <!-- ============ ÉDUCATION EXPRESS ============ -->
    <section class="sp-education" id="approche">
      <div class="sp-inner">
        <h2 class="sp-section-title">Ce qu'on regarde ensemble pour <em>faire parler vos vrais revenus</em>.</h2>

        <div class="sp-steps">
          <article class="sp-step">
            <div class="sp-step-num" aria-hidden="true">1</div>
            <h3 class="sp-step-title">Chaque prêteur calcule le revenu différemment</h3>
            <p class="sp-step-text">
              La majorité exigent 2 ans de déclarations fiscales. Certains acceptent un seul avis de cotisation
              en conventionnel sans majoration. Quelques prêteurs alternatifs offrent des programmes basés
              sur la capacité de remboursement démontrée, mais jamais sans aucune documentation.
            </p>
            <p class="sp-step-note">
              <strong>À noter :</strong> Les programmes sans déclarations fiscales sont rares, réservés
              aux profils B et comportent des conditions strictes (crédit, mise de fonds, etc.).
            </p>
          </article>

          <article class="sp-step">
            <div class="sp-step-num" aria-hidden="true">2</div>
            <h3 class="sp-step-title">Certaines dépenses peuvent être réintégrées au revenu</h3>
            <p class="sp-step-text">
              Pour les travailleurs autonomes <strong>non incorporés</strong>, les dépenses admissibles
              (amortissement, kilométrage, bureau à domicile) peuvent être rajoutées au revenu net.
              Plusieurs prêteurs permettent aussi une majoration forfaitaire de 15 %.
            </p>
            <p class="sp-step-note">
              <strong>À noter :</strong> Cette majoration ne s'applique pas aux entreprises incorporées.
              Le gain réel varie selon les dépenses déclarées — l'exemple « +15 000 $ » n'est pas garanti.
            </p>
          </article>

          <article class="sp-step">
            <div class="sp-step-num" aria-hidden="true">3</div>
            <h3 class="sp-step-title">Si incorporé : salaire + dividendes peuvent être combinés</h3>
            <p class="sp-step-text">
              Plusieurs prêteurs acceptent d'additionner le salaire (T4) et les dividendes (T5)
              pour calculer le revenu admissible. Certains permettent une majoration de 15 % sur les
              dividendes si l'année la plus récente est la plus élevée.
            </p>
            <p class="sp-step-note">
              <strong>À noter :</strong> Les bénéfices non répartis (BNR) ne sont généralement
              <em>pas</em> admissibles comme revenu chez les prêteurs A. Des états financiers complets
              des 2 dernières années sont requis.
            </p>
          </article>
        </div>
      </div>
    </section>

    <!-- ============ AUTORITÉ ============ -->
    <section class="sp-approach">
      <div class="sp-inner">
        <div class="sp-approach-grid">
          <div class="sp-approach-text">
            <h2 class="sp-section-title sp-section-title--light">Je parle <em>autonome</em>. Je parle <em>incorporé</em>. Et je parle banque.</h2>
            <p class="sp-approach-para">
              Avant de soumettre quoi que ce soit, je prends le temps de comprendre comment vous structurez vos revenus
              et je bâtis un dossier qui les met en valeur&nbsp;: avis de cotisation, états financiers,
              T1 Generals, contrats récurrents, dépôts bancaires des 12 derniers mois.
              Présenté correctement, votre dossier devient <strong>impossible à refuser pour la mauvaise raison</strong>.
            </p>
            <p class="sp-approach-para">
              Mon service est <strong>0&nbsp;$ sans frais de courtage</strong><span class="fee-tooltip-wrap"><button class="fee-info-btn" aria-label="En savoir plus sur les frais de courtage" aria-expanded="false" type="button">i</button><span class="fee-tooltip" role="tooltip">Frais de courtage à 0&nbsp;$ pour la vaste majorité des dossiers. Certains financements alternatifs ou privés peuvent comporter des frais, dont je vous informe avant toute démarche.</span></span>&nbsp;: ce sont les prêteurs qui me rémunèrent
              quand votre dossier se finalise. Pas de frais cachés. Pas de discours commercial.
              Si votre dossier n'est pas prêt cette année, je vous le dis — et je vous donne le plan pour qu'il le soit l'an prochain.
            </p>
          </div>

          <ul class="sp-approach-list" aria-label="Ce que vous obtenez">
            <li>
              <span class="sp-check" aria-hidden="true">✓</span>
              <div>
                <strong>Lecture experte des états financiers</strong>
                <span>Avis de cotisation, T1, T2, dépôts.</span>
              </div>
            </li>
            <li>
              <span class="sp-check" aria-hidden="true">✓</span>
              <div>
                <strong>Accès aux 20+ prêteurs</strong>
                <span>Incluant ceux qui acceptent le « stated income ».</span>
              </div>
            </li>
            <li>
              <span class="sp-check" aria-hidden="true">✓</span>
              <div>
                <strong>Stratégie incorporée</strong>
                <span>Salaire + dividendes + bénéfices retenus.</span>
              </div>
            </li>
            <li>
              <span class="sp-check" aria-hidden="true">✓</span>
              <div>
                <strong>Réponse claire, rapidement</strong>
                <span>Avec une fourchette d'achat réaliste.</span>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- ============ LEAD MAGNET / CTA FINAL ============ -->
    <section class="sp-magnet">
      <div class="sp-inner">
        <div class="sp-magnet-card">
          <h2 class="sp-magnet-title">
            Découvrez votre <em>vraie</em> capacité d'achat<br />— celle que les banques refusent de voir.
          </h2>
          <p class="sp-magnet-sub">
            Quelques questions simples — type de revenus (autonome, incorporé, commissions),
            ancienneté à votre compte, fourchette de revenus bruts, projet visé.
            Je vous reviens <strong>rapidement</strong> avec une fourchette d'achat réaliste,
            la liste des documents à préparer, et les prêteurs qui valoriseront votre dossier.
            <strong>Aucun engagement, aucun pointage de crédit.</strong>
          </p>

          <ul class="sp-magnet-proof">
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Aucun pointage de crédit
            </li>
            <li>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              Réponse rapide
            </li>
          </ul>
        </div>
      </div>
    </section>

  </main>

  <Contact />
  <Footer />
</MainLayout>

<script>
  document.querySelectorAll<HTMLAnchorElement>('[data-track]').forEach((el) => {
    el.addEventListener('click', () => {
      const name = el.dataset.track;
      if (!name) return;
      // @ts-ignore
      if (typeof window.umami?.track === 'function') window.umami.track(name);
      // @ts-ignore
      if (typeof window.gtag === 'function') window.gtag('event', name);
    });
  });
</script>
