---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Contact from '../../components/Contact.astro';
import MessengerBtn from '../../components/MessengerBtn.astro';
import { Image } from 'astro:assets';
import stephaniePhoto from '../../assets/stephanie.webp';
import { loadSiteConfig } from '../../config';

const config = loadSiteConfig();
const prenom = config.nom.split(' ')[0];
const telHref = `tel:${config.telephone.replace(/[^\d+]/g, '')}`;

const PAGE_URL = `${config.site_url}/villes/courtier-hypothecaire-repentigny`;
const STEPHANIE_IMAGE = `${config.site_url}/_astro/stephanie.Cm30Blgc.jpg`;

// Témoignages — placeholders éditables. Garder en haut du fichier pour faciliter l'édition.
const testimonials = [
  {
    citation: "Stéphanie a pris le temps de tout nous expliquer pour notre première maison à Repentigny. On a eu une réponse rapide et un taux qu'on n'aurait jamais obtenu seuls à la banque.",
    prenom: "Marie-Claude",
    nomInitiale: "L.",
    transaction: "Premier achat",
    ville: "Repentigny"
  },
  {
    citation: "Renouvellement géré de A à Z. J'ai économisé sur mes versements mensuels et tout s'est fait par courriel et téléphone, sans déplacement. Service impeccable.",
    prenom: "Jean-François",
    nomInitiale: "B.",
    transaction: "Renouvellement",
    ville: "Le Gardeur"
  },
  {
    citation: "Comme travailleuse autonome, ma banque m'avait dit non. Stéphanie a trouvé un prêteur qui comprend les revenus variables. Sans elle, je ne serais probablement pas propriétaire aujourd'hui.",
    prenom: "Audrey",
    nomInitiale: "P.",
    transaction: "Travailleuse autonome",
    ville: "Charlemagne"
  }
];

const faq = [
  {
    q: "Combien coûte un courtier hypothécaire à Repentigny ?",
    a: `Le service de courtage hypothécaire est <strong>entièrement gratuit pour vous</strong>. Je suis rémunérée par le prêteur qui finance votre dossier, au moment du déboursé. Aucun frais caché, aucune facture, aucun engagement tant qu'on n'a pas trouvé une solution qui vous convient.`
  },
  {
    q: "Quelle mise de fonds minimum pour acheter à Repentigny ?",
    a: `Au Canada, la mise de fonds minimale est de <strong>5 %</strong> sur la première tranche de 500 000 $, puis <strong>10 %</strong> entre 500 000 $ et 1,5 M$. Sous 20 % de mise de fonds, une prime d'assurance SCHL s'ajoute au prêt. Certaines conditions s'appliquent selon votre dossier — on regarde ensemble ce qui est réaliste pour vous.`
  },
  {
    q: "Quel est le prix médian d'une maison à Repentigny ?",
    a: `Les prix varient beaucoup selon le quartier (Le Gardeur, vieux Repentigny, Repentigny-Centre) et le type de propriété. Plutôt que de citer un chiffre qui se périme rapidement, je vous propose une consultation gratuite où on analyse votre capacité d'emprunt en fonction du marché actuel et de votre situation personnelle.`
  },
  {
    q: "Comment fonctionne le stress test fédéral au Québec ?",
    a: `Le test de résistance (stress test) fédéral oblige les prêteurs à qualifier votre dossier au <strong>plus élevé</strong> entre votre taux contractuel + 2 % et 5,25 %. C'est ce taux fictif qui sert à calculer votre capacité d'emprunt — pas celui que vous allez réellement payer. L'objectif : s'assurer que vous pouvez absorber une hausse éventuelle de taux.`
  },
  {
    q: "Combien de temps pour obtenir une pré-approbation ?",
    a: `Pour un dossier complet (documents fournis), je vise une <strong>réponse dans les meilleurs délais</strong>. Une pré-approbation est valide jusqu'à 120 jours, ce qui vous laisse le temps de magasiner sereinement. Je vous recontacte dès que possible après votre demande.`
  },
  {
    q: "Puis-je obtenir une hypothèque comme travailleur autonome à Repentigny ?",
    a: `Absolument. Les travailleurs autonomes et travailleuses autonomes représentent une grande partie de ma clientèle. J'ai accès à des prêteurs qui acceptent les revenus de travail autonome documentés par les <strong>avis de cotisation</strong> des deux dernières années — ou des solutions alternatives quand le dossier est plus complexe. Certaines conditions s'appliquent.`
  },
  {
    q: "Quelle est la différence entre courtier et conseiller bancaire ?",
    a: `Un conseiller bancaire vous propose <strong>les produits de sa propre banque</strong>. Comme courtière indépendante, j'ai accès à plus de 20 prêteurs (banques, caisses, prêteurs alternatifs) et je négocie pour vous, pas pour eux. Mon rôle est de défendre votre intérêt, pas de vendre un produit maison.`
  },
  {
    q: "Que se passe-t-il si ma banque a refusé ma demande ?",
    a: `Un refus de banque n'est pas un refus du marché. Chaque prêteur a ses propres critères, et ce qui ne passe pas chez l'un peut très bien passer ailleurs — notamment chez les prêteurs alternatifs. On reprend votre dossier, on identifie ce qui a bloqué, et on cherche la voie qui fonctionne pour votre profil.`
  }
];

// === Schemas JSON-LD ===
const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "FinancialService",
  "name": "Stéphanie Weyman - Courtière hypothécaire",
  "image": STEPHANIE_IMAGE,
  "url": PAGE_URL,
  "telephone": "+15149497627",
  "email": "sweyman@hypotheca.ca",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "3344 Fleury Est",
    "addressLocality": "Montréal",
    "addressRegion": "QC",
    "postalCode": "H1H 2R5",
    "addressCountry": "CA"
  },
  "areaServed": [
    { "@type": "City", "name": "Repentigny" },
    { "@type": "City", "name": "Le Gardeur" },
    { "@type": "City", "name": "Charlemagne" },
    { "@type": "City", "name": "L'Assomption" }
  ],
  "priceRange": "Free"
};

const schemaPerson = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Stéphanie Weyman",
  "jobTitle": "Courtière hypothécaire",
  "worksFor": { "@type": "Organization", "name": "Hypotheca" },
  "image": STEPHANIE_IMAGE,
  "url": config.site_url,
  "identifier": `AMF ${config.amf}`
};

// Le FAQPage est généré à partir du tableau `faq` ci-dessus.
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      // On retire le HTML pour la version texte du schema.
      "text": item.a.replace(/<[^>]+>/g, '')
    }
  }))
};

// Cache CDN — page éditoriale, change rarement.
Astro.response.headers.set('Cache-Control', 's-maxage=21600, stale-while-revalidate=3600');
---

<MainLayout
  fullTitle="Courtière hypothécaire à Repentigny – Stéphanie Weyman"
  description="Courtière hypothécaire à Repentigny. Pré-approbation, achat, renouvellement, refinancement. Accès à 20+ prêteurs. Service gratuit. Réponse rapide."
>
  <Fragment slot="head">
    <link rel="canonical" href={PAGE_URL} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(schemaPerson)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} is:inline />
  </Fragment>

  <MessengerBtn />
  <Nav />

  <main id="main-content">

    <!-- ============ SECTION 1 — HÉRO ============ -->
    <section class="rep-hero">
      <div class="rep-inner">
        <div class="rep-hero-grid">
          <div class="rep-hero-text">
            <div class="rep-eyebrow">Repentigny · Lanaudière</div>
            <h1 class="rep-h1">Courtière hypothécaire à Repentigny</h1>
            <p class="rep-subtitle">
              Pré-approbation rapide. Accès à 20+ prêteurs. Service 100 % gratuit pour vous.
            </p>

            <ul class="rep-trust-list" aria-label="Garanties de service">
              <li>
                <span class="rep-trust-icon" aria-hidden="true">🛡️</span>
                <span>Courtière agréée <strong>AMF n° {config.amf}</strong></span>
              </li>
              <li>
                <span class="rep-trust-icon" aria-hidden="true">💰</span>
                <span>Service gratuit (rémunérée par le prêteur)</span>
              </li>
              <li>
                <span class="rep-trust-icon" aria-hidden="true">⏱️</span>
                <span>Premier contact <strong>dans les meilleurs délais</strong></span>
              </li>
            </ul>

            <div class="rep-hero-ctas">
              <a href="#contact" class="btn-cta rep-cta-primary" aria-label="Obtenir ma pré-approbation gratuite">
                <span>Obtenir ma pré-approbation gratuite</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <a href={telHref} class="rep-cta-secondary" aria-label={`Appeler ${prenom} au ${config.telephone}`}>
                ou appelez le <strong>{config.telephone}</strong>
              </a>
            </div>
          </div>

          <aside class="rep-hero-photo" aria-label="Votre courtière">
            <Image
              src={stephaniePhoto}
              alt={`${config.nom}, courtière hypothécaire à Repentigny`}
              width={320}
              height={400}
              loading="eager"
              decoding="async"
              class="rep-photo"
            />
            <div class="rep-photo-caption">
              <strong>{prenom} Weyman</strong>
              <span>Courtière hypothécaire · Hypotheca</span>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============ SECTION 2 — POUR QUI ============ -->
    <section class="rep-services">
      <div class="rep-inner">
        <div class="rep-section-tag">Pour qui je travaille à Repentigny</div>
        <h2 class="rep-section-title">Quatre parcours, une seule personne pour vous accompagner.</h2>

        <div class="rep-cards-grid">
          <a href="/services/premier-achat" class="rep-card">
            <span class="rep-card-icon" aria-hidden="true">🏠</span>
            <h3 class="rep-card-title">Premier achat à Repentigny</h3>
            <p class="rep-card-text">Pré-approbation, RAP, CELIAPP, mise de fonds optimale.</p>
            <span class="rep-card-cta">En savoir plus →</span>
          </a>
          <a href="/services/renouvellement" class="rep-card">
            <span class="rep-card-icon" aria-hidden="true">🔄</span>
            <h3 class="rep-card-title">Renouvellement hypothécaire</h3>
            <p class="rep-card-text">Comparer avant de signer l'offre de votre banque actuelle.</p>
            <span class="rep-card-cta">En savoir plus →</span>
          </a>
          <a href="/services/refinancement" class="rep-card">
            <span class="rep-card-icon" aria-hidden="true">💰</span>
            <h3 class="rep-card-title">Refinancement</h3>
            <p class="rep-card-text">Libérer de l'équité pour rénover, consolider ou investir.</p>
            <span class="rep-card-cta">En savoir plus →</span>
          </a>
          <a href="/services/travailleur-autonome" class="rep-card">
            <span class="rep-card-icon" aria-hidden="true">💼</span>
            <h3 class="rep-card-title">Travailleur autonome</h3>
            <p class="rep-card-text">Revenus non traditionnels ? Des prêteurs comprennent votre réalité.</p>
            <span class="rep-card-cta">En savoir plus →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============ SECTION 3 — MARCHÉ LOCAL ============ -->
    <section class="rep-market">
      <div class="rep-inner rep-inner--narrow">
        <div class="rep-section-tag">Le marché immobilier</div>
        <h2 class="rep-section-title">Acheter ou refinancer à Repentigny en 2026</h2>

        <p>
          Repentigny est une ville recherchée pour son équilibre rare entre tranquillité résidentielle
          et proximité de Montréal. Coincée entre le fleuve Saint-Laurent et l'autoroute 40, elle
          attire chaque année une cohorte importante de <strong>premiers acheteurs</strong> et de
          familles qui veulent plus d'espace sans s'éloigner du centre-ville. Les secteurs du
          <strong> vieux Repentigny</strong> et de <strong>Repentigny-Centre</strong> regroupent
          beaucoup d'unifamiliales détachées, tandis que <strong>Le Gardeur</strong> mélange bungalows
          des années 70 et nouveaux développements. Chaque quartier a sa réalité de marché — et donc
          sa propre stratégie hypothécaire.
        </p>

        <p>
          La demande pour les unifamiliales reste forte, ce qui rend une <strong>pré-approbation</strong>
          presque incontournable avant de visiter quoi que ce soit. Sans elle, vous risquez de tomber
          en amour avec une propriété qui dépasse votre vraie capacité d'emprunt — ou de voir une offre
          partir au profit d'un acheteur déjà pré-approuvé. Le calcul de cette capacité tient compte
          du <strong>stress test fédéral</strong>, des règles de mise de fonds minimale, et, sous 20 %
          de mise, de la <strong>prime SCHL</strong> qui s'ajoute au prêt.
        </p>

        <p>
          Je dessers Repentigny et toutes les villes en proximité immédiate : <strong>Charlemagne,
          L'Assomption, Mascouche, Terrebonne</strong>, et plus largement Lanaudière et la couronne
          nord-est de Montréal. L'accès au train de banlieue (ligne Mascouche) et à l'autoroute 40
          rend toute cette zone particulièrement intéressante pour les acheteurs qui travaillent à
          Montréal mais cherchent un mode de vie plus posé. Quand le taux directeur de la Banque du
          Canada bouge, la fenêtre pour magasiner son hypothèque se rétrécit — d'où l'intérêt de
          travailler avec une courtière qui suit le marché en continu.
        </p>
      </div>
    </section>

    <!-- ============ SECTION 4 — BANQUE VS COURTIÈRE ============ -->
    <section class="rep-compare">
      <div class="rep-inner">
        <div class="rep-section-tag">Banque vs courtière</div>
        <h2 class="rep-section-title">Pourquoi parler à une courtière <em>avant</em> votre banque ?</h2>

        <div class="rep-compare-table-wrap" role="region" aria-label="Comparaison banque vs courtière" tabindex="0">
          <table class="rep-compare-table">
            <thead>
              <tr>
                <th scope="col">Avec {prenom} Weyman</th>
                <th scope="col">Avec votre banque</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><span class="rep-check" aria-hidden="true">✓</span> Accès à 20+ prêteurs</td>
                <td><span class="rep-x" aria-hidden="true">✕</span> Un seul prêteur</td>
              </tr>
              <tr>
                <td><span class="rep-check" aria-hidden="true">✓</span> Je négocie pour vous</td>
                <td><span class="rep-x" aria-hidden="true">✕</span> Le conseiller défend sa banque</td>
              </tr>
              <tr>
                <td><span class="rep-check" aria-hidden="true">✓</span> Service gratuit</td>
                <td><span class="rep-check" aria-hidden="true">✓</span> Service gratuit, mais options limitées</td>
              </tr>
              <tr>
                <td><span class="rep-check" aria-hidden="true">✓</span> Disponible soir et fin de semaine</td>
                <td><span class="rep-x" aria-hidden="true">✕</span> Heures de banque</td>
              </tr>
              <tr>
                <td><span class="rep-check" aria-hidden="true">✓</span> Conseils personnalisés à Repentigny</td>
                <td><span class="rep-x" aria-hidden="true">✕</span> Centre d'appel anonyme</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- ============ SECTION 5 — PROCESSUS ============ -->
    <section class="rep-process">
      <div class="rep-inner">
        <div class="rep-section-tag">Comment ça se passe</div>
        <h2 class="rep-section-title">Trois étapes, zéro stress.</h2>

        <ol class="rep-steps">
          <li class="rep-step">
            <div class="rep-step-num" aria-hidden="true">1</div>
            <h3 class="rep-step-title">Vous remplissez le formulaire</h3>
            <p class="rep-step-text">Deux minutes. Aucun pointage de crédit, aucun engagement.</p>
          </li>
          <li class="rep-step">
            <div class="rep-step-num" aria-hidden="true">2</div>
            <h3 class="rep-step-title">On se parle 15 minutes</h3>
            <p class="rep-step-text">J'analyse votre dossier et je vous explique vos vraies options.</p>
          </li>
          <li class="rep-step">
            <div class="rep-step-num" aria-hidden="true">3</div>
            <h3 class="rep-step-title">Vous recevez vos options</h3>
            <p class="rep-step-text">Vous choisissez celle qui vous convient — sans pression.</p>
          </li>
        </ol>
      </div>
    </section>

    <!-- ============ SECTION 6 — TÉMOIGNAGES ============ -->
    <section class="rep-testimonials">
      <div class="rep-inner">
        <div class="rep-section-tag">Témoignages clients</div>
        <h2 class="rep-section-title">Ils ont obtenu leur hypothèque à Repentigny avec moi.</h2>

        <div class="rep-testimonials-grid">
          {testimonials.map((t) => (
            <article class="rep-testimonial">
              <div class="rep-stars" aria-label="5 étoiles sur 5">
                <span aria-hidden="true">★★★★★</span>
              </div>
              <blockquote class="rep-quote">« {t.citation} »</blockquote>
              <footer class="rep-testimonial-meta">
                <strong>{t.prenom} {t.nomInitiale}</strong>
                <span>{t.transaction} · {t.ville}</span>
              </footer>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ SECTION 7 — FAQ ============ -->
    <section class="rep-faq">
      <div class="rep-inner rep-inner--narrow">
        <div class="rep-section-tag">FAQ — Repentigny</div>
        <h2 class="rep-section-title">Les questions qu'on me pose le plus souvent.</h2>

        <div class="rep-faq-list">
          {faq.map((item, i) => (
            <details class="rep-faq-item" name="rep-faq" open={i === 0}>
              <summary>
                <span>{item.q}</span>
                <span class="rep-faq-icon" aria-hidden="true">+</span>
              </summary>
              <div class="rep-faq-answer" set:html={item.a} />
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ SECTION 8 — CTA FINAL + FORMULAIRE ============ -->
    <section class="rep-final-cta">
      <div class="rep-inner">
        <div class="rep-final-header">
          <h2 class="rep-section-title rep-section-title--center">Prêt à obtenir votre pré-approbation à Repentigny ?</h2>
          <p class="rep-final-sub">Aucun engagement. Aucun frais. Réponse dans les meilleurs délais.</p>
        </div>
      </div>
      <Contact />
    </section>

  </main>

  <Footer />
</MainLayout>

<style>
  /* ===========================================================
     Page Repentigny — styles scopés
     S'appuie sur les variables globales définies dans global.css
     (--ink, --clay, --forest, --cream, --white, --border, etc.)
     =========================================================== */

  .rep-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .rep-inner--narrow {
    max-width: 820px;
  }

  .rep-section-tag {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--clay, #c47a52);
    font-weight: 600;
    margin-bottom: 0.9rem;
  }
  .rep-section-title {
    font-family: 'Lora', serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1.2;
    margin: 0 0 1.5rem;
    color: var(--ink, #1a1a1a);
    font-weight: 700;
  }
  .rep-section-title em {
    color: var(--clay, #c47a52);
    font-style: italic;
  }
  .rep-section-title--center {
    text-align: center;
  }

  /* ============ HÉRO ============ */
  .rep-hero {
    padding: 5rem 0 3.5rem;
    background: linear-gradient(180deg, var(--cream, #f7f2ec) 0%, var(--white, #fff) 100%);
  }
  .rep-hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .rep-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--clay, #c47a52);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .rep-h1 {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.15;
    margin: 0 0 1rem;
    color: var(--ink, #1a1a1a);
    font-weight: 700;
  }
  .rep-subtitle {
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--ink-soft, #4a4a4a);
    margin: 0 0 2rem;
  }
  .rep-trust-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .rep-trust-list li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.95rem;
  }
  .rep-trust-icon {
    font-size: 1.1rem;
    flex: 0 0 auto;
  }
  .rep-hero-ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.2rem;
  }
  .rep-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.95rem 1.6rem;
    background: linear-gradient(135deg, var(--clay, #c47a52), #b56f4c);
    color: #fff;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    box-shadow: 0 10px 24px rgba(196, 122, 82, 0.3);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .rep-cta-primary:hover,
  .rep-cta-primary:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(196, 122, 82, 0.4);
  }
  .rep-cta-secondary {
    color: var(--ink, #1a1a1a);
    text-decoration: none;
    font-size: 0.95rem;
  }
  .rep-cta-secondary strong {
    color: var(--clay, #c47a52);
    text-decoration: underline;
  }
  .rep-hero-photo {
    text-align: center;
  }
  .rep-photo {
    width: 100%;
    max-width: 320px;
    height: auto;
    border-radius: 12px;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.12);
  }
  .rep-photo-caption {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .rep-photo-caption strong {
    font-family: 'Lora', serif;
    font-size: 1.15rem;
  }
  .rep-photo-caption span {
