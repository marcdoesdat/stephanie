---
export const prerender = true;

import MainLayout from '../../layouts/MainLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Contact from '../../components/Contact.astro';
import MessengerBtn from '../../components/MessengerBtn.astro';
import { Image } from 'astro:assets';
import stephaniePhoto from '../../assets/stephanie.webp';
import { loadSiteConfig } from '../../config';
import PhoneLink from '../../components/PhoneLink.astro';
import RappelCTA from '../../components/RappelCTA.astro';

const config = loadSiteConfig();
const prenom = config.nom.split(' ')[0];

const PAGE_URL = `${config.site_url}/villes/courtier-hypothecaire-terrebonne`;
const STEPHANIE_IMAGE = `${config.site_url}/_astro/stephanie.Cm30Blgc.jpg`;

const faq = [
  {
    q: "Combien coûte un courtier hypothécaire à Terrebonne ?",
    a: `Rien pour vous : mon service est <strong>gratuit</strong>. C'est le prêteur qui finance votre dossier qui me rémunère, au moment du déboursé. Vous ne recevez aucune facture et vous ne vous engagez à rien tant qu'on n'a pas trouvé la bonne solution.`
  },
  {
    q: "Quelle mise de fonds pour acheter une maison à Terrebonne ?",
    a: `La règle canadienne s'applique : <strong>5 %</strong> de mise de fonds minimale sur la première tranche de 500 000 $, puis <strong>10 %</strong> entre 500 000 $ et 1,5 M$. Avec moins de 20 % de mise de fonds, une prime d'assurance SCHL s'ajoute à votre prêt. On calcule ensemble le scénario le plus avantageux selon votre situation.`
  },
  {
    q: "Comment financer une construction neuve dans Urbanova ?",
    a: `Le financement d'une propriété neuve ne fonctionne pas comme celui d'une revente : selon le projet, il peut y avoir des <strong>déboursés progressifs</strong>, des délais de livraison à couvrir et des conditions particulières du constructeur. Certains prêteurs sont beaucoup plus flexibles que d'autres sur le neuf — c'est exactement le genre de dossier où magasiner fait une vraie différence.`
  },
  {
    q: "Les prix sont-ils les mêmes dans tous les secteurs de Terrebonne ?",
    a: `Non — le <strong>Vieux-Terrebonne</strong> (maisons anciennes, plex), <strong>Lachenaie</strong> (unifamiliales plus récentes), <strong>La Plaine</strong> (grands terrains) et les développements neufs d'<strong>Urbanova</strong> ont chacun leur réalité de prix. Plutôt qu'un chiffre qui se périme, je vous propose d'évaluer votre capacité d'emprunt par rapport au secteur que vous visez, gratuitement.`
  },
  {
    q: "C'est quoi, le stress test, et est-ce qu'il s'applique à moi ?",
    a: `Oui, il s'applique à presque tous les emprunteurs au Canada. Les prêteurs doivent qualifier votre dossier au <strong>plus élevé</strong> entre votre taux contractuel + 2 % et 5,25 %. Ce taux fictif sert uniquement au calcul de votre capacité d'emprunt — ce n'est pas celui que vous paierez. Il faut simplement en tenir compte dès le départ pour viser le bon budget.`
  },
  {
    q: "En combien de temps puis-je être pré-approuvé ?",
    a: `Dès que votre dossier est complet (documents de revenus et de mise de fonds fournis), je vise une <strong>réponse dans les meilleurs délais</strong>. La pré-approbation reste ensuite valide jusqu'à 120 jours — le temps de magasiner à Terrebonne sans pression.`
  },
  {
    q: "Je suis travailleur autonome à Terrebonne : est-ce plus compliqué ?",
    a: `Plus encadré, oui ; impossible, non. Plusieurs de mes prêteurs acceptent les revenus autonomes documentés par vos <strong>avis de cotisation</strong> des deux dernières années, et il existe des programmes alternatifs quand le dossier sort du cadre. Certaines conditions s'appliquent — on en discute franchement dès le premier appel.`
  },
  {
    q: "Ma banque a refusé mon dossier. Est-ce que ça vaut la peine de vous appeler ?",
    a: `Oui. Chaque prêteur applique ses propres critères : un refus chez l'un ne veut pas dire un refus partout. On identifie ce qui a bloqué — ratio d'endettement, crédit, type de revenus — et on cible les prêteurs (y compris alternatifs) dont les critères correspondent à votre profil.`
  }
];

// === Schemas JSON-LD ===
const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "FinancialService",
  "name": "Stéphanie Weyman - Courtière hypothécaire",
  "image": STEPHANIE_IMAGE,
  "url": PAGE_URL,
  "telephone": "+15149497627",
  "email": "sweyman@hypotheca.ca",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "3344 Fleury Est",
    "addressLocality": "Montréal",
    "addressRegion": "QC",
    "postalCode": "H1H 2R5",
    "addressCountry": "CA"
  },
  "areaServed": [
    { "@type": "City", "name": "Terrebonne" },
    { "@type": "City", "name": "Lachenaie" },
    { "@type": "City", "name": "La Plaine" },
    { "@type": "City", "name": "Mascouche" },
    { "@type": "City", "name": "Bois-des-Filion" }
  ],
  "priceRange": "Free"
};

const schemaPerson = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Stéphanie Weyman",
  "jobTitle": "Courtière hypothécaire",
  "worksFor": { "@type": "Organization", "name": "Hypotheca" },
  "image": STEPHANIE_IMAGE,
  "url": config.site_url,
  "identifier": `AMF ${config.amf}`
};

// Le FAQPage est généré à partir du tableau `faq` ci-dessus.
const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      // On retire le HTML pour la version texte du schema.
      "text": item.a.replace(/<[^>]+>/g, '')
    }
  }))
};

// Cache CDN — page éditoriale, change rarement.
Astro.response.headers.set('Cache-Control', 's-maxage=21600, stale-while-revalidate=3600');
---

<MainLayout
  fullTitle="Courtière hypothécaire à Terrebonne – Stéphanie Weyman"
  description="Courtière hypothécaire à Terrebonne (Lachenaie, La Plaine, Urbanova). Pré-approbation, achat, construction neuve, renouvellement. 20+ prêteurs. Service gratuit."
>
  <Fragment slot="head">
    <link rel="canonical" href={PAGE_URL} />
    <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(schemaPerson)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} is:inline />
  </Fragment>

  <MessengerBtn />
  <Nav />

  <main id="main-content">

    <!-- ============ SECTION 1 — HÉRO ============ -->
    <section class="rep-hero">
      <div class="rep-inner">
        <div class="rep-hero-grid">
          <div class="rep-hero-text">
            <div class="rep-eyebrow">Terrebonne · Les Moulins</div>
            <h1 class="rep-h1">Courtière hypothécaire à Terrebonne</h1>
            <p class="rep-subtitle">
              Pré-approbation rapide. Accès à 20+ prêteurs. Frais de courtage&nbsp;: 0&nbsp;$<span class="fee-tooltip-wrap"><button class="fee-info-btn" aria-label="En savoir plus sur les frais de courtage" aria-expanded="false" type="button">i</button><span class="fee-tooltip" role="tooltip">Frais de courtage à 0&nbsp;$ pour la vaste majorité des dossiers. Certains financements alternatifs ou privés peuvent comporter des frais, dont je vous informe avant toute démarche.</span></span>.
            </p>

            <ul class="rep-trust-list" aria-label="Garanties de service">
              <li>
                <span class="rep-trust-icon" aria-hidden="true">💰</span>
                <span>Service gratuit (rémunérée par le prêteur)</span>
              </li>
              <li>
                <span class="rep-trust-icon" aria-hidden="true">⏱️</span>
                <span>Premier contact <strong>dans les meilleurs délais</strong></span>
              </li>
            </ul>

            <div class="rep-hero-ctas">
              <a href="#contact" class="btn-cta rep-cta-primary" aria-label="Obtenir ma pré-approbation gratuite">
                <span>Obtenir ma pré-approbation gratuite</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
              <span class="rep-cta-secondary">
                ou appelez le <PhoneLink variant="text" trackId="tel_click_terrebonne" aria-label={`Appeler ${prenom} au ${config.telephone}`} />
              </span>
            </div>
          </div>

          <aside class="rep-hero-photo" aria-label="Votre courtière">
            <Image
              src={stephaniePhoto}
              alt={`${config.nom}, courtière hypothécaire à Terrebonne`}
              width={320}
              height={400}
              loading="eager"
              decoding="async"
              class="rep-photo"
            />
            <div class="rep-photo-caption">
              <strong>{prenom} Weyman</strong>
              <span>Courtière hypothécaire · Hypotheca</span>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============ SECTION 2 — POUR QUI ============ -->
    <section class="rep-services">
      <div class="rep-inner">
        <div class="rep-section-tag">Pour qui je travaille à Terrebonne</div>
        <h2 class="rep-section-title">Six parcours, une seule personne pour vous accompagner.</h2>

        <div class="rep-cards-grid">
          <a href="/services/premier-achat" class="rep-card">
            <span class="rep-card-icon" aria-hidden="true">🏠</span>
            <h3 class="rep-card-title">Premier achat à Terrebonne</h3>
            <p class="rep-card-text">Pré-approbation, RAP, CELIAPP, mise de fonds optimale.</p>
            <span class="rep-card-cta">En savoir plus →</span>
          </a>
          <a href="/services/renouvellement" class="rep-card">
            <span class="rep-card-icon" aria-hidden="true">🔄</span>
            <h3 class="rep-card-title">Renouvellement hypothécaire</h3>
            <p class="rep-card-text">Comparer avant de signer l'offre de votre banque actuelle.</p>
            <span class="rep-card-cta">En savoir plus →</span>
          </a>
          <a href="/services/refinancement" class="rep-card">
            <span class="rep-card-icon" aria-hidden="true">💰</span>
            <h3 class="rep-card-title">Refinancement</h3>
            <p class="rep-card-text">Libérer de l'équité pour rénover, consolider ou investir.</p>
            <span class="rep-card-cta">En savoir plus →</span>
          </a>
          <a href="/services/travailleur-autonome" class="rep-card">
            <span class="rep-card-icon" aria-hidden="true">💼</span>
            <h3 class="rep-card-title">Travailleur autonome</h3>
            <p class="rep-card-text">Revenus non traditionnels ? Des prêteurs comprennent votre réalité.</p>
            <span class="rep-card-cta">En savoir plus →</span>
          </a>
          <a href="/services/dossier-refuse" class="rep-card">
            <span class="rep-card-icon" aria-hidden="true">🚫</span>
            <h3 class="rep-card-title">Dossier refusé</h3>
            <p class="rep-card-text">Un refus bancaire n'est pas une fin — des solutions alternatives existent.</p>
            <span class="rep-card-cta">En savoir plus →</span>
          </a>
          <a href="/services/nouveaux-arrivants" class="rep-card">
            <span class="rep-card-icon" aria-hidden="true">🌍</span>
            <h3 class="rep-card-title">Nouveaux arrivants</h3>
            <p class="rep-card-text">Résidence permanente ou permis de travail ? Des prêteurs s'adaptent à votre profil.</p>
            <span class="rep-card-cta">En savoir plus →</span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============ RAPPEL RENOUVELLEMENT ============ -->
    <section class="rep-rappel" aria-label="Rappel de renouvellement">
      <div class="rep-inner">
        <RappelCTA
          titre="Votre hypothèque arrive à échéance ?"
          texte="Le meilleur moment pour magasiner se situe 4 à 6 mois avant la fin de votre terme — avant que votre banque n'envoie son offre de renouvellement. Laissez vos coordonnées : je vous rappelle personnellement au bon moment."
          cta="Être rappelé·e au bon moment"
        />
      </div>
    </section>

    <!-- ============ SECTION 3 — MARCHÉ LOCAL ============ -->
    <section class="rep-market">
      <div class="rep-inner rep-inner--narrow">
        <div class="rep-section-tag">Le marché immobilier</div>
        <h2 class="rep-section-title">Acheter ou refinancer à Terrebonne en 2026</h2>

        <p>
          Plus grande ville de Lanaudière et cœur de la MRC Les Moulins, Terrebonne a plusieurs
          visages — et autant de réalités de marché. Le <strong>Vieux-Terrebonne</strong>, autour de
          l'Île-des-Moulins, concentre maisons de caractère et petits plex ; <strong>Lachenaie</strong>
          aligne des unifamiliales plus récentes prisées des jeunes familles ; <strong>La Plaine</strong>
          offre les grands terrains d'un secteur encore champêtre. S'ajoute <strong>Urbanova</strong>,
          l'un des plus vastes projets résidentiels planifiés au Québec, qui alimente une offre
          importante de <strong>constructions neuves</strong> — un type d'achat dont le financement
          obéit à ses propres règles (déboursés, délais de livraison, conditions du constructeur).
        </p>

        <p>
          Peu importe le secteur, la <strong>pré-approbation</strong> reste l'étape numéro un : elle
          fixe votre budget réel en intégrant le <strong>stress test fédéral</strong>, la mise de
          fonds minimale et, sous 20 % de mise, la prime SCHL ajoutée au prêt. Sur le neuf, elle
          permet en plus de sécuriser votre financement avant de signer un contrat préliminaire —
          un détail qui évite bien des mauvaises surprises entre la signature et la livraison.
        </p>

        <p>
          Je dessers Terrebonne, Lachenaie et La Plaine, ainsi que les villes voisines :
          <strong>Mascouche, Bois-des-Filion, Sainte-Anne-des-Plaines</strong> et, de l'autre côté
          de la MRC, <a href="/villes/courtier-hypothecaire-repentigny">Repentigny</a> et
          Charlemagne. Avec l'autoroute 25, la 640 et la gare Terrebonne de la ligne de train
          Mascouche, le secteur attire beaucoup d'acheteurs qui travaillent à Laval ou à Montréal.
          Quand les taux bougent, je suis le marché en continu pour saisir la bonne fenêtre à
          votre place.
        </p>
      </div>
    </section>

    <!-- ============ SECTION 4 — BANQUE VS COURTIÈRE ============ -->
    <section class="rep-compare">
      <div class="rep-inner">
        <div class="rep-section-tag">Banque vs courtière</div>
        <h2 class="rep-section-title">Ta banque te connaît. <em>Moi, je te défends.</em></h2>

        <div class="rep-compare-cards">
          <div class="rep-compare-card rep-compare-card--bad">
            <div class="rep-compare-card-icon" aria-hidden="true">🏦</div>
            <h3 class="rep-compare-card-title">Avec votre banque</h3>
            <ul class="rep-compare-list">
              <li><span class="rep-x" aria-hidden="true">✕</span> Une seule offre : la leur</li>
              <li><span class="rep-x" aria-hidden="true">✕</span> Le conseiller travaille pour la banque, pas pour vous</li>
              <li><span class="rep-x" aria-hidden="true">✕</span> Heures d'ouverture restrictives</li>
              <li><span class="rep-x" aria-hidden="true">✕</span> Pas de magasinage de taux pour vous</li>
              <li><span class="rep-x" aria-hidden="true">✕</span> Un refus = fin de la discussion</li>
            </ul>
          </div>

          <div class="rep-compare-card rep-compare-card--good">
            <div class="rep-compare-card-icon" aria-hidden="true">🤝</div>
            <h3 class="rep-compare-card-title">Avec {prenom} Weyman</h3>
            <ul class="rep-compare-list">
              <li><span class="rep-check" aria-hidden="true">✓</span> 20+ prêteurs comparés pour vous</li>
              <li><span class="rep-check" aria-hidden="true">✓</span> Je travaille pour <strong>vous,</strong> pas pour un prêteur</li>
              <li><span class="rep-check" aria-hidden="true">✓</span> Dispo soirs et fins de semaine</li>
              <li><span class="rep-check" aria-hidden="true">✓</span> Je négocie les taux et les conditions</li>
              <li><span class="rep-check" aria-hidden="true">✓</span> Un refus bancaire ? J'ai des solutions alternatives</li>
            </ul>
            <p class="rep-compare-bonus">💰 <strong>Service gratuit</strong> — rémunérée par le prêteur, pas par vous.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ SECTION 5 — PROCESSUS ============ -->
    <section class="rep-process">
      <div class="rep-inner">
        <div class="rep-section-tag">Comment ça se passe</div>
        <h2 class="rep-section-title">Trois étapes, zéro stress.</h2>

        <ol class="rep-steps">
          <li class="rep-step">
            <div class="rep-step-num" aria-hidden="true">1</div>
            <h3 class="rep-step-title">Vous remplissez le formulaire</h3>
            <p class="rep-step-text">Deux minutes. Aucun pointage de crédit, aucun engagement.</p>
          </li>
          <li class="rep-step">
            <div class="rep-step-num" aria-hidden="true">2</div>
            <h3 class="rep-step-title">On se parle 15 minutes</h3>
            <p class="rep-step-text">J'analyse votre dossier et je vous explique vos vraies options.</p>
          </li>
          <li class="rep-step">
            <div class="rep-step-num" aria-hidden="true">3</div>
            <h3 class="rep-step-title">Vous recevez vos options</h3>
            <p class="rep-step-text">Vous choisissez celle qui vous convient — sans pression.</p>
          </li>
        </ol>
      </div>
    </section>

    <!-- ============ SECTION 6 — FAQ ============ -->
    <section class="rep-faq">
      <div class="rep-inner rep-inner--narrow">
        <div class="rep-section-tag">FAQ — Terrebonne</div>
        <h2 class="rep-section-title">Les questions qu'on me pose le plus souvent.</h2>

        <div class="faq-list">
          {faq.map((item, i) => (
            <div class={`faq-item${i === 0 ? ' open' : ''}`} id={`faq-ville-${i}`}>
              <h3>
                <button
                  class="faq-q"
                  id={`faq-question-ville-${i}`}
                  aria-expanded={i === 0 ? 'true' : 'false'}
                  aria-controls={`faq-answer-ville-${i}`}
                >
                  <span class="faq-q-text">{item.q}</span>
                  <span class="faq-icon" aria-hidden="true">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                  </span>
                </button>
              </h3>
              <div
                class="faq-a"
                role="region"
                id={`faq-answer-ville-${i}`}
                aria-labelledby={`faq-question-ville-${i}`}
                aria-hidden={i === 0 ? 'false' : 'true'}
              >
                <div class="faq-a-inner" set:html={item.a} />
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ SECTION 8 — CTA FINAL + FORMULAIRE ============ -->
    <section class="rep-final-cta">
      <div class="rep-inner">
        <div class="rep-final-header">
          <h2 class="rep-section-title rep-section-title--center">Prêt à obtenir votre pré-approbation à Terrebonne ?</h2>
          <p class="rep-final-sub">Aucun engagement. Aucun frais. Réponse dans les meilleurs délais.</p>
        </div>
      </div>
      <Contact />
    </section>

  </main>

  <Footer />
</MainLayout>

<style>
  /* ===========================================================
     Page Terrebonne — styles scopés
     Mêmes classes (préfixe rep-) que la page Repentigny pour
     garder les deux gabarits villes synchronisés.
     S'appuie sur les variables globales de global.css.
     =========================================================== */

  .rep-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .rep-inner--narrow {
    max-width: 820px;
  }

  .rep-section-tag {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--clay, #c47a52);
    font-weight: 600;
    margin-bottom: 0.9rem;
  }
  .rep-section-title {
    font-family: 'Lora', serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    line-height: 1.2;
    margin: 0 0 1.5rem;
    color: var(--ink, #1a1a1a);
    font-weight: 700;
  }
  .rep-section-title em {
    color: var(--clay, #c47a52);
    font-style: italic;
  }
  .rep-section-title--center {
    text-align: center;
  }

  /* ============ HÉRO ============ */
  .rep-hero {
    padding: 5rem 0 3.5rem;
    background: linear-gradient(180deg, var(--cream, #f7f2ec) 0%, var(--white, #fff) 100%);
  }
  .rep-hero-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    align-items: center;
  }
  .rep-eyebrow {
    display: inline-block;
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--clay, #c47a52);
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .rep-h1 {
    font-family: 'Lora', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    line-height: 1.15;
    margin: 0 0 1rem;
    color: var(--ink, #1a1a1a);
    font-weight: 700;
  }
  .rep-subtitle {
    font-size: 1.15rem;
    line-height: 1.5;
    color: var(--ink-soft, #4a4a4a);
    margin: 0 0 2rem;
  }
  .rep-trust-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .rep-trust-list li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.95rem;
  }
  .rep-trust-icon {
    font-size: 1.1rem;
    flex: 0 0 auto;
  }
  .rep-hero-ctas {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.2rem;
  }
  .rep-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.95rem 1.6rem;
    background: linear-gradient(135deg, var(--clay, #c47a52), #b56f4c);
    color: #fff;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
    box-shadow: 0 10px 24px rgba(196, 122, 82, 0.3);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .rep-cta-primary:hover,
  .rep-cta-primary:focus-visible {
    transform: translateY(-2px);
