---
import MainLayout from '../../layouts/MainLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import PenaliteCalculator from '../../components/PenaliteCalculator.astro';
import { loadSiteConfig } from '../../config';
import { fetchHypothecaRates } from '../../services/ratesService';
import { preteursParCategorie } from '../../data/preteurs';

const config = loadSiteConfig();
const hypothecaRates = await fetchHypothecaRates();

const taux5ans = hypothecaRates?.fixe_5ans ?? 4.89;
const taux4ans = hypothecaRates?.fixe_4ans ?? ((hypothecaRates?.fixe_3ans ?? 4.69) + (hypothecaRates?.fixe_5ans ?? 4.89)) / 2;
const taux3ans = hypothecaRates?.fixe_3ans ?? 4.69;
const taux2ans = hypothecaRates?.fixe_2ans ?? ((hypothecaRates?.fixe_1ans ?? 5.49) + (hypothecaRates?.fixe_3ans ?? 4.69)) / 2;
const taux1an  = hypothecaRates?.fixe_1ans ?? 5.49;

const tauxMarcheDefaut = {
  '6': (taux1an + 0.15).toFixed(2),
  '12': taux1an.toFixed(2),
  '24': taux2ans.toFixed(2),
  '36': taux3ans.toFixed(2),
  '48': taux4ans.toFixed(2),
  '60': taux5ans.toFixed(2),
};

const dateMaj = hypothecaRates?.fetchedAt
  ? new Date(hypothecaRates.fetchedAt).toLocaleDateString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const groupes = preteursParCategorie();

Astro.response.headers.set('Cache-Control', 's-maxage=21600, stale-while-revalidate=3600');
---

<MainLayout
  fullTitle="Calculateur de pénalité de remboursement anticipé hypothécaire — Estimation IRD | Stéphanie Weyman"
  description="Estimez la pénalité pour briser votre hypothèque au Québec. Calcul IRD (taux affichés vs taux réels), 3 mois d'intérêts. Comparez grandes banques et prêteurs monolignes. Outil gratuit, sans inscription."
>
  <Nav />
  <main id="main-content">
    <section id="penalite-intro">
      <div class="section-inner penalite-intro-inner">
        <div class="fade-up">
          <div class="section-tag">Outil gratuit</div>
          <h1 class="section-title">Calculateur de pénalité<br /><em>hypothécaire</em> (IRD)</h1>
          <p class="section-sub">
            Estimez la pénalité de remboursement anticipé de votre prêt hypothécaire.
            Découvrez l'écart entre la méthode des grandes banques (taux affichés) et celle
            des prêteurs monolignes (taux réels). Gratuit, sans inscription, résultats instantanés.
          </p>
        </div>
      </div>
    </section>

    <PenaliteCalculator
      config={config}
      tauxMarcheDefaut={tauxMarcheDefaut}
      dateMaj={dateMaj}
      groupes={groupes}
    />

    <section id="penalite-edito">
      <div class="section-inner penalite-edito-inner">
        <article class="penalite-article fade-up">
          <h2>Comprendre la pénalité de remboursement anticipé (IRD)</h2>
          <h3>Qu'est-ce que l'IRD ?</h3>
          <p>L'<strong>indemnité de remboursement anticipé</strong> (IRD — Interest Rate Differential) est la pénalité que votre institution financière peut imposer si vous remboursez votre prêt hypothécaire avant la fin du terme. Cette pénalité compense le prêteur pour la perte de revenus d'intérêts.</p>
          <p>Au Canada, la pénalité est le <strong>plus élevé</strong> de : <strong>3 mois d'intérêts</strong> sur le solde, ou l'<strong>écart de taux (IRD)</strong> calculé sur la durée restante.</p>

          <h3>Pourquoi les banques calculent-elles différemment ?</h3>
          <p>Deux grandes méthodes existent, et l'écart peut représenter <strong>des milliers de dollars</strong> :</p>
          <ul>
            <li><strong>Méthode des taux affichés</strong> (RBC, TD, BMO, CIBC, Scotia, BN) : le taux de référence est le taux affiché au moment de la signature, souvent 1 à 2 % plus élevé que le taux réel. Pénalité plus élevée.</li>
            <li><strong>Méthode des taux réels</strong> (First National, MCAP, RFA, Strive) : le taux de référence est votre taux contractuel réel. Pénalité nettement plus basse.</li>
          </ul>

          <h3>Quand la pénalité vaut-elle la peine d'être payée ?</h3>
          <ul>
            <li><strong>Refinancement à taux plus bas</strong> : si les taux ont baissé de 1,5 % ou plus.</li>
            <li><strong>Regroupement de dettes</strong> : remplacer des dettes à taux élevé par un refinancement.</li>
            <li><strong>Vente de la propriété</strong> : frais de transition inévitables.</li>
            <li><strong>Passage à un prêteur à taux réel</strong> : flexibilité et économies à long terme.</li>
          </ul>
          <p>Chaque situation est unique. Une <strong>analyse personnalisée avec un courtier</strong> vous permet de comparer vos options réelles.</p>
        </article>

        <div class="penalite-faq fade-up">
          <h2 class="section-title">Foire aux questions</h2>
          <div class="penalite-faq-list">
            <details class="penalite-faq-item">
              <summary>Pourquoi ma banque calcule-t-elle une pénalité aussi élevée ?</summary>
              <p>Les grandes banques utilisent la <strong>méthode des taux affichés</strong>. Le taux affiché est le taux officiel publié, souvent 1 à 2 % plus élevé que le taux réellement négocié. L'IRD est donc mécaniquement gonflé — parfois de plusieurs milliers de dollars.</p>
            </details>
            <details class="penalite-faq-item">
              <summary>Qu'est-ce que la méthode des taux affichés ?</summary>
              <p>La méthode des taux affichés utilise comme référence le taux standard publié par l'institution au moment de la signature, et non le taux réduit réellement obtenu. Utilisée par les six grandes banques, elle produit des pénalités IRD plus élevées.</p>
            </details>
            <details class="penalite-faq-item">
              <summary>Puis-je négocier la pénalité ?</summary>
              <p>Il est <strong>rare</strong> qu'une institution accepte de réduire la pénalité contractuelle. Certains prêteurs offrent des clauses de remboursement partiel sans pénalité (15 à 20 % par an). Un courtier peut vous aider à évaluer vos options.</p>
            </details>
            <details class="penalite-faq-item">
              <summary>Y a-t-il des cas où la pénalité est annulée ?</summary>
              <p>Oui : <strong>décès</strong> d'un emprunteur, <strong>portabilité</strong> vers une nouvelle propriété, <strong>privilège de remboursement anticipé</strong> (souvent 15-20 % par an sans frais), et <strong>renouvellement à l'échéance</strong> (changer de prêteur sans pénalité).</p>
            </details>
            <details class="penalite-faq-item">
              <summary>Combien coûte un transfert hypothécaire à l'échéance versus avant ?</summary>
              <p>À l'<strong>échéance du terme</strong>, vous pouvez changer de prêteur <strong>sans pénalité</strong> — seuls des frais administratifs mineurs (300-500 $) s'appliquent. Avant l'échéance, la pénalité s'applique.</p>
            </details>
            <details class="penalite-faq-item">
              <summary>Quelle est la différence entre un prêteur monoligne et une grande banque ?</summary>
              <p>Un <strong>prêteur monoligne</strong> (First National, MCAP, RFA) se spécialise dans les prêts hypothécaires. Ils utilisent le <strong>taux contractuel réel</strong> pour l'IRD, donnant des pénalités plus basses. Pas de succursales — vous passez par un courtier.</p>
            </details>
            <details class="penalite-faq-item">
              <summary>Les prêts à taux variable ont-ils une pénalité IRD ?</summary>
              <p>Non. Les prêts à <strong>taux variable</strong> sont assortis d'une pénalité de <strong>3 mois d'intérêts seulement</strong>, sans calcul d'IRD. C'est un avantage clé du taux variable.</p>
            </details>
            <details class="penalite-faq-item">
              <summary>Comment connaître ma pénalité exacte ?</summary>
              <p>Demandez un <strong>relevé de remboursement anticipé à votre prêteur</strong>. Les taux changent quotidiennement, donc la pénalité varie. Notre calculateur donne une <strong>estimation indicative</strong> pour vous aider à planifier.</p>
            </details>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>

<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Calculateur de pénalité hypothécaire IRD — Stéphanie Weyman",
  "url": "https://stephanieweyman.ca/outils/calculateur-penalite-hypothecaire",
  "description": "Estimez la pénalité de remboursement anticipé de votre prêt hypothécaire au Québec.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "CAD" }
}
</script>

<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type": "Question", "name": "Pourquoi ma banque calcule-t-elle une pénalité aussi élevée ?", "acceptedAnswer": {"@type": "Answer", "text": "Les grandes banques utilisent la méthode des taux affichés : le taux de référence est le taux officiel publié, souvent 1 à 2 % plus élevé que le taux réel. L'IRD est donc mécaniquement plus élevé."}},
    {"@type": "Question", "name": "Puis-je négocier la pénalité de remboursement anticipé ?", "acceptedAnswer": {"@type": "Answer", "text": "Il est rare qu'une institution accepte de réduire la pénalité contractuelle. Certains prêteurs offrent des clauses de remboursement partiel sans pénalité (15 à 20 % par an). Un courtier peut vous aider."}},
    {"@type": "Question", "name": "Combien coûte un transfert hypothécaire à l'échéance versus avant ?", "acceptedAnswer": {"@type": "Answer", "text": "À l'échéance, vous pouvez changer de prêteur sans pénalité — seuls des frais administratifs mineurs (300-500 $) s'appliquent. Avant l'échéance, la pénalité IRD ou de 3 mois s'applique."}}
  ]
}
</script>

<style>
  #penalite-intro{background:var(--sand);padding:7rem 4rem 3rem;}
  .penalite-intro-inner{text-align:center;}
  .penalite-intro-inner .section-sub{max-width:640px;margin:0 auto;}

  #penalite-edito{background:var(--warm);padding:5rem 4rem;}
  .penalite-edito-inner{max-width:800px;margin:0 auto;}
  .penalite-article{margin-bottom:4rem;}
  .penalite-article h2{font-family:"Lora",serif;font-size:2.2rem;font-weight:700;color:var(--ink);margin-bottom:1.5rem;}
  .penalite-article h3{font-family:"Lora",serif;font-size:1.4rem;font-weight:600;color:var(--ink);margin:2rem 0 .75rem;}
  .penalite-article p{font-size:.95rem;color:var(--muted);line-height:1.9;margin-bottom:1rem;}
  .penalite-article ul{margin:.5rem 0 1rem 1.5rem;list-style:disc;}
  .penalite-article li{font-size:.93rem;color:var(--muted);line-height:1.8;margin-bottom:.5rem;}

  .penalite-faq h2{font-family:"Lora",serif;font-size:2.2rem;font-weight:700;color:var(--ink);margin-bottom:2rem;}
  .penalite-faq-list{display:flex;flex-direction:column;gap:.75rem;}
  .penalite-faq-item{border:1px solid var(--border);border-radius:14px;overflow:hidden;background:white;}
  .penalite-faq-item summary{padding:1.1rem 1.5rem;font-size:.92rem;font-weight:600;color:var(--ink);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;}
  .penalite-faq-item summary::after{content:'▸';font-size:.8rem;color:var(--muted);transition:transform .2s;}
  .penalite-faq-item[open] summary::after{transform:rotate(90deg);}
  .penalite-faq-item p{padding:0 1.5rem 1.25rem;font-size:.85rem;color:var(--muted);line-height:1.8;margin:0;}

  @media (max-width:768px){
    #penalite-intro,#penalite-edito{padding-left:1.5rem;padding-right:1.5rem;}
    .penalite-article h2,.penalite-faq h2{font-size:1.6rem;}
  }
</style>
