---
import MainLayout from '../../layouts/MainLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Calculator from '../../components/Calculator.astro';
import { fetchHypothecaRates } from '../../services/ratesService';

const hypothecaRates = await fetchHypothecaRates();
const defaultRate = hypothecaRates?.fixe_5ans ?? 4.99;

Astro.response.headers.set('Cache-Control', 's-maxage=21600, stale-while-revalidate=3600');
---

<MainLayout
  fullTitle="Calculateur de versements hypothécaires au Québec | Stéphanie Weyman"
  description="Calculez vos versements hypothécaires mensuels, aux deux semaines ou hebdomadaires. Taux d'intérêt, amortissement, taxes et frais inclus. Gratuit, sans inscription."
>
  <Nav />
  <main id="main-content">
    <section id="outil-intro" style="background:var(--sand);padding:7rem 4rem 3rem;text-align:center;">
      <div class="section-inner">
        <div class="fade-up">
          <div class="section-tag">Outil gratuit</div>
          <h1 class="section-title">Calculateur de<br /><em>versements</em> hypothécaires</h1>
          <p class="section-sub" style="max-width:640px;margin:0 auto;">
            Estimez vos versements hypothécaires en quelques secondes. Ajustez le taux,
            l'amortissement, la fréquence et les frais annexes. Gratuit, sans inscription.
          </p>
        </div>
      </div>
    </section>

    <Calculator defaultRate={defaultRate} />

    <section id="outil-edito" style="background:var(--warm);padding:5rem 4rem;">
      <div class="section-inner" style="max-width:800px;margin:0 auto;">
        <article class="fade-up" style="margin-bottom:3rem;">
          <h2 style="font-family:Lora,serif;font-size:2.2rem;font-weight:700;color:var(--ink);margin-bottom:1.5rem;">Comprendre votre versement hypothécaire</h2>
          <p style="font-size:.95rem;color:var(--muted);line-height:1.9;margin-bottom:1rem;">
            Votre versement hypothécaire est composé du <strong>capital</strong> et des <strong>intérêts</strong>.
            Selon votre mise de fonds, une <strong>prime d'assurance SCHL</strong> peut s'ajouter.
            Les <strong>taxes municipales et scolaires</strong> ainsi que les <strong>frais de chauffage</strong>
            font aussi partie du calcul de qualification.
          </p>
          <p style="font-size:.95rem;color:var(--muted);line-height:1.9;margin-bottom:1rem;">
            La <strong>fréquence de versement</strong> influence le coût total : des versements aux deux semaines
            accélérés vous font économiser des milliers de dollars en intérêts sur la durée du prêt.
          </p>
          <p style="font-size:.95rem;color:var(--muted);line-height:1.9;">
            Les résultats sont <strong>indicatifs</strong>. Pour un calcul précis adapté à votre dossier,
            <a href="/#contact" style="color:var(--clay);">contactez Stéphanie</a>.
          </p>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>

<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Calculateur de versements hypothécaires — Stéphanie Weyman",
  "url": "https://stephanieweyman.ca/outils/calculateur",
  "description": "Calculez vos versements hypothécaires mensuels, aux deux semaines ou hebdomadaires au Québec.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "CAD" }
}
</script>
