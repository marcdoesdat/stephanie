---
import MainLayout from '../../layouts/MainLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Simulator from '../../components/Simulator.astro';
import { fetchHypothecaRates } from '../../services/ratesService';

const hypothecaRates = await fetchHypothecaRates();
const defaultRate = hypothecaRates?.fixe_5ans ?? 4.99;

Astro.response.headers.set('Cache-Control', 's-maxage=21600, stale-while-revalidate=3600');
---

<MainLayout
  fullTitle="Simulateur de capacité d'emprunt hypothécaire au Québec | Stéphanie Weyman"
  description="Estimez combien vous pouvez emprunter selon vos revenus, dettes et mise de fonds. Simulateur gratuit, sans inscription, résultats instantanés."
>
  <Nav />
  <main id="main-content">
    <section id="outil-intro" style="background:var(--sand);padding:7rem 4rem 3rem;text-align:center;">
      <div class="section-inner">
        <div class="fade-up">
          <div class="section-tag">Outil gratuit</div>
          <h1 class="section-title">Simulateur de capacité<br /><em>d'emprunt</em></h1>
          <p class="section-sub" style="max-width:640px;margin:0 auto;">
            Estimez le montant maximal que vous pouvez emprunter selon vos revenus, vos dettes
            et votre mise de fonds. Gratuit, sans inscription, résultats instantanés.
          </p>
        </div>
      </div>
    </section>

    <Simulator defaultRate={defaultRate} />

    <section id="outil-edito" style="background:var(--warm);padding:5rem 4rem;">
      <div class="section-inner" style="max-width:800px;margin:0 auto;">
        <article class="fade-up" style="margin-bottom:3rem;">
          <h2 style="font-family:Lora,serif;font-size:2.2rem;font-weight:700;color:var(--ink);margin-bottom:1.5rem;">Comment fonctionne le simulateur ?</h2>
          <p style="font-size:.95rem;color:var(--muted);line-height:1.9;margin-bottom:1rem;">
            Le simulateur utilise les <strong>règles de qualification en vigueur au Canada</strong> :
            votre capacité d'emprunt est calculée à partir de votre revenu brut, de vos dettes mensuelles
            et d'un taux de qualification (le plus élevé entre votre taux contractuel + 2 % et le taux
            directeur de la Banque du Canada).
          </p>
          <p style="font-size:.95rem;color:var(--muted);line-height:1.9;margin-bottom:1rem;">
            L'<strong>ABD (amortissement brut de la dette)</strong> ne doit pas dépasser 39 % de votre revenu
            brut pour les frais de logement, et l'<strong>ATD (amortissement total de la dette)</strong>
            ne doit pas dépasser 44 % en incluant vos autres dettes.
          </p>
          <p style="font-size:.95rem;color:var(--muted);line-height:1.9;">
            Les résultats sont <strong>indicatifs</strong>. Pour une pré-approbation ferme adaptée à votre situation,
            <a href="/#contact" style="color:var(--clay);">contactez Stéphanie</a>.
          </p>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</MainLayout>

<script type="application/ld+json" is:inline>
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Simulateur de capacité d'emprunt hypothécaire — Stéphanie Weyman",
  "url": "https://stephanieweyman.ca/outils/simulateur",
  "description": "Estimez combien vous pouvez emprunter selon vos revenus, dettes et mise de fonds au Québec.",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Web",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "CAD" }
}
</script>
