---
import MainLayout from '../layouts/MainLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Simulator from '../components/Simulator.astro';
import Calculator from '../components/Calculator.astro';
import Comparateur from '../components/Comparateur.astro';
import PenaliteCalculator from '../components/PenaliteCalculator.astro';
import RefinancementSimulator from '../components/RefinancementSimulator.astro';
import DroitsMutationCalculator from '../components/DroitsMutationCalculator.astro';
import { fetchHypothecaRates } from '../services/ratesService';
import { loadSiteConfig } from '../config';
import { preteursParCategorie } from '../data/preteurs';
import { Image } from 'astro:assets';
import stephaniePhoto from '../assets/stephanie.webp';

const config = loadSiteConfig();
const prenom = config.nom.split(' ')[0] ?? 'Stéphanie';
const hypothecaRates = await fetchHypothecaRates();
const defaultRate = hypothecaRates?.fixe_5ans ?? 4.99;

const taux5ans = hypothecaRates?.fixe_5ans ?? 4.89;
const taux4ans = hypothecaRates?.fixe_4ans ?? ((hypothecaRates?.fixe_3ans ?? 4.69) + (hypothecaRates?.fixe_5ans ?? 4.89)) / 2;
const taux3ans = hypothecaRates?.fixe_3ans ?? 4.69;
const taux2ans = hypothecaRates?.fixe_2ans ?? ((hypothecaRates?.fixe_1ans ?? 5.49) + (hypothecaRates?.fixe_3ans ?? 4.69)) / 2;
const taux1an  = hypothecaRates?.fixe_1ans ?? 5.49;

const tauxMarcheDefaut = {
  '6': (taux1an + 0.15).toFixed(2),
  '12': taux1an.toFixed(2),
  '24': taux2ans.toFixed(2),
  '36': taux3ans.toFixed(2),
  '48': taux4ans.toFixed(2),
  '60': taux5ans.toFixed(2),
};

const dateMaj = hypothecaRates?.fetchedAt
  ? new Date(hypothecaRates.fetchedAt).toLocaleDateString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric' })
  : null;

const groupes = preteursParCategorie();

Astro.response.headers.set('Cache-Control', 's-maxage=21600, stale-while-revalidate=3600');

const tabs = [
  { id: 'simulateur', label: "Simulateur d'emprunt", sub: 'Capacité' },
  { id: 'calculateur', label: 'Calculateur de paiement', sub: 'Versements' },
  { id: 'comparateur', label: 'Comparateur de taux', sub: 'Économies' },
  { id: 'penalite', label: 'Calculer ma pénalité', sub: 'IRD' },
  { id: 'refinancement', label: 'Simulateur de refinancement', sub: '+ consolidation' },
  { id: 'droits-mutation', label: 'Droits de mutation', sub: 'Taxe de bienvenue' },
];

// FAQ sur les calculateurs — affichée en bas de page et balisée en FAQPage.
const outilsFaq = [
  {
    q: "Les résultats des calculateurs sont-ils fiables ?",
    a: `Les calculs utilisent les <strong>formules hypothécaires canadiennes</strong> (capitalisation semi-annuelle, règles de mise de fonds minimale, prime SCHL). Les résultats sont des <strong>estimations indicatives</strong> : votre montant réel dépend de votre dossier de crédit, de vos revenus vérifiés et du prêteur. Pour un chiffre engageant, il faut une pré-approbation.`
  },
  {
    q: "Quels taux sont utilisés dans les calculateurs ?",
    a: `Les taux par défaut proviennent des <strong>taux affichés par Hypotheca</strong>, mis à jour plusieurs fois par jour. Vous pouvez les remplacer par n'importe quel taux dans chaque outil pour tester vos propres scénarios.`
  },
  {
    q: "Quelle est la différence entre une simulation et une pré-approbation ?",
    a: `La simulation donne un <strong>ordre de grandeur instantané</strong>, sans vérification. La pré-approbation est un <strong>engagement écrit d'un prêteur</strong> : dossier vérifié, montant confirmé et taux protégé jusqu'à 120 jours. C'est elle qui compte au moment de faire une offre d'achat.`
  },
  {
    q: "Le test de résistance (stress test) est-il pris en compte ?",
    a: `Oui. Le simulateur d'emprunt qualifie votre capacité au <strong>taux de qualification fédéral</strong> — le plus élevé entre votre taux + 2 % et 5,25 % — comme le ferait un prêteur. Votre capacité affichée reflète donc la règle réelle, pas un calcul optimiste.`
  },
  {
    q: "La prime SCHL est-elle incluse dans les calculs ?",
    a: `Oui. Dès que la mise de fonds est inférieure à 20 %, la <strong>prime d'assurance SCHL</strong> est calculée automatiquement et ajoutée au prêt dans le simulateur et le calculateur de versement.`
  },
  {
    q: "Dois-je m'inscrire ou fournir mes coordonnées pour utiliser les outils ?",
    a: `Non. Les six outils sont <strong>gratuits et sans inscription</strong> : les calculs s'exécutent directement dans votre navigateur. Vous ne laissez vos coordonnées que si vous choisissez d'envoyer vos résultats à Stéphanie.`
  }
];

const outilsFaqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": outilsFaq.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a.replace(/<[^>]+>/g, '')
    }
  }))
};
---

<MainLayout
  fullTitle="Calculateur hypothécaire Québec – Capacité d'emprunt, versements, comparateur de taux et pénalité IRD | Stéphanie Weyman"
  description="Outils hypothécaires gratuits au Québec : simulateur de capacité d'emprunt, calculateur de versements, comparateur banque vs courtier, calculateur de pénalité IRD et simulateur de refinancement. Taux Hypotheca en temps réel, sans inscription."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(outilsFaqSchema)} is:inline />
  </Fragment>

  <Nav />
  <main id="main-content">
    <section id="outils-intro">
      <div class="section-inner outils-intro-inner">
        <h1 class="section-title">Calculateurs hypothécaires <em>gratuits</em> au Québec</h1>
        <p class="section-sub">
          Six calculateurs hypothécaires gratuits pour le Québec : estimez votre capacité
          d'emprunt, calculez un versement, comparez les taux affichés en banque avec ceux
          qu'un courtier peut négocier, évaluez votre pénalité de remboursement anticipé,
          simulez un refinancement et calculez vos droits de mutation (taxe de bienvenue) —
          le tout dans un même endroit, sans inscription.
        </p>
      </div>
    </section>

    <section id="outils-tabs-section">
      <div class="section-inner">
        <div
          class="outils-tablist"
          role="tablist"
          aria-label="Outils hypothécaires"
        >
          {tabs.map((tab, i) => (
            <button
              type="button"
              role="tab"
              id={`tab-${tab.id}`}
              class="comp-pill outils-tab"
              aria-controls={`panel-${tab.id}`}
              aria-selected={i === 0 ? 'true' : 'false'}
              tabindex={i === 0 ? 0 : -1}
              data-tab={tab.id}
            >
              <span class="outils-tab-label">{tab.label}</span>
              <span class="comp-pill-sub">{tab.sub}</span>
            </button>
          ))}
        </div>

        <div
          class="outils-panel"
          id="panel-simulateur"
          role="tabpanel"
          aria-labelledby="tab-simulateur"
          data-panel="simulateur"
        >
          <Simulator defaultRate={defaultRate} />
        </div>

        <div
          class="outils-panel"
          id="panel-calculateur"
          role="tabpanel"
          aria-labelledby="tab-calculateur"
          data-panel="calculateur"
          hidden
        >
          <Calculator defaultRate={defaultRate} />
        </div>

        <div
          class="outils-panel"
          id="panel-comparateur"
          role="tabpanel"
          aria-labelledby="tab-comparateur"
          data-panel="comparateur"
          hidden
        >
          <Comparateur
            defaultRate={defaultRate}
            afficheRate={hypothecaRates?.affiche_fixe_5ans}
            fetchedAt={hypothecaRates?.fetchedAt}
          />
        </div>

        <div
          class="outils-panel"
          id="panel-penalite"
          role="tabpanel"
          aria-labelledby="tab-penalite"
          data-panel="penalite"
          hidden
        >
          <PenaliteCalculator
            config={config}
            tauxMarcheDefaut={tauxMarcheDefaut}
            dateMaj={dateMaj}
            groupes={groupes}
          />
          <div class="outil-standalone-link">
            <a href="/outils/calculateur-penalite-hypothecaire">📄 Voir en pleine page →</a>
          </div>
        </div>

        <div
          class="outils-panel"
          id="panel-refinancement"
          role="tabpanel"
          aria-labelledby="tab-refinancement"
          data-panel="refinancement"
          hidden
        >
          <RefinancementSimulator defaultRate={defaultRate} />
        </div>

        <div
          class="outils-panel"
          id="panel-droits-mutation"
          role="tabpanel"
          aria-labelledby="tab-droits-mutation"
          data-panel="droits-mutation"
          hidden
        >
          <DroitsMutationCalculator />
        </div>
      </div>
    </section>

    <!-- FAQ sur les calculateurs (contenu visible = balisage FAQPage dans <head>) -->
    <section id="outils-faq">
      <div class="section-inner" style="max-width:820px">
        <div class="outils-faq-header">
          <span class="section-tag">FAQ — Calculateurs</span>
          <h2 class="outils-faq-title">Questions fréquentes sur les outils</h2>
        </div>
        <div class="outils-faq-list">
          {outilsFaq.map((item, i) => (
            <details class="outils-faq-item" name="outils-faq" open={i === 0}>
              <summary>
                <span>{item.q}</span>
                <span class="outils-faq-icon" aria-hidden="true">+</span>
              </summary>
              <div class="outils-faq-answer" set:html={item.a} />
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Mini contact — conversion post-outils -->
    <section id="outils-contact" class="fade-up">
      <div class="section-inner" style="max-width:680px">
        <div class="outils-contact-card">

          <!-- Bandeau de confiance -->
          <div class="outils-contact-trust">
            <Image
              src={stephaniePhoto}
              alt={prenom}
              width={56}
              height={56}
              loading="lazy"
              decoding="async"
              class="outils-contact-photo"
            />
            <div class="outils-contact-trust-text">
              <strong>Je vous réponds personnellement.</strong>
              <span>Réponse dans les meilleurs délais. Gratuit, sans engagement.</span>
            </div>
          </div>

          <h3 class="outils-contact-title">On en parle&nbsp;?</h3>
          <p class="outils-contact-sub">
            Vous avez vos chiffres en tête — {prenom} peut vous aider à passer à l'action.
          </p>

          <form
            name="contact-outils"
            class="outils-contact-form"
            novalidate
          >
            <!-- Champ peuplé par JS avec les données du simulateur actif -->
            <input type="hidden" name="simulateur-donnees" id="hidden-simulateur-donnees" />
            <div style="display:none" aria-hidden="true">
              <label>Ne pas remplir : <input name="bot-field" tabindex="-1" /></label>
            </div>

            <div class="outils-contact-fields">
              <label class="outils-contact-label" for="outils-prenom">Nom et prénom <span class="cform-required" aria-hidden="true">*</span></label>
              <input type="text" id="outils-prenom" name="prenom" placeholder="Marie Tremblay" required autocomplete="name" class="outils-contact-input" />

              <label class="outils-contact-label" for="outils-email">Courriel <span class="cform-required" aria-hidden="true">*</span></label>
              <input type="email" id="outils-email" name="email" placeholder="marie@exemple.com" required autocomplete="email" class="outils-contact-input" />

              <label class="outils-contact-label" for="outils-tel">Téléphone <span class="cform-required" id="outils-tel-required" aria-hidden="true">*</span></label>
              <input type="tel" id="outils-tel" name="telephone" placeholder="514 000-0000" inputmode="tel" autocomplete="tel" class="outils-contact-input" />

              <fieldset class="outils-contact-pref-fieldset">
                <legend class="outils-contact-label">Préférence de communication</legend>
                <div class="outils-contact-pref-group">
                  <input type="radio" name="pref-communication" id="pref-courriel" value="courriel" checked />
                  <label for="pref-courriel" class="outils-contact-pref-pill">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                    Courriel
                  </label>
                  <input type="radio" name="pref-communication" id="pref-appel" value="appel" />
                  <label for="pref-appel" class="outils-contact-pref-pill">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                    Appel
                  </label>
                  <input type="radio" name="pref-communication" id="pref-texto" value="texto" />
                  <label for="pref-texto" class="outils-contact-pref-pill">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                    Texto
                  </label>
                </div>
              </fieldset>

              <label class="outils-contact-label" for="outils-message">Message <span class="cform-optional">(facultatif)</span></label>

              <!-- Carte récapitulative de simulation (read-only, dismissible) -->
              <div class="outils-simulation-card" id="outils-simulation-card" hidden>
                <div class="outils-simulation-card-header">
                  <span class="outils-simulation-card-icon" aria-hidden="true">📎</span>
                  <span class="outils-simulation-card-title">Vos résultats sont joints</span>
                  <button type="button" class="outils-simulation-card-close" id="outils-simulation-card-close" aria-label="Retirer la simulation de ma demande">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  </button>
                </div>
                <dl class="outils-simulation-card-dl" id="outils-simulation-card-dl"></dl>
                <p class="outils-simulation-card-hint">Ces données seront envoyées avec votre message pour une réponse plus précise.</p>
              </div>
              <!-- Undo : affiché après retrait de la carte (données gardées en mémoire) -->
              <div class="outils-simulation-undo" id="outils-simulation-undo" hidden>
                <span class="outils-simulation-undo-text">Simulation retirée.</span>
                <button type="button" class="outils-simulation-undo-btn" id="outils-simulation-undo-btn">Rejoindre à nouveau</button>
              </div>
              <!-- Données techniques complètes (ratios inclus) → cachées du client -->
              <input type="hidden" name="simulation-brute" id="hidden-simulation-brute" />

              <textarea id="outils-message" name="message" placeholder="Dites-nous en quelques mots votre projet ou votre question…" rows="2" class="outils-contact-input"></textarea>

              <div class="outils-contact-consents">
                <label class="outils-consent-label">
                  <input type="checkbox" name="consentement-lcap" class="outils-consent-check" />
                  <span>Je consens à recevoir des communications électroniques de Stéphanie Weyman (conseils hypothécaires, guides et ressources) — conformément à la LCAP.</span>
                </label>
              </div>

              <button type="submit" class="btn-cta btn-cta--block">
                <span>Valider mes chiffres avec {prenom}</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </button>
              <p class="outils-contact-note">En envoyant ce formulaire, vous acceptez d'être recontacté·e au sujet de votre demande. Vos données ne sont jamais partagées — voir la <a href="/confidentialite">politique de confidentialité</a>.</p>
            </div>
          </form>

          <p id="outils-contact-status" class="outils-contact-status" role="status" aria-live="polite" hidden></p>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script>
    document.documentElement.classList.add('js-enabled');

    const tablist = document.querySelector<HTMLElement>('.outils-tablist');
    const tabs = Array.from(
      document.querySelectorAll<HTMLButtonElement>('button.outils-tab')
    );
    const panels = Array.from(
      document.querySelectorAll<HTMLElement>('.outils-panel')
    );

    // Déclaré tôt : activate() (appelée dès le chargement si l'URL a un hash)
    // invoque prefillMessageFromSession() qui dépend de ces éléments.
    const messageTextarea = document.getElementById('outils-message') as HTMLTextAreaElement;
    // Données de simulation sauvegardées en mémoire pour le undo (déclaré tôt
    // pour éviter une TDZ — prefillMessageFromSession() est appelée par activate()).
    let savedSimulationRaw: string | null = null;

    // Ajuste la hauteur du textarea à son contenu (utile en mobile où la poignée
    // de redimensionnement n'est pas accessible).
    function autoGrowMessage() {
      if (!messageTextarea) return;
      messageTextarea.style.height = 'auto';
      messageTextarea.style.height = Math.min(messageTextarea.scrollHeight, 420) + 'px';
    }

    // Auto-grow au fil de la frappe
    if (messageTextarea) {
      messageTextarea.addEventListener('input', autoGrowMessage);
    }

    function activeTabId(): string | null {
      const t = tabs.find((tab) => tab.getAttribute('aria-selected') === 'true');
      return t?.dataset.tab ?? null;
    }

    function activate(tabId: string, focus = false) {
      const targetTab = tabs.find((t) => t.dataset.tab === tabId);
      if (!targetTab) return;

      tabs.forEach((tab) => {
        const active = tab === targetTab;
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
        tab.setAttribute('tabindex', active ? '0' : '-1');
        tab.classList.toggle('active', active);
      });
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.panel !== tabId;
      });

      if (focus) targetTab.focus();

      const newHash = `#${tabId}`;
      if (window.location.hash !== newHash) {
        history.replaceState(null, '', `${window.location.pathname}${newHash}`);
      }

      // Mettre à jour le champ message avec les résultats du calculateur actif
      prefillMessageFromSession();
    }

    function tabIdFromHash(): string | null {
      const hash = window.location.hash.replace('#', '');
      if (!hash) return null;
      return tabs.some((t) => t.dataset.tab === hash) ? hash : null;
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const id = tab.dataset.tab;
        if (id) activate(id);
      });
    });

    tablist?.addEventListener('keydown', (e) => {
      const key = (e as KeyboardEvent).key;
      if (key !== 'ArrowLeft' && key !== 'ArrowRight' && key !== 'Home' && key !== 'End') return;
      e.preventDefault();
      const current = tabs.findIndex((t) => t.getAttribute('aria-selected') === 'true');
      let next = current;
      if (key === 'ArrowRight') next = (current + 1) % tabs.length;
      else if (key === 'ArrowLeft') next = (current - 1 + tabs.length) % tabs.length;
      else if (key === 'Home') next = 0;
      else if (key === 'End') next = tabs.length - 1;
      const id = tabs[next]?.dataset.tab;
      if (id) activate(id, true);
    });

    window.addEventListener('hashchange', () => {
      const id = tabIdFromHash();
      if (id) activate(id);
    });

    const initial = tabIdFromHash();
    if (initial) {
      activate(initial);
    } else {
      // Add .active on the first tab so iOS Safari repaints the selected state
      // (aria-selected from SSR HTML alone doesn't always trigger a repaint on first paint)
      tabs[0]?.classList.add('active');
    }

    // Fade-up fallback (même logique que la page d'accueil)
    const animClasses = ['.fade-up', '.fade-left', '.fade-right', '.scale-in', '.stagger-children'];
    const animEls = document.querySelectorAll(animClasses.join(','));
    const obs = new IntersectionObserver(
      (entries) =>
        entries.forEach((x) => {
          if (x.isIntersecting) {
            x.target.classList.add('visible');
            obs.unobserve(x.target);
          }
        }),
      { threshold: 0.12 }
    );
    animEls.forEach((el) => obs.observe(el));
    window.setTimeout(() => {
      animEls.forEach((el) => el.classList.add('visible'));
    }, 1200);

    // --- Préférence de communication (radios natifs) ---
    const telInput = document.getElementById('outils-tel') as HTMLInputElement;
    const telRequiredAsterisk = document.getElementById('outils-tel-required');
    const prefRadios = document.querySelectorAll<HTMLInputElement>('input[name="pref-communication"]');

    function updateTelRequired() {
      const checked = Array.from(prefRadios).find((r) => r.checked);
      const pref = checked?.value ?? 'courriel';
      const telRequis = pref === 'appel' || pref === 'texto';
      if (telInput) {
        if (telRequis) {
          telInput.setAttribute('required', '');
        } else {
          telInput.removeAttribute('required');
          telInput.classList.remove('cform-error');
        }
      }
      if (telRequiredAsterisk) {
        telRequiredAsterisk.hidden = !telRequis;
      }
    }

    prefRadios.forEach((radio) => {
      radio.addEventListener('change', updateTelRequired);
    });

    // --- Pré-remplissage : carte récapitulative (plus de dump dans le textarea) ---
    const simulationCard = document.getElementById('outils-simulation-card') as HTMLElement;
    const simulationCardDl = document.getElementById('outils-simulation-card-dl') as HTMLElement;
    const simulationCardClose = document.getElementById('outils-simulation-card-close') as HTMLButtonElement;
    const simulationUndo = document.getElementById('outils-simulation-undo') as HTMLElement;
    const simulationUndoBtn = document.getElementById('outils-simulation-undo-btn') as HTMLButtonElement;
    const simulationBruteInput = document.getElementById('hidden-simulation-brute') as HTMLInputElement;

    // Paires clé→valeur à afficher dans la carte, dans l'ordre.
    // Les clés absentes de cette liste sont masquées au client (ex. ratios ABD/ATD)
    // mais conservées dans le champ hidden.
    const CLIENT_KEYS: string[] = [
      'Prix max', 'Prix', 'Montant', 'Prêt', 'Prêt assuré', 'Prêt conventionnel',
      'Revenu annuel', 'Mise de fonds', 'Taux', 'Taux succursale', 'Taux négocié',
      'Versement', 'Paiement mensuel', 'Économie mensuelle', 'Verdict',
      'Pénalité estimée', 'Prêteur', 'Droits estimés', 'Municipalité',
    ];

    const TYPE_LABELS: Record<string, string> = {
      'calculateur': 'Calculateur de versement',
      'simulateur': "Simulateur d'emprunt",
      'comparateur': 'Comparateur de taux',
      'penalite': 'Calculateur de pénalité',
      'refinancement': 'Simulateur de refinancement',
      'droits-mutation': 'Droits de mutation',
    };

    function buildSimulationCard(raw: string) {
      if (!simulationCard || !simulationCardDl || !simulationBruteInput) return;

      // Stocker TOUTES les données techniques dans le champ hidden (ratios inclus)
      simulationBruteInput.value = raw;

      // Parser le résultat : "Clé : valeur, Clé : valeur, …"
      const pairs: { key: string; value: string }[] = [];
      const parts = raw.split(/, (?=[A-ZÀ-Ý])/);
      for (const part of parts) {
        const colonIdx = part.indexOf(' : ');
        if (colonIdx === -1) continue;
        const key = part.slice(0, colonIdx).trim();
        const value = part.slice(colonIdx + 3).trim();
        pairs.push({ key, value });
      }

      // Filtrer pour n'afficher que les clés pertinentes au client
      const visible = pairs.filter((p) => CLIENT_KEYS.some((k) => p.key === k || p.key.startsWith(k + ' ')));

      if (visible.length === 0) {
        simulationCard.hidden = true;
        return;
      }

      simulationCardDl.innerHTML = visible
        .map((p) => `<div><dt>${escapeHtml(p.key)}</dt><dd>${escapeHtml(p.value)}</dd></div>`)
        .join('');

      simulationCard.hidden = false;
      if (simulationUndo) simulationUndo.hidden = true;
      savedSimulationRaw = null; // plus en mode « retirée »
    }

    function escapeHtml(s: string): string {
      return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    // Retirer la carte : vide le hidden field, sauvegarde en mémoire, affiche l'undo
    function dismissSimulationCard() {
      if (!simulationCard || !simulationBruteInput) return;
      // Sauvegarder en mémoire avant de vider le champ
      if (simulationBruteInput.value) {
        savedSimulationRaw = simulationBruteInput.value;
      }
      simulationBruteInput.value = '';
      simulationCard.hidden = true;
      if (simulationCardDl) simulationCardDl.innerHTML = '';
      if (simulationUndo) {
        simulationUndo.hidden = false;
        // Déplacer le focus sur « Rejoindre à nouveau » pour éviter de perdre
        // le focus clavier sur un élément qui n'est plus visible
        if (simulationUndoBtn) simulationUndoBtn.focus();
      }
    }

    // Restaurer la carte depuis la mémoire
    function undoSilulationCard() {
      if (!savedSimulationRaw) return;
      buildSimulationCard(savedSimulationRaw);
    }

    simulationCardClose?.addEventListener('click', dismissSimulationCard);
    simulationUndoBtn?.addEventListener('click', undoSilulationCard);

    // Remplacer l'ancienne fonction : elle peuple maintenant la carte, pas le textarea
    function prefillMessageFromSession() {
      // Si l'utilisateur a retiré la carte manuellement (undo visible), ne pas écraser
      if (savedSimulationRaw !== null) return;
      try {
        const id = activeTabId();
        const raw = id ? sessionStorage.getItem('simulation-resultat:' + id) : null;
        if (!raw) {
          // Aucune donnée : masquer la carte sans afficher l'undo
          if (simulationCard) simulationCard.hidden = true;
          if (simulationCardDl) simulationCardDl.innerHTML = '';
          if (simulationBruteInput) simulationBruteInput.value = '';
          if (simulationUndo) simulationUndo.hidden = true;
          savedSimulationRaw = null;
          return;
        }
        const data = JSON.parse(raw);
        if (data && data.resultat && data.type) {
          const typeLisible = TYPE_LABELS[data.type] ?? data.type;
          const dateLisible = data.date
            ? new Date(data.date).toLocaleString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' })
            : '';
          const details = String(data.resultat).replace(/^.*?\s—\s/, '');
          const header = dateLisible ? `${typeLisible} — ${dateLisible}` : typeLisible;
          buildSimulationCard(`${header} : ${details}`);
        }
      } catch (e) { /* ignore */ }
    }
    prefillMessageFromSession();

    // Rafraîchir le résumé quand l'utilisateur atteint le formulaire (parcours
    // « un seul calculateur » : sessionStorage est écrit après le chargement,
    // sans changement d'onglet pour redéclencher le préremplissage).
    const contactSection = document.getElementById('outils-contact');
    if (contactSection && 'IntersectionObserver' in window) {
      const msgObs = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) prefillMessageFromSession();
        });
      }, { threshold: 0.2 });
      msgObs.observe(contactSection);
    }
    messageTextarea?.addEventListener('focus', prefillMessageFromSession);

    // --- Capture d'écran + données calculateur au submit ---
    const contactForm = document.querySelector<HTMLFormElement>('.outils-contact-form');
    const simulateurInput = document.getElementById('hidden-simulateur-donnees') as HTMLInputElement;
    const contactStatusEl = document.getElementById('outils-contact-status') as HTMLElement | null;

    function setContactStatus(state: 'error' | 'success' | null, msg: string) {
      if (!contactStatusEl) return;
      if (!state) { contactStatusEl.hidden = true; contactStatusEl.removeAttribute('data-state'); contactStatusEl.textContent = ''; return; }
      contactStatusEl.hidden = false;
      contactStatusEl.setAttribute('data-state', state);
      contactStatusEl.textContent = msg;
    }

    function getActiveTabLabel(): string {
      const activeTab = tabs.find((t) => t.getAttribute('aria-selected') === 'true');
      return activeTab?.textContent?.trim() ?? 'Outil hypothécaire';
    }

    function updateSimulateurDonnees() {
      if (!simulateurInput) return;
      const activePanel = panels.find((p) => !p.hidden);
      if (!activePanel) return;
      const label = getActiveTabLabel();
      const lines = (activePanel as HTMLElement).innerText
        .split('\n')
        .map((l) => l.trim())
        .filter((l) => l.length > 0);
      simulateurInput.value = `Outil utilisé : ${label}\n\n${lines.join('\n')}`;
    }

    const submitBtn = contactForm?.querySelector<HTMLButtonElement>('button[type="submit"]');
    const submitLabel = submitBtn?.querySelector('span');

    // Validation des champs obligatoires (présence + format email/téléphone)
    function validateRequiredFields(form: HTMLFormElement): boolean {
      const requiredFields = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[required]');
      let valid = true;
      requiredFields.forEach((field) => {
        const value = field.value.trim();
        let badFormat = false;
        if (value && field instanceof HTMLInputElement) {
          if (field.type === 'email') badFormat = !field.checkValidity();
          else if (field.type === 'tel') badFormat = (value.match(/\d/g) || []).length < 10;
        }
        if (!value || badFormat) {
          field.classList.add('cform-error');
          valid = false;
        } else {
          field.classList.remove('cform-error');
        }
      });
      if (!valid) {
        const firstError = form.querySelector<HTMLElement>('.cform-error');
        firstError?.focus();
      }
      return valid;
    }

    // Clear error styling on input
    document.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('.outils-contact-form [required]').forEach((el) => {
      el.addEventListener('input', () => el.classList.remove('cform-error'));
    });

    contactForm?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Valider les champs obligatoires avant la capture
      if (!validateRequiredFields(contactForm!)) return;

      // Verrouiller le bouton pour éviter une double soumission pendant la capture
      const originalLabel = submitLabel?.textContent ?? '';
      if (submitBtn) submitBtn.disabled = true;
      if (submitLabel) submitLabel.textContent = 'Envoi en cours…';
      setContactStatus(null, '');

      // Texte résumé
      updateSimulateurDonnees();

      // Capture d'écran du panneau actif
      let screenshotBase64 = '';
      const activePanel = panels.find((p) => !p.hidden) as HTMLElement | undefined;
      if (activePanel) {
        try {
          const { default: html2canvas } = await import('html2canvas');
          const canvas = await html2canvas(activePanel, {
            backgroundColor: '#fdfaf6',
            scale: 1.5,
            useCORS: true,
            logging: false,
          });
          const blob = await new Promise<Blob | null>((resolve) => {
            canvas.toBlob((b) => resolve(b), 'image/png', 0.9);
          });
          if (blob) {
            const dataUrl = await new Promise<string>((resolve, reject) => {
              const reader = new FileReader();
              reader.onloadend = () => resolve(reader.result as string);
              reader.onerror = reject;
              reader.readAsDataURL(blob);
            });
            screenshotBase64 = dataUrl.split(',')[1] || '';
          }
        } catch {
          // Ne pas bloquer le submit si la capture échoue
        }
      }

      const formData = new FormData(contactForm!);
      const payload: Record<string, string> = {};
      formData.forEach((value, key) => {
        payload[key] = typeof value === 'string' ? value : '';
      });
      payload['consentement-lcap'] = (document.querySelector('.outils-consent-check') as HTMLInputElement | null)?.checked ? 'true' : '';
      payload.screenshotBase64 = screenshotBase64;

      try {
        const res = await fetch('/api/outils-submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            ...payload,
            'consentement-lcap': payload['consentement-lcap'] === 'true',
          }),
        });
        if (!res.ok) throw new Error('Erreur ' + res.status);

        document.body.dataset.outilsConverted = 'true';
        window.dispatchEvent(new CustomEvent('outils:converted'));
        window.location.href = '/merci';
      } catch {
        setContactStatus('error', "Une erreur est survenue lors de l'envoi. Veuillez vérifier votre connexion et réessayer.");
        if (submitBtn) submitBtn.disabled = false;
        if (submitLabel) submitLabel.textContent = originalLabel;
      }
    });
  </script>

