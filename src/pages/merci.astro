---
import Layout from '../layouts/MainLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { loadSiteConfig } from '../config';

export const prerender = true;

const config = loadSiteConfig();
const prenom = config.nom.split(' ')[0] ?? 'Stéphanie';
---

<Layout
  title="Demande envoyée — Merci"
  description="Votre demande a bien été reçue. Stéphanie Weyman vous recontacte dans les meilleurs délais."
  noindex={true}
>
  <Nav />

  <!-- Conversion Google Ads (AW-18126348856) : le tag global est chargé après consentement par
       /js/consent.js → /js/gtag-init.js, qui le configure aussi sur cette page. Pas de tag dédié ici. -->


  <main id="main-content" class="merci-page">
    <section class="section-inner merci-inner">
      <div class="merci-card">
        <span class="merci-check" aria-hidden="true">✅</span>
        <h1 class="merci-title">Merci, votre demande est envoyée&nbsp;!</h1>
        <p class="merci-sub">
          {prenom} a bien reçu vos informations et vous recontacte dans les meilleurs délais —
          gratuit et sans engagement.
        </p>

        <div class="merci-actions">
          <a href="/rendez-vous" class="btn-cta" data-umami-event="cta_booking_merci">
            <span>Réserver un appel tout de suite</span>
          </a>
          {config.messenger_url && (
            <a href={config.messenger_url} target="_blank" rel="noopener noreferrer" class="merci-secondary">
              💬 Écrire sur Messenger
            </a>
          )}
        </div>

        <p class="merci-back">
          <a href="/outils">← Revenir aux calculateurs</a>
          <span aria-hidden="true">·</span>
          <a href="/">Accueil</a>
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .merci-page {
    background: var(--sand);
  }
  .merci-inner {
    display: flex;
    justify-content: center;
    padding-top: 4rem;
    padding-bottom: 5rem;
  }
  .merci-card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    padding: 3rem 2.2rem;
    max-width: 560px;
    text-align: center;
  }
  .merci-check {
    font-size: 2.6rem;
    line-height: 1;
    display: inline-block;
    margin-bottom: 1rem;
  }
  .merci-title {
    font-family: "Lora", serif;
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0 0 .75rem;
  }
  .merci-sub {
    font-size: 1rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0 0 2rem;
  }
  .merci-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .merci-secondary {
    color: var(--forest);
    font-weight: 600;
    text-decoration: none;
    font-size: .95rem;
  }
  .merci-secondary:hover {
    text-decoration: underline;
  }
  .merci-back {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: .6rem;
    font-size: .85rem;
    margin: 0;
  }
  .merci-back a {
    color: var(--clay);
    font-weight: 600;
    text-decoration: none;
  }
  .merci-back a:hover {
    text-decoration: underline;
  }
  .merci-back span {
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .merci-card {
      padding: 2.2rem 1.4rem;
    }
    .merci-title {
      font-size: 1.4rem;
    }
  }
</style>
