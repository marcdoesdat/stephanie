</style>

<script is:inline>
  (function () {
    var form = document.getElementById('demande-form');
    if (!form) return;

    var btn = document.getElementById('demande-submit');
    var label = form.querySelector('.demande-submit-label');
    var statusEl = document.getElementById('demande-status');
    var successEl = document.getElementById('demande-success');
    var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    var TEL_RE = /\d[\s.\-()]*\d[\s.\-()]*\d[\s.\-()]*\d[\s.\-()]*\d[\s.\-()]*\d[\s.\-()]*\d[\s.\-()]*\d[\s.\-()]*\d[\s.\-()]*\d/;

    // --- Conditional blocks ---
    function toggleBlock(radioName, blockId, showValue) {
      var radios = form.querySelectorAll('input[name="' + radioName + '"]');
      var block = document.getElementById(blockId);
      if (!block) return;
      function update() {
        var checked = form.querySelector('input[name="' + radioName + '"]:checked');
        block.style.display = (checked && checked.value === showValue) ? '' : 'none';
      }
      radios.forEach(function (r) { r.addEventListener('change', update); });
      update();
    }

    // Type de demande → refi block
    toggleBlock('type_demande', 'demande-refi-block', 'refinancement');

    // Co-emprunteur
    toggleBlock('co_emprunteur', 'demande-co-block', 'deux');

    // Situation logement → proprio block
    toggleBlock('situation_logement', 'demande-proprio-block', 'proprietaire');

    // Promesse d'achat
    toggleBlock('promesse_achat', 'demande-promesse-oui', 'oui');

    // Adresse < 3 ans → adresse précédente
    toggleBlock('adresse_3ans', 'demande-adresse-prev-group', 'non');

    // Type de propriété → condo / plex blocks
    var typePropriete = document.getElementById('demande-type-propriete');
    var condoBlock = document.getElementById('demande-condo-block');
    var plexBlock = document.getElementById('demande-plex-block');
    if (typePropriete) {
      typePropriete.addEventListener('change', function () {
        if (condoBlock) condoBlock.style.display = typePropriete.value === 'condo' ? '' : 'none';
        if (plexBlock) plexBlock.style.display = typePropriete.value === 'plex' ? '' : 'none';
      });
    }

    // --- Statut ---
    function setStatus(state, msg) {
      if (!statusEl) return;
      if (!state) { statusEl.hidden = true; statusEl.removeAttribute('data-state'); statusEl.textContent = ''; return; }
      statusEl.hidden = false;
      statusEl.setAttribute('data-state', state);
      statusEl.textContent = msg;
    }

    function fieldInvalid(el, invalid) {
      if (!el) return;
      if (invalid) el.setAttribute('aria-invalid', 'true');
      else el.removeAttribute('aria-invalid');
    }

    // --- Validation ---
    function getField(name) { return form.querySelector('[name="' + name + '"]'); }
    function val(name) { var el = getField(name); return el ? el.value.trim() : ''; }
    function radioVal(name) { var checked = form.querySelector('input[name="' + name + '"]:checked'); return checked ? checked.value : ''; }

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      // Clear previous errors
      form.querySelectorAll('[aria-invalid]').forEach(function (el) { el.removeAttribute('aria-invalid'); });

      var errors = [];
      function req(name, label) { if (!val(name)) { var el = getField(name); fieldInvalid(el, true); errors.push(label); } }

      // Section 1 — Type de demande
      if (!radioVal('type_demande')) { errors.push('Type de demande'); }
      if (radioVal('type_demande') === 'refinancement') {
        req('refi_solde', 'Solde hypothécaire');
        req('refi_valeur', 'Valeur estimée');
      }

      // Section 2 — Identité
      req('nom', 'Nom complet');
      req('naissance', 'Date de naissance');
      req('adresse', 'Adresse');
      req('ville', 'Ville');
      req('code_postal', 'Code postal');
      if (!radioVal('adresse_3ans')) { errors.push('Adresse — 3 ans'); }
      if (!val('statut_residence')) { var sr = getField('statut_residence'); fieldInvalid(sr, true); errors.push('Statut de résidence'); }
      if (!val('etat_civil')) { var ec = getField('etat_civil'); fieldInvalid(ec, true); errors.push('État civil'); }
      if (!TEL_RE.test(val('telephone'))) { var tel = getField('telephone'); fieldInvalid(tel, true); errors.push('Téléphone valide'); }
      if (!EMAIL_RE.test(val('courriel'))) { var em = getField('courriel'); fieldInvalid(em, true); errors.push('Courriel valide'); }

      // Section 3 — Co-emprunteur
      if (!radioVal('co_emprunteur')) { errors.push('Co-emprunteur'); }
      if (radioVal('co_emprunteur') === 'deux') {
        req('co_nom', 'Nom co-emprunteur');
        req('co_naissance', 'Date naissance co-emprunteur');
      }

      // Section 4 — Situation actuelle
      if (!radioVal('situation_logement')) { errors.push('Situation logement'); }

      // Section 5 — Emploi
      req('employeur', 'Employeur');
      req('titre_poste', 'Titre du poste');
      if (!val('statut_emploi')) { var se = getField('statut_emploi'); fieldInvalid(se, true); errors.push('Statut d\'emploi'); }
      if (!val('anciennete')) { var anc = getField('anciennete'); fieldInvalid(anc, true); errors.push('Ancienneté'); }
      req('revenu_base', 'Revenu annuel brut');

      // Section 6 — Crédit
      if (!radioVal('auto_evaluation_credit')) { errors.push('Auto-évaluation crédit'); }

      // Section 7 — Mise de fonds (sauf si refinancement)
      if (radioVal('type_demande') !== 'refinancement') {
        req('mise_montant', 'Mise de fonds');
        if (!val('source_fonds')) { var sf = getField('source_fonds'); fieldInvalid(sf, true); errors.push('Source des fonds'); }
        if (!radioVal('fonds_90jours')) { errors.push('Fonds — 90 jours'); }
      }

      // Section 9 — Préférences
      if (!radioVal('pref_taux')) { errors.push('Préférence taux'); }

      // Section 10 — Propriété
      if (!radioVal('promesse_achat')) { errors.push('Promesse d\'achat'); }

      // Final consent
      var consentFinal = document.getElementById('demande-consent-final');
      if (consentFinal && !consentFinal.checked) { errors.push('Consentement final'); }

      if (errors.length > 0) {
        setStatus('error', 'Veuillez remplir les champs requis : ' + errors.slice(0, 5).join(', ') + (errors.length > 5 ? '…' : ''));
        var firstError = form.querySelector('[aria-invalid]');
        if (firstError && firstError.focus) firstError.focus();
        if (firstError && firstError.scrollIntoView) firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }

      if (!btn) return;
      btn.disabled = true;
      if (label) label.textContent = 'Envoi en cours…';
      setStatus('sending', 'Envoi de votre demande…');

      var formData = new FormData(form);
      var payload = {};
      formData.forEach(function (value, key) {
        var v = typeof value === 'string' ? value : '';
        if (Object.prototype.hasOwnProperty.call(payload, key)) {
          if (Array.isArray(payload[key])) payload[key].push(v);
          else payload[key] = [payload[key], v];
        } else {
          payload[key] = v;
        }
      });
      payload.consentement = !!(consentFinal && consentFinal.checked);

      fetch('/api/demande-submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      })
        .then(function (res) {
          if (!res.ok) throw new Error('Erreur ' + res.status);
          form.reset();
          form.hidden = true;
          setStatus(null);
          if (successEl) {
            successEl.hidden = false;
            var firstFocusable = successEl.querySelector('a, button, [tabindex]');
            if (firstFocusable && firstFocusable.focus) firstFocusable.focus();
            successEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        })
        .catch(function () {
          if (btn) btn.disabled = false;
          if (label) label.textContent = 'Envoyer ma demande';
          setStatus('error', "Une erreur est survenue lors de l'envoi. Veuillez vérifier votre connexion et réessayer.");
        });
    });
  })();
</script>
