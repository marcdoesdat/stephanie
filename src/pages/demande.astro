---
export const prerender = true;

import MainLayout from '../layouts/MainLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import MessengerBtn from '../components/MessengerBtn.astro';
import { loadSiteConfig } from '../config';

const config = loadSiteConfig();
const prenom = config.nom.split(' ')[0];
---

<MainLayout
  title="Demande de financement hypothécaire"
  description="Nouvel achat ou refinancement — remplissez ce formulaire et Stéphanie Weyman, courtière hypothécaire, analysera votre dossier gratuitement. Diagnostic personnalisé, sans engagement."
  noindex={true}
>
  <MessengerBtn />
  <Nav />

  <main id="main-content">
    <section class="demande-section">
      <div class="section-inner demande-inner">

        <div class="demande-intro fade-up">
          <div class="section-tag">Nouvel achat · Refinancement</div>
          <h1 class="section-title">Votre projet <em>commence ici</em></h1>
          <p class="section-sub">
            Chaque champ est une pièce du casse-tête. Plus vous m'en donnez, plus je peux vous revenir avec une réponse précise — et vite.
            Tout est <strong>strictement confidentiel</strong>. Aucune enquête de crédit n'est lancée sans votre consentement écrit.
          </p>
        </div>

        <div class="demande-card fade-up">
          <form id="demande-form" name="demande" novalidate>
            <!-- Honeypot anti-spam -->
            <div class="demande-hp" aria-hidden="true">
              <label>Ne pas remplir <input type="text" name="company" tabindex="-1" autocomplete="off" /></label>
            </div>

            <!-- ================================================================ -->
            <!-- SECTION 1 : Type de demande                                      -->
            <!-- ================================================================ -->
            <fieldset class="demande-fieldset">
              <legend class="demande-legend"><span class="demande-step-num">1</span> Type de demande</legend>
              <p class="demande-legend-sub">Nouvel achat ou refinancement ? Le formulaire s'adaptera selon votre réponse.</p>

              <div class="demande-field">
                <label>Vous souhaitez : <span class="demande-req">*</span></label>
                <div class="demande-radio-group">
                  <label class="demande-radio-label"><input type="radio" name="type_demande" value="achat" required /> <strong>Nouvel achat</strong> — acheter une propriété</label>
                  <label class="demande-radio-label"><input type="radio" name="type_demande" value="refinancement" /> <strong>Refinancement</strong> — refinancer ou renouveler mon prêt actuel</label>
                </div>
              </div>

              <div id="demande-refi-block" style="display:none;">
                <div class="demande-row">
                  <div class="demande-field">
                    <label for="demande-refi-solde">Solde hypothécaire actuel ($) <span class="demande-req">*</span></label>
                    <input type="text" id="demande-refi-solde" name="refi_solde" inputmode="numeric" placeholder="250 000" />
                  </div>
                  <div class="demande-field">
                    <label for="demande-refi-valeur">Valeur estimée de la propriété ($) <span class="demande-req">*</span></label>
                    <input type="text" id="demande-refi-valeur" name="refi_valeur" inputmode="numeric" placeholder="450 000" />
                  </div>
                </div>
                <div class="demande-row">
                  <div class="demande-field">
                    <label for="demande-refi-preteur">Prêteur actuel</label>
                    <input type="text" id="demande-refi-preteur" name="refi_preteur" placeholder="Ex. Desjardins, BMO, RBC…" />
                  </div>
                  <div class="demande-field">
                    <label for="demande-refi-echeance">Date d'échéance du terme</label>
                    <input type="month" id="demande-refi-echeance" name="refi_echeance" />
                  </div>
                </div>
                <div class="demande-field">
                  <label>But du refinancement</label>
                  <div class="demande-checklist">
                    <label class="demande-check-label"><input type="checkbox" name="refi_but" value="consolidation" /> Consolidation de dettes</label>
                    <label class="demande-check-label"><input type="checkbox" name="refi_but" value="renos" /> Rénovations</label>
                    <label class="demande-check-label"><input type="checkbox" name="refi_but" value="equite" /> Libération d'équité (projet, investissement)</label>
                    <label class="demande-check-label"><input type="checkbox" name="refi_but" value="meilleur_taux" /> Meilleur taux ou conditions</label>
                    <label class="demande-check-label"><input type="checkbox" name="refi_but" value="autre" /> Autre</label>
                  </div>
                </div>
              </div>
            </fieldset>

            <!-- ================================================================ -->
            <!-- SECTION 2 : Identité et situation personnelle                    -->
            <!-- ================================================================ -->
            <fieldset class="demande-fieldset">
              <legend class="demande-legend"><span class="demande-step-num">2</span> Identité et situation personnelle</legend>
              <p class="demande-legend-sub">Stéphanie doit d'abord savoir à qui elle a affaire — pour des raisons légales et pour préparer l'enquête de crédit.</p>

              <div class="demande-field">
                <label for="demande-nom">Nom complet <span class="demande-req">*</span></label>
                <input type="text" id="demande-nom" name="nom" required autocomplete="name" placeholder="Marie Tremblay" />
              </div>

              <div class="demande-field">
                <label for="demande-naissance">Date de naissance <span class="demande-req">*</span></label>
                <input type="date" id="demande-naissance" name="naissance" required autocomplete="bday" />
              </div>

              <div class="demande-field">
                <label for="demande-adresse">Adresse actuelle <span class="demande-req">*</span></label>
                <input type="text" id="demande-adresse" name="adresse" required autocomplete="street-address" placeholder="123 rue Principale, app. 4" />
              </div>

              <div class="demande-row demande-row--3col">
                <div class="demande-field">
                  <label for="demande-ville">Ville <span class="demande-req">*</span></label>
                  <input type="text" id="demande-ville" name="ville" required autocomplete="address-level2" placeholder="Repentigny" />
                </div>
                <div class="demande-field">
                  <label for="demande-code-postal">Code postal <span class="demande-req">*</span></label>
                  <input type="text" id="demande-code-postal" name="code_postal" required autocomplete="postal-code" placeholder="J5Y 1A1" maxlength="7" />
                </div>
                <div class="demande-field">
                  <label for="demande-province">Province</label>
                  <input type="text" id="demande-province" name="province" value="Québec" readonly class="demande-readonly" />
                </div>
              </div>

              <div class="demande-field">
                <label>Habitez-vous à cette adresse depuis plus de 3 ans ? <span class="demande-req">*</span></label>
                <div class="demande-radio-group">
                  <label class="demande-radio-label"><input type="radio" name="adresse_3ans" value="oui" required /> Oui</label>
                  <label class="demande-radio-label"><input type="radio" name="adresse_3ans" value="non" /> Non</label>
                </div>
              </div>

              <div class="demande-field" id="demande-adresse-prev-group" style="display:none;">
                <label for="demande-adresse-prev">Adresse précédente</label>
                <input type="text" id="demande-adresse-prev" name="adresse_precedente" autocomplete="street-address" placeholder="Adresse complète où vous habitiez avant" />
              </div>

              <div class="demande-row">
                <div class="demande-field">
                  <label for="demande-statut-residence">Statut de résidence <span class="demande-req">*</span></label>
                  <select id="demande-statut-residence" name="statut_residence" required>
                    <option value="" disabled selected>Choisir…</option>
                    <option value="citoyen">Citoyen·ne canadien·ne</option>
                    <option value="resident_permanent">Résident·e permanent·e</option>
                    <option value="permis_travail">Permis de travail</option>
                    <option value="autre_statut">Autre</option>
                  </select>
                  <small class="demande-field-hint">Détermine les programmes admissibles et la mise de fonds minimale.</small>
                </div>
                <div class="demande-field">
                  <label for="demande-etat-civil">État civil <span class="demande-req">*</span></label>
                  <select id="demande-etat-civil" name="etat_civil" required>
                    <option value="" disabled selected>Choisir…</option>
                    <option value="celibataire">Célibataire</option>
                    <option value="marie">Marié·e</option>
                    <option value="conjoint_fait">Conjoint·e de fait</option>
                    <option value="divorce">Divorcé·e</option>
                    <option value="veuf">Veuf·ve</option>
                  </select>
                </div>
              </div>

              <div class="demande-field demande-field--nas-note">
                <p class="demande-nas-info">🔒 <strong>Numéro d'assurance sociale (NAS)</strong> — sera demandé de façon sécurisée lors de l'appel. Aucune donnée sensible ne transite par ce formulaire.</p>
              </div>

              <div class="demande-row">
                <div class="demande-field">
                  <label for="demande-tel">Téléphone <span class="demande-req">*</span></label>
                  <input type="tel" id="demande-tel" name="telephone" required autocomplete="tel" placeholder="514 000-0000" />
                </div>
                <div class="demande-field">
                  <label for="demande-courriel">Courriel <span class="demande-req">*</span></label>
                  <input type="email" id="demande-courriel" name="courriel" required autocomplete="email" placeholder="marie@exemple.com" />
                </div>
              </div>
            </fieldset>

            <!-- ================================================================ -->
            <!-- SECTION 3 : Co-emprunteur                                        -->
            <!-- ================================================================ -->
            <fieldset class="demande-fieldset">
              <legend class="demande-legend"><span class="demande-step-num">3</span> Co-emprunteur</legend>
              <p class="demande-legend-sub">La majorité des achats se font à deux. Si vous achetez ou refinancez avec quelqu'un, remplissez cette section.</p>

              <div class="demande-field">
                <label>Vous achetez / refinancez : <span class="demande-req">*</span></label>
                <div class="demande-radio-group">
                  <label class="demande-radio-label"><input type="radio" name="co_emprunteur" value="seul" required /> Seul·e</label>
                  <label class="demande-radio-label"><input type="radio" name="co_emprunteur" value="deux" /> À deux</label>
                </div>
              </div>

              <div id="demande-co-block" style="display:none;">
                <p class="demande-legend-sub" style="margin-top:.5rem;">Informations du co-emprunteur</p>

                <div class="demande-row">
                  <div class="demande-field">
                    <label for="demande-co-nom">Nom complet du co-emprunteur <span class="demande-req">*</span></label>
                    <input type="text" id="demande-co-nom" name="co_nom" autocomplete="name" placeholder="Jean Tremblay" />
                  </div>
                  <div class="demande-field">
                    <label for="demande-co-naissance">Date de naissance <span class="demande-req">*</span></label>
                    <input type="date" id="demande-co-naissance" name="co_naissance" autocomplete="bday" />
                  </div>
                </div>

                <div class="demande-row">
                  <div class="demande-field">
                    <label for="demande-co-statut-emploi">Statut d'emploi</label>
                    <select id="demande-co-statut-emploi" name="co_statut_emploi">
                      <option value="" disabled selected>Choisir…</option>
                      <option value="salarie">Salarié·e (T4)</option>
                      <option value="travailleur_autonome">Travailleur·e autonome</option>
                      <option value="commission">À commission</option>
                      <option value="contractuel">Contractuel·le</option>
                      <option value="sans_emploi">Sans emploi actuellement</option>
                    </select>
                  </div>
                  <div class="demande-field">
                    <label for="demande-co-revenu">Revenu annuel brut ($)</label>
                    <input type="text" id="demande-co-revenu" name="co_revenu" inputmode="numeric" placeholder="65 000" />
                  </div>
                </div>
                <p class="demande-nas-info" style="font-size:.72rem;">🔒 NAS du co-emprunteur — demandé de façon sécurisée lors de l'appel.</p>
              </div>
            </fieldset>

            <!-- ================================================================ -->
            <!-- SECTION 4 : Situation actuelle                                   -->
            <!-- ================================================================ -->
            <fieldset class="demande-fieldset">
              <legend class="demande-legend"><span class="demande-step-num">4</span> Situation actuelle</legend>

              <div class="demande-row">
                <div class="demande-field">
                  <label>Vous êtes actuellement : <span class="demande-req">*</span></label>
                  <div class="demande-radio-group">
                    <label class="demande-radio-label"><input type="radio" name="situation_logement" value="locataire" required /> Locataire</label>
                    <label class="demande-radio-label"><input type="radio" name="situation_logement" value="proprietaire" /> Propriétaire</label>
                    <label class="demande-radio-label"><input type="radio" name="situation_logement" value="famille" /> Habite chez la famille / ami</label>
                  </div>
                </div>
                <div class="demande-field">
                  <label for="demande-paiement-actuel">Loyer ou paiement hypothécaire actuel ($/mois)</label>
                  <input type="text" id="demande-paiement-actuel" name="paiement_actuel" inputmode="numeric" placeholder="1 200" />
                </div>
              </div>

              <div id="demande-proprio-block" style="display:none;">
                <div class="demande-field">
                  <label>Prévoyez-vous vendre votre propriété actuelle ?</label>
                  <div class="demande-radio-group">
                    <label class="demande-radio-label"><input type="radio" name="vente_propriete" value="oui" /> Oui — achat-vente simultané</label>
                    <label class="demande-radio-label"><input type="radio" name="vente_propriete" value="non" /> Non — je la conserve</label>
                  </div>
                </div>
              </div>

              <div class="demande-field">
                <label>Êtes-vous premier acheteur ?</label>
                <div class="demande-radio-group">
                  <label class="demande-radio-label"><input type="radio" name="premier_acheteur" value="oui" /> Oui — première propriété</label>
                  <label class="demande-radio-label"><input type="radio" name="premier_acheteur" value="non" /> Non — j'ai déjà été propriétaire</label>
                </div>
                <small class="demande-field-hint">Détermine l'admissibilité au RAP, CELIAPP, crédit d'impôt et exemptions de droits de mutation.</small>
              </div>
            </fieldset>

            <!-- ================================================================ -->
            <!-- SECTION 5 : Emploi et revenus                                    -->
            <!-- ================================================================ -->
            <fieldset class="demande-fieldset">
              <legend class="demande-legend"><span class="demande-step-num">5</span> Emploi et revenus</legend>
              <p class="demande-legend-sub">Les prêteurs veulent s'assurer de la stabilité de vos revenus. Ces informations déterminent votre capacité d'emprunt.</p>

              <div class="demande-row">
                <div class="demande-field">
                  <label for="demande-employeur">Employeur <span class="demande-req">*</span></label>
                  <input type="text" id="demande-employeur" name="employeur" required autocomplete="organization" placeholder="Ex. Desjardins, Shopify…" />
                </div>
                <div class="demande-field">
                  <label for="demande-titre-poste">Titre du poste <span class="demande-req">*</span></label>
                  <input type="text" id="demande-titre-poste" name="titre_poste" required autocomplete="organization-title" placeholder="Ex. Analyste financier…" />
                </div>
              </div>

              <div class="demande-row">
                <div class="demande-field">
                  <label for="demande-statut-emploi">Statut d'emploi <span class="demande-req">*</span></label>
                  <select id="demande-statut-emploi" name="statut_emploi" required>
                    <option value="" disabled selected>Choisir…</option>
                    <option value="salarie">Salarié·e (T4)</option>
                    <option value="travailleur_autonome">Travailleur·e autonome</option>
                    <option value="commission">À commission</option>
                    <option value="contractuel">Contractuel·le</option>
                    <option value="sans_emploi">Sans emploi actuellement</option>
                  </select>
                </div>
                <div class="demande-field">
                  <label for="demande-anciennete">Ancienneté chez l'employeur actuel <span class="demande-req">*</span></label>
                  <select id="demande-anciennete" name="anciennete" required>
                    <option value="" disabled selected>Choisir…</option>
                    <option value="moins_6mois">Moins de 6 mois</option>
                    <option value="6mois_1an">6 mois à 1 an</option>
                    <option value="1a_2ans">1 à 2 ans</option>
                    <option value="2a_5ans">2 à 5 ans</option>
                    <option value="5ans_plus">Plus de 5 ans</option>
                    <option value="travailleur_autonome">Travailleur autonome (précisez années ci-dessous)</option>
                  </select>
                  <small class="demande-field-hint">Les prêteurs aiment voir au moins 2 ans de stabilité, surtout pour les travailleurs autonomes.</small>
                </div>
              </div>

              <div class="demande-row">
                <div class="demande-field">
                  <label for="demande-revenu-base">Revenu annuel brut de base ($) <span class="demande-req">*</span></label>
                  <input type="text" id="demande-revenu-base" name="revenu_base" required inputmode="numeric" placeholder="75 000" />
                </div>
                <div class="demande-field">
                  <label for="demande-revenu-extra">Bonus / commissions / heures supp. annuels ($) <span class="demande-opt">(si applicable)</span></label>
                  <input type="text" id="demande-revenu-extra" name="revenu_extra" inputmode="numeric" placeholder="10 000" />
                </div>
              </div>

              <div class="demande-field">
                <label for="demande-autres-revenus">Vous avez d'autres revenus ? Décrivez-les ici <span class="demande-opt">(facultatif)</span></label>
                <textarea id="demande-autres-revenus" name="autres_revenus" rows="2" placeholder="Ex. revenus de location, pensions, dividendes, pourboires non déclarés ci-dessus, travail à temps partiel…"></textarea>
                <small class="demande-field-hint">Toute source de revenu supplémentaire peut augmenter votre capacité d'emprunt.</small>
              </div>

              <div class="demande-field">
                <label>Quels documents avez-vous déjà en main ?</label>
                <div class="demande-checklist">
                  <label class="demande-check-label"><input type="checkbox" name="docs_disponibles" value="talons_paie" /> Talons de paie récents (2 derniers)</label>
                  <label class="demande-check-label"><input type="checkbox" name="docs_disponibles" value="lettre_emploi" /> Lettre d'emploi récente</label>
                  <label class="demande-check-label"><input type="checkbox" name="docs_disponibles" value="t4" /> T4 / Relevé 1 (2 dernières années)</label>
                  <label class="demande-check-label"><input type="checkbox" name="docs_disponibles" value="avis_cotisation" /> Avis de cotisation fédéral et provincial (2 dernières années)</label>
                  <label class="demande-check-label"><input type="checkbox" name="docs_disponibles" value="aucun" /> Aucun pour le moment — j'en discuterai avec Stéphanie</label>
                </div>
                <small class="demande-field-hint">Les avis de cotisation sont cruciaux pour prouver qu'il n'y a pas d'impôts impayés et pour valider les revenus des travailleurs autonomes.</small>
              </div>
            </fieldset>

            <!-- ================================================================ -->
            <!-- SECTION 6 : Crédit                                               -->
            <!-- ================================================================ -->
            <fieldset class="demande-fieldset">
              <legend class="demande-legend"><span class="demande-step-num">6</span> Votre crédit</legend>
              <p class="demande-legend-sub">Cette information détermine vers quel type de prêteur orienter votre dossier (A ou B). Aucune enquête formelle n'est lancée maintenant.</p>

              <div class="demande-row">
                <div class="demande-field">
                  <label>Comment évaluez-vous votre crédit ? <span class="demande-req">*</span></label>
                  <div class="demande-radio-group">
                    <label class="demande-radio-label"><input type="radio" name="auto_evaluation_credit" value="excellent" required /> Excellent — toujours payé à temps</label>
                    <label class="demande-radio-label"><input type="radio" name="auto_evaluation_credit" value="bon" /> Bon — quelques retards mineurs</label>
                    <label class="demande-radio-label"><input type="radio" name="auto_evaluation_credit" value="a_reconstruire" /> À reconstruire — retards fréquents</label>
                    <label class="demande-radio-label"><input type="radio" name="auto_evaluation_credit" value="ne_sais_pas" /> Je ne sais pas</label>
                  </div>
                </div>
                <div class="demande-field">
                  <label>Avez-vous déjà eu une faillite ou une proposition de consommateur ?</label>
                  <div class="demande-radio-group">
                    <label class="demande-radio-label"><input type="radio" name="faillite_passee" value="non" /> Non</label>
                    <label class="demande-radio-label"><input type="radio" name="faillite_passee" value="oui_liberee" /> Oui — libérée</label>
                    <label class="demande-radio-label"><input type="radio" name="faillite_passee" value="oui_active" /> Oui — en cours</label>
                  </div>
                </div>
              </div>
            </fieldset>

            <!-- ================================================================ -->
            <!-- SECTION 7 : Mise de fonds                                        -->
            <!-- ================================================================ -->
            <fieldset class="demande-fieldset" id="demande-mise-fonds-section">
              <legend class="demande-legend"><span class="demande-step-num">7</span> Mise de fonds</legend>
              <p class="demande-legend-sub">Au Canada, Stéphanie doit prouver la provenance de chaque dollar investi.</p>

              <div class="demande-row">
                <div class="demande-field">
                  <label for="demande-mise-montant">Montant total disponible ($) <span class="demande-req">*</span></label>
                  <input type="text" id="demande-mise-montant" name="mise_montant" required inputmode="numeric" placeholder="45 000" />
                </div>
                <div class="demande-field">
                  <label for="demande-prix-vise">Prix de la propriété visée ($) <span class="demande-opt">(si connu)</span></label>
                  <input type="text" id="demande-prix-vise" name="prix_vise" inputmode="numeric" placeholder="450 000" />
                </div>
              </div>

              <div class="demande-field">
                <label for="demande-source-fonds">Source principale des fonds <span class="demande-req">*</span></label>
                <select id="demande-source-fonds" name="source_fonds" required>
                  <option value="" disabled selected>Choisir…</option>
                  <option value="epargne">Épargne personnelle (compte chèque/épargne)</option>
                  <option value="reer_rap">REER — Régime d'accession à la propriété (RAP)</option>
                  <option value="celiapp">CELIAPP</option>
                  <option value="don">Don d'un proche (parents, famille)</option>
                  <option value="vente">Vente d'une propriété actuelle</option>
                  <option value="refinancement">Refinancement d'une autre propriété</option>
                  <option value="heritage">Héritage</option>
                  <option value="combinaison">Combinaison de plusieurs sources</option>
                </select>
              </div>

              <div class="demande-field">
                <label>Les fonds sont-ils dans votre compte bancaire depuis plus de 90 jours ? <span class="demande-req">*</span></label>
                <div class="demande-radio-group">
                  <label class="demande-radio-label"><input type="radio" name="fonds_90jours" value="oui" required /> Oui — les relevés bancaires le prouveront</label>
                  <label class="demande-radio-label"><input type="radio" name="fonds_90jours" value="non" /> Non — ils proviennent d'un dépôt récent</label>
                  <label class="demande-radio-label"><input type="radio" name="fonds_90jours" value="partiel" /> En partie seulement</label>
                </div>
                <small class="demande-field-hint">Stéphanie aura besoin des relevés bancaires des <strong>90 derniers jours</strong> pour prouver la provenance des fonds. Si l'argent vient d'un don, une lettre de don signée sera exigée.</small>
              </div>

              <div class="demande-field">
                <label for="demande-mise-precisions">Précisions sur votre mise de fonds <span class="demande-opt">(facultatif)</span></label>
                <textarea id="demande-mise-precisions" name="mise_precisions" rows="2" placeholder="Ex. don familial de 20 000 $, REER décaissé le mois dernier, vente prévue en juillet…"></textarea>
              </div>
            </fieldset>

            <!-- ================================================================ -->
            <!-- SECTION 8 : Dettes et obligations                                -->
            <!-- ================================================================ -->
            <fieldset class="demande-fieldset">
              <legend class="demande-legend"><span class="demande-step-num">8</span> Dettes et obligations</legend>
              <p class="demande-legend-sub">Pour calculer votre capacité d'emprunt, Stéphanie doit connaître vos obligations mensuelles.</p>

              <div class="demande-field">
                <label for="demande-paiement-dettes">Paiements mensuels totaux de dettes ($) <span class="demande-opt">(estimation)</span></label>
                <input type="text" id="demande-paiement-dettes" name="paiement_dettes" inputmode="numeric" placeholder="Ex. 850 — auto, cartes, prêts, etc." />
              </div>

              <div class="demande-field">
                <label>Types de dettes</label>
                <div class="demande-checklist">
                  <label class="demande-check-label"><input type="checkbox" name="types_dettes" value="cartes_credit" /> Cartes de crédit / marges</label>
                  <label class="demande-check-label"><input type="checkbox" name="types_dettes" value="pret_auto" /> Prêt ou location auto</label>
                  <label class="demande-check-label"><input type="checkbox" name="types_dettes" value="pret_etudiant" /> Prêt étudiant</label>
                  <label class="demande-check-label"><input type="checkbox" name="types_dettes" value="pret_personnel" /> Prêt personnel</label>
                  <label class="demande-check-label"><input type="checkbox" name="types_dettes" value="pension_alimentaire" /> Pension alimentaire</label>
                  <label class="demande-check-label"><input type="checkbox" name="types_dettes" value="hypotheque_autre" /> Hypothèque autre propriété</label>
                  <label class="demande-check-label"><input type="checkbox" name="types_dettes" value="aucune_dette" /> Aucune dette</label>
                </div>
              </div>

              <div class="demande-row">
                <div class="demande-field">
                  <label for="demande-personnes-charge">Personnes à charge</label>
                  <select id="demande-personnes-charge" name="personnes_charge">
                    <option value="" disabled selected>Choisir…</option>
                    <option value="0">Aucune</option>
                    <option value="1">1</option>
                    <option value="2">2</option>
                    <option value="3">3 ou plus</option>
                  </select>
                </div>
                <div class="demande-field demande-field--consent">
                  <label class="demande-check-label demande-check-label--box" for="demande-consent-credit">
                    <input type="checkbox" id="demande-consent-credit" name="consentement_credit" value="oui" />
                    <span>Je comprends qu'une <strong>enquête de crédit</strong> sera requise. Stéphanie me fera signer un consentement écrit avant. <span class="demande-req">*</span></span>
                  </label>
                </div>
              </div>
            </fieldset>

            <!-- ================================================================ -->
            <!-- SECTION 9 : Préférences de financement                           -->
            <!-- ================================================================ -->
            <fieldset class="demande-fieldset">
              <legend class="demande-legend"><span class="demande-step-num">9</span> Préférences de financement</legend>
              <p class="demande-legend-sub">Pour vous recommander le bon produit, Stéphanie doit comprendre votre tolérance au risque et vos projets.</p>

              <div class="demande-field">
                <label>Taux fixe ou variable ? <span class="demande-req">*</span></label>
                <div class="demande-radio-group">
                  <label class="demande-radio-label"><input type="radio" name="pref_taux" value="fixe" required /> <strong>Taux fixe</strong> — la sécurité d'un paiement qui ne bouge jamais</label>
                  <label class="demande-radio-label"><input type="radio" name="pref_taux" value="variable" /> <strong>Taux variable</strong> — prêt à assumer des fluctuations pour potentiellement économiser</label>
                  <label class="demande-radio-label"><input type="radio" name="pref_taux" value="indecis" /> Je ne sais pas — j'aimerais en discuter avec Stéphanie</label>
                </div>
              </div>

              <div class="demande-field">
                <label for="demande-duree-terme">Durée du terme recherchée</label>
                <select id="demande-duree-terme" name="duree_terme">
                  <option value="" disabled selected>Choisir…</option>
                  <option value="1a_3ans">Court terme (1 à 3 ans)</option>
                  <option value="5ans">Standard (5 ans)</option>
                  <option value="indecis">Je ne sais pas — j'aimerais en discuter</option>
                </select>
              </div>

              <div class="demande-field">
                <label>Paiements anticipés importants prévus ?</label>
                <div class="demande-radio-group">
                  <label class="demande-radio-label"><input type="radio" name="paiements_anticipes" value="oui" /> Oui — je prévois faire des paiements forfaitaires chaque année</label>
                  <label class="demande-radio-label"><input type="radio" name="paiements_anticipes" value="peut_etre" /> Peut-être — j'aimerais avoir cette flexibilité</label>
                  <label class="demande-radio-label"><input type="radio" name="paiements_anticipes" value="non" /> Non — je vais suivre l'échéancier standard</label>
                </div>
              </div>

              <div class="demande-field">
                <label>Prévoyez-vous vendre la propriété à court terme (moins de 3 ans) ?</label>
                <div class="demande-radio-group">
                  <label class="demande-radio-label"><input type="radio" name="vente_court_terme" value="oui" /> Oui — cela pourrait arriver</label>
                  <label class="demande-radio-label"><input type="radio" name="vente_court_terme" value="non" /> Non — je compte y rester</label>
                </div>
                <small class="demande-field-hint">Si oui, Stéphanie en tiendra compte pour minimiser la pénalité de bris de contrat.</small>
              </div>
            </fieldset>

            <!-- ================================================================ -->
            <!-- SECTION 10 : Propriété visée                                     -->
            <!-- ================================================================ -->
            <fieldset class="demande-fieldset">
              <legend class="demande-legend"><span class="demande-step-num">10</span> La propriété visée</legend>

              <div class="demande-field">
                <label>Promesse d'achat acceptée ? <span class="demande-req">*</span></label>
                <div class="demande-radio-group">
                  <label class="demande-radio-label"><input type="radio" name="promesse_achat" value="oui" required /> Oui</label>
                  <label class="demande-radio-label"><input type="radio" name="promesse_achat" value="non" /> Non — je magasine</label>
                </div>
              </div>

              <div id="demande-promesse-oui" style="display:none;">
                <div class="demande-callout">
                  <strong>⚠️ Urgent — documents requis</strong>
                  <p>Stéphanie aura besoin de : fiche descriptive (Centris/SIA), déclaration du vendeur, taxes municipales/scolaires, et promesse d'achat signée.</p>
                </div>

                <div class="demande-field">
                  <label for="demande-adresse-propriete">Adresse de la propriété visée</label>
                  <input type="text" id="demande-adresse-propriete" name="adresse_propriete" autocomplete="street-address" placeholder="123 rue Principale, Repentigny" />
                </div>

                <div class="demande-field">
                  <label for="demande-date-possession">Date de possession prévue</label>
                  <input type="date" id="demande-date-possession" name="date_possession" />
                </div>
              </div>

              <div class="demande-row">
                <div class="demande-field">
                  <label for="demande-type-propriete">Type de propriété</label>
                  <select id="demande-type-propriete" name="type_propriete">
                    <option value="" disabled selected>Choisir…</option>
                    <option value="maison">Maison unifamiliale</option>
                    <option value="condo">Condo / copropriété</option>
                    <option value="plex">Plex (duplex, triplex…)</option>
                    <option value="maison_mobile">Maison mobile</option>
                    <option value="terrain">Terrain</option>
                    <option value="autre">Autre</option>
                  </select>
                </div>
                <div class="demande-field">
                  <label for="demande-usage">Usage</label>
                  <select id="demande-usage" name="usage_propriete">
                    <option value="" disabled selected>Choisir…</option>
                    <option value="principale">Résidence principale</option>
                    <option value="secondaire">Résidence secondaire / chalet</option>
                    <option value="revenus">Immeuble à revenus</option>
                  </select>
                </div>
              </div>

              <div id="demande-condo-block" style="display:none;">
                <div class="demande-field">
                  <label for="demande-frais-condo">Frais de copropriété ($/mois)</label>
                  <input type="text" id="demande-frais-condo" name="frais_condo" inputmode="numeric" placeholder="300" />
                  <small class="demande-field-hint">50 % de ce montant est inclus dans les ratios d'endettement.</small>
                </div>
              </div>

              <div id="demande-plex-block" style="display:none;">
                <div class="demande-field">
                  <label for="demande-revenus-locatifs">Revenus locatifs estimés ($/mois)</label>
                  <input type="text" id="demande-revenus-locatifs" name="revenus_locatifs" inputmode="numeric" placeholder="1 500" />
                  <small class="demande-field-hint">Les prêteurs considèrent généralement 50 à 80 % des revenus locatifs dans les ratios.</small>
                </div>
              </div>
            </fieldset>

            <!-- ================================================================ -->
            <!-- Préférences de contact + Source                                  -->
            <!-- ================================================================ -->
            <fieldset class="demande-fieldset">
              <legend class="demande-legend"><span class="demande-step-num" style="background:var(--forest);">✓</span> Dernières questions</legend>

              <div class="demande-row">
                <div class="demande-field">
                  <label for="demande-pref-contact">Préférence de contact</label>
                  <select id="demande-pref-contact" name="pref_contact">
                    <option value="" disabled selected>Choisir…</option>
                    <option value="telephone">Téléphone</option>
                    <option value="texto">Texto</option>
                    <option value="courriel">Courriel</option>
                    <option value="indifferent">Peu importe</option>
                  </select>
                </div>
                <div class="demande-field">
                  <label for="demande-moment-contact">Meilleur moment</label>
                  <select id="demande-moment-contact" name="moment_contact">
                    <option value="" disabled selected>Choisir…</option>
                    <option value="jour">En journée (9 h – 17 h)</option>
                    <option value="soir">En soirée (17 h – 20 h)</option>
                    <option value="weekend">Week-end</option>
                    <option value="flexible">Flexible</option>
                  </select>
                </div>
              </div>

              <div class="demande-field">
                <label for="demande-source">Comment avez-vous connu Stéphanie ?</label>
                <select id="demande-source" name="source">
                  <option value="" disabled selected>Choisir…</option>
                  <option value="google">Recherche Google</option>
                  <option value="facebook">Facebook</option>
                  <option value="bouche_oreille">Bouche-à-oreille / recommandation</option>
                  <option value="hypotheca">Hypotheca</option>
                  <option value="centris">Centris / fiche descriptive</option>
                  <option value="autre_source">Autre</option>
                </select>
              </div>
            </fieldset>

            <!-- ================================================================ -->
            <!-- Message libre + Consentement final                               -->
            <!-- ================================================================ -->
            <div class="demande-field">
              <label for="demande-message">Précisions ou questions pour Stéphanie <span class="demande-opt">(facultatif)</span></label>
              <textarea id="demande-message" name="message" rows="4" placeholder="Toute information supplémentaire qui pourrait aider Stéphanie à préparer votre dossier…"></textarea>
            </div>

            <label class="demande-consent" for="demande-consent-final">
              <input type="checkbox" id="demande-consent-final" name="consentement" value="oui" required />
              <span>
                J'accepte que {prenom} utilise les renseignements ci-dessus pour analyser mon dossier et me recontacter.
                Ces informations sont <strong>strictement confidentielles</strong> et utilisées uniquement dans le cadre de ma demande de financement — voir la
                <a href="/confidentialite">politique de confidentialité</a>. Aucune enquête de crédit ne sera lancée sans mon consentement écrit. <span class="demande-req">*</span>
              </span>
            </label>

            <button type="submit" class="btn-cta btn-cta--block" id="demande-submit">
              <span class="demande-submit-label">Envoyer ma demande</span>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>

            <p class="demande-note">Gratuit · Confidentiel · Réponse dans les meilleurs délais</p>
            <p class="demande-note demande-note--next">Pour la suite, {prenom} vous contactera personnellement pour obtenir les documents nécessaires (talons de paie, avis de cotisation, relevés bancaires, etc.).</p>
          </form>

          <!-- Message d'état -->
          <p id="demande-status" class="demande-status" role="status" aria-live="polite" hidden></p>

          <!-- Message de succès -->
          <div id="demande-success" class="demande-success" hidden>
            <span class="demande-success-check" aria-hidden="true">✅</span>
            <strong>Votre demande est envoyée&nbsp;!</strong>
            <p>{prenom} analysera votre dossier et vous contactera personnellement dans les meilleurs délais.</p>
            <a href="/" class="btn-secondary" style="margin-top:1.5rem;display:inline-flex;align-items:center;gap:.5rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
              Retour à l'accueil
            </a>
          </div>
        </div>

      </div>
    </section>
  </main>

  <Footer />
</MainLayout>

<style>
  .demande-section { background: var(--sand); padding: 7rem 1.5rem 5rem; }
  .demande-inner { max-width: 780px; margin: 0 auto; }

  .demande-intro { text-align: center; margin-bottom: 2.5rem; }
