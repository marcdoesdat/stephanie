<script is:inline>
  (function () {
    var form = document.getElementById('part-form-el');
    if (!form) return;

    var btn = document.getElementById('part-submit');
    var label = form.querySelector('.part-submit-label');
    var statusEl = document.getElementById('part-status');

    function setStatus(state, msg) {
      if (!statusEl) return;
      if (!state) { statusEl.hidden = true; statusEl.removeAttribute('data-state'); statusEl.textContent = ''; return; }
      statusEl.hidden = false;
      statusEl.setAttribute('data-state', state);
      statusEl.textContent = msg;
    }

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      if (!form.reportValidity()) return;

      var botField = form.elements['bot-field'];

      btn.disabled = true;
      if (label) label.textContent = 'Envoi en cours…';
      setStatus('sending', 'Envoi de votre référence…');

      fetch('/api/partenaires-submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          'nom-partenaire': form.elements['nom-partenaire'].value.trim(),
          profession: form.elements['profession'].value,
          'contact-partenaire': form.elements['contact-partenaire'].value.trim(),
          'client-nom': form.elements['client-nom'].value.trim(),
          'client-telephone': form.elements['client-telephone'].value.trim(),
          'type-projet': form.elements['type-projet'].value,
          notes: form.elements['notes'].value.trim(),
          'consentement-client': form.elements['consentement-client'].checked,
          'bot-field': botField ? botField.value : ''
        })
      })
        .then(function (res) {
          if (!res.ok) throw new Error('Erreur ' + res.status);
          window.location.href = '/merci';
        })
        .catch(function () {
          btn.disabled = false;
          if (label) label.textContent = 'Envoyer la référence';
          setStatus('error', "Une erreur est survenue lors de l'envoi. Veuillez vérifier votre connexion et réessayer.");
        });
    });
  })();
</script>
